
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the role of the currently authenticated user.
    // It reads the 'role' field from the user's document in the 'users' collection.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper function to check if the user is authenticated.
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for the 'users' collection.
    match /users/{userId} {
      // Any signed-in user can read their own user document.
      // Admins can read any user document.
      allow read: if isSignedIn() && (request.auth.uid == userId || getUserRole() == 'admin');
      
      // Only admins can create or update user documents.
      allow write: if getUserRole() == 'admin';
    }

    // Rules for the 'patients' collection and its sub-collections.
    match /patients/{patientId} {
      // Allow read access to patient records for authenticated clinical and administrative staff.
      allow read: if isSignedIn() && getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'pharmacist', 'lab_technician'];
      
      // Allow write access (e.g., updating admission status) to clinical and administrative staff.
      allow write: if isSignedIn() && getUserRole() in ['admin', 'doctor', 'nurse'];

      // == NURSING MODULE RULES ==
      // These rules grant specific permissions to nurses for their workflow.

      // Rules for the 'vitals' sub-collection.
      match /vitals/{vitalId} {
        // Doctors and nurses can read vitals.
        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];
        // Only nurses can create or update vitals records.
        allow create, update: if getUserRole() == 'nurse';
      }

      // Rules for the 'care_plans' sub-collection.
      match /care_plans/{planId} {
        // Doctors and nurses can read care plans.
        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];
        // Only nurses can create or update care plans.
        allow create, update: if getUserRole() == 'nurse';
      }

      // Rules for the 'medication_administration_logs' sub-collection.
      match /medication_administration_logs/{logId} {
        // Doctors and nurses can read the administration log.
        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];
        // Only nurses can create new log entries.
        allow create: if getUserRole() == 'nurse';
      }

      // == DOCTOR-SPECIFIC & OTHER RULES ==
      // These rules restrict write access on certain sub-collections to doctors.
      // This also serves as the rule for `progress_notes` when nurses add notes,
      // as they share the same data model.
      match /clinical_notes/{noteId} {
        // Doctors and nurses can read all notes.
        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];
        // Both Doctors (for clinical notes) and Nurses (for progress notes) can create notes.
        allow create: if getUserRole() in ['doctor', 'nurse'];
      }
      
      // Only doctors can write diagnoses.
      match /diagnoses/{diagnosisId} {
        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];
        allow write: if getUserRole() == 'doctor';
      }
      
      // Only doctors can write new prescriptions to the patient's history.
      match /medication_history/{prescriptionId} {
        allow read: if getUserRole() in ['doctor', 'nurse', 'pharmacist', 'admin'];
        allow write: if getUserRole() == 'doctor';
      }
      
      // Lab results can be read by clinical staff, but only written by lab technicians (or triggered functions).
      match /lab_results/{resultId} {
        allow read: if getUserRole() in ['doctor', 'nurse', 'admin', 'lab_technician'];
        // Writes would typically be handled by a Cloud Function with admin privileges.
        // Direct client writes might be limited to lab technicians updating the status.
        allow write: if getUserRole() == 'lab_technician';
      }
      
      // Admissions can be read by most staff, but only written by doctors or nurses.
      match /admissions/{admissionId} {
        allow read: if getUserRole() in ['doctor', 'nurse', 'admin', 'billing_clerk'];
        allow write: if getUserRole() in ['doctor', 'nurse', 'admin'];
      }
    }
  }
}
