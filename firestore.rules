
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user role from a separate 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Patients collection
    match /patients/{patientId} {
      allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'pharmacist', 'lab_technician', 'receptionist', 'radiologist', 'dietitian'];
      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];

      // Sub-collections for a patient's EHR
      match /{subcollection}/{documentId} {
        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
      }
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth.uid == userId || getUserRole() in ['admin'];
      allow write: if request.auth.uid == userId || getUserRole() in ['admin'];
    }

    // Beds collection
    match /beds/{bedId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() in ['admin', 'nurse', 'doctor'];
    }

    // Appointments collection
    match /appointments/{appointmentId} {
        allow read: if request.auth != null;
        allow create: if getUserRole() in ['admin', 'doctor', 'patient', 'receptionist'];
        allow update: if getUserRole() in ['admin', 'doctor', 'receptionist'];
    }

    // Operating Theatre (OT) Sessions & Schedules
    match /ot_sessions/{sessionId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || request.auth.uid == resource.data.patientId;
      allow create, update: if getUserRole() in ['admin', 'doctor', 'ot_coordinator'];

      // Vitals Log sub-collection for post-operative recovery tracking
      match /vitals_log/{logId} {
        allow create: if getUserRole() in ['admin', 'nurse'];
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || request.auth.uid == get(/databases/$(database)/documents/ot_sessions/$(sessionId)).data.patientId;
      }
    }
    
    // Dietary Management
    match /dietary_profiles/{profileId} {
      allow create, update: if getUserRole() in ['admin', 'nurse', 'dietitian'] || request.auth.uid == resource.data.patientId;
      allow read: if getUserRole() in ['admin', 'nurse', 'dietitian', 'doctor'] || request.auth.uid == resource.data.patientId;
    }

    match /meal_orders/{orderId} {
       allow create: if getUserRole() in ['admin', 'nurse', 'doctor'];
       allow read: if getUserRole() in ['admin', 'nurse', 'doctor', 'dietitian'] || request.auth.uid == resource.data.patientId;
       allow update: if getUserRole() in ['admin', 'nurse', 'dietitian', 'kitchen_staff'];
    }
  }
}
