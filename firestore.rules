
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =================================
    // == Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isDoctor() {
      return getUserRole() == 'doctor';
    }
    
    function isNurse() {
        return getUserRole() == 'nurse';
    }
    
    function isAdmin() {
      return getUserRole() == 'admin';
    }
    
    function isPatient(patientId) {
        return request.auth.uid == get(/databases/$(database)/documents/patients/$(patientId)).data.uid;
    }
    
    // =================================
    // == Collection Rules
    // =================================
    
    match /users/{userId} {
      // Users can read their own data. Admins can read anyone's data.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Users can only update their own data.
      allow update: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /patients/{patientId} {
        // Any authenticated staff member or the patient themselves can read patient data.
        allow read: if isSignedIn() && (getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'lab_technician'] || isPatient(patientId));
        // Only admins and nurses can create new patient records.
        allow create: if isSignedIn() && (isAdmin() || isNurse());
        // Only admins and clinical staff can update patient records.
        allow update: if isSignedIn() && (isAdmin() || isDoctor() || isNurse());
    }

    match /patients/{patientId}/{subCollection}/{docId} {
        // Any authenticated staff member or the patient themselves can read sub-collection data.
        allow read: if isSignedIn() && (getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'lab_technician'] || isPatient(patientId));
        // Only admins and clinical staff can create new data in sub-collections.
        allow create, update: if isSignedIn() && (isAdmin() || isDoctor() || isNurse());
    }
    
    match /appointments/{appointmentId} {
        allow read, write: if isSignedIn();
    }
    
    match /beds/{bedId} {
        allow read: if isSignedIn();
        // Bed status should only be updated by a trusted Cloud Function or a ward manager
        allow update: if isAdmin();
    }

    match /ot_sessions/{caseId} {
        allow read: if isSignedIn() && (getUserRole() in ['admin', 'doctor', 'nurse', 'ot_coordinator'] || request.auth.uid == resource.data.patientId);
        allow create, update: if isSignedIn() && (getUserRole() in ['admin', 'doctor', 'ot_coordinator']);
        allow delete: if isAdmin();
    }
    
    match /referrals/{referralId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (getUserRole() in ['admin', 'doctor', 'receptionist']);
    }
    
     match /pharmacy_orders/{orderId} {
      allow read: if isSignedIn() && (getUserRole() in ['pharmacist', 'doctor', 'admin']);
      allow create: if isDoctor() || isAdmin();
      allow update: if getUserRole() == 'pharmacist' || isAdmin();
    }
    
    match /inventory/{itemId} {
      allow read: if isSignedIn() && (getUserRole() in ['pharmacist', 'doctor', 'nurse', 'admin']);
      allow write: if getUserRole() == 'pharmacist' || isAdmin();
    }
    
     match /controlled_substances/{substanceId} {
        allow read: if isSignedIn() && getUserRole() in ['pharmacist', 'admin'];
        allow write: if getUserRole() in ['pharmacist', 'admin'];
     }
     
     match /controlled_substance_log/{logId} {
        allow read: if isSignedIn() && getUserRole() in ['pharmacist', 'admin'];
        allow create: if getUserRole() == 'pharmacist' || isAdmin(); // Logs are immutable
     }
    
    match /dietary_profiles/{profileId} {
        allow read: if isSignedIn() && (getUserRole() in ['admin', 'nurse', 'dietitian', 'doctor'] || request.auth.uid == resource.data.patientId);
        allow create, update: if isSignedIn() && (getUserRole() in ['admin', 'nurse', 'dietitian'] || request.auth.uid == resource.data.patientId);
    }
    
    match /meal_orders/{mealOrderId} {
        allow read: if isSignedIn() && (getUserRole() in ['admin', 'nurse', 'dietitian', 'doctor'] || request.auth.uid == resource.data.patientId);
        allow create: if isSignedIn() && getUserRole() in ['admin', 'nurse', 'doctor'];
        allow update: if isSignedIn() && getUserRole() in ['admin', 'nurse', 'dietitian'];
    }
  }
}
