rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =================================================================
    // Helper Functions
    // =================================================================
    
    // Placeholder function to get the role of the currently authenticated user.
    // In a real implementation, this would look up the user's role from the 'users' collection.
    // function getUserRole() {
    //   return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    // }
    
    // =================================================================
    // patients collection rules
    // =================================================================
    match /patients/{patientId} {
      // Allow create only by admin or billing_clerk
      // 1. User must have the correct role.
      // 2. The document ID must match the patientId field in the data to ensure consistency.
      allow create: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.role == 'nurse')
                    && request.resource.id == request.resource.data.patient_id;

      // Allow updates by authorized staff
      // 1. User must have the correct role.
      // 2. The patientId field cannot be changed after creation.
      allow update: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.role == 'nurse')
                    && request.resource.data.patient_id == resource.data.patient_id;
                    
      // Allow read access to authorized staff and the patient themselves.
      allow read: if request.auth != null; // For prototype, allow any authenticated user.
      
      // =================================================================
      // admissions sub-collection rules
      // =================================================================
      match /admissions/{admissionId} {
        
        // Allow read access to authorized staff and the patient themselves.
        // A patient can read their own admission records.
        // Clinical staff (doctor, nurse) and administrative staff (admin, billing_clerk) can also read.
        allow read: if request.auth != null && 
                    (request.auth.token.patient_id == patientId ||
                     request.auth.token.role in ['admin', 'doctor', 'nurse', 'billing_clerk']);
        
        // Allow creation by administrative staff who handle patient intake.
        allow create: if request.auth != null && request.auth.token.role in ['admin', 'nurse'];

        // Allow updates based on role.
        // Admins and clinical staff can update visit records.
        allow update: if request.auth != null && 
                      (request.auth.token.role in ['admin', 'doctor', 'nurse']);
      }
    }
    
    // =================================================================
    // beds collection rules
    // =================================================================
    match /beds/{bedId} {
      allow read: if request.auth != null;
      // Bed updates are handled by backend functions, so direct client updates can be restricted.
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    // =================================================================
    // users collection rules
    // =================================================================
    match /users/{userId} {
      // Users can read their own profile. Admins can read any profile.
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');
      // Only admins can create or modify user roles.
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
  }
}
