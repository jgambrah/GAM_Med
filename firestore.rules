
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    // Check if the user is authenticated.
    function isAuth() {
      return request.auth != null;
    }

    // Get the data for a specific user document.
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // Get the role of a specific user.
    function getUserRole(uid) {
      return getUserData(uid).role;
    }
    
    // Check if a user's role is one of the allowed roles.
    function isOneOfRoles(uid, roles) {
      return isAuth() && getUserRole(uid) in roles;
    }

    // =====================================================================
    // Collection: users
    // =====================================================================
    match /users/{userId} {
      // Allow users to read their own profile.
      // Allow admins to read/write any user profile.
      allow read: if isAuth() && (request.auth.uid == userId || getUserRole(request.auth.uid) == 'admin');
      allow write: if isAuth() && getUserRole(request.auth.uid) == 'admin';
    }

    // =====================================================================
    // Collection: patients
    // =====================================================================
    match /patients/{patientId} {
      // READ: Allowed for clinical staff, admins, and the patient themselves.
      // A user is the patient if their user document has a matching patient_id field.
      allow read: if isOneOfRoles(request.auth.uid, ['admin', 'doctor', 'nurse', 'pharmacist']) ||
                     (getUserData(request.auth.uid).patient_id == patientId);

      // CREATE: Allowed for staff who handle patient registration.
      allow create: if isOneOfRoles(request.auth.uid, ['admin', 'nurse']);

      // UPDATE: Allowed for administrative staff.
      // Field-level restrictions should be handled by Cloud Functions for complex validation.
      allow update: if isOneOfRoles(request.auth.uid, ['admin', 'nurse']);
      
      // DELETE: Only admins can delete patient records (a destructive action).
      allow delete: if isOneOfRoles(request.auth.uid, ['admin']);
      
      // --- Sub-collection: admissions ---
      match /admissions/{admissionId} {
        // READ: Access mirrors the parent patient document.
        allow read: if isOneOfRoles(request.auth.uid, ['admin', 'doctor', 'nurse', 'pharmacist']) ||
                       (getUserData(request.auth.uid).patient_id == patientId);
                       
        // WRITE: Admission creation/updates are highly sensitive and should be handled
        // exclusively by trusted backend Cloud Functions to ensure data integrity.
        allow write: if false; // No direct client writes allowed.
      }
    }

    // =====================================================================
    // Collection: beds
    // =====================================================================
    match /beds/{bedId} {
       // READ: Clinical and admin staff need to see bed status in real-time.
      allow read: if isOneOfRoles(request.auth.uid, ['admin', 'doctor', 'nurse']);
      
      // WRITE: Bed status changes are critical and should only be performed
      // by trusted backend Cloud Functions to prevent unauthorized modifications.
      allow write: if false; // No direct client writes allowed.
    }
  }
}
