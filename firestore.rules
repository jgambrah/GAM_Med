
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to simplify rule logic
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isOneOfRoles(roles) {
      return isAuthenticated() && getUserData().role in roles;
    }
    
    function isPatientOwner(patientId) {
        return isAuthenticated() && getUserData().patient_id == patientId;
    }

    // Rules for user data
    match /users/{userId} {
      // Users can read their own data. Admins can read anyone's data.
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
      // Only users can update their own data, and only specific fields. Admins can update anything.
      allow update: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
    }

    // Rules for patient records and their sub-collections
    match /patients/{patientId} {
      allow read: if isOneOfRoles(['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist']) || isPatientOwner(patientId);
      allow create, update: if isOneOfRoles(['admin', 'doctor', 'nurse']);
      
      // Rules for EHR sub-collections
      match /{subcollection}/{docId} {
        allow read, write: if isOneOfRoles(['admin', 'doctor', 'nurse']);
      }

      // Specific rule for admissions to allow download by patient
      match /admissions/{admissionId} {
        allow read: if isOneOfRoles(['admin', 'doctor', 'nurse']) || isPatientOwner(patientId);
        allow write: if isOneOfRoles(['admin', 'doctor', 'nurse']);
      }
    }
    
    // Rules for billing and financial data
    match /invoices/{invoiceId} {
        // Read: Admins, billing clerks, or the patient who owns the invoice can read.
        allow read: if isOneOfRoles(['admin', 'billing_clerk']) || isPatientOwner(resource.data.patientId);
        
        // Create/Update: Only admins and billing clerks can create or modify invoices.
        // The Cloud Function will have elevated privileges to write automatically.
        allow create, update: if isOneOfRoles(['admin', 'billing_clerk']);
    }

    // Rules for locking down the `isBilled` flag on services.
    // This ensures only the automated billing function can mark a service as billed.
    
    // Appointments
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      // Allow general updates by clinical/admin staff
      allow write: if isOneOfRoles(['admin', 'doctor', 'nurse']);

      // But add a specific, stricter rule for the 'isBilled' flag
      allow update: if request.resource.data.isBilled == true 
                       && resource.data.isBilled == false; // Allow only changing from false to true
                       // This update is performed by the trusted Cloud Function.
    }

    // Lab Results
    match /patients/{patientId}/lab_results/{resultId} {
      // General access rules
      allow read: if isOneOfRoles(['admin', 'doctor', 'nurse', 'lab_technician']) || isPatientOwner(patientId);
      allow write: if isOneOfRoles(['admin', 'doctor', 'nurse', 'lab_technician']);

      // Stricter rule for the 'isBilled' flag
      allow update: if request.resource.data.isBilled == true
                       && resource.data.isBilled == false
                       && isOneOfRoles(['admin', 'billing_clerk']); // Or allow update if user is billing staff
    }
    
     // Medication Administration Logs
    match /patients/{patientId}/medication_administration_logs/{logId} {
       // General access rules
      allow read, write: if isOneOfRoles(['admin', 'doctor', 'nurse']);

      // Stricter rule for the 'isBilled' flag
      allow update: if request.resource.data.isBilled == true
                       && resource.data.isBilled == false
                       && isOneOfRoles(['admin', 'billing_clerk']);
    }
    
    // All other collections have default deny access unless specified
  }
}
