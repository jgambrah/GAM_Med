
rules_version = '2';

function getUserRole() {
  return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
}

function isUserAuthenticated() {
  return request.auth != null;
}

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public read for basic data, but restrict sensitive info
    match /users/{userId} {
      allow read: if isUserAuthenticated();
      allow write: if request.auth.uid == userId; // Users can only write to their own doc
    }
    
    match /patients/{patientId} {
        allow read: if isUserAuthenticated();
        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }
    
    // Allow read access for authenticated users, but restrict writes to clinical staff
    match /patients/{patientId}/{subcollection}/{docId} {
        allow read: if isUserAuthenticated();
        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }

    match /beds/{bedId} {
        allow read, write: if isUserAuthenticated();
    }

    match /appointments/{appointmentId} {
        allow read, write: if isUserAuthenticated();
    }

    match /referrals/{referralId} {
        allow read, write: if isUserAuthenticated();
    }

    match /pharmacy_orders/{orderId} {
        allow read, write: if getUserRole() in ['admin', 'pharmacist', 'doctor'];
    }
    
    match /inventory/{itemId} {
        allow read: if isUserAuthenticated();
        allow write: if getUserRole() in ['admin', 'pharmacist']; // Only pharmacy staff can update inventory
    }

    match /controlled_substances/{substanceId} {
      allow read: if getUserRole() in ['admin', 'pharmacist'];
      // Writes must go through the trusted Cloud Function
      allow write: if false;
    }

    match /controlled_substance_log/{logId} {
      allow read: if getUserRole() in ['admin', 'pharmacist'];
      // Immutable log
      allow write: if false;
    }

    // New rules for assets and depreciation
    match /assets/{assetId} {
      allow read: if getUserRole() in ['admin', 'maintenance_manager', 'technician'];
      // Restrict direct updates to financial details. 
      // This must be done via a trusted Cloud Function.
      allow update: if getUserRole() == 'admin';
      allow create: if getUserRole() in ['admin', 'maintenance_manager'];
    }

    match /depreciation_records/{recordId} {
      // Only financial staff can view these sensitive records.
      allow read: if getUserRole() in ['admin', 'billing_clerk'];
      // The depreciation ledger is immutable and can only be created by the server.
      allow create: if false;
      allow update, delete: if false;
    }
    
    match /utility_consumption/{logId} {
      allow read: if getUserRole() in ['admin', 'facilities_manager'];
      // Data ingested from smart meters via a Cloud Function
      allow create, update, delete: if false;
    }

    match /security_incidents/{incidentId} {
      allow read, create: if getUserRole() in ['admin', 'security'];
      allow update: if getUserRole() in ['admin', 'security'];
    }

    match /housekeeping_tasks/{taskId} {
      allow read: if getUserRole() in ['admin', 'nurse', 'housekeeping'];
      allow create: if getUserRole() in ['admin', 'nurse'];
      allow update: if getUserRole() in ['admin', 'housekeeping'];
    }
    
    match /spare_parts/{partId} {
      allow read: if getUserRole() in ['admin', 'technician'];
      // Allow only admins to create or manually update spare parts.
      // Day-to-day decrements should happen via a Cloud Function.
      allow write: if getUserRole() == 'admin';
    }

    // Fallback for collections not explicitly defined
    match /{path=**}/ {
      allow read, write: if isUserAuthenticated() && getUserRole() == 'admin';
    }
  }
}
