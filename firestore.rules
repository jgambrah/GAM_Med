
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /patients/{patientId} {
      allow read, update, delete: if getUserRole() in ['admin', 'doctor', 'nurse'];
      allow create: if getUserRole() in ['admin', 'nurse'];

      // Patients can read their own data
      allow read: if request.auth.uid == resource.data.patient_id;

      // Rules for EHR sub-collections
      match /{collection}/{docId} {
        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
        // Patients can read their own history
        allow read: if request.auth.uid == resource.data.patient_id;
      }

      // Specific rule for appointment_history
       match /appointment_history/{appointmentId} {
         allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'receptionist'];
         allow write: if false; // Should only be written by backend functions
       }
    }

    match /beds/{bedId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() in ['admin', 'nurse'];
    }

    match /appointments/{appointmentId} {
        allow create: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == request.resource.data.patientId;
        allow read: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId;
        allow update: if getUserRole() in ['admin', 'receptionist'];
        allow delete: if getUserRole() in ['admin', 'receptionist'];
    }

    match /doctor_schedules/{scheduleId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() == 'admin' || (getUserRole() == 'doctor' && request.auth.uid == request.resource.data.doctorId);
    }
  }
}
