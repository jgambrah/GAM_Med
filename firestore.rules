
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the role of the currently authenticated user
    function getUserRole() {
      // Access the user's document in the 'users' collection using their UID
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if the user is a patient and their ID matches
    function isPatientOwner(patientId) {
      // Get the user document to access their linked patient_id
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return getUserRole() == 'patient' && userDoc.patient_id == patientId;
    }

    // Rules for the top-level 'patients' collection
    match /patients/{patientId} {
      // Allow read access to admins, clinical staff, and the patient themselves
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || isPatientOwner(patientId);
      
      // Allow writes only from authorized backend processes (e.g., Cloud Functions)
      // For this prototype, we are allowing more open write access for admins/nurses for simplicity.
      allow write: if getUserRole() in ['admin', 'nurse']; 
    }
    
    // Rules for the 'admissions' sub-collection
    match /patients/{patientId}/admissions/{admissionId} {
      // Allow read access to admins, clinical staff, and the patient who owns the record
      allow read: if getUserRole() in ['admin', 'billing_clerk', 'doctor', 'nurse'] || isPatientOwner(patientId);

      // Allow updates under specific conditions to enforce the discharge workflow
      allow update: if 
        // Condition 1: Doctor finalizing their summary before administrative sign-off
        (resource.data.isSummaryFinalized == false && getUserRole() == 'doctor' && request.auth.uid == resource.data.dischargeByDoctorId) ||
        // Condition 2: Admin finalizing the summary
        (resource.data.isSummaryFinalized == false && getUserRole() == 'admin') ||
        // Condition 3: Billing clerk can ONLY update the finalBillId
        (getUserRole() == 'billing_clerk' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['finalBillId']));
        
      // Allow creation of new admission records by authorized staff
      allow create: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }
    
    // Rules for the 'referrals' collection
    match /referrals/{referralId} {
        // Allow creation by administrative or triage staff
        allow create: if getUserRole() in ['admin', 'nurse', 'billing_clerk']; // Assuming 'nurse' or 'billing_clerk' can act as triage

        // Allow reading by admin/triage staff, or the specific doctor it's assigned to
        allow read: if getUserRole() in ['admin', 'nurse', 'billing_clerk', 'doctor'] && 
                     (getUserRole() != 'doctor' || request.auth.uid == resource.data.assignedToDoctorId);

        // Allow updates by admin/triage staff, or by the assigned doctor under limited conditions
        allow update: if getUserRole() in ['admin', 'nurse', 'billing_clerk'] ||
                       (request.auth.uid == resource.data.assignedToDoctorId && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
    }

    // Rules for all other collections (e.g., users, beds, etc.)
    // For this prototype, we'll keep them relatively open but in production,
    // these would have very specific rules.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
