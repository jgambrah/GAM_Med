
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions for Multi-Tenant Isolation (The SaaS Wall)
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || isSuperAdmin());
    }

    function getMyHospitalId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hospitalId;
    }

    function isSameHospital(docData) {
      return isSignedIn() && (docData.hospitalId == getMyHospitalId() || isSuperAdmin());
    }

    function isPatient(patientId) {
      return isSignedIn() && request.auth.token.patientId == patientId;
    }

    // --------------------------------------------------------------------
    // Global Bypass for Super Admin
    // --------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --------------------------------------------------------------------
    // Referral Module Rules (The SaaS Window)
    // --------------------------------------------------------------------
    match /referrals/{referralId} {
      allow read: if isSignedIn() && (
        resource.data.fromHospitalId == getMyHospitalId() || 
        resource.data.toHospitalId == getMyHospitalId() ||
        isSuperAdmin()
      );

      allow create: if isSignedIn() && request.resource.data.fromHospitalId == getMyHospitalId();

      allow update: if isSignedIn() && (
        resource.data.toHospitalId == getMyHospitalId() ||
        isSuperAdmin()
      );
    }

    // --------------------------------------------------------------------
    // Primary Tenant Collections
    // --------------------------------------------------------------------

    match /hospitals/{hospId} {
      allow create: if isSignedIn() && (hospId == 'GAMMED_HQ' || isSuperAdmin());
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSameHospital(resource.data));
      allow list: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && isAdmin() && request.resource.data.hospitalId == getMyHospitalId();
      allow update: if isSignedIn() && (request.auth.uid == userId || (isAdmin() && isSameHospital(resource.data)));
    }

    match /patients/{patientId} {
      allow list: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());
      allow get: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin() || isPatient(patientId));
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.hospitalId == getMyHospitalId());
      allow update: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    // --------------------------------------------------------------------
    // Module-Specific Logic
    // --------------------------------------------------------------------

    match /vitals/{vitalId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /clinical_notes/{noteId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /lab_orders/{orderId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /appointments/{apptId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patient_id));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /ot_sessions/{sessionId} {
      allow read: if isSignedIn() && isSameHospital(resource.data);
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /medical_equipment/{equipId} {
      allow read: if isSignedIn() && isSameHospital(resource.data);
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /invoices/{invId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /mortality_records/{mortId} {
      allow read: if isSignedIn() && isSameHospital(resource.data);
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /diagnoses/{diagId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /{collection}/{docId} {
      allow read, write: if isSignedIn() && (isSuperAdmin() || isSameHospital(resource.data));
    }
  }
}
