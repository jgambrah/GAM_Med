
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
  
    match /patients/{patientId} {
      allow read: if request.auth != null;
      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || getUserRole() == 'admin';
    }
    
    match /appointments/{appointmentId} {
        allow read, create: if request.auth != null;
        allow update, delete: if getUserRole() in ['admin', 'doctor'];
    }

    match /inventory/{itemId} {
      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];
      allow update: if getUserRole() in ['admin', 'pharmacist'];
      allow create, delete: if getUserRole() == 'admin';
    }

    match /pharmacy_orders/{orderId} {
      allow read, create, update: if getUserRole() in ['admin', 'pharmacist'];
    }
  }
}
