
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to get user role
    function getUserRole() {
      return getUserData().role;
    }

    // Users can read and update their own user document
    // Users can be created by any authenticated user during signup
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid != null;
    }

    // Role-based access for the 'patients' collection
    match /patients/{patientId} {
      // Admins, Doctors, and Nurses can read/update all patient data
      allow read, update: if getUserRole() in ['admin', 'doctor', 'nurse'];
      // Admins can create new patient records
      allow create: if getUserRole() == 'admin';
      // Patients can read their own data via a linked patient_id
      allow read: if getUserData().patient_id == patientId;
    }
    
    // Rules for the 'admissions' sub-collection
    match /patients/{patientId}/admissions/{admissionId} {
        // Admins, Doctors, and Nurses can read/write admission data
        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }
  }
}
