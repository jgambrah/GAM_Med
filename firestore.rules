
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions for Multi-Tenant Isolation (The SaaS Wall)
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }

    /**
     * @description Fetches the hospitalId for the currently logged-in user.
     * Priorities: 1. Custom Claims (JWT) | 2. Role Registry Fallback
     */
    function getMyHospitalId() {
      // Priority 1: Trusted Custom Claims (Most secure and performant)
      if (request.auth.token.hospitalId != null) {
        return request.auth.token.hospitalId;
      }
      
      // Priority 2: Firestore Lookups (Fallback for un-stamped legacy accounts)
      let adminPath = /databases/$(database)/documents/roles_admin/$(request.auth.uid);
      if (exists(adminPath)) {
        return get(adminPath).data.hospitalId;
      }
      
      let staffPath = /databases/$(database)/documents/roles_staff/$(request.auth.uid);
      if (exists(staffPath)) {
        return get(staffPath).data.hospitalId;
      }
      
      return null;
    }

    /**
     * @description Checks if the user is a registered Admin or Director.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        request.auth.token.role == 'director' ||
        isSuperAdmin()
      );
    }

    /**
     * @description Checks if the document belongs to the user's hospital.
     */
    function isSameHospital(docData) {
      return isSignedIn() && (docData.hospitalId == getMyHospitalId() || isSuperAdmin());
    }

    function isPatient(patientId) {
      return isSignedIn() && request.auth.token.patientId == patientId;
    }

    /**
     * @description SAAS FEATURE GATING: Check if hospital has the required feature plan
     */
    function hasFeature(slug) {
      let hId = getMyHospitalId();
      let hospitalDoc = get(/databases/$(database)/documents/hospitals/$(hId));
      let plan = hospitalDoc.data.subscriptionTier;
      
      return (plan == 'enterprise') || 
             (plan == 'professional' && slug in ['ehr', 'vitals', 'appointments', 'billing', 'pharmacy', 'lab', 'wards', 'inventory', 'nursing']) ||
             (plan == 'clinic-starter' && slug in ['ehr', 'vitals', 'appointments', 'billing']);
    }

    // --------------------------------------------------------------------
    // Global Bypass for Super Admin
    // --------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --------------------------------------------------------------------
    // Public Discovery & Leads
    // --------------------------------------------------------------------
    match /pricing_plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /demo_requests/{leadId} {
      allow create: if true; 
      allow read: if isAdmin(); 
      allow write: if isSuperAdmin();
    }

    match /hospitals/{hospId} {
      allow get: if true; 
      allow list: if isSuperAdmin();
      allow update: if isSuperAdmin();
    }

    // --------------------------------------------------------------------
    // Referral Module Rules
    // --------------------------------------------------------------------
    match /referrals/{referralId} {
      allow read: if isSignedIn() && (
        resource.data.fromHospitalId == getMyHospitalId() || 
        resource.data.toHospitalId == getMyHospitalId() ||
        isSuperAdmin()
      );

      allow create: if isSignedIn() && request.resource.data.fromHospitalId == getMyHospitalId();

      allow update: if isSignedIn() && (
        resource.data.toHospitalId == getMyHospitalId() ||
        isSuperAdmin()
      );
    }

    // --------------------------------------------------------------------
    // Primary Tenant Collections
    // --------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSameHospital(resource.data));
      allow list: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && isAdmin() && request.resource.data.hospitalId == getMyHospitalId();
      allow update: if isSignedIn() && (request.auth.uid == userId || (isAdmin() && isSameHospital(resource.data)));
    }

    match /patients/{patientId} {
      allow list: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());
      allow get: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin() || isPatient(patientId));
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.hospitalId == getMyHospitalId()) && hasFeature('ehr');
      allow update: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    // --------------------------------------------------------------------
    // Clinical & Operational Modules
    // --------------------------------------------------------------------

    match /vitals/{vitalId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data) && hasFeature('vitals');
    }

    match /clinical_notes/{noteId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data) && hasFeature('ehr');
    }

    match /lab_orders/{orderId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data) && hasFeature('lab');
    }

    match /ot_sessions/{sessionId} {
      allow read: if isSignedIn() && isSameHospital(resource.data) && hasFeature('surgery');
      allow write: if isSignedIn() && isSameHospital(request.resource.data) && hasFeature('surgery');
    }

    match /dietary_orders/{orderId} {
      allow read: if isSignedIn() && isSameHospital(resource.data);
      allow write: if isSignedIn() && isSameHospital(request.resource.data) && hasFeature('nursing');
    }

    match /{collection}/{docId} {
      allow read, write: if isSignedIn() && (isSuperAdmin() || isSameHospital(resource.data));
    }
  }
}
