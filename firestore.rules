rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get the user's role from their user document.
    // In a real implementation, this would fetch from /users/{request.auth.uid}.
    function getUserRole() {
      // This is a placeholder. In a real scenario, you would use:
      // return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return 'admin'; // Defaulting to admin for conceptual purposes.
    }

    // Placeholder function to get a user's assigned clinic.
    function getUserClinic() {
      // This would fetch from /users/{request.auth.uid}.
      return 'Cardiology'; // Placeholder value
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || getUserRole() == 'admin';
    }

    match /patients/{patientId} {
      allow read: if request.auth != null;
      allow write: if getUserRole() == 'admin' || getUserRole() == 'nurse';
      
      // Allow read/write to subcollections for authorized roles
      match /{allPaths=**} {
        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
      }
    }

    match /beds/{bedId} {
      allow read: if request.auth != null;
      allow write: if getUserRole() in ['admin', 'nurse'];
    }

    match /appointments/{appointmentId} {
        allow read: if request.auth.uid == resource.data.patient_id 
                    || request.auth.uid == resource.data.doctor_id
                    || getUserRole() == 'admin'
                    || (getUserRole() == 'billing_clerk' && resource.data.clinicId == getUserClinic());
        allow write: if getUserRole() in ['admin', 'doctor'];
    }
    
    match /referrals/{referralId} {
      allow read: if getUserRole() in ['admin', 'doctor'];
      allow write: if getUserRole() in ['admin', 'doctor'];
    }

    match /doctor_schedules/{scheduleId} {
      allow read: if request.auth != null;
      allow write: if getUserRole() == 'admin' || (getUserRole() == 'doctor' && request.auth.uid == resource.data.doctorId);
    }
    
    match /clinics/{clinicId} {
      allow read: if request.auth != null;
      allow write: if getUserRole() == 'admin';
    }
    
    match /resources/{resourceId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() == 'admin';
    }
  }
}
