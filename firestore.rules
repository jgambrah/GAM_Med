rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to simplify rule definitions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return request.auth.uid == userId;
    }

    // Get the user's role from their document in the 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isRole(role) {
        return isAuthenticated() && getUserRole() == role;
    }

    function isOneOfRoles(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }
    
    // Check if incoming data for an update only contains allowed fields
    function isUpdatingAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    // --- Users Collection Rules ---
    // Users can read their own data.
    // Only authenticated users can create their own user record (during sign-up).
    // Users can only update their own data.
    match /users/{userId} {
      allow read, update: if isAuthenticated() && isUser(userId);
      allow create: if isAuthenticated();
    }

    // --- Patients Collection Rules ---
    match /patients/{patientId} {
      // READ: Admins, Doctors, Nurses, and BillingClerks can read any patient data.
      // A patient can read their own record (assuming patientId might be linked to auth UID in a real scenario,
      // but for RBAC, role is the primary gatekeeper).
      // For this ruleset, we will rely on role-based access for clinical/admin staff.
      // A rule for patients reading their own data would require a field like `uid` on the patient doc:
      // `|| isUser(resource.data.uid)`
      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']);

      // CREATE: Only Admins and BillingClerks can register new patients.
      allow create: if isOneOfRoles(['Admin', 'BillingClerk']);

      // UPDATE: Admins/BillingClerks can update administrative fields.
      // Clinical staff (Doctors/Nurses) can only update admission status as part of a workflow.
      allow update: if isOneOfRoles(['Admin', 'BillingClerk']) ||
                      (isOneOfRoles(['Doctor', 'Nurse']) && isUpdatingAllowedFields(['isAdmitted', 'currentAdmissionId', 'updatedAt']));
                      
      // DELETE: No one can delete patient records through the client. Deletion should be a backend process.
      allow delete: if false;

      // --- Admissions Sub-collection Rules ---
      match /admissions/{admissionId} {
        // READ: Access is granted if the user has rights to read the parent patient document.
        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']);
        
        // CREATE: Clinical staff and admins can create admission records.
        allow create: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
        
        // UPDATE/DELETE: Primarily handled by server-side logic (simulated by Server Actions).
        // Limited client-side updates can be allowed for specific fields if necessary.
        allow update: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
        allow delete: if false;
      }
    }
    
    // --- Beds Collection Rules ---
    match /beds/{bedId} {
        // READ: All clinical and admin staff can see bed statuses.
        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
        
        // WRITE (Create, Update, Delete): Only clinical staff and admins can manage beds.
        // This is crucial for the admission/discharge/transfer workflows.
        allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
    }
  }
}
