
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for collections

    match /patients/{patientId} {
      allow read, write: if isAuth(); // Simple rule for now
    }

    match /beds/{bedId} {
        allow read, write: if isAuth();
    }

    match /appointments/{appointmentId} {
        allow read, write: if isAuth();
    }
    
    match /referrals/{referralId} {
        allow read, write: if isAuth();
    }
    
    match /prescriptions/{prescriptionId} {
        allow read, write: if isAuth();
    }
    
    match /pharmacy_orders/{orderId} {
        allow read, write: if isAuth();
    }
    
    match /lab_orders/{orderId} {
        allow read, write: if isAuth();
    }
    
    match /lab_results/{resultId} {
        allow read, write: if isAuth();
    }

    match /doctor_schedules/{scheduleId} {
        allow read, write: if isAuth();
    }

    match /expenses/{expenseId} {
      allow create, update: if getUserRole() in ['admin', 'financial_staff'];
      allow read: if getUserRole() in ['admin', 'financial_staff', 'hospital_manager'];
    }

    match /financial_summaries/{summaryId} {
      allow read: if getUserRole() in ['admin', 'financial_staff', 'CEO', 'hospital_manager'];
      allow write: if false; // Should only be written by backend functions
    }
    
    match /saved_reports/{reportId} {
        allow create, update, delete: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow read: if isAuth() && (resource.data.userId == request.auth.uid || getUserRole() == 'admin');
    }

    match /kpi_metrics/{metricId} {
        allow read: if isAuth() && getUserRole() in ['admin', 'hospital_manager', 'CEO'];
        allow write: if false; // Written by backend functions
    }

    match /bi_reports/{reportId} {
        allow read: if isAuth() && getUserRole() in ['admin', 'financial_staff', 'CEO'];
        allow write: if false; // Written by backend functions
    }

    match /clinical_reports/{reportId} {
        allow read: if isAuth() && getUserRole() in ['admin', 'doctor', 'nurse', 'hospital_manager'];
        allow write: if false; // Written by backend functions
    }
  }
}
