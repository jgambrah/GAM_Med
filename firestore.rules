rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // =====================================================================
    // Helper Functions
    // =====================================================================
    
    // Get the role of the currently authenticated user from the 'users' collection.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Check if the user is one of the specified roles.
    function isOneOfRoles(roles) {
      return getUserRole() in roles;
    }

    // Check if the request is from an authenticated user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    // Users collection: Basic access controls
    match /users/{userId} {
      // Allow users to read their own profile.
      // Admins can read any user's profile.
      allow read: if isAuthenticated() && (request.auth.uid == userId || getUserRole() == 'admin');
      
      // Allow users to update their own profile. Admins can update any.
      allow write: if isAuthenticated() && (request.auth.uid == userId || getUserRole() == 'admin');
    }
    
    // Beds collection: Staff can read, only specific roles can update.
    match /beds/{bedId} {
      allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse', 'billing_clerk']);
      allow write: if isAuthenticated() && isOneOfRoles(['admin', 'nurse']);
    }

    // Referrals collection: Staff can read, specific roles can write.
    match /referrals/{referralId} {
        allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse', 'triage_officer']);
        allow write: if isAuthenticated() && isOneOfRoles(['admin', 'nurse', 'triage_officer']);
    }
    
    // Pharmacy Orders: Pharmacists and prescribing doctors can access.
    match /pharmacy_orders/{orderId} {
        allow read, write: if isAuthenticated() && isOneOfRoles(['pharmacist', 'admin']);
    }
    
    // Lab Requests: Lab technicians and ordering doctors can access.
    match /lab_requests/{requestId} {
        allow read, write: if isAuthenticated() && isOneOfRoles(['lab_technician', 'admin']);
    }
    
    // Appointments Collection Rules
    match /appointments/{appointmentId} {
      // Allow read access to admins and the doctor assigned to the appointment.
      allow read: if isAuthenticated() && 
                  (getUserRole() == 'admin' || resource.data.attendingDoctorId == request.auth.uid);
                  
      // Allow write access (e.g., for updating status) to admins and the assigned doctor.
      allow write: if isAuthenticated() &&
                   (getUserRole() == 'admin' || resource.data.attendingDoctorId == request.auth.uid);
    }
    
    // =====================================================================
    // Patient EHR Rules (Main Document and Sub-collections)
    // =====================================================================
    
    match /patients/{patientId} {
      // Allow read access to a wide range of clinical staff and the patient themselves.
      // The patient's UID is assumed to be stored and retrievable for this check.
      allow read: if isAuthenticated() && 
                  (isOneOfRoles(['admin', 'doctor', 'nurse', 'pharmacist', 'lab_technician', 'billing_clerk']) || 
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);
                  
      // Write access to the main patient document is highly restricted.
      allow write: if isAuthenticated() && isOneOfRoles(['admin', 'nurse']);

      // --- EHR Sub-collection: Clinical Notes ---
      match /clinical_notes/{noteId} {
        allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse']);
        // Only doctors and nurses can create/update notes.
        // On update, we could add a check: resource.data.recordedByUserId == request.auth.uid
        allow write: if isAuthenticated() && isOneOfRoles(['doctor', 'nurse']);
      }
      
      // --- EHR Sub-collection: Vitals ---
      match /vitals/{vitalId} {
        allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse']);
        // Only nurses can record vitals.
        allow write: if isAuthenticated() && getUserRole() == 'nurse';
      }

      // --- EHR Sub-collection: Diagnoses ---
      match /diagnoses/{diagnosisId} {
        allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse']);
        // Only doctors can add or modify a diagnosis.
        allow write: if isAuthenticated() && getUserRole() == 'doctor';
      }

      // --- EHR Sub-collection: Medication History ---
      match /medication_history/{prescriptionId} {
        allow read: if isAuthenticated() && 
                    (isOneOfRoles(['admin', 'doctor', 'nurse', 'pharmacist']) || 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);
        // Only the prescribing doctor can create or modify a prescription.
        allow create: if isAuthenticated() && getUserRole() == 'doctor';
        allow update: if isAuthenticated() && getUserRole() == 'doctor' && resource.data.prescribedByDoctorId == request.auth.uid;
      }
      
      // --- EHR Sub-collection: Lab Results ---
      match /lab_results/{testId} {
        allow read: if isAuthenticated() &&
                    (isOneOfRoles(['admin', 'doctor', 'nurse', 'lab_technician']) ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);

        // Only doctors can order a new test.
        allow create: if isAuthenticated() && getUserRole() == 'doctor';
        
        // Only a lab technician can update a result, and they can only change specific fields.
        allow update: if isAuthenticated() && getUserRole() == 'lab_technician' &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'result', 'status', 'completedAt', 'labTechnicianId', 'resultPdfUrl'
                      ]);
      }
      
       // --- EHR Sub-collection: Admissions ---
      match /admissions/{admissionId} {
        // Broad read access for clinical staff and the patient.
        allow read: if isAuthenticated() &&
                    (isOneOfRoles(['admin', 'doctor', 'nurse', 'billing_clerk']) ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);
                     
        // Write access is restricted to clinical staff.
        allow write: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse']);
      }
    }
  }
}
