
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the user's role from the 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if the user is an admin or billing clerk
    function isFinancialStaff() {
      return getUserRole() in ['admin', 'billing_clerk'];
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Allow users to read their own user document
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
    }

    // Rules for the 'patients' collection
    match /patients/{patientId} {
        // Anyone authenticated can create a patient (via server action)
        allow create: if getUserRole() in ['admin', 'nurse', 'receptionist'];

        // Admins, doctors, and nurses can read any patient record.
        // Patients can read their own record.
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'] || request.auth.uid == resource.data.uid;
        
        // Allow updates only by authorized staff, with specific field protection.
        allow update: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist']
                      // Protect patientType field to be only updatable by financial staff
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['patientType']) || isFinancialStaff());
                      
        // Allow deletion only by admins (generally discouraged)
        allow delete: if getUserRole() == 'admin';

        // Allow granular access to subcollections
        match /{subcollection}/{docId} {
          allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'];
        }
    }
    
    // Rules for top-level collections
    match /appointments/{appointmentId} {
        allow read, write: if getUserRole() in ['admin', 'doctor', 'receptionist', 'billing_clerk'];
    }
    
    match /beds/{bedId} {
       allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }

    match /referrals/{referralId} {
        allow read, write: if getUserRole() in ['admin', 'doctor', 'triage_officer'];
    }

    match /pharmacy_orders/{orderId} {
        allow read, write: if getUserRole() in ['admin', 'pharmacist', 'doctor'];
    }

    match /prescriptions/{prescriptionId} {
        allow read, write: if getUserRole() in ['admin', 'pharmacist', 'doctor'];
    }
    
    match /waiting_lists/{listId} {
        allow read, write: if getUserRole() in ['admin', 'receptionist'];
    }

    match /ot_sessions/{sessionId} {
      allow read, write: if getUserRole() in ['admin', 'ot_coordinator', 'doctor'];
    }

    // == BILLING SECURITY RULES ==

    // Rules for the central 'invoices' collection
    match /invoices/{invoiceId} {
      // Only financial staff can create/update invoices.
      // In a real app, you'd add a condition to allow creation by a trusted Cloud Function.
      allow create, update: if isFinancialStaff();

      // Financial staff can read any invoice. Patients can read their own.
      allow read: if isFinancialStaff() || get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.uid == request.auth.uid;
    }
    
    // Rules for the 'payments' collection
    match /payments/{paymentId} {
      allow read, write: if isFinancialStaff();
    }

    // Rules for 'insurance_claims'
    match /insurance_claims/{claimId} {
      allow read, write: if isFinancialStaff();
    }
    
    // Rules for 'billing_codes'
    match /billing_codes/{codeId} {
      // Allow read for authenticated users, but only write for financial staff.
      allow read: if request.auth != null;
      allow write: if isFinancialStaff();
    }
    
    // Rules for 'pricing_tables'
    match /pricing_tables/{pricingId} {
      // ONLY financial staff can read or write pricing information.
      allow read, write: if isFinancialStaff();
    }
  }
}
