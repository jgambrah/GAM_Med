
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function hasAnyRole(roles) {
      return request.auth.uid != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }
    
    // =====================================================================
    // == Global Roles & Permissions
    // =====================================================================
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isDoctor() {
      return hasAnyRole(['admin', 'doctor']);
    }
    
    function isNurse() {
        return hasAnyRole(['admin', 'nurse']);
    }
    
    function isClinicalStaff() {
        return hasAnyRole(['admin', 'doctor', 'nurse']);
    }
    
    function isBilling() {
        return hasAnyRole(['admin', 'billing_clerk']);
    }
    
    function isPharmacist() {
        return hasAnyRole(['admin', 'pharmacist']);
    }

    function isLabStaff() {
        return hasAnyRole(['admin', 'lab_technician']);
    }

    function isRadiologyStaff() {
        return hasAnyRole(['admin', 'radiologist', 'receptionist']);
    }
    
    function isAdmin() {
        return hasAnyRole(['admin']);
    }
    
    // =====================================================================
    // == Collection-Specific Rules
    // =====================================================================
    
    match /users/{userId} {
      // Users can read their own data. Admins can read anyone's data.
      allow read: if request.auth.uid == userId || isAdmin();
      // Only admins can create or update user roles and details.
      allow write: if isAdmin();
    }

    match /patients/{patientId} {
      // Admins and clinical staff can read all patient records.
      // Patients can only read their own record.
      allow read: if isClinicalStaff() || request.auth.uid == resource.data.uid;
      // Only admins and nurses can create or update patient records.
      allow write: if hasAnyRole(['admin', 'nurse']);

      // Sub-collection rules inherit the parent `read` rule by default,
      // but we can make them more restrictive if needed.
      match /{subcollection}/{docId} {
        // Clinical staff can read/write to most sub-collections.
        allow read, write: if isClinicalStaff();
      }
    }
    
    match /beds/{bedId} {
      // Any authenticated user can see the bed status.
      allow read: if isSignedIn();
      // Only clinical staff can update bed status (e.g., assign a patient, mark for cleaning).
      allow write: if isClinicalStaff();
    }

    match /ot_sessions/{caseId} {
        allow read: if isClinicalStaff() || request.auth.uid == resource.data.patientId;
        allow write: if hasAnyRole(['admin', 'doctor', 'ot_coordinator']);

        match /vitals_log/{logId} {
            allow create: if isNurse();
            allow read: if isClinicalStaff() || request.auth.uid == parent(collection).data.patientId;
        }
    }

    match /employees/{employeeId} {
        allow read: if hasAnyRole(['admin', 'hr_manager']) || request.auth.uid == resource.id;
        allow create, update, delete: if hasAnyRole(['admin', 'hr_manager']);

        match /documents/{documentId} {
            allow create: if hasAnyRole(['admin', 'hr_manager']) || request.auth.uid == parent(collection).id;
            allow read: if hasAnyRole(['admin', 'hr_manager']) || request.auth.uid == parent(collection).id;
        }
    }

    match /attendance_logs/{logId} {
        allow create: if hasAnyRole(['admin', 'hr_manager']); // In a real app, this might be a specific service account
        allow read: if hasAnyRole(['admin', 'hr_manager']);
    }

    // Rules for results and student_academic_records
    function isExamAdmin() {
      return hasAnyRole(['admin', 'registrar']);
    }
    function isStudent(studentId) {
        return request.auth.uid == studentId;
    }
    
    match /results/{docId} {
        // READ: Only the student themselves can read their result IF it's published. Exam Admins can read all.
        allow read: if (resource.data.studentId == request.auth.uid && resource.data.isPublished == true) || isExamAdmin();
        // WRITE: Only a Cloud Function can manage results to ensure data integrity and controlled publication.
        allow write: if false;
    }
    
    match /student_academic_records/{docId} {
        // READ: Students can only read their own records IF the final result is published. Exam Admins can read all.
        allow read: if (resource.data.studentId == request.auth.uid && resource.data.finalResultPublished == true) || isExamAdmin();
        // WRITE: Only a Cloud Function can write to this collection to ensure data integrity.
        allow write: if false;
    }

  }
}
