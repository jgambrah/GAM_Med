rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get a user's role from the 'users' collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Rules for User management
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId; // Users can update their own profile
    }

    // Rules for Patient records
    match /patients/{patientId} {
      // Allow read access to the patient themselves, or clinical/admin staff
      allow read: if request.auth.token.patient_id == patientId || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'receptionist', 'billing_clerk'];
      // Restrict writes to trusted server-side functions or admins
      allow write: if getUserRole(request.auth.uid) == 'admin';
      
      // Rules for all patient sub-collections
      match /{subcollection}/{docId} {
        allow read: if request.auth.token.patient_id == patientId || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse'];
        allow write: if getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse'];
      }
    }
    
    // Rules for Ward and Bed Management
    match /wards/{wardId} {
        allow read: if getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'receptionist'];
        // In a real app, 'ward_manager' role would be used. For now, only admin can write.
        allow write: if getUserRole(request.auth.uid) == 'admin';
    }

    match /beds/{bedId} {
        allow read: if getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'receptionist'];
        // Direct writes are disallowed; all updates must go through Cloud Functions.
        allow write: if false; 
    }

    // Rules for Dietary Management
    match /dietary_profiles/{profileId} {
      function isOwner() {
        return get(/databases/$(database)/documents/patients/$(profileId)).data.uid == request.auth.uid;
      }
      allow create, update: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'dietitian'] || isOwner();
      allow read: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'dietitian', 'doctor'] || isOwner();
    }

    match /meal_orders/{orderId} {
       function isPatientOfOrder() {
        return get(/databases/$(database)/documents/meal_orders/$(orderId)).data.patientId == request.auth.token.patient_id;
      }
      allow create: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'doctor'];
      allow read: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'doctor', 'dietitian'] || isPatientOfOrder();
      allow update: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'dietitian']; // Assuming 'kitchen_staff' role is not yet defined
    }
  }
}
