
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get the user's role from the 'users' collection.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // =============================================
    // Users Collection
    // =============================================
    match /users/{userId} {
      // Users can read their own data.
      // Admins can read any user's data.
      allow read: if request.auth.uid == userId
                  || getUserData().role == 'Admin';
                  
      // Users can create their own user document upon registration.
      allow create: if request.auth.uid == userId;
      
      // Users can update their own non-critical info. Role changes must be done by an Admin.
      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role
                    || getUserData().role == 'Admin';
    }

    // =============================================
    // Patients Collection
    // =============================================
    match /patients/{patientId} {
      // Admins, Doctors, and Nurses can create new patient records.
      allow create: if getUserData().role in ['Admin', 'Doctor', 'Nurse'];

      // Admins, Doctors, and Nurses can read patient records.
      // Patients can read their own record (requires linking auth UID to patient record).
      allow read: if getUserData().role in ['Admin', 'Doctor', 'Nurse'];
      
      // Admins, Doctors, and Nurses can update patient records.
      allow update: if getUserData().role in ['Admin', 'Doctor', 'Nurse'];
      
      // Only Admins can delete patient records (soft delete recommended).
      allow delete: if getUserData().role == 'Admin';
    }

    // =============================================
    // Appointments Collection
    // =============================================
    match /appointments/{appointmentId} {
        // Admins, Doctors, and Nurses can create appointments.
        allow create: if getUserData().role in ['Admin', 'Doctor', 'Nurse'];

        // Admins, Doctors, and Nurses can view any appointment.
        // A patient can view their own appointment.
        // A doctor can view an appointment assigned to them.
        allow read: if getUserData().role in ['Admin', 'Doctor', 'Nurse']
                    || resource.data.patientId == request.auth.uid // This assumes patientId is linked to auth UID
                    || resource.data.doctorId == request.auth.uid;

        // Admins, Doctors, and Nurses can update appointments.
        // Patients can cancel their own appointments.
        allow update: if getUserData().role in ['Admin', 'Doctor', 'Nurse']
                      || (resource.data.patientId == request.auth.uid && request.resource.data.status == 'Canceled');
                      
        // Only Admins can delete appointments.
        allow delete: if getUserData().role == 'Admin';
    }
  }
}
