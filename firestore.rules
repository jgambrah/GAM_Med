rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. GOD MODE: Dr. Gambrah (SUPER_ADMIN) bypasses all restrictions
    match /{document=**} {
      allow read, write: if request.auth.token.role == 'SUPER_ADMIN';
    }

    // 2. PUBLIC LEAD CAPTURE: Anyone can submit a demo request
    match /leads/{leadId} {
      allow create: if true;
    }

    // 3. TENANT ISOLATION: For regular Hospital Staff
    match /hospitals/{hospitalId}/{allPaths=**} {
       allow read, write: if request.auth.token.hospitalId == hospitalId;
    }
  }
}
