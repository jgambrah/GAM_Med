
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the user's role from the 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Rules for the 'patients' collection and its sub-collections
    match /patients/{patientId} {
      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
      
      // EHR Sub-collection for lab results
      match /lab_history/{resultId} {
      	allow create: if false; // Only backend functions can create
        allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor'];
      }
    }
    
    // Rules for the 'lab_results' collection
    match /lab_results/{resultId} {
    	allow create: if getUserRole() in ['lab_technician'];
      allow update: if getUserRole() in ['lab_technician', 'lab_supervisor'] && resource.data.status == 'Draft';
      allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;
    }
    
    // Rules for the 'equipment_logs' collection
    match /equipment_logs/{logId} {
    	// Only a trusted backend process (Cloud Function) should create these logs.
      // We deny client-side creation entirely.
    	allow create: if false;
      allow read: if getUserRole() in ['admin', 'lab_tech'];
    }
  }
}
