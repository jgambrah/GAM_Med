
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles and authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRole(role) {
        return isAuthenticated() && getUserData().role == role;
    }
    
    function isOneOfRoles(roles) {
        return isAuthenticated() && getUserData().role in roles;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Users can read their own profile information
      allow read: if isUser(userId);
      // New users can create their own profile during sign-up
      allow create: if isAuthenticated();
      // Users can update their own profile
      allow update: if isUser(userId);
      // Deletion should be restricted, e.g., only by an Admin
      allow delete: if isRole('Admin');
    }

    // Rules for the 'patients' collection
    match /patients/{patientId} {
      // READ:
      // - The patient themselves can read their own record.
      // - Doctors, Nurses, and Admins can read any patient record.
      allow read: if (isUser(patientId) && isRole('Patient')) || isOneOfRoles(['Doctor', 'Nurse', 'Admin']);

      // CREATE:
      // - Only Admins can create new patient records.
      allow create: if isRole('Admin');
      
      // UPDATE:
      // - Admins can update any field.
      // - Doctors/Nurses can only update admission status fields.
      allow update: if isOneOfRoles(['Admin']) || 
                     (isOneOfRoles(['Doctor', 'Nurse']) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmitted', 'currentAdmissionId', 'updatedAt']));

      // DELETE:
      // - Deleting patient records is a sensitive operation and restricted to Admins.
      // - In a production environment, this might be disallowed entirely in favor of an 'inactive' status.
      allow delete: if isRole('Admin');

      // Rules for the 'admissions' sub-collection
      match /admissions/{admissionId} {
        // READ:
        // - Access is inherited from the parent patient document.
        allow read: if (isUser(patientId) && isRole('Patient')) || isOneOfRoles(['Doctor', 'Nurse', 'Admin']);
        
        // CREATE:
        // - Admins, Doctors, or Nurses can create admission records.
        allow create: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
        
        // UPDATE:
        // - Admins or clinical staff can update admission records (e.g., to discharge).
        allow update: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
        
        // DELETE:
        // - Deletion is restricted to Admins.
        allow delete: if isRole('Admin');
      }
    }

    // Rules for the 'beds' collection
    match /beds/{bedId} {
      // READ:
      // - Bed status is generally not sensitive. Allow any authenticated user to see bed availability.
      allow read: if isAuthenticated();
      
      // WRITE (create, update, delete):
      // - Managing beds (allocating, cleaning, maintenance) is a clinical/admin task.
      allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
    }
  }
}
