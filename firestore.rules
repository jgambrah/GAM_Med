
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for role-based access control
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data
    }
    
    function getUserRole() {
        return getUserData().role
    }

    function hasAnyRole(roles) {
      return isSignedIn() && getUserRole() in roles;
    }
    
    function isExamAdmin() {
      return hasAnyRole(['admin', 'registrar']);
    }
    
    function isStudent(studentId) {
        return request.auth.uid == studentId;
    }

    // Rules for User Management
    match /users/{userId} {
      allow read: if request.auth.uid == userId || hasAnyRole(['admin', 'HR']);
      allow update: if request.auth.uid == userId || hasAnyRole(['admin', 'HR']);
      allow create: if hasAnyRole(['HR']);
    }

    // Rules for other collections...
    match /beds/{bedId} {
      allow read: if isSignedIn();
      // Write access is typically handled by backend functions
      allow write: if hasAnyRole(['admin', 'doctor', 'nurse']);
    }

    match /patients/{patientId} {
      allow read: if isSignedIn();
      // More granular rules can be added for sub-collections
      allow write: if hasAnyRole(['admin', 'doctor', 'nurse']);

      // Sub-collection rules can be nested here
      // e.g., match /clinical_notes/{noteId} { ... }
    }
    
    match /results/{docId} {
        // READ: Only the student themselves can read their result IF it's published. Exam Admins can read all.
        allow read: if (resource.data.studentId == request.auth.uid && resource.data.isPublished == true) || isExamAdmin();
        // WRITE: Only a Cloud Function can manage results to ensure data integrity and controlled publication.
        allow write: if false;
    }
    
    match /student_academic_records/{docId} {
        // READ: Students can only read their own records IF the final result is published. Exam Admins can read all.
        allow read: if (resource.data.studentId == request.auth.uid && resource.data.finalResultPublished == true) || isExamAdmin();
        // WRITE: Only a Cloud Function can write to this collection to ensure data integrity.
        allow write: if false;
    }
    
    // =============================================================
    // == Shift & Roster Management Rules
    // =============================================================
    
    match /shifts/{shiftId} {
      // Anyone signed in can read the available shift patterns.
      allow read: if isSignedIn();
      // Only admins can create or modify shift definitions.
      allow write: if hasAnyRole(['admin']);
    }
    
    match /rosters/{rosterId} {
      // Allow creation by admins or department managers.
      allow create: if hasAnyRole(['admin', 'department_manager']);
      // Allow read if user is an admin/manager, or if their UID is in the roster's assignment list.
      // NOTE: This assumes a field like 'assignedUserIds' exists on the roster document for efficiency.
      allow read: if hasAnyRole(['admin', 'department_manager']) || request.auth.uid in resource.data.assignedUserIds;
      // Allow updates only by admins or managers.
      allow update: if hasAnyRole(['admin', 'department_manager']);
    }
    
    match /staff_availability/{userId} {
      // Allow read access to admins, managers, and the staff member themselves.
      allow read: if hasAnyRole(['admin', 'department_manager']) || request.auth.uid == userId;
      // Allow write access to admins, managers, and the staff member themselves.
      allow write: if hasAnyRole(['admin', 'department_manager']) || request.auth.uid == userId;
    }

  }
}
