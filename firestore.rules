rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    //
    // Helper Functions
    //
    function isAuth() {
      return request.auth != null;
    }

    function isPatientOwner(patientId) {
      // Check if the authenticated user's UID matches the patient's UID in the users collection
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.patient_id == patientId;
    }

    function getUserRole() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isDoctor() {
      return getUserRole() == 'doctor';
    }

    function isNurse() {
        return getUserRole() == 'nurse';
    }

    function isAdmin() {
        return getUserRole() == 'admin';
    }

    //
    // Collection Rules
    //

    // Users can read other user profiles (for names, etc.) but only update their own.
    // Critically, users cannot change their own role.
    match /users/{userId} {
      allow read: if isAuth();
      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;
      allow create, delete: if isAdmin();
    }
    
    // Roles and Audit Logs are admin-only and immutable from the client.
    match /roles/{roleId} {
        allow read, write, create, delete: if isAdmin();
    }
    
    match /audit_logs/{logId} {
        // No client access. All writes should be from trusted backend functions.
        allow read, write: if false;
    }
    
    // Health content is readable by any authenticated user, but only writable by admins.
    match /health_content/{contentId} {
        allow read: if isAuth();
        allow write: if isAdmin();
    }
    
    // Reminders are private to the patient they belong to. Only backend can create them.
    match /reminders/{reminderId} {
        allow read: if isPatientOwner(resource.data.patientId);
        allow write: if false; // Should be managed by Cloud Functions
    }

    // Core patient data and sub-collections
    match /patients/{patientId} {
      allow read, write: if isDoctor() || isNurse() || isAdmin();
      allow create: if isAuth();

      // Patients can only book their own appointments. Doctors and staff can also view.
      match /appointments/{appointmentId} {
        allow create: if isPatientOwner(request.resource.data.patientId);
        allow read: if isPatientOwner(resource.data.patientId) || isDoctor() || isNurse() || isAdmin();
        // Allow updates only from authorized users or the patient themselves for cancellation.
        allow update: if isDoctor() || isAdmin() || isPatientOwner(resource.data.patientId);
      }
      
      // Clinical data is restricted to clinical staff.
      match /clinical_notes/{noteId} {
        allow read, create: if isDoctor() || isNurse() || isAdmin();
      }
      
      match /vitals/{vitalId} {
        allow read, create: if isDoctor() || isNurse() || isAdmin();
      }

      // Other sub-collections can inherit from the parent or have specific rules.
      // By default, access is denied unless explicitly allowed.
    }
  }
}
