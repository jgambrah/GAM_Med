rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /patients/{patientId} {
      allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'];
      allow write: if getUserRole() in ['admin', 'doctor'];
      
      // Sub-collections
      match /{allPaths=**} {
        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
      }
    }
    
    match /beds/{bedId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() in ['admin', 'nurse', 'doctor'];
    }
    
    match /appointments/{appointmentId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() in ['admin', 'receptionist', 'doctor'];
    }
    
    match /referrals/{referralId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'];
      allow write: if getUserRole() in ['admin', 'receptionist'];
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || getUserRole() == 'admin';
    }

    match /invoices/{invoiceId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() in ['admin', 'billing_clerk'];
    }

    match /payments/{paymentId} {
        allow read: if getUserRole() in ['admin', 'billing_clerk'];
        allow create: if request.auth != null; // Patients or clerks can create payments
    }
    
    match /pharmacy_orders/{orderId} {
        allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor'];
        allow write: if getUserRole() in ['admin', 'pharmacist'];
    }

    match /inventory/{itemId} {
        allow read: if getUserRole() in ['admin', 'pharmacist', 'nurse', 'doctor'];
        allow write: if getUserRole() in ['admin', 'pharmacist'];
    }

    match /work_orders/{workOrderId} {
        allow create: if request.auth != null;
        allow read: if getUserRole() in ['admin', 'maintenance_manager', 'technician'] || request.auth.uid == resource.data.reportedByUserId || request.auth.uid == resource.data.assignedToUserId;
        allow update: if getUserRole() in ['admin', 'maintenance_manager'] || (getUserRole() == 'technician' && request.auth.uid == resource.data.assignedToUserId);
    }
    
    match /spare_parts/{partId} {
        allow read: if getUserRole() in ['admin', 'technician'];
        allow write: if getUserRole() == 'admin';
    }
  }
}
