
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      // In a real app, you might want to handle the case where the user document doesn't exist yet.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Allow read access for all authenticated users to their own user document
    match /users/{userId} {
      allow read: if isUserAuthenticated();
      allow write: if isUserAuthenticated() && request.auth.uid == userId;
    }
    
    match /patients/{patientId} {
      allow read: if isUserAuthenticated(); // More specific rules for subcollections
      allow write: if getUserRole() in ['admin', 'doctor', 'nurse']; // Or a trusted Cloud Function
      
      // Rules for daily_care_plans subcollection
      match /daily_care_plans/{carePlanId} {
        allow create: if false; // Only allow creation via trusted Cloud Function
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'ward_manager'] 
                       || request.auth.uid == resource.data.assignedToUserId 
                       || request.auth.uid == patientId;
        allow update: if getUserRole() in ['nurse', 'ward_manager'] && request.auth.uid == resource.data.assignedToUserId;
      }
    }

    match /wards/{wardId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist', 'ward_manager'];
      // Allow write only by ward managers or trusted functions
      allow write: if getUserRole() == 'ward_manager';
    }

    match /beds/{bedId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];
      // Allow write only by trusted functions (or specific admin roles like ward_manager)
      allow write: if getUserRole() in ['admin', 'ward_manager'];
    }
    
    match /operating_theatres/{theatreId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'];
      allow write: if getUserRole() == 'admin'; // Or trusted function
    }
  }
}
