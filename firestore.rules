rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // ===================================
    // == Operating Theatre (OT) Rules
    // ===================================
    match /operating_theaters/{theaterId} {
      allow read: if getUserRole() in ['admin', 'ot_coordinator', 'doctor'];
      allow write: if getUserRole() == 'admin';
    }
    
    match /ot_sessions/{sessionId} {
      allow create: if getUserRole() in ['admin', 'ot_coordinator', 'doctor'] 
                    && request.resource.data.leadSurgeonId == request.auth.uid;
      allow read: if getUserRole() in ['admin', 'ot_coordinator'] 
                  || request.auth.uid == resource.data.leadSurgeonId 
                  || request.auth.uid in resource.data.teamIds;
      allow update: if getUserRole() in ['admin', 'ot_coordinator'];
      // No delete rule for audit purposes
    }

    // ===================================
    // == Resource Scheduling Rules
    // ===================================
    match /resources/{resourceId} {
      allow read: if request.auth != null; // All authenticated users can see the resource catalog
      allow write: if getUserRole() == 'admin'; // Only admins can add/edit resources
    }

    match /resource_bookings/{bookingId} {
      allow create: if getUserRole() in ['admin', 'doctor', 'receptionist', 'ot_coordinator'];
      allow read: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.bookedByUserId;
      allow update: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.bookedByUserId;
    }
    
    // Other rules will go here...
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
