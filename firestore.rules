rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      // In a real app, this would get the role from custom claims on the auth token.
      // For this prototype, we read it from the user's document.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Rules for Business Intelligence & KPI Data
    match /bi_reports/{reportId} {
      allow read: if getUserRole() in ['admin', 'hospital_manager', 'financial_staff'];
      allow write: if false; // Should only be written by backend services
    }

    match /kpi_metrics/{metricId} {
        allow read: if getUserRole() in ['admin', 'hospital_manager', 'department_head'];
        allow write: if false; // Should only be written by backend services
    }

    // Rule for user-specific dashboard preferences
    match /user_preferences/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
