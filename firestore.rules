
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isUserRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isUserRole('admin');
      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;
      allow create, delete: if isUserRole('admin');
    }

    match /roles/{roleId} {
      allow read: if isUserRole('admin');
      allow write: if false; // Roles are read-only from the client
    }

    match /patients/{patientId} {
      // Allow doctors to read any patient, and patients to read their own record.
      allow read: if isUserRole('doctor') || request.auth.uid == resource.data.uid;
      // Allow only admins to create or update patient records.
      allow write: if isUserRole('admin');
    }

    match /invoices/{invoiceId} {
        // Allow billing clerks to read any invoice, and patients to read their own.
        allow read: if isUserRole('billing_clerk') || request.auth.uid == resource.data.patient_uid;
        // Only allow billing clerks to create or modify invoices.
        allow write: if isUserRole('billing_clerk');
    }

    match /audit_logs/{logId} {
      allow read: if isUserRole('admin');
      allow write: if false; // Deny all client-side writes to ensure immutability
    }
  }
}
