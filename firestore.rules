rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get user's role from the 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if the user is an Admin
    function isAdmin() {
      return getUserRole() == 'Admin';
    }
    
    // Helper function to check if user is a staff member
    function isStaff() {
      return getUserRole() in ['Admin', 'Doctor', 'Nurse', 'BillingClerk', 'Pharmacist'];
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow users to read their own data
      allow read: if request.auth.uid == userId || isAdmin();
      // Allow users to create their own user document on signup
      allow create: if request.auth.uid == userId;
      // Allow users to update their own data, but not their role
      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;
    }

    // Rules for the 'patients' collection
    match /patients/{patientId} {
      // Staff can read/write all patient data.
      allow read, write: if isStaff();
      // Patients can only read their own data (requires a more complex rule, assuming a link field exists)
      // allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientId == patientId;
    }
    
    // Rules for the 'admissions' collection
    match /admissions/{admissionId} {
       allow read, write: if isStaff();
       // Patients could potentially read their own admissions, similar to the patient rule above.
    }

    // --- Rules for the 'beds' collection ---
    match /beds/{bedId} {
      // READ: Allow authenticated staff members to view bed statuses.
      allow read: if isStaff();

      // CREATE: Only Admins can create new bed documents (for initial setup).
      allow create: if isAdmin();

      // UPDATE: Granular rules for updates.
      // Admins have full update access.
      // Nurses/other staff have limited access to perform valid state transitions.
      allow update: if isAdmin() || isStateTransitionValid();
      
      // No user should ever be able to delete a bed document.
      allow delete: if false;
    }
    
    // Helper function to validate bed status transitions
    function isStateTransitionValid() {
      let userRole = getUserRole();
      let incomingData = request.resource.data;
      let existingData = resource.data;
      
      // Transition 1: A Nurse can assign a vacant bed to a patient.
      // This is part of the admission/transfer action.
      let isAssigningBed = existingData.status == 'vacant' 
                        && incomingData.status == 'occupied'
                        && incomingData.currentPatientId != null
                        && incomingData.currentAdmissionId != null;

      // Transition 2: A Nurse can free up a bed after a patient is transferred/discharged.
      let isVacatingBed = existingData.status == 'occupied'
                       && incomingData.status == 'cleaning'
                       && incomingData.currentPatientId == null
                       && incomingData.currentAdmissionId == null;
                       
      // Transition 3: A Nurse/Housekeeper marks a bed as clean and available.
      let isMarkingClean = existingData.status == 'cleaning'
                        && incomingData.status == 'vacant'
                        && incomingData.cleaningNeeded == false;

      return (userRole == 'Nurse' && (isAssigningBed || isVacatingBed || isMarkingClean));
    }
  }
}
