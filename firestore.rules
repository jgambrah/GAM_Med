rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the role of the requesting user
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow users to read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Allow users to create their own profile upon signup
      allow create: if isAuthenticated();
      // Allow users to update their own profile
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for the 'patients' collection
    match /patients/{patientId} {
      allow read: if isAuthenticated() && (
        getUserRole() in ['Admin', 'Doctor', 'Nurse', 'BillingClerk'] ||
        // Patients can read their own data, assuming patientId matches their auth uid
        (getUserRole() == 'Patient' && request.auth.uid == patientId)
      );
      
      allow create: if isAuthenticated() && getUserRole() in ['Admin', 'BillingClerk'];
      
      allow update: if isAuthenticated() && (
        // Admins and Billing Clerks can update administrative fields
        getUserRole() in ['Admin', 'BillingClerk'] ||
        // Doctors and Nurses can update specific clinical fields (e.g., via a trusted server action)
        (getUserRole() in ['Doctor', 'Nurse'] && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmitted', 'currentAdmissionId', 'updatedAt']))
      );

      // Rules for the 'admissions' sub-collection
      match /admissions/{admissionId} {
        allow read: if isAuthenticated() && (
          getUserRole() in ['Admin', 'Doctor', 'Nurse', 'BillingClerk'] ||
          (getUserRole() == 'Patient' && request.auth.uid == patientId)
        );
        
        allow create: if isAuthenticated() && getUserRole() in ['Admin', 'BillingClerk'];

        // Updates are restricted and typically handled by server-side logic (e.g., discharging a patient)
        allow update: if isAuthenticated() && getUserRole() in ['Admin', 'Doctor', 'Nurse'];
      }
    }
    
    // Rules for the 'beds' collection
    match /beds/{bedId} {
      allow read: if isAuthenticated() && getUserRole() in ['Admin', 'Doctor', 'Nurse'];
      
      // Only Admins or trusted server-side logic should modify bed status
      allow update: if isAuthenticated() && getUserRole() == 'Admin';
      
      // Disallow client-side creation/deletion of beds
      allow create, delete: if false;
    }
  }
}
