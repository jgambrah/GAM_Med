
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to get user data and check roles
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOneOfRoles(allowedRoles) {
      return getUserData().role in allowedRoles;
    }

    // Rules for the users collection
    match /users/{userId} {
      // Users can read their own data.
      allow read: if request.auth.uid == userId;
      // Users can create their own user document upon signup.
      allow create: if request.auth.uid == userId;
      // Users can update their own data, but cannot change their role.
      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;
    }

    // Rules for the patients collection
    match /patients/{patientId} {
      // Admins, Doctors, and Nurses can read all patient data.
      // Patients can only read their own data (we'd need to match patientId to a field in their user doc).
      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
      
      // Admins can create new patients.
      allow create: if isOneOfRoles(['Admin']);
      
      // Admins, Doctors, and Nurses can update patient records.
      allow update: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
      
      // Only Admins can delete patient records (soft-delete preferred).
      allow delete: if isOneOfRoles(['Admin']);
    }

    // Rules for the admissions sub-collection
    match /admissions/{admissionId} {
        // Admins, Doctors, and Nurses can read all admission data.
        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
        // Admins, Doctors, and Nurses can create and update admissions.
        allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
    }

    // Rules for the beds collection
    match /beds/{bedId} {
      // Allow read access to all clinical and administrative staff.
      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']);

      // Only Admins can create new bed documents during initial system setup.
      allow create: if isOneOfRoles(['Admin']);

      // Allow updates based on role and valid state transitions.
      // Server-side actions with admin privileges will bypass these client-side rules.
      allow update: if 
        // Admins have full update access.
        isOneOfRoles(['Admin']) ||
        
        // A Nurse can perform valid state transitions.
        (isOneOfRoles(['Nurse']) && (
            // Nurse can mark a bed as clean (cleaning -> vacant)
            (resource.data.status == 'cleaning' && request.resource.data.status == 'vacant') ||
            // Nurse can transfer a patient (occupied -> cleaning for the old bed)
            (resource.data.status == 'occupied' && request.resource.data.status == 'cleaning') ||
            // Nurse can admit a patient (vacant -> occupied)
            (resource.data.status == 'vacant' && request.resource.data.status == 'occupied')
        ));
        
       // No one should be able to delete a bed document from the client.
       allow delete: if false;
    }
  }
}
