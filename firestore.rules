rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check a user's role from the 'users' collection.
    // The user's document ID in the 'users' collection must match their auth UID.
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Helper function to get the patient_id associated with a user's auth UID.
    function getPatientIdForUser(userId) {
        return get(/databases/$(database)/documents/users/$(userId)).data.patient_id;
    }

    // =====================================================================
    // E-Prescribing Module Rules
    // =====================================================================

    // Rules for the central 'medications' formulary.
    match /medications/{medicationId} {
      // Allow any authenticated user to read the drug catalog for searching/display.
      allow read: if request.auth != null;

      // Only allow admins and pharmacists to write to the central drug formulary.
      allow write: if getUserRole(request.auth.uid) in ['admin', 'pharmacist'];
    }

    // Rules for the top-level 'prescriptions' collection, used by the pharmacy.
    match /prescriptions/{prescriptionId} {
      // Only doctors can create new prescriptions.
      allow create: if getUserRole(request.auth.uid) == 'doctor';

      // Allow reading by admin, doctor, pharmacist, or the patient themselves.
      allow read: if getUserRole(request.auth.uid) in ['admin', 'doctor', 'pharmacist']
                  || getPatientIdForUser(request.auth.uid) == resource.data.patientId;

      // Allow updates only by doctors (to cancel) or pharmacists (to dispense).
      // This uses a more secure check on the request data to ensure only specific fields can be changed.
      allow update: if (getUserRole(request.auth.uid) == 'doctor' && request.resource.data.status == 'Canceled')
                    || (getUserRole(request.auth.uid) == 'pharmacist' && request.resource.data.status == 'Dispensed' && request.resource.data.filledAt != null);
      
      // Prescriptions should never be deleted to maintain a clear audit trail.
      allow delete: if false;
    }

    // Rules for patient-specific data.
    match /patients/{patientId} {
        // Only allow read access by the patient, or clinical/admin staff.
        // Assumes the patient's document in the `users` collection contains their `patient_id`.
        allow read: if getPatientIdForUser(request.auth.uid) == patientId
                    || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'pharmacist'];
        
        // Rules for the 'allergies' sub-collection within a patient's record.
        match /allergies/{allergyId} {
            // Allow reading by clinical staff or the patient themselves.
            allow read: if getPatientIdForUser(request.auth.uid) == patientId
                        || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'pharmacist'];
            
            // Only doctors and nurses can record or update allergy information.
            allow create, update: if getUserRole(request.auth.uid) in ['doctor', 'nurse'];

            // Allergy records should not be deleted to maintain history.
            allow delete: if false;
        }

        // Rules for the 'medication_history' sub-collection within a patient's record.
        match /medication_history/{prescriptionId} {
            // This is a mirror of the top-level prescription for the patient's EHR.
            // It should only be created by the system (via a Cloud Function).
            // Direct client creation is denied.
            allow create: if false;

            // Reading is allowed by clinical staff or the patient.
            allow read: if getPatientIdForUser(request.auth.uid) == patientId
                        || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'pharmacist'];
            
            // Only the prescribing doctor can update (e.g., change status to 'Discontinued').
            allow update: if getUserRole(request.auth.uid) == 'doctor' && resource.data.prescribedByDoctorId == request.auth.uid;

            // History should never be deleted.
            allow delete: if false;
        }
    }
  }
}
