rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || getUserRole() == 'admin';
      allow write: if request.auth.uid == userId || getUserRole() == 'admin';
    }

    match /patients/{patientId} {
      allow read, write: if getUserRole() == 'admin' 
                      || request.auth.uid == patientId
                      || request.auth.uid in get(/databases/$(database)/documents/patients/$(patientId)).data.assignedCareTeam;
    }

    match /audit_logs/{logId} {
      allow read: if getUserRole() == 'admin';
      allow write: if false; // Immutable from the client
    }

    match /prescriptions/{prescriptionId} {
      allow create: if getUserRole() == 'doctor';
      allow update: if getUserRole() == 'pharmacist';
      // No one can delete a prescription record directly, it must be marked as 'Canceled'.
      allow delete: if false; 
    }

    match /inventory/{itemId} {
      // Only pharmacists can update inventory levels (e.g., through dispensing or restocking).
      allow update: if getUserRole() == 'pharmacist';
      allow read: if request.auth.uid != null; // Allow any authenticated user to read inventory levels
      allow create, delete: if getUserRole() == 'admin'; // Only admins can add new items to the catalog
    }
  }
}
