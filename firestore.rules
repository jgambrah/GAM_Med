rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user role
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId; // Allow users to create their own profile
      allow update: if request.auth.uid == userId; // Allow users to update their own profile
    }

    // Rules for the 'patients' collection
    match /patients/{patientId} {
      allow read: if request.auth != null && (getUserRole(request.auth.uid) == 'Admin' || getUserRole(request.auth.uid) == 'Doctor');
      // Patients can read their own data, identified by a field linking to their auth UID
      // allow read: if request.auth.uid == resource.data.authUid; 
      allow create, update, delete: if request.auth != null && getUserRole(request.auth.uid) == 'Admin';
    }

    // Rules for the 'admissions' collection
    match /admissions/{admissionId} {
        allow read: if request.auth != null && (getUserRole(request.auth.uid) == 'Admin' || getUserRole(request.auth.uid) == 'Doctor');
        // allow read: if request.auth != null && exists(/databases/$(database)/documents/patients/$(resource.data.patientId)) && request.auth.uid == get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.authUid;
        allow create, update: if request.auth != null && getUserRole(request.auth.uid) == 'Admin';
    }

    // Rules for the 'beds' collection
    match /beds/{bedId} {
        allow read: if request.auth != null; // All authenticated users can see bed status
        allow update: if request.auth != null && (getUserRole(request.auth.uid) == 'Admin' || getUserRole(request.auth.uid) == 'Housekeeping');
    }

    // Rules for the 'referrals' collection
    match /referrals/{referralId} {
      // Admins can create referrals.
      allow create: if request.auth != null && getUserRole(request.auth.uid) == 'Admin';

      // Admins and the assigned doctor can read the referral.
      allow read: if request.auth != null && 
                    (getUserRole(request.auth.uid) == 'Admin' || request.auth.uid == resource.data.assignedToDoctorId);

      // Admins can update any field. Doctors can only update the status.
      allow update: if request.auth != null && getUserRole(request.auth.uid) == 'Admin';
      // A more granular rule for doctors would be:
      // allow update: if (getUserRole(request.auth.uid) == 'Admin') || 
      //               (request.auth.uid == resource.data.assignedToDoctorId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
    }

  }
}
