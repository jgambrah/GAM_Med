
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function getUserRole() {
      // In a real app, you would get the user's custom claims or read their user document.
      // For this prototype, we'll assume a helper function exists.
      // Example: return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return 'admin'; // Defaulting to admin for simplicity in prototype
    }
    
     function getUserClinic() {
      // In a real app, you would get the user's assigned clinic.
      return 'Cardiology'; 
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      allow write: if request.auth.uid == userId;
    }

    match /patients/{patientId}/{document=**} {
      allow read, write: if request.auth.uid != null; // Simplified for prototype
    }
    
    match /beds/{bedId} {
       allow read, write: if request.auth.uid != null;
    }

    match /clinics/{clinicId} {
      allow read: if true;
      allow write: if getUserRole() == 'admin';
    }
    
    match /appointments/{appointmentId} {
      allow read: if request.auth.uid == resource.data.patientId 
                   || request.auth.uid == resource.data.doctorId 
                   || getUserRole() in ['admin'] 
                   || (getUserRole() == 'receptionist' && getUserClinic() == resource.data.clinicId);
      allow create, update, delete: if request.auth.uid != null; // Simplified for prototype
    }

    match /doctor_schedules/{scheduleId} {
      allow read: true;
      allow write: if getUserRole() == 'admin' || (getUserRole() == 'doctor' && request.auth.uid == request.resource.data.doctorId);
    }

    match /operating_theaters/{otRoomId} {
      allow read: if getUserRole() in ['admin', 'ot_coordinator', 'doctor'];
      allow write: if getUserRole() == 'admin';
    }

    match /ot_sessions/{sessionId} {
      allow create: if getUserRole() in ['admin', 'ot_coordinator', 'doctor'] && request.resource.data.leadSurgeonId == request.auth.uid;
      allow read: if getUserRole() in ['admin', 'ot_coordinator'] || request.auth.uid == resource.data.leadSurgeonId || request.auth.uid in resource.data.teamIds;
      allow update: if getUserRole() in ['admin', 'ot_coordinator'];
      allow delete: if getUserRole() in ['admin', 'ot_coordinator'];
    }
  }
}
