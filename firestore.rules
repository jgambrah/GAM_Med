rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the user's role from the 'users' collection.
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Helper function to check if the user is an authorized clinical or admin staff.
    function isStaff() {
      let userRole = getUserRole(request.auth.uid);
      return request.auth != null && (userRole == 'admin' || userRole == 'doctor' || userRole == 'nurse');
    }

    // Helper function to check for administrative roles that can handle records.
    function isRecordsAdmin() {
        let userRole = getUserRole(request.auth.uid);
        return request.auth != null && (userRole == 'admin' || userRole == 'billing_clerk');
    }

    // =====================================================================
    // PATIENTS Collection
    // =====================================================================
    match /patients/{patientId} {
      /**
       * READ:
       * - Allow authorized staff (admin, doctor, nurse) to read any patient record.
       * - Allow patients to read their own record if their user document is linked.
       */
      allow read: if isStaff() || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);

      /**
       * CREATE:
       * - Only authorized administrative staff can create patient records.
       * - Enforce that the document ID must be identical to the `patientId` field within the document.
       *   This is a critical integrity check.
       */
      allow create: if isRecordsAdmin() && request.resource.id == request.resource.data.patientId;

      /**
       * UPDATE:
       * - Only authorized administrative staff can update patient records.
       * - Crucially, prevent the `patientId` field from ever being changed.
       * - Other clinical fields would be updated via sub-collections with their own rules.
       */
      allow update: if isRecordsAdmin() && request.resource.data.patientId == resource.data.patientId;
      
      // DENY all deletes to prevent accidental data loss. Data should be marked 'inactive' or 'deceased'.
      allow delete: if false;

      // --- Admissions Sub-collection ---
      match /admissions/{admissionId} {
        /**
         * READ:
         * - Staff can read admission history.
         * - Patients can read their own admission history.
         */
        allow read: if isStaff() || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);
        
        /**
         * WRITE:
         * - All admission/discharge logic is handled exclusively by secure Cloud Functions.
         * - Direct client writes are forbidden to ensure data consistency.
         */
        allow write: if false; // Writes should only be from Cloud Functions
      }
    }

    // =====================================================================
    // BEDS Collection
    // =====================================================================
    match /beds/{bedId} {
      /**
       * READ:
       * - Only authorized clinical and administrative staff can view bed status.
       */
      allow read: if isStaff();
      
      /**
       * WRITE:
       * - Bed status changes are highly sensitive and are only managed by secure Cloud Functions
       *   during admission, transfer, or discharge to prevent inconsistencies.
       */
      allow write: if false; // Writes should only be from Cloud Functions
    }

    // =====================================================================
    // USERS Collection
    // =====================================================================
    match /users/{userId} {
       // Allow users to read their own document. Admins can read any user document.
      allow read: if request.auth.uid == userId || getUserRole(request.auth.uid) == 'admin';
      
      // Allow users to update their own non-critical info. Role changes are admin-only.
      allow update: if request.auth.uid == userId;
    }
  }
}
