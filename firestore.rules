rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get user role
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Users can read their own data.
    // Admins can read anyone's data.
    match /users/{userId} {
      allow read: if request.auth.uid == userId 
                  || getUserRole(request.auth.uid) == 'Admin';
      allow create: if request.auth.uid != null;
      allow write: if request.auth.uid == userId 
                   || getUserRole(request.auth.uid) == 'Admin';
    }

    // Patients can only read their own appointments.
    // Doctors can read appointments assigned to them.
    // Nurses and Admins can read all appointments.
    match /appointments/{appointmentId} {
      allow read: if (getUserRole(request.auth.uid) == 'Patient' && resource.data.patientId == request.auth.uid)
                  || (getUserRole(request.auth.uid) == 'Doctor' && resource.data.doctorId == request.auth.uid)
                  || (getUserRole(request.auth.uid) == 'Nurse')
                  || (getUserRole(request.auth.uid) == 'Admin');
      
      // Allow creation/updates for Admins, or Doctors/Nurses for scheduling
      allow write: if getUserRole(request.auth.uid) in ['Admin', 'Doctor', 'Nurse'];
    }

    // Patients can read their own records.
    // Doctors, Nurses, and Admins can read all patient records.
    match /patients/{patientId} {
       allow read: if (getUserRole(request.auth.uid) == 'Patient' && request.auth.uid == patientId)
                  || getUserRole(request.auth.uid) in ['Doctor', 'Nurse', 'Admin'];

      // Allow creation/updates for Admins, Doctors, Nurses
       allow write: if getUserRole(request.auth.uid) in ['Admin', 'Doctor', 'Nurse'];
    }
  }
}
