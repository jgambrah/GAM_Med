
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      // Assumes a 'role' custom claim has been set for the user.
      return request.auth.token.role;
    }

    // == USER DATA ==
    match /users/{userId} {
      // Users can read their own profile. Authenticated staff can read other profiles.
      allow read: if request.auth.uid == userId || getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];
      // Only admins can modify user roles or other details. This protects the 'availability' map.
      allow write: if getUserRole() == 'admin';
    }

    // == RADIOLOGY ==
    match /radiology_studies/{studyId} {
        // Anyone authenticated can see what studies are available.
        allow read: if request.auth != null;
        // Only admins can add or change studies.
        allow write: if getUserRole() == 'admin';
    }

    match /radiology_orders/{orderId} {
        // Doctors can create orders.
        allow create: if getUserRole() in ['admin', 'doctor'];
        // Receptionists/Admins can update the status. Radiologists can add report details.
        allow update: if getUserRole() in ['admin', 'receptionist', 'radiologist'];
        // Only involved staff or the patient themselves can read the order.
        allow read: if getUserRole() in ['admin', 'doctor', 'receptionist', 'radiologist'] || request.auth.uid == resource.data.patientId;
    }
    
    match /radiology_reports/{reportId} {
        // Radiologists can create reports.
        allow create: if getUserRole() in ['admin', 'radiologist'];
        // Only involved staff or the patient themselves can read the report.
        allow read: if getUserRole() in ['admin', 'doctor', 'receptionist', 'radiologist'] || request.auth.uid == resource.data.patientId;
    }
    
    // == SCHEDULING & RESOURCES ==
    match /appointments/{appointmentId} {
        // Only authorized staff can create or modify appointments.
        allow create, update: if getUserRole() in ['admin', 'receptionist', 'radiologist'];
        // Involved staff or the patient can view the appointment.
        allow read: if getUserRole() in ['admin', 'doctor', 'receptionist', 'radiologist'] || request.auth.uid == resource.data.patientId;
    }
    
    match /equipment/{equipmentId} {
        // Any authenticated user can see the equipment list.
        allow read: if request.auth != null;
        // Only an admin (representing the backend function) can update equipment details like availability.
        allow write: if getUserRole() == 'admin';
    }

    // Fallback rule to deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
