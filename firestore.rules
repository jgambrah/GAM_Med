
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get the user's role from the 'users' collection.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Allow read access to users collection for authenticated users
    match /users/{userId} {
      allow read: if request.auth != null;
      // Write access might be more restricted, e.g., only by the user themselves or admins.
      allow write: if request.auth.uid == userId || getUserRole() == 'admin';
    }

    // Rules for the 'patients' collection
    match /patients/{patientId} {
      // Allow read access to clinical staff and the patient themselves
      allow read: if request.auth != null && (getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || request.auth.uid == resource.data.uid);
      
      // Allow creation by admins and nurses
      allow create: if request.auth != null && getUserRole() in ['admin', 'nurse'];

      // Allow updates by clinical staff
      allow update: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse'];
      
      // Deletion should be highly restricted, perhaps only by admins and requiring a 'soft-delete' flag.
      allow delete: if request.auth != null && getUserRole() == 'admin';

      // Rules for the 'admissions' sub-collection
      match /admissions/{admissionId} {
        // Read access for clinical staff and the specific patient.
        allow read: if request.auth != null && 
                    (getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || 
                    get(/databases/$(database)/documents/patients/$(patientId)).data.uid == request.auth.uid);

        // Allow creation during the admission process
        allow create: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse'];

        // Complex update rules based on discharge workflow state.
        allow update: if request.auth != null && (
            // Rule for Doctors: Can update the summary if it's not yet finalized.
            ( getUserRole() == 'doctor' && resource.data.isSummaryFinalized == false ) ||
            // Rule for Billing Clerks: Can only update specific financial fields.
            ( getUserRole() == 'billing_clerk' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['finalBillId', 'status'])) ||
            // Rule for Admins: Broader update permissions.
            ( getUserRole() == 'admin' )
        );
      }
    }
    
    // Rules for the 'beds' collection
    match /beds/{bedId} {
        // All clinical and admin staff can see bed status.
        allow read: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'];
        
        // Only admins or nurses can update bed status (e.g., for cleaning, maintenance).
        allow write: if request.auth != null && getUserRole() in ['admin', 'nurse'];
    }

    // Rules for the 'referrals' collection
    match /referrals/{referralId} {
      allow read: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse'];
      allow create, update: if request.auth != null && getUserRole() in ['admin', 'nurse'];
      allow delete: if request.auth != null && getUserRole() == 'admin';
    }

    // Rules for the 'appointments' collection
    match /appointments/{appointmentId} {
      // Patients can read their own appointments, staff can read all.
      allow read: if request.auth != null && 
                  (getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || 
                  resource.data.patient_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id);
                  
      // Staff can create appointments. Patients might be able to request them.
      allow create: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse'];
      
      // Allow updates by staff or the patient who owns the appointment (e.g., to cancel).
      allow update: if request.auth != null && 
                  (getUserRole() in ['admin', 'doctor', 'nurse'] || 
                  resource.data.patient_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id);
    }
  }
}
