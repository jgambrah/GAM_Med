
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to simplify rule logic
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserRole() {
      // Return null if user isn't signed in to prevent errors
      return isSignedIn() ? getUserData().role : null;
    }

    // Secure the users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isUser(userId); // Users can only edit their own profile
    }

    // Rules for the main patients collection and its sub-collections
    match /patients/{patientId} {
      // Clinical, admin, and billing staff can view patient records.
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'pharmacist', 'lab_technician'];
      // Only admins should modify the top-level patient document to prevent accidental changes.
      allow write: if getUserRole() == 'admin';
      
      // == NURSING MODULE RULES ==
      // These rules grant nurses specific permissions for their workflows.
      
      // Vitals can be read by clinical staff, but only created/updated by nurses.
      match /vitals/{vitalId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        allow create, update: if getUserRole() == 'nurse';
        // No delete allowed to preserve history.
        allow delete: if false;
      }
      
      // Care plans can be read by clinical staff, but only created/updated by nurses.
      match /care_plans/{planId} {
         allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
         allow create, update: if getUserRole() == 'nurse';
         allow delete: if false;
      }
      
      // Medication administration logs can be read by clinical staff, but only created by nurses.
      // Updates are disallowed to maintain the integrity of the log.
      match /medication_administration_logs/{logId} {
         allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
         allow create: if getUserRole() == 'nurse';
         allow update, delete: if false;
      }
      
      // Progress notes can be read by clinical staff, but only created by nurses.
      // These are distinct from doctor's clinical notes.
      match /progress_notes/{noteId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        allow create: if getUserRole() == 'nurse';
        allow update, delete: if false;
      }

      // == DOCTOR-SPECIFIC RULES (FOR COMPARISON) ==
      // These rules explicitly prevent nurses from writing to doctor-only sub-collections.
      
      // Clinical notes are the primary domain of doctors.
      match /clinical_notes/{noteId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        allow write: if getUserRole() == 'doctor';
      }
      
      // Diagnoses are made exclusively by doctors.
      match /diagnoses/{diagnosisId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        allow write: if getUserRole() == 'doctor';
      }

      // Prescriptions are written exclusively by doctors.
      match /medication_history/{prescriptionId} {
          allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'patient'];
          allow write: if getUserRole() == 'doctor';
      }
      
      // Lab results can be read by clinical staff, but only written by the lab system/technician.
      match /lab_results/{testId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'lab_technician'];
        allow write: if getUserRole() == 'lab_technician'; // Or a dedicated service account
      }

      // Admissions history can be read widely, but written only by secure Cloud Functions.
      match /admissions/{admissionId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'patient'];
        allow write: if false; // Should only be written by backend functions
      }
    }
  }
}
