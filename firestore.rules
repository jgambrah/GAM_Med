rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get the user's role from their user document.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Rules for the main collections
    match /patients/{patientId} {
      allow read, write: if request.auth != null; // Basic auth for now
      
      // Sub-collection rules can be more granular
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId; // Users can update their own profile
    }

    match /inventory/{itemId} {
      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];

      // Allow updates to inventory levels (batches) only by trusted functions
      // and specific updates to reorder settings by authorized staff.
      allow update: if (getUserRole() in ['admin', 'pharmacist', 'inventory_manager'] &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reorderLevel', 'isAutoReorder']))
                     || (request.auth.uid in get(/databases/$(database)/documents/system/trusted_functions).data.uids); // Placeholder for trusted function UIDs
    }
    
    match /inventory/{itemId}/transactions/{transactionId} {
      // Allow creation only by authorized roles or trusted functions.
      allow create: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager']
                     || (request.auth.uid in get(/databases/$(database)/documents/system/trusted_functions).data.uids);
      allow read: if getUserRole() in ['admin', 'pharmacist'];
    }

    match /reorder_requests/{requestId} {
      allow read, update: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager'];
      allow create: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager']
                     || (request.auth.uid in get(/databases/$(database)/documents/system/trusted_functions).data.uids);
    }
    
    match /{document=**} {
      allow read, write: if false; // Default deny all
    }
  }
}
