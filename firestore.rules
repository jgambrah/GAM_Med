
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function getUserRole() {
      // Return the role of the user making the request.
      // This assumes a 'role' field exists on the user's document in the /users/ collection.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isHRAdmin() {
        return getUserRole() in ['admin', 'hr']; // Define HR role for reuse
    }

    match /users/{userId} {
      // READ: Users can read their own profile. HR and Admins can read any profile.
      allow read: if request.auth.uid == userId || isHRAdmin();
      
      // UPDATE: Users can update their own profile (potentially limited fields). HR and Admins can update any profile.
      // A more granular rule could be: `allow update: if (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contactInfo'])) || isHRAdmin();`
      allow update: if request.auth.uid == userId || isHRAdmin();
      
      // CREATE: Only HR and Admins can create new user/employee records.
      allow create: if isHRAdmin();
      
      // DELETE: Only Admins can delete user records.
      allow delete: if getUserRole() == 'admin';
    }

    match /patients/{patientId} {
      allow read, write: if request.auth != null;

      match /admissions/{admissionId} {
        allow read, write: if request.auth != null;
      }

      match /clinical_notes/{noteId} {
        allow read, write: if request.auth != null;
      }
      
      match /vitals/{vitalId} {
        allow read, write: if request.auth != null;
      }
      
      match /care_plans/{planId} {
        allow read, write: if request.auth != null;
      }
      
       match /medication_history/{medId} {
        allow read, write: if request.auth != null;
      }
      
      match /lab_results/{testId} {
        allow read, write: if request.auth != null;
      }
      
      match /immunizations/{recordId} {
         allow read, write: if request.auth != null;
      }
    }
    
    match /ot_sessions/{caseId} {
      allow read, write: if getUserRole() in ['admin', 'surgeon', 'nurse'] OR request.auth.uid == resource.data.patientId;
      
      match /vitals_log/{logId} {
         allow create: if getUserRole() in ['admin', 'nurse'];
         allow read: if getUserRole() in ['admin', 'surgeon', 'nurse'] OR request.auth.uid == parent(collection).data.patientId;
      }
    }

    match /beds/{bedId} {
        allow read, write: if request.auth != null;
    }
    
     match /appointments/{appointmentId} {
        allow read, write: if request.auth != null;
    }
    
    match /referrals/{referralId} {
        allow read, write: if request.auth != null;
    }
    
    match /pharmacy_orders/{orderId} {
       allow read, write: if request.auth != null;
    }
    
    match /prescriptions/{prescriptionId} {
       allow read, write: if request.auth != null;
    }
    
    match /results/{docId} {
        allow read: if (resource.data.studentId == request.auth.uid && resource.data.isPublished == true) || getUserRole() in ['admin', 'registrar'];
        allow write: if false;
    }
    
    match /student_academic_records/{docId} {
        allow read: if (resource.data.studentId == request.auth.uid && resource.data.finalResultPublished == true) || getUserRole() in ['admin', 'registrar'];
        allow write: if false;
    }
    
    match /employees/{employeeId} {
      allow read: if request.auth.uid == employeeId || getUserRole() in ['admin', 'hr_manager'];
      allow create: if getUserRole() == 'hr_manager';
    }

    match /employees/{employeeId}/employee_documents/{documentId} {
      allow create: if request.auth.uid == employeeId || getUserRole() in ['admin', 'hr_manager'];
      allow read: if request.auth.uid == employeeId || getUserRole() in ['admin', 'hr_manager'];
    }

    match /attendance_logs/{logId} {
      allow create: if getUserRole() in ['admin', 'hr_manager']; // Simplified for this context
      allow read: if getUserRole() in ['admin', 'hr_manager'];
    }
  }
}
