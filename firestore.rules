rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user's role from the 'users' collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Helper function to check if the user is an authenticated staff member
    function isStaff() {
      return request.auth != null && getUserRole(request.auth.uid) in ['Admin', 'Doctor', 'Nurse', 'BillingClerk'];
    }
    
    // Helper function to check for Admin role
    function isAdmin() {
      return request.auth != null && getUserRole(request.auth.uid) == 'Admin';
    }

    // Helper function to check for Nurse or Admin role
    function isNurseOrAdmin() {
      return request.auth != null && getUserRole(request.auth.uid) in ['Admin', 'Nurse'];
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Rules for the 'patients' collection
    match /patients/{patientId} {
      allow read: if isStaff() || (request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == resource.data.fullName);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }
    
    // Rules for the 'admissions' collection
    match /admissions/{admissionId} {
       allow read: if isStaff() || (request.auth != null && get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.fullName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name);
       allow create: if isNurseOrAdmin();
       allow update: if isNurseOrAdmin();
       allow delete: if isAdmin();
    }

    // --- Bed Management Security Rules ---
    match /beds/{bedId} {
      // Allow read access to all staff members
      allow read: if isStaff();
      
      // Only Admins can create or delete bed documents
      allow create, delete: if isAdmin();

      // Allow updates only by authorized staff and under specific conditions
      allow update: if isNurseOrAdmin() &&
        (
          // Case 1: Admin can do anything
          isAdmin() ||
          
          // Case 2: Admitting a patient (vacant -> occupied)
          (request.resource.data.status == 'occupied' && resource.data.status == 'vacant' && request.resource.data.currentPatientId != null) ||
          
          // Case 3: Discharging or transferring a patient (occupied -> cleaning)
          (request.resource.data.status == 'cleaning' && resource.data.status == 'occupied' && request.resource.data.currentPatientId == null) ||
          
          // Case 4: Marking a bed as clean after service (cleaning -> vacant)
          (request.resource.data.status == 'vacant' && resource.data.status == 'cleaning' && request.resource.data.currentPatientId == null)
        );
    }
  }
}
