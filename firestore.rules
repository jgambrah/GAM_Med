rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user's role from their token
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Rules for the users collection
    match /users/{userId} {
      // Allow users to read their own data
      allow read: if request.auth.uid == userId;
      // Allow only admins to create or modify user roles
      allow write: if getUserRole() == 'admin';
    }
    
    // Rules for the patients collection and its subcollections
    match /patients/{patientId} {
        // Allow read/write access to clinical staff
        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
        
        // Allow a patient to read their own main record
        allow read: if request.auth.uid == resource.data.userId;

        // Rules for patient subcollections (EHR data)
        match /{subcollection}/{docId} {
             // Allow read/write access to clinical staff
            allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];

             // Allow a patient to read their own subcollection data
            allow read: if request.auth.uid == get(/databases/$(database)/documents/patients/$(patientId)).data.userId;
        }
    }
    
    // Rules for the appointments collection
    match /appointments/{appointmentId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist', 'radiologist'];
        allow create, update: if getUserRole() in ['admin', 'receptionist', 'radiologist'];
    }
    
    // Rules for equipment (resources)
    match /equipment/{equipmentId} {
        allow read: if request.auth.uid != null;
        // Only allow admins (representing trusted server functions) to update availability
        allow write: if getUserRole() == 'admin';
    }

    // Rules for radiology orders (worklist)
    match /radiology_orders/{orderId} {
      // Allow read access to relevant roles and the assigned radiologist
      allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'] 
                  || request.auth.uid == resource.data.assignedRadiologistId;

      // Allow creation by authorized roles (doctor, admin)
      allow create: if getUserRole() in ['admin', 'doctor'];

      // Allow updates by admin or receptionist (for scheduling)
      // Restrict who can change specific fields. `isReported` is only changed by the Cloud Function (admin).
      allow update: if (getUserRole() in ['admin', 'receptionist'] 
                      && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'scheduledDateTime', 'assignedRadiologistId']))
                    || getUserRole() == 'admin'; // Admin can change anything
    }
    
    // Rules for radiology reports
    match /radiology_reports/{reportId} {
       // Allow read to relevant staff or the patient themselves (conceptual)
       allow read: if getUserRole() in ['admin', 'doctor', 'radiologist'];
       // Allow writes only from trusted backend processes (represented by admin)
       allow write: if getUserRole() == 'admin';
    }
  }
}
