rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuth() {
      return request.auth != null;
    }

    function isOneOfRoles(roles) {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    // Rules for 'users' collection
    match /users/{userId} {
      // Allow users to read their own profile
      allow read: if isAuth() && request.auth.uid == userId;
      // Allow users to create their own profile upon signup
      allow create: if isAuth() && request.auth.uid == userId;
      // Allow users to update their own profile
      allow update: if isAuth() && request.auth.uid == userId;
    }

    // Rules for 'patients' collection
    match /patients/{patientId} {
      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']);
      allow list: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
      allow create: if isOneOfRoles(['Admin']);
      allow update: if isOneOfRoles(['Admin', 'Doctor']);
      allow delete: if isOneOfRoles(['Admin']);
    }

    // Rules for 'admissions' collection
    match /admissions/{admissionId} {
      allow read, list: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
      allow create, update: if isOneOfRoles(['Admin', 'Doctor']);
    }

    // Rules for 'beds' collection
    match /beds/{bedId} {
      allow read, list: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'Housekeeping']);
      allow update: if isOneOfRoles(['Admin', 'Nurse', 'Housekeeping']);
    }
    
    // Rules for 'referrals' collection
    match /referrals/{referralId} {
        allow read, list: if isOneOfRoles(['Admin', 'Doctor']);
        allow create: if isOneOfRoles(['Admin']);
        allow update: if isOneOfRoles(['Admin', 'Doctor']);
    }

  }
}
