
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check user roles
    function isUserRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Patients can only be created by admins/nurses.
    // Patients can read/update their own data.
    match /patients/{patientId} {
      allow read, update: if request.auth.uid == patientId || isUserRole('admin') || isUserRole('doctor') || isUserRole('nurse');
      allow create: if isUserRole('admin') || isUserRole('nurse');

      // Sub-collections for a patient
      match /{subcollection}/{docId} {
        allow read, write: if request.auth.uid == patientId || isUserRole('admin') || isUserRole('doctor') || isUserRole('nurse');
      }
    }

    // Users can read/update their own profile.
    // Availability map can only be changed by backend functions (admins cannot edit directly).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth.uid == userId && !("availability" in request.resource.data);
      allow write: if isUserRole('admin');
    }

    // Beds can be read by any authenticated user, but only updated by clinical staff/admin.
    match /beds/{bedId} {
        allow read: if request.auth != null;
        allow write: if isUserRole('admin') || isUserRole('doctor') || isUserRole('nurse');
    }

    // Appointments can be created by the patient themselves.
    // They can be read by the patient or the doctor involved.
    match /appointments/{appointmentId} {
      allow create: if request.auth.uid == request.resource.data.patientId;
      allow read: if request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId;
      allow update, delete: if isUserRole('admin') || isUserRole('doctor') || isUserRole('receptionist');
    }

    // Health Content can be read by any authenticated user, but only written by an admin.
    match /health_content/{contentId} {
      allow read: if request.auth != null;
      allow write: if isUserRole('admin');
    }

    // Reminders are private and can only be read by the patient they are assigned to.
    // Creation is handled by secure backend Cloud Functions, so client-side create is denied.
    match /reminders/{reminderId} {
      allow read: if request.auth.uid == resource.data.patientId;
      allow create, update, delete: if false; // Handled by backend
    }
  }
}
