rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DOCUMENTATION: Firestore Security Rules
     *
     * Core Philosophy:
     * This ruleset implements a "Public Read, Admin Write" model for marketing and pricing data. 
     * It is designed to allow the Landing Page to remain dynamic by fetching data directly 
     * from Firestore, while strictly protecting against unauthorized modifications.
     *
     * Data Structure:
     * All pricing data is stored in a top-level `/pricing_plans` collection. Each document 
     * represents a tier (e.g., 'clinic-starter', 'professional').
     *
     * Key Security Decisions:
     * 1. Public Accessibility: Since pricing plans are intended for a public landing page, 
     *    read access (get/list) is granted to all users, including those not signed in.
     * 2. Administrative Control: Write operations are restricted to users who have an 
     *    entry in the `/roles_admin` collection. This provides a centralized way to 
     *    manage administrative privileges without cluttering the data documents.
     * 3. Relational Integrity: On creation, the rules enforce that the internal 'id' field 
     *    of a pricing plan matches the Firestore document ID to ensure consistency.
     * 4. Update Safety: Critical identifiers are made immutable during updates to prevent 
     *    accidental data corruption or orphaned records.
     */

    // --- Helper Functions ---

    /**
     * @description Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user has administrative privileges 
     * by looking up their UID in the roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for pricing plans which are displayed on the public landing page.
     * @path /pricing_plans/{planId}
     * @allow (get, list) Any user, even unauthenticated, to view pricing.
     * @allow (create, update, delete) Only users with an admin record in /roles_admin.
     * @deny (write) Any non-admin user attempting to change price or features.
     * @principle Public consumption with restrictive, role-based administrative writes.
     */
    match /pricing_plans/{planId} {
      
      // Reads are public for the Landing Page
      allow get, list: if true;

      // Writes require Admin privileges
      allow create: if isAdmin() && request.resource.data.id == planId;
      
      allow update: if isAdmin() 
                    && resource != null 
                    && request.resource.data.id == resource.data.id;

      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for the admin roles collection used for authorization.
     * @path /roles_admin/{userId}
     * @allow (get) Any signed-in user to check their own admin status.
     * @deny (list, write) All client-side operations to prevent privilege escalation.
     * @principle Closed, read-only role mapping for security bootstrapping.
     */
    match /roles_admin/{userId} {
      // Users can check their own status, but cannot list or modify roles from the client.
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list, create, update, delete: if false;
    }

  }
}