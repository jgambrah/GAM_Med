rules_version = '2';

// Helper function to get the user's role from the 'users' collection
function getUserRole() {
  return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
}

// Helper function to check if the user is authenticated
function isSignedIn() {
  return request.auth != null;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can read their own profile.
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Admins can read/write any user profile.
      allow read, write: if getUserRole() == 'admin';
    }

    // Rules for the main 'patients' collection
    match /patients/{patientId} {
      // Allow read access if user is staff or the patient themselves
      allow read: if isSignedIn() && (getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist', 'billing_clerk'] || request.auth.uid == patientId);
      // Allow create only by admin/reception/nurse
      allow create: if getUserRole() in ['admin', 'receptionist', 'nurse'];
      // Allow update by clinical staff or admin
      allow update: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }
    
    // Rules for the 'radiology_orders' collection
    match /radiology_orders/{orderId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'receptionist', 'radiologist'] || request.auth.uid == resource.data.assignedRadiologistId;
      allow create: if getUserRole() in ['admin', 'doctor'];
      allow update: if getUserRole() in ['admin', 'receptionist', 'radiologist'];
    }
    
    // Rules for the 'radiology_reports' collection
    match /radiology_reports/{reportId} {
      allow create: if getUserRole() in ['admin', 'radiologist'];
      // Allow read by clinical staff or the patient to whom the report belongs.
      // Assumes 'patientId' is denormalized onto the report document.
      allow read: if getUserRole() in ['admin', 'doctor', 'radiologist'] || request.auth.uid == resource.data.patientId;
      // Only allow updates if the report is not yet final.
      allow update: if getUserRole() == 'radiologist' && resource.data.isFinal == false;
    }

    // Rules for the 'radiology_history' sub-collection within a patient's record.
    match /patients/{patientId}/radiology_history/{historyId} {
      // Disallow all direct client writes. Only backend functions can create/update this log.
      allow write: if false; 
      // Allow read by the patient or authorized clinical staff.
      allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor'];
    }

    // Default deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
