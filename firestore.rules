rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get user role from the 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Allow public read for specific public-facing collections if needed
    // e.g., match /public_data/{docId} { allow read: if true; }

    // Rules for User management
    match /users/{userId} {
      allow read: if request.auth != null; // Allow any authenticated user to read user profiles (e.g., for contact info)
      allow write: if request.auth.uid == userId || getUserRole() == 'admin'; // Allow users to edit their own profile or admins to edit any
    }
    
    // Rules for Patient Records
    match /patients/{patientId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'] || request.auth.uid == patientId; // Patient can read their own record
      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];
      
      // Sub-collections within a patient's record
      match /{subcollection}/{docId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'] || request.auth.uid == patientId;
        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];
      }
    }
    
    // Rules for Pharmacy Module
    match /pharmacy_orders/{orderId} {
        allow read, write: if getUserRole() in ['admin', 'pharmacist', 'doctor'];
    }
    
    // Rules for Appointments
    match /appointments/{appointmentId} {
      allow read: if request.auth != null;
      allow create, update, delete: if getUserRole() in ['admin', 'doctor', 'receptionist'];
    }

    // Rules for Beds and Wards
    match /beds/{bedId} {
      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }
    
    match /wards/{wardId} {
      allow read: if request.auth != null;
      allow write: if getUserRole() == 'admin';
    }
    
    // Rules for Referrals
    match /referrals/{referralId} {
      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }
    
    // Rules for Billing and Financials
    match /invoices/{invoiceId} {
       allow read: if getUserRole() in ['admin', 'billing_clerk'] || get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.userId == request.auth.uid;
       allow create, update: if getUserRole() in ['admin', 'billing_clerk'];
    }
    
    match /payments/{paymentId} {
      allow read: if getUserRole() in ['admin', 'billing_clerk'];
      allow create: if request.auth != null; // Allow patients and staff to create payments
    }
    
    match /insurance_claims/{claimId} {
      allow read, write: if getUserRole() in ['admin', 'billing_clerk'];
    }
    
    // Rules for Asset & Facilities Management
    match /assets/{assetId} {
      allow read: if getUserRole() in ['admin', 'finance', 'it_manager', 'asset_manager', 'technician'];
      // Only Admins or Asset Managers can create, update, or delete asset records directly.
      // Specific fields like service dates are updated via a trusted Cloud Function.
      allow create, delete: if getUserRole() in ['admin', 'asset_manager'];
      allow update: if getUserRole() in ['admin', 'asset_manager', 'it_manager']; 
    }
    
    match /maintenance_logs/{logId} {
      allow read: if getUserRole() in ['admin', 'manager', 'technician'];
      // Maintenance logs are an immutable audit trail.
      // They can only be created by technicians or admins. They cannot be updated or deleted.
      allow create: if getUserRole() in ['admin', 'technician'];
      allow update, delete: if false;
    }
  }
}
