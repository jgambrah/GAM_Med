rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions for Multi-Tenant Logical Isolation
    // --------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Retrieves the authenticated user's profile.
     * Note: In a production environment with high scale, you would migrate 
     * 'hospitalId' and 'role' to Custom Auth Claims to avoid this 'get' call.
     */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Verifies that the document belongs to the user's hospital.
     */
    function isSameHospital(docData) {
      return isSignedIn() && docData.hospitalId == getUserData().hospitalId;
    }

    /**
     * Checks if the user is an employee of their hospital.
     */
    function isEmployee() {
      return isSignedIn() && getUserData().role in [
        'admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk', 
        'lab_technician', 'radiologist', 'dietitian', 'receptionist'
      ];
    }

    /**
     * Checks if the user is a hospital administrator.
     */
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    /**
     * Checks if the authenticated user is the owner of the document.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    // Hospitals (Tenant Masters)
    match /hospitals/{hospitalId} {
      allow get: if isSignedIn() && getUserData().hospitalId == hospitalId;
      allow write: if false; // Provisioning is handled via system admin tools
    }

    // Users & Staff Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || (isEmployee() && isSameHospital(resource.data));
      allow list: if isEmployee(); // Queries must filter by hospitalId
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // Patients
    match /patients/{patientId} {
      allow get: if (isSignedIn() && getUserData().patient_id == patientId) || (isEmployee() && isSameHospital(resource.data));
      allow list: if isEmployee();
      allow create: if isEmployee() && isSameHospital(request.resource.data);
      allow update: if isEmployee() && isSameHospital(resource.data) && isSameHospital(request.resource.data);
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow read: if (isSignedIn() && getUserData().patient_id == resource.data.patientId) || (isEmployee() && isSameHospital(resource.data));
      allow create: if isSignedIn() && isSameHospital(request.resource.data);
      allow update: if isEmployee() && isSameHospital(resource.data);
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    // Admissions & Beds
    match /admissions/{admissionId} {
      allow read, write: if isEmployee() && (resource == null || isSameHospital(resource.data)) && (request.resource == null || isSameHospital(request.resource.data));
    }
    match /beds/{bedId} {
      allow read: if isEmployee() && isSameHospital(resource.data);
      allow write: if isEmployee() && isSameHospital(request.resource.data);
    }

    // Billing & Invoices
    match /invoices/{invoiceId} {
      allow read: if (isSignedIn() && getUserData().patient_id == resource.data.patientId) || (isEmployee() && isSameHospital(resource.data));
      allow create, update: if isEmployee() && isSameHospital(request.resource.data);
    }

    // Laboratory & Radiology
    match /lab_results/{testId} {
      allow read: if (isSignedIn() && getUserData().patient_id == resource.data.patientId) || (isEmployee() && isSameHospital(resource.data));
      allow write: if isEmployee() && (resource == null || isSameHospital(resource.data)) && (request.resource == null || isSameHospital(request.resource.data));
    }
    match /radiology_orders/{orderId} {
      allow read, write: if isEmployee() && (resource == null || isSameHospital(resource.data)) && (request.resource == null || isSameHospital(request.resource.data));
    }

    // Generic fallback for hospital-specific data (Clinical Notes, Vitals, etc.)
    match /{collection}/{docId} {
      allow read, write: if isEmployee() && 
        (resource == null || isSameHospital(resource.data)) && 
        (request.resource == null || isSameHospital(request.resource.data));
    }
  }
}