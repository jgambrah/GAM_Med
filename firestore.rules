rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user's role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Patients can only access their own data
    match /patients/{patientId} {
      allow read: if request.auth.uid == resource.data.userId || getUserRole() in ['admin', 'doctor', 'nurse'];
      allow update: if request.auth.uid == resource.data.userId; // Simplified for now

      // Messages sub-collection
      match /messages/{messageId} {
        allow read, create: if request.auth.uid == patientId || request.auth.uid == resource.data.receiverId;
      }
    }

    // Appointments can only be read by participants
    match /appointments/{appointmentId} {
        allow read: if request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId;
    }
    
    // Remote patient data can be created by the patient and read by the patient or their care team
    match /remote_patient_data/{dataId} {
        allow create: if request.auth.uid == request.resource.data.patientId;
        allow read: if request.auth.uid == resource.data.patientId || getUserRole() in ['admin', 'doctor', 'nurse'];
    }
  }
}
