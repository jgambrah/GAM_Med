rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the requesting user's data from the 'users' collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to get the user's role
    function getUserRole() {
      return getUserData().role;
    }

    // Global rule for authenticated users to manage their own user data
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      // Allow creation of a user document if one doesn't already exist for the auth UID
      allow create: if request.auth.uid != null && !exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Role-based access for the 'patients' collection
    match /patients/{patientId} {
      // Admins, Doctors, and Nurses can read all patient data.
      // A patient can read their own data via the patient portal.
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || getUserData().patient_id == patientId;
      
      // Admins can create new patient records
      allow create: if getUserRole() == 'admin';
      
      // Admins, Doctors, and Nurses can update patient records
      allow update: if getUserRole() in ['admin', 'doctor', 'nurse'];
      
      // No one can delete patient records directly (soft delete should be used)
      allow delete: if false;
    }

    // Rules for other collections will go here...
    // e.g., appointments, EHR, billing, etc.

  }
}
