
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get user's role from a 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Patients collection rules
    match /patients/{patientId} {
      allow read, write: if request.auth != null; // Simplified for prototype

      // Sub-collections
      match /radiology_history/{reportId} {
         // This is a log. Only our backend function can create it.
        allow create: if false;
        // The patient and their doctors can read it.
        allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor'];
        allow write: if false; // Immutable
      }
    }
    
    // Radiology reports rules
    match /radiology_reports/{reportId} {
      allow create: if getUserRole() in ['admin', 'radiologist'];
      // The patient who owns the report, plus relevant staff can read it.
      allow read: if request.auth.uid == resource.data.patientId || getUserRole() in ['admin', 'doctor', 'radiologist'];
      // Only a radiologist can update a report, and only if it hasn't been finalized.
      allow update: if getUserRole() == 'radiologist' && resource.data.isFinal == false;
      allow delete: if getUserRole() == 'admin';
    }

    // Wards collection rules
    match /wards/{wardId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];
        // All writes must go through a trusted backend function
        allow write: if false; 
    }

    // Beds collection rules
    match /beds/{bedId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];
        // All writes must go through a trusted backend function
        allow write: if false;
    }

     // Operating Theatres collection rules
    match /operating_theatres/{theatreId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'];
        // All writes must go through a trusted backend function
        allow write: if false;
    }
  }
}
