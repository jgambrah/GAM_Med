rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get the user's role from the 'users' collection.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // =====================================================================
    // == Clinical Decision Support (CDS) Rules
    // =====================================================================
    
    // The `clinical_rules` collection contains the core logic for the CDS engine.
    // We want to ensure that only administrators can modify these rules, but all
    // authenticated staff can read them to understand the system's logic.
    match /clinical_rules/{ruleId} {
      // Allow any authenticated user to read the rules.
      allow read: if request.auth != null;
      
      // Allow only users with the 'admin' role to create, update, or delete rules.
      allow write: if getUserRole() == 'admin';
    }

    // =====================================================================
    // == Patient Data Rules
    // =====================================================================
    match /patients/{patientId} {
      // Allow read/write access to a patient record for authorized staff.
      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];

      // --- EHR Sub-Collection Rules ---
      
      // Clinical Notes can only be written by doctors.
      match /clinical_notes/{noteId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        allow write: if getUserRole() == 'doctor';
      }
      
      // Diagnoses can only be managed by doctors.
      match /diagnoses/{diagnosisId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        allow write: if getUserRole() == 'doctor';
      }

      // --- Nursing Module Sub-Collection Rules ---
      
      // Vitals can be read by all clinical staff, but only created/updated by nurses.
      match /vitals/{vitalId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        allow create, update: if getUserRole() == 'nurse';
      }
      
      // Care Plans can be read by all clinical staff, but only managed by nurses.
      match /care_plans/{planId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        allow create, update: if getUserRole() == 'nurse';
      }
      
      // Medication Administration Logs can be read by all clinical staff, but only created by nurses.
      // Updates are disallowed to preserve the integrity of the log entry.
      match /medication_administration_logs/{logId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        allow create: if getUserRole() == 'nurse';
        allow update: if false; // Disallow updates to maintain log integrity
      }
      
      // Progress Notes can be read by all clinical staff, and created by nurses.
      // This uses the same collection as clinical_notes but we can differentiate with rules.
      // For this implementation, `clinical_notes` serves as progress notes.
      // A more complex implementation might use a different collection or field.
      // Let's assume progress notes are a type of clinical note.
      // The rule below is for a conceptual `progress_notes` collection.
      match /progress_notes/{noteId} {
         allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
         allow create: if getUserRole() == 'nurse';
      }
      
      // --- CDS Alerts Sub-Collection Rules ---
      
      // The `alerts` sub-collection stores alerts generated by the backend CDS engine.
      // These rules ensure that only the backend can create alerts, and only authorized
      // clinicians can read and acknowledge them.
      match /alerts/{alertId} {
        // Allow clinical staff to read alerts for their patients.
        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
        
        // Disallow client-side creation. Alerts should only be created by trusted
        // backend Cloud Functions, which bypass these security rules.
        allow create: if false;
        
        // Allow doctors and admins to acknowledge an alert. This rule is very specific:
        // it only permits an update if the `isAcknowledged` field is the only one being changed.
        allow update: if getUserRole() in ['admin', 'doctor'] 
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAcknowledged']);
      }
    }

    // Rules for other collections like 'users', 'beds', etc. would go here.
    match /users/{userId} {
      allow read: if request.auth != null;
    }
  }
}
