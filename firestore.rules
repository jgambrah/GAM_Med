rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user's role from the 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Rules for patients collection
    match /patients/{patientId} {
      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
      allow create: if getUserRole() in ['admin', 'nurse'];
    }

    // Rules for all subcollections of patients
    match /patients/{patientId}/{subcollection}/{docId} {
       allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }

    // Rules for insurance_claims collection
    match /insurance_claims/{claimId} {
        allow read, update, create: if getUserRole() in ['admin', 'billing_clerk'];
    }
    
    // Rules for insurance_providers collection
    match /insurance_providers/{providerId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() == 'admin';
    }

    // Rules for payments collection
    match /payments/{paymentId} {
      allow create: if getUserRole() in ['admin', 'receptionist', 'billing_clerk'];
      // Patients should only be able to read their own payments, which requires a more complex rule.
      // For now, we restrict read access to staff.
      allow read: if getUserRole() in ['admin', 'billing_clerk'];
    }
    
    // Rules for payment_gateways collection
    match /payment_gateways/{gatewayId} {
      allow read: if getUserRole() in ['admin', 'billing_clerk'];
      allow write: if getUserRole() == 'admin';
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
