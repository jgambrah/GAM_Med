
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isDoctor() {
      return getUserRole() == 'doctor';
    }
    
    function isPatient() {
      return getUserRole() == 'patient';
    }
    
    function isNurse() {
      return getUserRole() == 'nurse';
    }
    
    function isAdmin() {
      return getUserRole() == 'admin';
    }
    
    function isBillingClerk() {
      return getUserRole() == 'billing_clerk';
    }
    
    function isTriageOfficer() {
        return getUserRole() == 'triage_officer';
    }
    
    function isReceptionist() {
        return getUserRole() == 'receptionist';
    }

    match /patients/{patientId} {
      allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();
      allow write: if isAdmin();
      
      match /admissions/{admissionId} {
        allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();
        allow write: if isDoctor() || isAdmin();
      }
      
      match /clinical_notes/{noteId} {
          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();
          allow create: if isDoctor() || isNurse();
          allow update, delete: if isAdmin();
      }

      match /diagnoses/{diagnosisId} {
          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();
          allow create: if isDoctor();
          allow update, delete: if isAdmin();
      }

      match /lab_results/{testId} {
          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();
          allow create: if isDoctor(); // Only a doctor can order a test
          allow update: if isDoctor() || isAdmin(); // Lab tech would update via a function
      }
      
      match /medication_history/{prescriptionId} {
          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();
          allow create: if isDoctor();
          allow update, delete: if isDoctor() || isAdmin();
      }
      
      match /vitals/{vitalId} {
          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();
          allow create: if isNurse() || isDoctor();
          allow update, delete: if isAdmin();
      }

      match /appointment_history/{appointmentId} {
        allow read: if request.auth.uid == patientId || isReceptionist() || isAdmin();
        allow write: if false; // Denormalized data, only written by backend functions
      }
    }

    match /appointments/{appointmentId} {
      allow create: if isReceptionist() || isAdmin() || request.auth.uid == request.resource.data.patientId;
      allow read: if request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId || isReceptionist() || isAdmin();
      // Patient can only update to cancel their own appointment.
      allow update: if isReceptionist() || isAdmin() || (isDoctor() && request.auth.uid == resource.data.doctorId) || (request.auth.uid == resource.data.patientId && request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }
    
    match /doctor_schedules/{scheduleId} {
        allow read: if request.auth != null;
        allow create, update: if isAdmin() || (isDoctor() && request.auth.uid == resource.data.doctorId);
        allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
    
    match /referrals/{referralId} {
        allow read: if request.auth != null;
        allow create: if isReceptionist() || isTriageOfficer() || isAdmin();
        allow update: if isDoctor() || isReceptionist() || isTriageOfficer() || isAdmin();
    }
    
    match /users/{userId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow write: if isAdmin();
    }
  }
}
