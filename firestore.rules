
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user's role from the 'users' collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Security rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can create their own user profile document
      allow create: if request.auth != null && request.auth.uid == userId;
      // Users can only read their own data
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users can only update their own data, but cannot change their role
      allow update: if request.auth != null && request.auth.uid == userId && request.resource.data.role == resource.data.role;
    }

    // Security rules for the 'patients' collection
    match /patients/{patientId} {
      // Admins and Nurses can create new patients
      allow create: if getUserRole(request.auth.uid) in ['Admin', 'Nurse'];
      // Admins, Nurses, and Doctors can read any patient's data
      // Patients can read their own data (requires linking auth UID to patient record)
      allow read: if getUserRole(request.auth.uid) in ['Admin', 'Nurse', 'Doctor'] || resource.data.authUid == request.auth.uid;
       // Admins and Nurses can update patient data
      allow update: if getUserRole(request.auth.uid) in ['Admin', 'Nurse'];
    }
    
    // Security rules for the 'admissions' collection
    match /admissions/{admissionId} {
        // Admins, Nurses, and Doctors can create admission records
        allow create: if getUserRole(request.auth.uid) in ['Admin', 'Nurse', 'Doctor'];
        // Admins, Nurses, and Doctors can read any admission record
        // Patients can read their own admission records
        allow read: if getUserRole(request.auth.uid) in ['Admin', 'Nurse', 'Doctor'] || get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.authUid == request.auth.uid;
        // Admins, Nurses, and Doctors can update admission records
        allow update: if getUserRole(request.auth.uid) in ['Admin', 'Nurse', 'Doctor'];
    }

    // Security rules for the 'beds' collection
    match /beds/{bedId} {
        // Only Admins can create or delete bed records (initial setup)
        allow create, delete: if getUserRole(request.auth.uid) == 'Admin';
        // Any authenticated user can view the status of beds
        allow read: if request.auth != null;
        // Only Admins and Nurses can update bed statuses (e.g., for allocation, transfer, maintenance)
        allow update: if getUserRole(request.auth.uid) in ['Admin', 'Nurse'];
    }
  }
}
