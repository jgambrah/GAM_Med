
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isUserAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isUserAuthenticated();
      allow write: if isOwner(userId) || getUserRole() in ['admin', 'hr'];
    }

    match /patients/{patientId} {
        allow read, write: if isUserAuthenticated(); // Simplified for prototype
    }
    
    match /patients/{patientId}/{document=**} {
        allow read, write: if isUserAuthenticated(); // Simplified for prototype
    }

    match /beds/{bedId} {
        allow read, write: if isUserAuthenticated();
    }

    match /appointments/{appointmentId} {
        allow read, write: if isUserAuthenticated();
    }
    
    match /referrals/{referralId} {
        allow read, write: if isUserAuthenticated();
    }
    
    match /leave_requests/{leaveId} {
      allow create: if isUserAuthenticated();
      allow read: if isOwner(get(/databases/$(database)/documents/leave_requests/$(leaveId)).data.staffId) || getUserRole() in ['admin', 'doctor'];
      allow update: if (resource.data.status == 'Pending' && isOwner(resource.data.staffId)) || getUserRole() in ['admin', 'doctor'];
    }
    
    match /performance_reviews/{reviewId} {
        allow create: if getUserRole() in ['admin', 'hr', 'doctor'];
        allow read: if isOwner(resource.data.employeeId) || isOwner(resource.data.reviewerId) || getUserRole() in ['admin', 'hr'];
        allow update: if isOwner(resource.data.reviewerId) || getUserRole() in ['admin', 'hr'];
    }

    match /training_courses/{courseId} {
        allow read: if isUserAuthenticated();
        allow write: if getUserRole() in ['admin', 'hr'];
    }
  }
}
