rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =====================================================================
    // Helper Functions
    // =====================================================================
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isPatient(patientId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    // Users can only read their own data, but this can be expanded for specific admin/doctor views.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
    }

    // Patients can be read by authorized staff, but only created/updated via secure functions.
    match /patients/{patientId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'lab_technician'];
      // Write access should be handled by backend Cloud Functions for security and data integrity.
      allow write: if false; 
    }
    
    // Clinical Decision Support rules can be read by any authenticated user, but only written by admins.
    match /clinical_rules/{ruleId} {
      allow read: if request.auth != null;
      allow write: if getUserRole() == 'admin';
    }

    // Alerts can only be created by backend functions. They can be read by clinical staff
    // and acknowledged (updated) by doctors or admins.
    match /patients/{patientId}/alerts/{alertId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
      allow create: if false; // Should only be created by Cloud Functions
      // Allow update only for the 'isAcknowledged' field by authorized roles.
      allow update: if getUserRole() in ['admin', 'doctor']
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAcknowledged']);
    }

    // Beds can be read by clinical staff, but only updated via secure functions.
    match /beds/{bedId} {
       allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
       allow write: if false; // Bed status changes should be handled by backend functions.
    }
    
    // Appointments can be read by involved parties, but only created/updated via secure functions.
    match /appointments/{appointmentId} {
        allow read: if getUserRole() in ['admin', 'doctor', 'billing_clerk'] || isPatient(resource.data.patient_id);
        allow write: if false; // All mutations should go through Cloud Functions.
    }

    // The master vaccine catalog is readable by all authenticated users, but writable only by admins.
    match /vaccine_catalog/{vaccineId} {
      allow read: if request.auth != null;
      allow write: if getUserRole() == 'admin';
    }

    // Patient immunization records can be read by staff and the patient themselves.
    // Writes are restricted to clinical staff.
    match /patients/{patientId}/immunizations/{immunizationId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || isPatient(patientId);
      allow create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];
      allow delete: if getUserRole() == 'admin';
    }
    
    // All other sub-collections under patients are restricted to clinical/admin staff for reading
    // and should only be written to by backend functions.
    match /patients/{patientId}/{collection}/{docId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'lab_technician', 'pharmacist'];
      allow write: if false;
    }
  }
}
