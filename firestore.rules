
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Patients collection
    match /patients/{patientId} {
      allow read, write: if request.auth != null; // Placeholder, refine later
      
      // Sub-collections
      match /admissions/{admissionId} {
        allow read, write: if request.auth != null;
      }
      match /clinical_notes/{noteId} {
        allow read, write: if request.auth != null;
      }
      // ... other sub-collections
    }

    // Lab Orders collection
    match /lab_orders/{orderId} {
      allow create: if getUserRole() in ['admin', 'doctor'];
      allow update: if getUserRole() in ['admin', 'lab_tech'];
      allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;
      
      // Sample Audit sub-collection
      match /sample_audit/{auditId} {
        allow create: if getUserRole() in ['admin', 'lab_tech'];
        allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;
        allow update, delete: if false; // Immutable
      }
    }

    // Lab Results collection
    match /lab_results/{resultId} {
      allow create: if getUserRole() == 'lab_tech';
      allow update: if getUserRole() in ['lab_tech', 'lab_supervisor'] && resource.data.status == 'Draft';
      allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId; // Users can edit their own profile
    }
  }
}
