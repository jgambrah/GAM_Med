
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Patients Collection
    match /patients/{patientId} {
      allow read, write: if request.auth != null; // Allow authenticated users to read/write for now
    }

    // Beds Collection
    match /beds/{bedId} {
      allow read, write: if request.auth != null;
    }
    
    // Referrals Collection
    match /referrals/{referralId} {
      allow read, write: if request.auth != null;
    }
    
    // Users Collection
    match /users/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (request.auth.uid == userId || getUserRole() == 'admin');
    }

    // Payroll Records Collection
    match /payroll_runs/{runId} {
        allow read: if getUserRole() in ['admin', 'financial_staff'];
        allow write: if getUserRole() in ['admin']; // Only admins or cloud functions can write
        
        match /payroll_records/{recordId} {
            allow read: if getUserRole() in ['admin', 'financial_staff'] || request.auth.uid == resource.data.userId;
            allow write: if getUserRole() in ['admin'];
        }
    }
    
    // Asset Management Collections
    match /assets/{assetId} {
      allow read: if getUserRole() in ['admin', 'finance', 'it_manager', 'asset_manager'];
      allow create, delete: if getUserRole() in ['admin', 'asset_manager'];
      allow update: if getUserRole() in ['admin', 'asset_manager'] ||
                      (getUserRole() in ['it_manager', 'department_head'] && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedToUserId', 'location', 'status']));
    }

    match /facility_zones/{zoneId} {
        allow read: if getUserRole() in ['admin', 'manager', 'technician'];
        allow update: if getUserRole() in ['admin', 'facility_manager'];
    }

    match /maintenance_requests/{requestId} {
        allow create: if request.auth != null; // Any staff member can report an issue
        allow read: if getUserRole() in ['admin', 'manager', 'technician'];
        allow update: if getUserRole() in ['admin', 'technician'];
    }

  }
}
