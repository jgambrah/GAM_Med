
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get the user's role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Rules for User management
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Allow admins to manage all user profiles
      allow write: if getUserRole() == 'admin';
    }

    // Rules for Patient records
    match /patients/{patientId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'] || request.auth.uid == patientId;
      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];

      // Sub-collection rules
      match /{subcollection}/{docId} {
        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];
      }
    }
    
    // Rules for Bed management
    match /beds/{bedId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() in ['admin', 'nurse'];
    }

    // Rules for Appointments
    match /appointments/{appointmentId} {
        allow read: if request.auth != null;
        // Allow staff to create, allow assigned doctor/patient to update/cancel
        allow write: if getUserRole() in ['admin', 'doctor', 'receptionist'] || request.resource.data.doctor_id == request.auth.uid || request.resource.data.patient_id == request.auth.uid;
    }

    // Rules for Pharmacy Inventory
    match /inventory/{itemId} {
      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];
      allow write: if getUserRole() in ['admin', 'pharmacist'];
    }

    // Rules for Prescriptions
    match /prescriptions/{prescriptionId} {
        allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor'] || (request.auth.uid == resource.data.patientId && getUserRole() == 'patient');
        allow write: if getUserRole() in ['admin', 'pharmacist', 'doctor'];
    }
    
    // Rules for Payroll
    match /payroll_runs/{runId} {
        allow read: if getUserRole() in ['admin'];
        allow write: if getUserRole() in ['admin'];

        match /payroll_records/{staffId} {
            allow read: if getUserRole() in ['admin'] || request.auth.uid == staffId;
            allow write: if getUserRole() in ['admin'];
        }
    }

    // Rules for Asset & Facilities Management
    match /equipment/{equipmentId} {
      allow read: if getUserRole() in ['admin', 'manager', 'technician'];
      // A more specific 'asset_manager' role would be ideal in a real system.
      allow create, update, delete: if getUserRole() in ['admin']; 
    }

    match /facility_zones/{zoneId} {
      allow read: if getUserRole() in ['admin', 'manager', 'technician'];
      // A more specific 'facility_manager' role would be ideal.
      allow update: if getUserRole() in ['admin'];
    }

    match /maintenance_requests/{requestId} {
      allow create: if request.auth != null; // Any authenticated staff member can report an issue
      allow read: if getUserRole() in ['admin', 'manager', 'technician'];
      // Only admins or technicians can update the status of a request
      allow update: if getUserRole() in ['admin', 'technician'];
    }

    // Conceptual rules for Firebase Storage
    // match /credentials/{userId}/{documentName} {
    //   allow read: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'hr'];
    //   allow write: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    // }
  }
}
