rules_version = '2';

// Helper function to get user's role from a custom claim
// In a real project, you would set a custom claim 'role' for each user.
function getUserRole() {
  return request.auth.token.role;
}

service cloud.firestore {
  match /databases/{database}/documents {
    // A user can only read and write their own preferences
    match /user_preferences/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // BI reports are read-only for management roles
    match /bi_reports/{reportId} {
      allow read: if getUserRole() in ['admin', 'hospital_manager', 'department_head'];
    }

    // KPI metrics are read-only for management roles
    match /kpi_metrics/{metricId} {
      allow read: if getUserRole() in ['admin', 'hospital_manager', 'department_head'];
    }

    // Infection data can be created by clinical staff and read by a limited set of roles
    match /infections/{infectionId} {
      allow create: if getUserRole() in ['admin', 'infection_control_officer', 'doctor'];
      allow read: if getUserRole() in ['admin', 'doctor', 'infection_control_officer'];
    }

    // Clinical reports are read-only for management and quality control roles
    match /clinical_reports/{reportId} {
      allow read: if getUserRole() in ['admin', 'hospital_manager', 'quality_control'];
    }
  }
}
