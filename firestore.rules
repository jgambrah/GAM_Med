/**
 * MedFlow GH - Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset enforces a Role-Based Access Control (RBAC) model combined with
 * strict data ownership. Patients have control over their own records, while
 * hospital employees (Doctors, Nurses, Admins) are granted access based on
 * their roles and relationship to the data. The default security posture is
 * to deny access unless explicitly permitted.
 *
 * Data Structure:
 * The database uses a set of top-level collections for primary entities like
 * `users`, `patients`, `employees`, and `appointments`. Sensitive patient data,
 * such as `medicalHistories`, is stored in a subcollection under the
 * corresponding patient document to facilitate inherited permissions.
 *
 * Key Security Decisions:
 * - User-Scoped Data: All data in `/users/{userId}` is strictly private to the
 *   authenticated user matching the `userId`.
 * - Employee Access: Authenticated employees are granted read access to patient,
 *   employee, and schedule collections to facilitate clinical workflows. Writes
 *   are more restricted.
 * - Patient Privacy: A user can only access a `/patients` document if their
 *   own user profile in `/users/{userId}` contains a matching `patientId`.
 * - Shared Documents: Access to `appointments` is shared between the patient
 *   and the doctor associated with the appointment, determined by the `patientId`
 *   and `doctorId` fields on the appointment document itself.
 * - Admin Operations: Collections like `departments` and `resources` are readable
 *   by all staff but are configured to be writable only by users with an 'Admin'
 *   role (currently locked down as a secure default).
 *
 * Denormalization for Authorization:
 * To create simpler and more performant rules, this ruleset relies on denormalization.
 * For example, the `/appointments/{appointmentId}` document contains `patientId` and
 * `doctorId` fields directly. This allows rules to check permissions without needing
 * slow and costly `get()` calls to other documents, enforcing the principle of
 * "Authorization Independence".
 *
 * Structural Segregation:
 * The data model separates distinct entities with different access patterns into
 * different top-level collections (e.g., `patients` vs. `employees`). This is
 * more secure and efficient for list queries than co-locating them and filtering
 * with a 'type' field.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * This is the fundamental check for document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the user is an owner and the document already exists.
     * Used for safe update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * Retrieves the authenticated user's profile document from the /users collection.
     * This is used to check for roles and relationships (e.g., patientId).
     */
    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    /**
     * Returns true if the authenticated user's role is 'Admin'.
     * Used for granting privileged access.
     */
    function isAdmin() {
        return isSignedIn() && getUserData().role == 'Admin';
    }
    
    /**
     * Returns true if the user's role is one of the employee types.
     */
    function isEmployee() {
        return isSignedIn() && getUserData().role in ['Doctor', 'Nurse', 'Pharmacist', 'Admin'];
    }

    /**
     * Returns true if the authenticated user is the patient specified by patientId.
     * Checks the `patientId` field on the user's own profile document.
     */
    function isUserThePatient(patientId) {
        return isSignedIn() && getUserData().patientId == patientId;
    }

    /**
     * Returns true if the authenticated user is the employee specified by employeeId.
     * Checks the `employeeId` field on the user's own profile document.
     */
    function isUserTheEmployee(employeeId) {
        return isSignedIn() && getUserData().employeeId == employeeId;
    }
    
    /**
     * On create, validates that the new document's ID matches the user's UID.
     */
    function newUserDataIsValid(userId) {
        return request.resource.data.id == userId;
    }

    /**
     * On update, ensures the document's ID remains unchanged.
     */
    function existingUserDataIsValid() {
        return request.resource.data.id == resource.data.id;
    }

    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    /**
     * @description Users can create, read, and update their own user profile. Deletion is disallowed.
     * @path /users/{userId}
     * @allow (create) a new user creates their own user document: auth.uid == 'user_abc', path == '/users/user_abc'.
     * @deny (get) a user tries to read another user's profile: auth.uid == 'user_123', path == '/users/user_456'.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Disallow listing all users for privacy.
      allow create: if isOwner(userId) && newUserDataIsValid(userId);
      allow update: if isExistingOwner(userId) && existingUserDataIsValid();
      allow delete: if false; // Users should not be able to delete their own auth record.
    }

    /**
     * @description A patient can manage their own record. Employees can view any patient's record.
     * @path /patients/{patientId}
     * @allow (get) An authenticated doctor views a patient's record.
     * @deny (update) A patient tries to update another patient's record.
     * @principle Enforces a combination of data ownership for patients and role-based read access for staff.
     */
    match /patients/{patientId} {
      allow get: if isUserThePatient(patientId) || isEmployee();
      allow list: if isEmployee(); // Only employees can list/browse patients.
      allow create: if false; // TODO: Patient records should be created by an Admin.
      allow update: if (isUserThePatient(patientId) && resource != null) || (isAdmin() && resource != null);
      allow delete: if false; // TODO: Patient records should be archived by an Admin, not deleted.
    }
    
    /**
     * @description Medical history is highly sensitive. Access is inherited from the parent patient record.
     * @path /patients/{patientId}/medicalHistories/{medicalHistoryId}
     * @allow (get) A doctor views the medical history of a patient they have access to.
     * @deny (list) A patient tries to list the medical history of another patient.
     * @principle Secures a subcollection by checking permissions on the parent document.
     */
    match /patients/{patientId}/medicalHistories/{medicalHistoryId} {
      allow get: if isUserThePatient(patientId) || isEmployee();
      allow list: if isUserThePatient(patientId) || isEmployee();
      // Only employees (e.g., Doctors, Nurses) can create or update medical history.
      allow create: if isEmployee() && request.resource.data.patientId == patientId;
      allow update: if isEmployee() && resource != null && request.resource.data.patientId == resource.data.patientId;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Employee profiles are viewable by any authenticated user (like a staff directory).
     * @path /employees/{employeeId}
     * @allow (get) Any signed-in user (e.g., a patient) can look up a doctor's profile.
     * @deny (update) An employee tries to modify another employee's profile.
     * @principle Implements a public-read directory model for non-sensitive data, with ownership for writes.
     */
    match /employees/{employeeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false; // TODO: Employee records should be created by an Admin.
      allow update: if (isUserTheEmployee(employeeId) && resource != null) || (isAdmin() && resource != null);
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Appointments can be read by the patient or doctor involved. Patients can create them.
     * @path /appointments/{appointmentId}
     * @allow (get) A patient with patientId 'p123' reads an appointment where `resource.data.patientId` is 'p123'.
     * @deny (update) A doctor tries to modify an appointment they are not assigned to.
     * @principle Implements a shared access model for documents involving multiple parties.
     */
    match /appointments/{appointmentId} {
      // An appointment can be read by the patient or the doctor involved.
      function isParticipant(doc) {
        return isUserThePatient(doc.patientId) || isUserTheEmployee(doc.doctorId);
      }
      
      allow get: if isParticipant(resource.data);
      allow list: if false; // Prevent querying all appointments; queries must be specific.
      // A patient can create their own appointment, or an employee can create one for them.
      allow create: if isUserThePatient(request.resource.data.patientId) || isEmployee();
      // An existing appointment can be updated by a participant.
      allow update: if isParticipant(resource.data) && resource != null;
      // An existing appointment can be deleted (cancelled) by a participant.
      allow delete: if isParticipant(resource.data) && resource != null;
    }

    /**
     * @description Schedules are managed by the employee they belong to, but viewable by all staff.
     * @path /schedules/{scheduleId}
     * @allow (get) A nurse looks up a doctor's schedule.
     * @deny (create) A patient tries to create a schedule for a doctor.
     * @principle Enforces document ownership for writes while allowing broader read access for internal staff.
     */
    match /schedules/{scheduleId} {
      allow get: if isEmployee();
      allow list: if isEmployee();
      // An employee can create a schedule for themselves.
      allow create: if isUserTheEmployee(request.resource.data.employeeId);
      // Only the assigned employee or an Admin can update/delete their schedule.
      allow update: if (isUserTheEmployee(resource.data.employeeId) && resource != null) || (isAdmin() && resource != null);
      allow delete: if (isUserTheEmployee(resource.data.employeeId) && resource != null) || (isAdmin() && resource != null);
    }

    /**
     * @description Department and Resource info is public to all authenticated users, but writable only by Admins.
     * @path /departments/{departmentId}
     * @allow (get) Any authenticated user can read department information.
     * @deny (create) Any non-admin user tries to create a new department.
     * @principle Provides public read access for system-wide data with centralized admin control for writes.
     */
    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // TODO: Implement `if isAdmin();` when admin role is fully defined.
    }
    
    /**
     * @description Department and Resource info is public to all authenticated users, but writable only by Admins.
     * @path /resources/{resourceId}
     * @allow (get) Any authenticated user can read resource information (e.g., operating rooms).
     * @deny (create) Any non-admin user tries to create a new resource.
     * @principle Provides public read access for system-wide data with centralized admin control for writes.
     */
    match /resources/{resourceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // TODO: Implement `if isAdmin();` when admin role is fully defined.
    }
  }
}