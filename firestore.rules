rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =================================
    // Helper Functions
    // =================================
    
    // Check if the user's role is in the allowed list
    function isOneOfRoles(allowedRoles) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in allowedRoles;
    }
    
    // Validate the incoming patient data schema
    function isPatientDataValid(data) {
      return data.fullName is string &&
             data.dob is timestamp &&
             data.gender is string &&
             data.contact.primaryPhone is string &&
             data.isAdmitted is bool;
    }
    
    // =================================
    // Collections
    // =================================
    
    // User profile information, including their role.
    match /users/{userId} {
      // Users can only read their own profile.
      allow read: if request.auth.uid == userId;
      // Users can only create their own profile during signup.
      allow create: if request.auth.uid == userId;
      // Users can only update their own profile.
      allow update: if request.auth.uid == userId;
    }

    // Main patient records collection.
    match /patients/{patientId} {
      
      // CREATE: Only Admins can register new patients.
      allow create: if isOneOfRoles(['Admin']) && isPatientDataValid(request.resource.data);
      
      // READ:
      // - Admins, Doctors, and Nurses can read any patient's record.
      // - A patient can read their own record (assumes patient doc has a 'uid' field matching their auth uid).
      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']) || 
                     (isOneOfRoles(['Patient']) && resource.data.uid == request.auth.uid);
      
      // UPDATE: Only Admins and Doctors can update patient records.
      allow update: if isOneOfRoles(['Admin', 'Doctor']) && isPatientDataValid(request.resource.data);
      
      // DELETE: No one should be able to delete patient records directly.
      // Records should be marked as 'inactive' or 'deceased' via an update.
      allow delete: if false;
    }
    
    // Admissions records for patient visits.
    match /admissions/{admissionId} {
       allow read, write: if isOneOfRoles(['Admin', 'Doctor']);
    }

    // Bed status and allocation records.
    match /beds/{bedId} {
        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'Housekeeping']);
        allow write: if isOneOfRoles(['Admin']);
    }
  }
}
