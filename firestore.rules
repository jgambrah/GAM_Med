

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the request's authenticated UID matches the provided userId.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Retrieves the calling user's profile data from the /users collection.
     * This is the core of the document-based part of the RBAC model.
     * CRITICAL: Do NOT use this function in `allow list` rules.
     */
    function getCallingUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Returns true if the user is a global administrator (SUPER_ADMIN).
     * This check is based on the role field in the user's own profile document.
     */
    function isSuperAdmin() {
      return isSignedIn() && getCallingUserData().role == 'SUPER_ADMIN';
    }
    
    /**
     * SECURE HELPER FOR LIST RULES: Checks if the calling user belongs to the specified hospital.
     */
    function isStaffOfHospital(hospitalId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hospitalId == hospitalId;
    }

    /**
     * Returns true if the user is a staff member of the hospital with a high-privilege
     * administrative role ('HospitalDirector' or 'HR').
     */
    function isDirectorOrAdmin(hospitalId) {
      let userData = getCallingUserData();
      return isSignedIn() 
          && userData != null 
          && userData.hospitalId == hospitalId 
          && userData.role in ['DIRECTOR', 'ADMIN', 'ACCOUNTANT', 'HR_MANAGER'];
    }

    /**
     * Returns true if the user is a staff member of the hospital with a clinical role.
     */
    function isClinicalStaff(hospitalId) {
      let userData = getCallingUserData();
      return isSignedIn() 
          && userData != null 
          && userData.hospitalId == hospitalId 
          && userData.role in ['DIRECTOR', 'DOCTOR', 'NURSE', 'PHARMACIST', 'LAB_TECH', 'RADIOLOGIST'];
    }
    
    /**
     * Returns true if the user is any authorized staff member of the specified hospital.
     */
    function isAnyStaff(hospitalId) {
      let userData = getCallingUserData();
      return isSignedIn() 
          && userData != null 
          && userData.hospitalId == hospitalId 
          && userData.role in ['DIRECTOR', 'HR_MANAGER', 'DOCTOR', 'NURSE', 'PHARMACIST', 'RECEPTIONIST', 'LAB_TECH', 'ADMIN', 'RADIOLOGIST', 'ACCOUNTANT', 'CASHIER', 'STORE_MANAGER', 'ORDERLY'];
    }
    
    /**
     * Returns true if the user has a supply chain management role.
     */
    function isSupplyChainStaff(hospitalId) {
      let userData = getCallingUserData();
      return isSignedIn() 
          && userData != null 
          && userData.hospitalId == hospitalId 
          && userData.role in ['DIRECTOR', 'ADMIN', 'STORE_MANAGER', 'PHARMACIST'];
    }


    // ===================================
    //  COLLECTION GROUP QUERIES
    // ===================================
    // NOTE: For collection group queries, the rule must be simple and cannot depend
    // on `resource.data`. The client query is responsible for filtering by hospitalId.

    match /{path=**}/beds/{bedId} {
      allow list: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hospitalId != null);
    }
    
    match /{path=**}/deliveries/{deliveryId} {
        allow list: if isSignedIn();
    }
    
    match /{path=**}/encounters/{encounterId} {
      allow list: if isSignedIn();
    }
    
    match /{path=**}/lab_orders/{orderId} {
      allow list: if isSignedIn();
    }
    
    match /{path=**}/radiology_orders/{orderId} {
       allow list: if isSignedIn();
    }
    
    match /{path=**}/maternity_profiles/{profileId} {
      allow list: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hospitalId != null);
    }
    
    match /{path=**}/patients/{patientId} {
      allow list: if request.query.limit == 1; 
    }
    
    match /{path=**}/payments/{paymentId} {
      allow list: if isSignedIn();
    }


    // --------------------------------
    // Global Platform Collections
    // --------------------------------
    
    match /appointments/{appointmentId} {
        allow create: if true; // Allows unauthenticated patient portal
        allow read: if isAnyStaff(resource.data.hospitalId) || true; // Open for patient portal
        allow list: if request.query.patientId != null || (isSuperAdmin() || isStaffOfHospital(request.query.hospitalId));
        allow update: if (isAnyStaff(resource.data.hospitalId)) || (request.resource.data.status == 'CANCELLED_BY_PATIENT');
        allow delete: if isDirectorOrAdmin(resource.data.hospitalId);
    }

    match /doctor_availability/{doctorId} {
      allow read, list: if isSignedIn();
      allow write: if isOwner(doctorId);
    }

    match /global_audit_logs/{logId} {
      allow read, list: if isSuperAdmin();
      allow create: if isSignedIn(); // Allow backend functions to write
      allow update, delete: if false;
    }
    
    match /platform_global_health_stats/{recordId} {
      allow create: if isClinicalStaff(request.resource.data.hospitalId);
      allow read, list: if isSuperAdmin();
      allow update, delete: if false; // Immutable logs
    }

    match /platform_config/{configId} {
      allow read, write: if isSuperAdmin();
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, list, update, delete: if isSuperAdmin();
    }

    match /pricing_plans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }
    
    match /sms_logs/{logId} {
      allow create: if false; // Only backend can create
      allow read, list: if isSuperAdmin(); // Only CEO can review logs
      allow update, delete: if false; // Immutable
    }
    
    match /chart_of_accounts/{accountId} {
        allow read: if isAnyStaff(resource.data.hospitalId);
        allow write: if isSuperAdmin(); // Only provisioned by function
    }
    
    match /product_template/{productId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin();
    }
    

    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /users/{userId} {
      function isHospitalAdminForUser() {
        let userData = getCallingUserData();
        let resourceData = get(/databases/$(database)/documents/users/$(userId)).data;
        return userData != null && resourceData != null && userData.hospitalId == resourceData.hospitalId && userData.role in ['DIRECTOR', 'ADMIN', 'HR_MANAGER'];
      }

      allow get: if isSuperAdmin() || isOwner(userId) || isHospitalAdminForUser();
      allow list: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hospitalId != null);
      allow update: if isSuperAdmin() || isOwner(userId) || isHospitalAdminForUser();
      allow create: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /hospitals/{hospitalId} {
      allow get: if isSuperAdmin() || isAnyStaff(hospitalId);
      allow list, create, update, delete: if isSuperAdmin();
      
      // Allow writes to subcollections to "pass through"
      // while still protecting the hospital document itself with more specific rules below.
      allow write: if isSuperAdmin() || isAnyStaff(hospitalId);
      
      match /surgeries/{surgeryId} {
        allow read, list: if isClinicalStaff(hospitalId);
        allow create: if isClinicalStaff(hospitalId);
        allow update: if isClinicalStaff(hospitalId);
        allow delete: if isDirectorOrAdmin(hospitalId);
      }

      match /theaters/{theaterId} {
        allow read, list: if isSuperAdmin() || isAnyStaff(hospitalId);
        allow create, update, delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
      }
      
      match /specialty_units/{unitId} {
        allow get, create, update, delete: if isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }
      
      match /treatment_plans/{planId} {
        allow get, create, update: if isSuperAdmin() || isClinicalStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);

        match /sessions/{sessionId} {
          allow get, create: if isSuperAdmin() || isClinicalStaff(hospitalId);
          allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
          allow update: if isSuperAdmin() || isDirectorOrAdmin(hospitalId); // Only admin can edit a logged session
          allow delete: if false; // Sessions are part of the medical record
        }
      }
      
      match /cpd_submissions/{submissionId} {
        allow create: if isSuperAdmin() || (isAnyStaff(hospitalId) && request.resource.data.staffId == request.auth.uid);
        allow get: if isSuperAdmin() || isDirectorOrAdmin(hospitalId) || (isAnyStaff(hospitalId) && resource.data.staffId == request.auth.uid);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
      }
      
       match /requisitions/{requisitionId} {
        allow create: if isSuperAdmin() || isAnyStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow get: if isSuperAdmin() || isAnyStaff(hospitalId);
        allow update: if isSuperAdmin() 
                      || (isDirectorOrAdmin(hospitalId) && request.resource.data.status in ['APPROVED', 'REJECTED'])
                      || (isSupplyChainStaff(hospitalId) && resource.data.status == 'APPROVED' && request.resource.data.status == 'ISSUED')
                      || (isOwner(resource.data.requestedBy) && resource.data.status == 'PENDING');
      }

      match /assets/{assetId} {
        allow get, create, update, delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }
      
      match /payment_vouchers/{voucherId} {
        allow get, create: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update: if isSuperAdmin() || (isDirectorOrAdmin(hospitalId) && getCallingUserData().role == 'DIRECTOR');
        allow delete: if false;
      }
      
      match /journal_entries/{journalId} {
        allow get, create: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update, delete: if false;
      }

      match /accounts_payable/{payableId} {
        allow get, update: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow create: if isSuperAdmin() || isSupplyChainStaff(hospitalId);
        allow delete: if false;
      }
      
      match /receivables/{receivableId} {
        allow get, create, update: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow delete: if false; 
      }
      
      match /payers/{payerId} {
        allow get, create, update, delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }

      match /clinical_alerts/{alertId} {
        allow get, create: if isSuperAdmin() || isClinicalStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update: if isSuperAdmin() || isClinicalStaff(hospitalId);
      }
      
      match /disposal_logs/{logId} {
        allow create: if isSuperAdmin() || isSupplyChainStaff(hospitalId);
        allow get: if isSuperAdmin() || isSupplyChainStaff(hospitalId) || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update, delete: if false;
      }

      match /shifts/{shiftId} {
        allow get, create, update, delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }
      
      match /nursing_handovers/{handoverId} {
        allow get, create: if isSuperAdmin() || isClinicalStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update, delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
      }

      match /attendance_logs/{logId} {
        allow get: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow create: if isSuperAdmin() || (isAnyStaff(hospitalId) && request.resource.data.staffId == request.auth.uid);
        allow update: if isSuperAdmin() || isDirectorOrAdmin(hospitalId) || isOwner(resource.data.staffId);
        allow delete: if false;
      }
      
      match /leave_requests/{requestId} {
        allow create: if isSuperAdmin() || (isAnyStaff(hospitalId) && request.resource.data.staffId == request.auth.uid);
        allow get: if isSuperAdmin() || isDirectorOrAdmin(hospitalId) || (isAnyStaff(hospitalId) && resource.data.staffId == request.auth.uid);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
      }

      match /appraisal_cycles/{cycleId} {
        allow get, create, update, delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }

      match /appraisals/{appraisalId} {
        allow create: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow get: if isSuperAdmin() || isDirectorOrAdmin(hospitalId) || (resource.data.staffId == request.auth.uid);
        allow update, delete: if false;
      }
      
      match /disciplinary_records/{recordId} {
        allow get, create, update, delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }
      
      match /mortality_archive/{recordId} {
        allow create: if isClinicalStaff(hospitalId);
        allow get: if isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update, delete: if false;
      }

      match /payroll_config/{configId} {
        allow read, write: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
      }
      
      match /salary_profiles/{staffId} {
        allow read, write: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
      }

      match /payroll_runs/{runId} {
        allow get, create: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update, delete: if false;
      }

      match /payslips/{slipId} {
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow get: if isSuperAdmin() || isDirectorOrAdmin(hospitalId) || (resource.data.staffId == request.auth.uid);
        allow create: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow update, delete: if false;
      }

      match /general_services/{serviceId} {
        allow get, create, update, delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }

       match /billing_items/{itemId} {
        allow create: if isAnyStaff(hospitalId);
        allow get, update, delete: if isDirectorOrAdmin(hospitalId) || getCallingUserData().role == 'CASHIER';
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }
      
      match /patients/{patientId} {
        allow get, create, delete: if isSuperAdmin() || isAnyStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update: if (isSuperAdmin() || isAnyStaff(hospitalId)) && (resource.data.isLocked == false || !('isLocked' in resource.data));

        match /encounters/{encounterId} {
           allow read, list, create, update, delete: if isSuperAdmin() || isAnyStaff(hospitalId);
        }

        match /maternity_profiles/{profileId} {
           allow read, list, create, update, delete: if isSuperAdmin() || isClinicalStaff(hospitalId);

           match /deliveries/{deliveryId} {
              allow read, create: if isSuperAdmin() || isClinicalStaff(hospitalId);
              allow update, delete: if false;
           }
        }
      }
      
      match /admissions/{admissionId} {
        allow get, create, update: if isSuperAdmin() || isAnyStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        
        match /rounds/{roundId} {
          allow create: if isSuperAdmin() || isClinicalStaff(hospitalId);
          allow get, list: if isSuperAdmin() || isAnyStaff(hospitalId);
          allow update, delete: if false;
        }
      }

      match /pharmacy_inventory/{itemId} {
        allow get, create, delete: if isSuperAdmin() || isSupplyChainStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update: if isSuperAdmin() || isSupplyChainStaff(hospitalId) || isClinicalStaff(hospitalId);
      }
      
      match /product_catalog/{productId} {
        allow get, create, delete: if isSuperAdmin() || isSupplyChainStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
        allow update: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
      }

      match /suppliers/{supplierId} {
        allow get, create, update, delete: if isSuperAdmin() || isSupplyChainStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }

      match /purchase_orders/{orderId} {
        allow get, create, update, delete: if isSuperAdmin() || isSupplyChainStaff(hospitalId);
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }
      
      match /grn_logs/{grnId} {
        allow create: if isSuperAdmin() || isSupplyChainStaff(hospitalId);
        allow get, list: if isSuperAdmin() || isSupplyChainStaff(hospitalId);
        allow update, delete: if false;
      }

      match /lab_menu/{testId} {
        allow get, create, update, delete: if isSuperAdmin() || getCallingUserData().role in ['LAB_TECH', 'ADMIN', 'DIRECTOR'];
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }

      match /lab_orders/{orderId} {
        allow get: if isSuperAdmin() || isAnyStaff(hospitalId);
        allow list: if isSignedIn();
        allow create: if false;
        allow update: if isSuperAdmin() || getCallingUserData().role in ['LAB_TECH', 'DIRECTOR', 'ADMIN'];
        allow delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
      }
      
      match /radiology_menu/{scanId} {
        allow get, create, update, delete: if isSuperAdmin() || getCallingUserData().role in ['RADIOLOGIST', 'ADMIN', 'DIRECTOR'];
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }

      match /procedure_menu/{procedureId} {
        allow get, create, update, delete: if isSuperAdmin() || getCallingUserData().role in ['ADMIN', 'DIRECTOR'];
        allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }

      match /procedure_logs/{logId} {
        allow create: if isSuperAdmin() || isClinicalStaff(hospitalId);
        allow read, list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
      }

      match /radiology_orders/{orderId} {
        allow get: if isSuperAdmin() || isAnyStaff(hospitalId);
        allow list: if isSignedIn();
        allow create: if false;
        allow update: if isSuperAdmin() || getCallingUserData().role in ['RADIOLOGIST', 'DIRECTOR', 'ADMIN'];
        allow delete: if isSuperAdmin() || isDirectorOrAdmin(hospitalId);
      }

      match /wards/{wardId} {
        allow read, list: if isSuperAdmin() || isAnyStaff(hospitalId);
        allow create, delete: if isSuperAdmin() || getCallingUserData().role in ['DIRECTOR', 'ADMIN'];
        allow update: if isSuperAdmin() || (getCallingUserData().role in ['DIRECTOR', 'ADMIN']) ||
                         (isClinicalStaff(hospitalId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['occupancy']));

        match /beds/{bedId} {
           allow get: if isSuperAdmin() || isAnyStaff(hospitalId);
           allow list: if isSuperAdmin() || isStaffOfHospital(hospitalId);
           allow create, delete: if false;
           allow update: if isSuperAdmin() || isClinicalStaff(hospitalId) || getCallingUserData().role in ['ADMIN', 'DIRECTOR'];
        }
      }
      
      match /payments/{paymentId} {
        allow read, list: if isSuperAdmin() || isDirectorOrAdmin(hospitalId) || getCallingUserData().role == 'CASHIER';
        allow create: if (isSuperAdmin() || isDirectorOrAdmin(hospitalId) || getCallingUserData().role == 'CASHIER') && request.resource.data.hospitalId == hospitalId;
        allow delete: if false; // Payments are immutable
        // Allow accountants/directors to update only the claim status fields
        allow update: if (isSuperAdmin() || isDirectorOrAdmin(hospitalId))
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['claimStatus', 'submittedAt']);
      }
    }
  }
}
