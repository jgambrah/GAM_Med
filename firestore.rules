
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user's role from their user document.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper function to check if the requesting user is the patient in question.
    function isPatient(patientId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId;
    }

    // Rules for user-specific data
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Main collection rules
    match /patients/{patientId} {
      // Allow read access to authorized staff and the patient themselves.
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || isPatient(patientId);
      // Allow write access only to clinical staff and admins.
      // This is simplified; in production, you'd have more granular field-level validation.
      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }

    // Rules for the admissions sub-collection
    match /patients/{patientId}/admissions/{admissionId} {

      // READ: Clinical staff, admins, billing, and the patient themselves can read.
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || isPatient(patientId);
      
      // CREATE: New admissions can be created by clinical staff or admins.
      allow create: if getUserRole() in ['admin', 'doctor', 'nurse'];

      // UPDATE: Granular update rules based on role and document state.
      // This rule allows doctors to update a summary as long as it's not yet finalized.
      allow update: if resource.data.isSummaryFinalized == false 
                      && getUserRole() == 'doctor'
                      && request.auth.uid == resource.data.dischargeByDoctorId;

      // This rule allows billing clerks to ONLY update the finalBillId.
      allow update: if resource.data.isSummaryFinalized == false
                      && getUserRole() == 'billing_clerk'
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['finalBillId']);
      
      // Note: Full updates to change status to 'Discharged' would be handled by a Cloud Function,
      // which has privileged access and bypasses these end-user rules.
    }

    match /beds/{bedId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];
      // Writes to bed status should be handled by trusted Cloud Functions.
      allow write: if false; 
    }
  }
}
