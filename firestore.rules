rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user has a specific role
    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Helper function to check if a user is an admin, doctor, or nurse
    function isClinicalStaff() {
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return userRole == 'admin' || userRole == 'doctor' || userRole == 'nurse';
    }

    //------------------------------------------------------------
    // Users Collection
    //------------------------------------------------------------
    match /users/{userId} {
      // Admins can read/write any user profile
      // Users can read/update their own profile
      allow read, update: if request.auth.uid == userId || isRole('admin');
      // Only admins can create or delete user profiles
      allow create, delete: if isRole('admin');
    }

    //------------------------------------------------------------
    // Patients Collection
    //------------------------------------------------------------
    match /patients/{patientId} {
      // Clinical staff can read any patient's record.
      // A patient can read their own record (if their user doc is linked).
      allow read: if isClinicalStaff() || 
                     (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);
                     
      // Clinical staff can update patient records.
      allow update: if isClinicalStaff();

      // Only admins or nurses can create new patient records.
      allow create: if isRole('admin') || isRole('nurse');

      // Deleting patient records should be highly restricted, e.g., only by an admin.
      // Or, prefer soft-delete by setting a 'status' to 'archived'.
      allow delete: if isRole('admin');

      // --- Admissions Sub-collection ---
      match /admissions/{admissionId} {
        // Inherit read access from the parent patient document.
        allow read: if isClinicalStaff() || 
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);
        
        // Only clinical staff can create or update admission records.
        allow create, update: if isClinicalStaff();

        // Deleting admission records should be restricted.
        allow delete: if isRole('admin');
      }
    }

    //------------------------------------------------------------
    // Beds Collection
    //------------------------------------------------------------
    match /beds/{bedId} {
        // All clinical staff can view bed status.
        allow read: if isClinicalStaff();
        // Bed status is updated via server-side logic (Cloud Functions), not directly by clients.
        // Allowing direct client updates is risky as it could lead to race conditions.
        // For this prototype, we allow clinical staff to update. In production, this would be locked down.
        allow write: if isClinicalStaff();
    }
    
    //------------------------------------------------------------
    // Appointments Collection
    //------------------------------------------------------------
    match /appointments/{appointmentId} {
        // Clinical staff can read any appointment.
        // A patient can read their own appointments.
        allow read: if isClinicalStaff() || resource.data.patient_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id;
        
        // Clinical staff can create/update appointments.
        // Patients might be allowed to create/cancel their own appointments in a portal.
        allow write: if isClinicalStaff();
    }
  }
}
