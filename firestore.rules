
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for security rules
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isDoctor() {
      return isSignedIn() && getUserRole() == 'Doctor';
    }

    function isNurse() {
      return isSignedIn() && getUserRole() == 'Nurse';
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'Admin';
    }
    
    function isPharmacist() {
        return isSignedIn() && getUserRole() == 'Pharmacist';
    }
    
    function isPatientOwner(patientId) {
      // Assuming the user's UID is the same as the patient's document ID in a `patients` collection
      // or that there's a linking field. For this app, we check if the authenticated user's ID
      // matches a `userId` field on the patient document.
      // This part is conceptual as we don't have a direct user-to-patient link in the mock data.
      // A real implementation would require this link. For now, we'll assume a patient can read their own data.
      return request.auth.uid == resource.data.userId; 
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Users can read their own data. Admins can read anyone's data.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Users can create their own profile, or an admin can.
      allow create: if isSignedIn();
      // Users can update their own data. Admins can update anyone's.
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Rules for the 'patients' collection and its sub-collections
    match /patients/{patientId} {
      // CREATE: New patients can be created by Admins or Doctors.
      allow create: if isDoctor() || isAdmin();
      
      // READ: Admins, Doctors, and Nurses can read patient records.
      // A patient should be able to read their own record (isPatientOwner check).
      allow read: if isDoctor() || isNurse() || isAdmin() || isPatientOwner(patientId);
      
      // UPDATE: Patient demographics can be updated by Admins.
      // Clinical status updates might be handled by Doctors or Nurses.
      allow update: if isDoctor() || isAdmin();

      // DELETE: Generally, patient records should not be deleted (soft-delete instead).
      // Only allow deletion by a super-admin role if absolutely necessary.
      allow delete: if false;

      // --- EHR Sub-collections ---

      // Clinical Notes (Doctors, Nurses)
      match /clinicalNotes/{noteId} {
        allow read, write: if isDoctor() || isNurse();
      }

      // Vital Signs (Primarily Nurses)
      match /vitalSigns/{vitalId} {
        allow read: if isDoctor() || isNurse();
        allow write: if isNurse(); // Nurses typically record vitals
      }

      // Lab Results (Doctors, Nurses can view; Lab system writes)
      match /labResults/{labResultId} {
        allow read: if isDoctor() || isNurse();
        // Writes would typically come from a trusted backend service/lab system, not directly from a user role.
        // For direct entry, you could allow doctors.
        allow write: if isDoctor(); 
      }

      // Medication Orders (Doctors write; Pharmacists read/update status)
      match /medicationOrders/{orderId} {
        allow read: if isDoctor() || isNurse() || isPharmacist();
        allow create: if isDoctor();
        // Allow pharmacists to update the status (e.g., 'filled')
        allow update: if isPharmacist();
      }

      // Allergy records
      match /allergies/{allergyId} {
        allow read, write: if isDoctor() || isNurse();
      }
      
      // Imaging Reports
      match /imagingReports/{reportId} {
        allow read: if isDoctor();
        // Write would come from a backend imaging service
        allow write: if isDoctor(); 
      }
    }
    
    // Rules for other collections
    match /admissions/{admissionId} {
        allow read, write: if isDoctor() || isAdmin();
    }
    
    match /beds/{bedId} {
        allow read: if isDoctor() || isNurse() || isAdmin();
        allow write: if isAdmin(); // Only admins can directly manipulate bed status, others via actions.
    }
  }
}
