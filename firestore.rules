rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get user's role from the 'users' collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    // Helper function to check if a user has a specific role
    function isRole(role) {
      return request.auth != null && getUserRole(request.auth.uid) == role;
    }

    // Helper function to check if a user has one of several roles
    function isOneOfRoles(roles) {
      return request.auth != null && getUserRole(request.auth.uid) in roles;
    }

    // Rules for the 'users' collection (basic setup)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isRole('Admin');
    }

    // Rules for the 'patients' collection
    match /patients/{patientId} {
      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']) || request.auth.uid == patientId;
      
      allow create: if isOneOfRoles(['Admin', 'BillingClerk'])
                    && request.resource.id == request.resource.data.patientId;
                    
      allow update: if isOneOfRoles(['Admin', 'BillingClerk', 'Doctor', 'Nurse'])
                    && request.resource.data.patientId == resource.data.patientId;

      // Rules for the 'admissions' sub-collection
      match /admissions/{admissionId} {
        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']) || request.auth.uid == patientId;
        allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
      }
    }

    // Rules for the 'beds' collection
    match /beds/{bedId} {
      allow read: if request.auth != null; // Any authenticated user can see bed status
      allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);
    }
  }
}
