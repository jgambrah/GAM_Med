rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to simplify rule logic
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isManagerOrAdmin() {
        let role = getUserRole();
        return role == 'admin' || role == 'department_manager';
    }

    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if isOwner(userId) || getUserRole() in ['admin', 'HR'];
      // Employees can update their own profile, but cannot change their leave balance.
      allow update: if (isOwner(userId) && !('leaveBalances' in request.resource.data)) || isManagerOrAdmin();
      allow create: if getUserRole() == 'HR';
    }

    // Rules for 'shifts' collection
    match /shifts/{shiftId} {
      allow read: if request.auth != null;
      allow write: if getUserRole() == 'admin';
    }

    // Rules for 'rosters' collection
    match /rosters/{rosterId} {
        function isAssigned() {
            // This is a simplified check. A real implementation might need to handle larger rosters.
            return request.auth.uid in resource.data.staffAssignments.map(a => a.userId);
        }

        allow create: if isManagerOrAdmin();
        allow read: if isManagerOrAdmin() || isAssigned();
        allow update: if isManagerOrAdmin();
    }
    
     // Rules for 'staff_availability' collection
    match /staff_availability/{userId} {
      allow read: if isManagerOrAdmin() || isOwner(userId);
      allow write: if isManagerOrAdmin() || isOwner(userId);
    }

    // Rules for 'leave_requests' collection
    match /leave_requests/{leaveId} {
      allow read: if isManagerOrAdmin() || isOwner(resource.data.employeeId);
      allow create: if isOwner(request.resource.data.employeeId);
      allow update: if isManagerOrAdmin() || (resource.data.status == 'Pending' && isOwner(resource.data.employeeId));
    }
  }
}
