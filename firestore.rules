rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get the role of the currently authenticated user.
    // It reads the 'role' field from the user's document in the 'users' collection.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Rules for the 'users' collection itself.
    // Users should be able to read their own profile data.
    // Only admins should be able to modify roles (not shown here for brevity).
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Rules for the 'patients' collection.
    match /patients/{patientId} {
      // READ access is granted to staff roles or to the patient themselves.
      // Note: For a patient to read their own data, their user document
      // would need a field linking to their patientId, e.g., `resource.data.linkedPatientId == patientId`.
      // For simplicity here, we focus on staff access.
      allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'Pharmacist', 'BillingClerk'];
      
      // CREATE access is restricted to Admins.
      allow create: if getUserRole() == 'Admin';

      // UPDATE access is restricted to clinical staff (Admin, Doctor, Nurse).
      allow update: if getUserRole() in ['Admin', 'Doctor', 'Nurse'];
      
      // DELETE access is highly restricted, typically only for Admins for data cleanup.
      allow delete: if getUserRole() == 'Admin';
    }
    
    // Rules for admissions
    match /admissions/{admissionId} {
    	allow read, write: if getUserRole() in ['Admin', 'Doctor', 'Nurse'];
    }
    
    // Rules for beds
    match /beds/{bedId} {
    	allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'Housekeeping'];
      allow write: if getUserRole() in ['Admin', 'Housekeeping'];
    }

  }
}
