
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user's role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Patients:
    // - Authenticated users can create their own patient record.
    // - Only the patient themselves or authorized staff can read/write their data.
    match /patients/{patientId} {
      allow read, write: if request.auth != null && (request.auth.uid == resource.data.uid || getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk']);

      // Sub-collections can inherit or have more specific rules.
      match /{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'nurse']);
      }
    }
    
    // Users:
    // - Only the user themselves or an admin can read/write their user document.
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || getUserRole() == 'admin');
    }
    
    // Appointments:
    // - Authenticated users can create appointments.
    // - Only involved parties (patient, doctor) or staff can read/update.
    match /appointments/{appointmentId} {
        allow create: if request.auth != null;
        allow read, update: if request.auth != null && 
                               (request.auth.uid == resource.data.patient_id || 
                                request.auth.uid == resource.data.doctor_id ||
                                getUserRole() in ['admin', 'receptionist', 'nurse']);
    }

    // lab_tests: Read-only for authenticated users, write for admin
    match /lab_tests/{testId} {
        allow read: if request.auth != null;
        allow write: if getUserRole() == 'admin';
    }

    // lab_orders: Role-based access for creating and updating lab orders.
    match /lab_orders/{orderId} {
        allow create: if getUserRole() in ['admin', 'doctor'];
        allow update: if getUserRole() in ['admin', 'lab_tech'];
        allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;
    }

    // lab_results: Role-based access for results.
    match /lab_results/{resultId} {
        allow create: if getUserRole() in ['admin', 'lab_tech'];
        allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;
    }

  }
}
