rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || getUserRole() in ['admin'];
      allow write: if request.auth.uid == userId || getUserRole() in ['admin'];
    }

    match /patients/{patientId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist', 'billing_clerk'] || request.auth.uid == resource.data.uid;
      allow create, update, delete: if getUserRole() in ['admin', 'receptionist'];
    }

    // Rules for EHR sub-collections
    match /patients/{patientId}/{subcollection}/{documentId} {
      // Allow read for clinical staff and the patient themselves
      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist', 'billing_clerk'] || request.auth.uid == patientId;
      
      // Allow write for clinical staff only
      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];
    }

    match /beds/{bedId} {
        allow read: if request.auth.uid != null; // Allow any authenticated user to see bed status
        allow write: if getUserRole() in ['admin', 'nurse']; // Only admin and nurses can update bed status
    }
    
    match /appointments/{appointmentId} {
      allow read: if request.auth.uid != null;
      allow create, update, delete: if getUserRole() in ['admin', 'receptionist', 'radiologist'];
    }
    
    match /equipment/{equipmentId} {
      allow read: if request.auth.uid != null;
      // Write access is restricted to admin to simulate a trusted server process
      allow write: if getUserRole() in ['admin']; 
    }

    match /radiology_orders/{orderId} {
      allow create: if getUserRole() in ['admin', 'doctor'];
      allow read: if getUserRole() in ['admin', 'doctor', 'receptionist', 'radiologist'] || get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.uid == request.auth.uid;
      allow update: if getUserRole() in ['admin', 'receptionist', 'radiologist'];
    }
    
    match /radiology_reports/{reportId} {
      allow read: if getUserRole() in ['admin', 'doctor', 'radiologist'] || get(/databases/$(database)/documents/radiology_orders/$(reportId)).data.patientId == request.auth.uid;
      // Only radiologists or admins can create/update reports
      allow write: if getUserRole() in ['admin', 'radiologist'];
    }

    match /radiology_studies/{studyId} {
      allow read: if request.auth.uid != null;
      allow write: if getUserRole() in ['admin'];
    }

  }
}
