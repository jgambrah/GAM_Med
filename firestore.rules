rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the user's role from the 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper function to check if the user is an admin or system service
    function isAdmin() {
      return getUserRole() == 'Admin';
    }

    // Helper function to check for clinical staff
    function isClinicalStaff() {
      let role = getUserRole();
      return role == 'Doctor' || role == 'Nurse';
    }
    
    // Helper function to check for administrative staff
    function isAdministrativeStaff() {
        let role = getUserRole();
        return role == 'Admin' || role == 'BillingClerk';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow list: if isAdmin();
    }
    
    // Rules for the 'patients' collection
    match /patients/{patientId} {
        allow read: if isClinicalStaff() || isAdministrativeStaff() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == resource.data.contact.email;
        allow create: if isAdministrativeStaff();
        // Only allow specific fields to be updated by certain roles
        allow update: if isAdministrativeStaff() || (isClinicalStaff() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmitted', 'currentAdmissionId', 'updatedAt']));
        
        // Rules for the 'admissions' sub-collection
        match /admissions/{admissionId} {
            allow read: if isClinicalStaff() || isAdministrativeStaff() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == get(/databases/$(database)/documents/patients/$(patientId)).data.contact.email;
            allow create: if isAdministrativeStaff();
            // Updates are primarily handled by server-side logic (simulated by actions)
            allow update: if isAdmin(); 
        }
    }

    // Rules for the 'beds' collection
    match /beds/{bedId} {
        allow read: if isClinicalStaff() || isAdmin();
        // Bed status updates should be handled by trusted server-side logic
        allow update: if isAdmin();
    }
  }
}
