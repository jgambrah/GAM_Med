
{
  "entities": {
    "Hospital": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Hospital",
      "type": "object",
      "description": "Represents a tenant (hospital) in the GamMed multi-tenant system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the hospital."
        },
        "name": {
          "type": "string",
          "description": "The name of the hospital."
        },
        "subdomain": {
          "type": "string",
          "description": "The unique subdomain for the hospital (e.g., city-general)."
        },
        "apiKey": {
          "type": "string",
          "description": "A unique API key for external integrations."
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the hospital's account is currently active."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the hospital was registered."
        }
      },
      "required": [
        "id",
        "name",
        "isActive"
      ]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the MedFlow GH system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user entity."
        },
        "hospitalId": {
          "type": "string",
          "description": "Reference to the Hospital this user belongs to."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "User's phone number."
        },
        "displayName": {
          "type": "string",
          "description": "User's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "URL of the user's profile photo.",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "description": "User's role in the system (e.g., Patient, Doctor, Nurse, Pharmacist, Admin)."
        },
        "patientId": {
          "type": "string",
          "description": "Reference to Patient. (Relationship: User 1:1 Patient).  Only populated if the user is a patient."
        },
        "employeeId": {
          "type": "string",
          "description": "Reference to Employee. (Relationship: User 1:1 Employee). Only populated if the user is an employee (Doctor, Nurse, Pharmacist, Admin)."
        },
        "emailVerified": {
          "type": "boolean",
          "description": "Indicates whether the user's email address has been verified."
        }
      },
      "required": [
        "id",
        "hospitalId",
        "email",
        "role"
      ]
    },
    "Patient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Patient",
      "type": "object",
      "description": "Represents a patient in the MedFlow GH system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the patient entity."
        },
        "hospitalId": {
          "type": "string",
          "description": "Reference to the Hospital this patient belongs to."
        },
        "uniquePatientId": {
          "type": "string",
          "description": "Unique patient identifier assigned by the hospital."
        },
        "firstName": {
          "type": "string",
          "description": "Patient's first name."
        },
        "lastName": {
          "type": "string",
          "description": "Patient's last name."
        },
        "dateOfBirth": {
          "type": "string",
          "description": "Patient's date of birth.",
          "format": "date-time"
        },
        "gender": {
          "type": "string",
          "description": "Patient's gender."
        },
        "address": {
          "type": "string",
          "description": "Patient's address."
        },
        "phoneNumber": {
          "type": "string",
          "description": "Patient's phone number."
        },
        "emergencyContactName": {
          "type": "string",
          "description": "Name of the patient's emergency contact."
        },
        "emergencyContactPhone": {
          "type": "string",
          "description": "Phone number of the patient's emergency contact."
        },
        "medicalHistoryIds": {
          "type": "array",
          "description": "References to MedicalHistories. (Relationship: Patient 1:N MedicalHistory)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "hospitalId",
        "uniquePatientId",
        "firstName",
        "lastName",
        "dateOfBirth",
        "gender"
      ]
    },
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee of the hospital (Doctor, Nurse, Pharmacist, Admin).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the employee entity."
        },
        "hospitalId": {
          "type": "string",
          "description": "Reference to the Hospital this employee belongs to."
        },
        "firstName": {
          "type": "string",
          "description": "Employee's first name."
        },
        "lastName": {
          "type": "string",
          "description": "Employee's last name."
        },
        "employeeId": {
          "type": "string",
          "description": "Employee ID assigned by the hospital."
        },
        "role": {
          "type": "string",
          "description": "Employee's role (Doctor, Nurse, Pharmacist, Admin)."
        },
        "departmentId": {
          "type": "string",
          "description": "Reference to Department. (Relationship: Employee 1:N Department)"
        },
        "specialization": {
          "type": "string",
          "description": "Employee's specialization (e.g., Cardiology, Pediatrics)."
        },
        "scheduleIds": {
          "type": "array",
          "description": "References to Schedules. (Relationship: Employee 1:N Schedule)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "hospitalId",
        "firstName",
        "lastName",
        "employeeId",
        "role",
        "departmentId"
      ]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents an appointment scheduled in the MedFlow GH system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the appointment entity."
        },
        "hospitalId": {
          "type": "string",
          "description": "Reference to the Hospital this appointment belongs to."
        },
        "patientId": {
          "type": "string",
          "description": "Reference to Patient. (Relationship: Patient 1:N Appointment)"
        },
        "doctorId": {
          "type": "string",
          "description": "Reference to Employee (Doctor). (Relationship: Employee 1:N Appointment)"
        },
        "scheduleId": {
          "type": "string",
          "description": "Reference to Schedule. (Relationship: Schedule 1:N Appointment)"
        },
        "startTime": {
          "type": "string",
          "description": "Start time of the appointment.",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "description": "End time of the appointment.",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "description": "Notes about the appointment."
        },
        "status": {
          "type": "string",
          "description": "Status of the appointment (e.g., Scheduled, Confirmed, Cancelled, Completed)."
        }
      },
      "required": [
        "id",
        "hospitalId",
        "patientId",
        "doctorId",
        "scheduleId",
        "startTime",
        "endTime",
        "status"
      ]
    },
    "Admission": {
      "title": "Admission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hospitalId": { "type": "string" },
        "patientId": { "type": "string" },
        "bedId": { "type": "string" },
        "admissionDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Admitted", "Discharged", "Pending Discharge"] }
      },
      "required": ["id", "hospitalId", "patientId", "bedId", "status"]
    },
    "Bed": {
      "title": "Bed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hospitalId": { "type": "string" },
        "wardName": { "type": "string" },
        "status": { "type": "string", "enum": ["vacant", "occupied", "cleaning", "maintenance"] }
      },
      "required": ["id", "hospitalId", "wardName", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/hospitals/{hospitalId}",
        "definition": {
          "entityName": "Hospital",
          "schema": { "$ref": "#/backend/entities/Hospital" },
          "description": "Stores master data for each hospital (tenant)."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user authentication data. Isolated by hospitalId."
        }
      },
      {
        "path": "/patients/{patientId}",
        "definition": {
          "entityName": "Patient",
          "schema": { "$ref": "#/backend/entities/Patient" },
          "description": "Stores patient-specific data partitioned by hospitalId."
        }
      },
      {
        "path": "/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": { "$ref": "#/backend/entities/Appointment" },
          "description": "Appointment data partitioned by hospitalId."
        }
      },
      {
        "path": "/beds/{bedId}",
        "definition": {
          "entityName": "Bed",
          "schema": { "$ref": "#/backend/entities/Bed" },
          "description": "Hospital bed inventory partitioned by hospitalId."
        }
      },
      {
        "path": "/admissions/{admissionId}",
        "definition": {
          "entityName": "Admission",
          "schema": { "$ref": "#/backend/entities/Admission" },
          "description": "Inpatient admission records partitioned by hospitalId."
        }
      }
    ]
  }
}
