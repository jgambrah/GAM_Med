rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions for Multi-Tenant Isolation (The SaaS Wall)
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid)) ||
        request.auth.token.role == 'super_admin'
      );
    }

    /**
     * @description Fetches the hospitalId for the currently logged-in user.
     * Uses a robust fallback chain: Token Claim -> Admin Registry -> Staff Registry.
     */
    function getMyHospitalId() {
      return request.auth.token.hospitalId != null 
        ? request.auth.token.hospitalId 
        : (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) 
          ? get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.hospitalId 
          : (exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid)) 
            ? get(/databases/$(database)/documents/roles_staff/$(request.auth.uid)).data.hospitalId 
            : null));
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        request.auth.token.role == 'director' ||
        request.auth.token.role == 'admin' ||
        isSuperAdmin()
      );
    }

    function isSameHospital(docData) {
      let myHospId = getMyHospitalId();
      return isSignedIn() && (docData.hospitalId == myHospId || isSuperAdmin());
    }

    function isPatient(patientId) {
      return isSignedIn() && (request.auth.token.patientId == patientId || request.auth.token.patient_id == patientId);
    }

    // --------------------------------------------------------------------
    // Global Bypass for Super Admin
    // --------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --------------------------------------------------------------------
    // Public Discovery & Leads
    // --------------------------------------------------------------------
    match /pricing_plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /demo_requests/{leadId} {
      allow create: if true; 
      allow read: if isAdmin(); 
      allow write: if isSuperAdmin();
    }

    match /hospitals/{hospId} {
      allow get: if true; 
      allow list: if isSuperAdmin();
      allow update: if isSuperAdmin();
      
      match /counters/{counterId} {
        allow read, write: if isSignedIn() && (request.auth.token.hospitalId == hospId || getMyHospitalId() == hospId || isSuperAdmin());
      }
    }

    // --------------------------------------------------------------------
    // Primary Tenant Collections
    // --------------------------------------------------------------------

    match /users/{userDocId} {
      allow list: if isSignedIn() && (
        (request.query.limit <= 100 && request.query.filters.size() >= 1 && request.query.filters[0].field == "uid" && request.query.filters[0].value == request.auth.uid) ||
        (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId())
      );
      allow get: if isSignedIn() && (request.auth.uid == resource.data.uid || isSameHospital(resource.data));
      allow create: if isSignedIn() && isAdmin() && request.resource.data.hospitalId == getMyHospitalId();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.uid || (isAdmin() && isSameHospital(resource.data)));
    }

    match /patients/{patientId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow get: if isSignedIn() && (isSameHospital(resource.data) || isPatient(patientId));
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.hospitalId == getMyHospitalId());
      allow update: if isSignedIn() && isSameHospital(resource.data);
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    match /appointments/{apptId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow get: if isSignedIn() && isSameHospital(resource.data);
      allow create: if isSignedIn() && request.resource.data.hospitalId == getMyHospitalId();
      allow update: if isSignedIn() && isSameHospital(resource.data);
    }

    match /wards/{wardId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow read, write: if isSignedIn() && isSameHospital(resource.data || request.resource.data);
    }

    match /beds/{bedId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow read, write: if isSignedIn() && isSameHospital(resource.data || request.resource.data);
    }

    match /vitals/{vitalId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /clinical_notes/{noteId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /lab_orders/{orderId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /radiology_orders/{orderId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow read, write: if isSignedIn() && isSameHospital(resource.data || request.resource.data);
    }

    match /dietary_orders/{orderId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow read, write: if isSignedIn() && isSameHospital(resource.data || request.resource.data);
    }

    match /invoices/{invId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId());
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data) && isAdmin();
    }

    match /nhis_claims/{claimId} {
      allow list: if isSignedIn() && (request.query.filters.size() >= 1 && request.query.filters[0].field == "hospitalId" && request.query.filters[0].value == getMyHospitalId()) && (isAdmin() || request.auth.token.role == 'billing_clerk' || isSuperAdmin());
      allow read: if isSignedIn() && isSameHospital(resource.data) && (isAdmin() || request.auth.token.role == 'billing_clerk' || isSuperAdmin());
      allow write: if isSignedIn() && isSameHospital(request.resource.data) && (isAdmin() || request.auth.token.role == 'billing_clerk' || isSuperAdmin());
      allow create: if isSignedIn() && request.resource.data.hospitalId == getMyHospitalId();
    }

    match /referrals/{refId} {
      allow list: if isSignedIn() && (
        (request.query.filters.size() >= 1 && request.query.filters[0].field == "toHospitalId" && request.query.filters[0].value == getMyHospitalId()) ||
        (request.query.filters.size() >= 1 && request.query.filters[0].field == "fromHospitalId" && request.query.filters[0].value == getMyHospitalId()) ||
        isSuperAdmin()
      );
      allow get: if isSignedIn() && (resource.data.toHospitalId == getMyHospitalId() || resource.data.fromHospitalId == getMyHospitalId() || isSuperAdmin());
      allow create: if isSignedIn() && request.resource.data.fromHospitalId == getMyHospitalId();
      allow update: if isSignedIn() && (resource.data.toHospitalId == getMyHospitalId() || resource.data.fromHospitalId == getMyHospitalId() || isSuperAdmin());
    }

    // Generic fallback for other logically isolated documents
    match /{collection}/{docId} {
      allow read, write: if isSignedIn() && (isSuperAdmin() || (resource.data.hospitalId == getMyHospitalId() || request.resource.data.hospitalId == getMyHospitalId()));
    }
  }
}
