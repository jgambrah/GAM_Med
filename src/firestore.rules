
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions for Multi-Tenant Isolation (The SaaS Wall)
    // --------------------------------------------------------------------

    /**
     * Helper: Check if the user is the Platform Owner (Super Admin).
     * This role has a global bypass for maintenance and debugging.
     */
    function isSuperAdmin() {
      return request.auth != null && 
             request.auth.token != null && 
             request.auth.token.role == 'super_admin';
    }

    /**
     * Helper: Check if the user is authenticated and has a hospitalId claim.
     */
    function isAuthenticated() {
      return request.auth != null && 
             request.auth.token != null && 
             request.auth.token.hospitalId != null;
    }

    /**
     * Logic: The token's hospitalId MUST match the data's hospitalId.
     */
    function isSameHospital(docData) {
      return isAuthenticated() && docData.hospitalId == request.auth.token.hospitalId;
    }

    /**
     * THE SAFETY NET: Enforces logical isolation for queries (list).
     * Mandates that the query MUST include a filter for the user's hospitalId.
     */
    function isQueryScoped() {
      return isAuthenticated() && request.query.filters.hospitalId == request.auth.token.hospitalId;
    }

    /**
     * Checks if the user has an authorized employee role via claims.
     */
    function isEmployee() {
      return isAuthenticated() && request.auth.token.role in [
        'director', 'admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk', 
        'lab_technician', 'radiologist', 'dietitian', 'receptionist',
        'ot_coordinator', 'housekeeping', 'space_manager'
      ];
    }

    /**
     * Checks if the user is a hospital administrator or director via claims.
     */
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role in ['admin', 'director'];
    }

    /**
     * Checks if the authenticated user is the owner of the document.
     */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --------------------------------------------------------------------
    // Global Bypass for Super Admin (God Mode)
    // --------------------------------------------------------------------
    match /{document=**} {
      // Platform owners can see and do everything across all tenants.
      allow read, write: if isSuperAdmin();
    }

    // --------------------------------------------------------------------
    // Tenant-Specific Collection Rules
    // --------------------------------------------------------------------

    // Hospitals (Tenant Masters)
    match /hospitals/{hospId} {
      // Allow public discovery of active hospitals for the login page dropdown
      // Discovery is restricted to a list of active tenants with a safety limit
      allow list: if request.query.limit <= 50 && (resource == null || resource.data.status == 'active');
      
      // Accessing full hospital settings/metadata requires being a member or Super Admin
      allow get: if isSuperAdmin() || (isAuthenticated() && request.auth.token.hospitalId == hospId);
      
      // Management is handled via Super Admin God Mode
    }

    // Users & Staff Profiles
    match /users/{userId} {
      allow list: if isEmployee() && isAdmin() && isQueryScoped();
      allow get: if isOwner(userId) || (isEmployee() && isSameHospital(resource.data));
      
      // Enforce the Multi-tenant Unique Constraint pattern: {hospitalId}_{email}
      allow create: if isOwner(userId) && 
                    isSameHospital(request.resource.data) && 
                    userId == request.resource.data.hospitalId + "_" + request.resource.data.email;
      
      allow update: if (isOwner(userId) || isAdmin()) && isSameHospital(request.resource.data);
    }

    // Patients
    match /patients/{patientId} {
      // Queries must be scoped to the tenant and limited for performance
      allow list: if isEmployee() && isQueryScoped() && request.query.limit <= 50;
      
      // Direct access check
      allow get: if (isAuthenticated() && request.auth.token.patient_id == patientId) || (isEmployee() && isSameHospital(resource.data));
      
      // Enforce: Must tag new patients with your own hospitalId + follow MRN pattern
      allow create: if isEmployee() && 
                    isSameHospital(request.resource.data) && 
                    patientId == request.resource.data.hospitalId + "_MRN" + request.resource.data.mrn;
      
      allow update: if isEmployee() && isSameHospital(resource.data) && isSameHospital(request.resource.data);
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow list: if (isEmployee() && isQueryScoped()) || (isAuthenticated() && request.query.filters.patient_id == request.auth.token.patient_id);
      allow get: if (isAuthenticated() && request.auth.token.patient_id == resource.data.patient_id) || (isEmployee() && isSameHospital(resource.data));
      allow create: if isAuthenticated() && isSameHospital(request.resource.data);
      allow update: if isEmployee() && isSameHospital(request.resource.data);
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    // Generic Safety Net for all other tenant-scoped documents (Admissions, Invoices, Lab Results, etc.)
    match /{collection}/{docId} {
      allow list: if isEmployee() && isQueryScoped() && request.query.limit <= 50;
      allow get: if isEmployee() && isSameHospital(resource.data);
      allow write: if isEmployee() && 
                    (resource == null || isSameHospital(resource.data)) && 
                    (request.resource == null || isSameHospital(request.resource.data));
    }
  }
}
