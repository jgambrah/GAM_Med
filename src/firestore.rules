rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions for Multi-Tenant Isolation (The SaaS Wall)
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid)) ||
        request.auth.token.role == 'super_admin'
      );
    }

    /**
     * @description Fetches the hospitalId for the currently logged-in user.
     * Priority 1: Trusted Custom Claims (JWT)
     * Priority 2: Role Registry Fallback (Handles new users before claim propagation)
     */
    function getMyHospitalId() {
      if (request.auth.token.hospitalId != null) {
        return request.auth.token.hospitalId;
      }
      
      // Fallback: Check the role registries which use the UID as the Document ID
      let adminPath = /databases/$(database)/documents/roles_admin/$(request.auth.uid);
      if (exists(adminPath)) {
        return get(adminPath).data.hospitalId;
      }
      
      let staffPath = /databases/$(database)/documents/roles_staff/$(request.auth.uid);
      if (exists(staffPath)) {
        return get(staffPath).data.hospitalId;
      }
      
      return null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        request.auth.token.role == 'director' ||
        request.auth.token.role == 'admin' ||
        isSuperAdmin()
      );
    }

    /**
     * @description Ensures the document belongs to the user's hospital.
     */
    function isSameHospital(docData) {
      return isSignedIn() && (docData.hospitalId == getMyHospitalId() || isSuperAdmin());
    }

    function isPatient(patientId) {
      return isSignedIn() && request.auth.token.patientId == patientId;
    }

    /**
     * @description Feature Gating based on subscription tier
     */
    function hasFeature(slug) {
      let hId = getMyHospitalId();
      let hospitalDoc = get(/databases/$(database)/documents/hospitals/$(hId));
      let plan = hospitalDoc.data.subscriptionTier;
      
      return (plan == 'enterprise') || 
             (plan == 'professional' && slug in ['ehr', 'vitals', 'appointments', 'billing', 'pharmacy', 'lab', 'wards', 'inventory', 'nursing']) ||
             (plan == 'clinic-starter' && slug in ['ehr', 'vitals', 'appointments', 'billing']);
    }

    // --------------------------------------------------------------------
    // Global Bypass for Super Admin
    // --------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --------------------------------------------------------------------
    // Public Discovery & Leads
    // --------------------------------------------------------------------
    match /pricing_plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /demo_requests/{leadId} {
      allow create: if true; 
      allow read: if isAdmin(); 
      allow write: if isSuperAdmin();
    }

    match /hospitals/{hospId} {
      allow get: if true; 
      allow list: if isSuperAdmin();
      allow update: if isSuperAdmin();
    }

    // --------------------------------------------------------------------
    // Primary Tenant Collections (Explicit Matches)
    // --------------------------------------------------------------------

    match /users/{userId} {
      // allow get if it's the user's own profile OR if they are in the same hospital
      allow get: if isSignedIn() && (request.auth.uid == resource.data.uid || isSameHospital(resource.data));
      allow list: if isSignedIn() && isSameHospital(resource.data);
      allow create: if isSignedIn() && isAdmin() && request.resource.data.hospitalId == getMyHospitalId();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.uid || (isAdmin() && isSameHospital(resource.data)));
    }

    match /patients/{patientId} {
      allow list: if isSignedIn() && (resource.data.hospitalId == getMyHospitalId());
      allow get: if isSignedIn() && (resource.data.hospitalId == getMyHospitalId() || isPatient(patientId));
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.hospitalId == getMyHospitalId());
      allow update: if isSignedIn() && isSameHospital(resource.data);
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    match /appointments/{apptId} {
      allow read, write: if isSignedIn() && (request.resource.data.hospitalId == getMyHospitalId() || resource.data.hospitalId == getMyHospitalId());
    }

    // --------------------------------------------------------------------
    // Clinical & Operational Modules
    // --------------------------------------------------------------------

    match /vitals/{vitalId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /clinical_notes/{noteId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /lab_orders/{orderId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data);
    }

    match /referrals/{referralId} {
      allow read: if isSignedIn() && (
        resource.data.fromHospitalId == getMyHospitalId() || 
        resource.data.toHospitalId == getMyHospitalId()
      );
      allow create: if isSignedIn() && request.resource.data.fromHospitalId == getMyHospitalId();
      allow update: if isSignedIn() && (
        resource.data.toHospitalId == getMyHospitalId() ||
        resource.data.fromHospitalId == getMyHospitalId()
      );
    }

    match /invoices/{invId} {
      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));
      allow write: if isSignedIn() && isSameHospital(request.resource.data) && isAdmin();
    }

    // Generic fallback for other logically isolated documents
    match /{collection}/{docId} {
      allow read, write: if isSignedIn() && (isSuperAdmin() || (resource.data.hospitalId == getMyHospitalId() || request.resource.data.hospitalId == getMyHospitalId()));
    }
  }
}