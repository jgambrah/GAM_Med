rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions for Multi-Tenant Isolation (The SaaS Wall)
    // --------------------------------------------------------------------

    /**
     * Helper: Check if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Helper: Check if the user is the Platform Owner (Super Admin) via DBAC.
     */
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }

    /**
     * Logic: The token's hospitalId (or doc data) MUST match the requested data's hospitalId.
     */
    function isSameHospital(docData) {
      return isSignedIn() && 
             docData.hospitalId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hospitalId;
    }

    /**
     * Checks if the user is a hospital administrator or director via DBAC.
     */
    function isAdmin() {
      return isSignedIn() && (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || isSuperAdmin());
    }

    // --------------------------------------------------------------------
    // Global Bypass for Super Admin (God Mode)
    // --------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --------------------------------------------------------------------
    // Tenant-Specific Collection Rules
    // --------------------------------------------------------------------

    // Hospitals (Tenant Masters)
    match /hospitals/{hospId} {
      allow create: if isSignedIn() && (hospId == 'GAMMED_HQ' || isSuperAdmin());
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
    }

    // Role Markers (DBAC)
    match /roles_super_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via internal setup/signup once
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Users & Staff Profiles
    match /users/{userId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.uid || isAdmin());
    }

    // Patients
    match /patients/{patientId} {
      allow list: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());
      allow get: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());
      allow delete: if isAdmin();
    }

    // Generic Safety Net for all other tenant-scoped documents
    match /{collection}/{docId} {
      allow read, write: if isSignedIn() && (isSuperAdmin() || isSameHospital(resource.data));
    }
  }
}