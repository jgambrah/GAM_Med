
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions for Multi-Tenant Isolation
    // --------------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Retrieves the authenticated user's profile document.
     * In a multi-tenant setup, this document MUST contain the 'hospitalId'.
     */
    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Enforces logical isolation. 
     * Ensures the request data's hospitalId matches the user's hospitalId.
     */
    function isSameHospital(docData) {
        return docData.hospitalId == getUserData().hospitalId;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
        return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isEmployee() {
        return isSignedIn() && getUserData().role in ['doctor', 'nurse', 'pharmacist', 'admin', 'lab_technician', 'radiologist', 'billing_clerk'];
    }

    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    /**
     * @description Hospital master records are read-only for their own employees.
     */
    match /hospitals/{hospitalId} {
      allow get: if isSignedIn() && getUserData().hospitalId == hospitalId;
      allow list: if false; // List only via admin tools if needed
      allow write: if false; // Tenant provisioning is an external admin task
    }

    /**
     * @description Users can manage their own profile within their hospital.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || (isEmployee() && isSameHospital(resource.data));
      allow create: if isOwner(userId) && isSameHospital(request.resource.data);
      allow update: if isOwner(userId) && isSameHospital(request.resource.data) && isSameHospital(resource.data);
      allow list: if isEmployee() && getUserData().role == 'admin';
    }

    /**
     * @description Patients are isolated by hospitalId.
     */
    match /patients/{patientId} {
      allow get: if (isSignedIn() && getUserData().patientId == patientId) || (isEmployee() && isSameHospital(resource.data));
      allow list: if isEmployee(); // Queries must filter by hospitalId
      allow create: if isEmployee() && isSameHospital(request.resource.data);
      allow update: if isEmployee() && isSameHospital(resource.data) && isSameHospital(request.resource.data);
      
      // Medical History sub-collection
      match /medicalHistories/{historyId} {
        allow read, write: if isEmployee() && isSameHospital(get(/databases/$(database)/documents/patients/$(patientId)).data);
      }
    }

    /**
     * @description Appointments are isolated by hospitalId.
     */
    match /appointments/{appointmentId} {
      allow read: if (isSignedIn() && getUserData().patientId == resource.data.patientId) || (isEmployee() && isSameHospital(resource.data));
      allow create: if isSignedIn() && isSameHospital(request.resource.data);
      allow update, delete: if isEmployee() && isSameHospital(resource.data);
    }

    /**
     * @description Generic rule for other shared collections (beds, schedules, etc.)
     */
    match /{collection}/{docId} {
      allow read, write: if isEmployee() && 
        (resource == null || isSameHospital(resource.data)) && 
        (request.resource == null || isSameHospital(request.resource.data));
    }
  }
}
