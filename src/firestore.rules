
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions for Multi-Tenant Isolation (SaaS Safety Net)
    // --------------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Enforces logical isolation for direct document access (get/write).
     * Ensures the user's hospitalId matches the document's hospitalId.
     */
    function isSameHospital(docData) {
      return isSignedIn() && docData.hospitalId == request.auth.token.hospitalId;
    }

    /**
     * THE SAFETY NET: Enforces logical isolation for queries (list).
     * Mandates that the query MUST include a filter for the user's hospitalId.
     */
    function isQueryScoped() {
      return isSignedIn() && request.query.filters.hospitalId == request.auth.token.hospitalId;
    }

    /**
     * Checks if the user has an authorized employee role via claims.
     */
    function isEmployee() {
      return isSignedIn() && request.auth.token.role in [
        'admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk', 
        'lab_technician', 'radiologist', 'dietitian', 'receptionist'
      ];
    }

    /**
     * Checks if the user is a hospital administrator via claims.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    /**
     * Checks if the authenticated user is the owner of the document.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    // Hospitals (Tenant Masters)
    match /hospitals/{hospitalId} {
      allow get: if isSignedIn() && request.auth.token.hospitalId == hospitalId;
      allow write: if false; // Provisioning is handled via system admin tools
    }

    // Users & Staff Profiles
    match /users/{userId} {
      allow list: if isEmployee() && isAdmin() && isQueryScoped();
      allow get: if isOwner(userId) || (isEmployee() && isSameHospital(resource.data));
      
      // Enforce the Multi-tenant Unique Constraint pattern: {hospitalId}_{email}
      allow create: if isOwner(userId) && 
                    isSameHospital(request.resource.data) && 
                    userId == request.resource.data.hospitalId + "_" + request.resource.data.email;
      
      allow update: if (isOwner(userId) || isAdmin()) && isSameHospital(request.resource.data);
    }

    // Patients
    match /patients/{patientId} {
      // The Ultimate Protection: Queries must be scoped and limited
      allow list: if isEmployee() && isQueryScoped() && request.query.limit <= 50;
      
      // Direct access protection
      allow get: if (isSignedIn() && request.auth.token.patient_id == patientId) || (isEmployee() && isSameHospital(resource.data));
      
      // Enforce the Gold Standard pattern: {hospitalId}_MRN{mrn}
      allow create: if isEmployee() && 
                    isSameHospital(request.resource.data) && 
                    patientId == request.resource.data.hospitalId + "_MRN" + request.resource.data.mrn;
      
      allow update: if isEmployee() && isSameHospital(resource.data) && isSameHospital(request.resource.data);
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow list: if (isEmployee() && isQueryScoped()) || (isSignedIn() && request.query.filters.patient_id == request.auth.token.patient_id);
      allow get: if (isSignedIn() && request.auth.token.patient_id == resource.data.patient_id) || (isEmployee() && isSameHospital(resource.data));
      allow create: if isSignedIn() && isSameHospital(request.resource.data);
      allow update: if isEmployee() && isSameHospital(resource.data);
      allow delete: if isAdmin() && isSameHospital(resource.data);
    }

    // Generic Safety Net for all other tenant-scoped documents
    match /{collection}/{docId} {
      allow list: if isEmployee() && isQueryScoped() && request.query.limit <= 50;
      allow get: if isEmployee() && isSameHospital(resource.data);
      allow write: if isEmployee() && (request.resource == null || isSameHospital(request.resource.data));
    }
  }
}
