rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /hospitals/{hospitalId}/{allPaths=**} {
      // Only staff from the SAME hospital can see/upload images
      // And the CEO (Super Admin)
      allow read, write: if request.auth.token.hospitalId == hospitalId || request.auth.token.role == 'SUPER_ADMIN';
    }
  }
}
