[debug] [2025-09-04T16:03:16.681Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to get the user's role from the 'users' collection.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the 'users' collection.\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId; // Users can only write to their own document.\n    }\n    \n    // Rules for the 'patients' collection and its sub-collections.\n    match /patients/{patientId} {\n      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n\n      // Allow patients to read their own data.\n      allow read: if request.auth.uid == resource.data.patient_id;\n\n      // Secure all sub-collections under a patient.\n      match /{subcollection}/{docId} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow read: if request.auth.uid == patientId;\n      }\n    }\n    \n    // Rules for the 'appointments' collection.\n    match /appointments/{appointmentId} {\n      allow read, create, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n\n    // Rules for the 'lab_orders' collection\n    match /lab_orders/{orderId} {\n      allow create: if getUserRole() in ['admin', 'doctor'];\n      allow update: if getUserRole() in ['admin', 'lab_tech'];\n      allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;\n\n      // Rules for the 'sample_audit' sub-collection\n      // This creates an immutable, append-only log.\n      match /sample_audit/{auditId} {\n        allow create: if getUserRole() in ['admin', 'lab_tech'];\n        allow read: if getUserRole() in ['admin', 'lab_tech'] || request.auth.uid == resource.data.patientId;\n        allow update, delete: if false; // No one can modify or delete an audit log entry.\n      }\n    }\n    \n    // Rules for the 'lab_tests' (catalog) collection\n    match /lab_tests/{testId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin';\n    }\n    \n    // Rules for the 'lab_results' collection\n    match /lab_results/{resultId} {\n       allow create: if getUserRole() in ['admin', 'doctor'];\n       allow update: if getUserRole() in ['admin', 'lab_tech'];\n       allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;\n    }\n\n  }\n}\n"}]}}
