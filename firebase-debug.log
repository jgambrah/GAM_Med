[debug] [2026-02-26T08:23:27.461Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // --------------------------------------------------------------------\n    // Helper Functions for Multi-Tenant Isolation (The SaaS Wall)\n    // --------------------------------------------------------------------\n\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isSuperAdmin() {\n      return isSignedIn() && exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));\n    }\n\n    function isAdmin() {\n      return isSignedIn() && (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || isSuperAdmin());\n    }\n\n    /**\n     * @description Fetches the hospitalId for the currently logged-in user.\n     */\n    function getMyHospitalId() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hospitalId;\n    }\n\n    /**\n     * @description Checks if the document belongs to the user's hospital.\n     */\n    function isSameHospital(docData) {\n      return isSignedIn() && (docData.hospitalId == getMyHospitalId() || isSuperAdmin());\n    }\n\n    function isPatient(patientId) {\n      return isSignedIn() && request.auth.token.patientId == patientId;\n    }\n\n    function getMyRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // --------------------------------------------------------------------\n    // Global Bypass for Super Admin\n    // --------------------------------------------------------------------\n    match /{document=**} {\n      allow read, write: if isSuperAdmin();\n    }\n\n    // --------------------------------------------------------------------\n    // Public Pricing Plans (Public Read, Super Admin Write)\n    // --------------------------------------------------------------------\n    match /pricing_plans/{planId} {\n      allow read: if true;\n      allow write: if isSuperAdmin();\n    }\n\n    // --------------------------------------------------------------------\n    // Referral Module Rules (The SaaS Window)\n    // --------------------------------------------------------------------\n    match /referrals/{referralId} {\n      allow read: if isSignedIn() && (\n        resource.data.fromHospitalId == getMyHospitalId() || \n        resource.data.toHospitalId == getMyHospitalId() ||\n        isSuperAdmin()\n      );\n\n      allow create: if isSignedIn() && request.resource.data.fromHospitalId == getMyHospitalId();\n\n      allow update: if isSignedIn() && (\n        resource.data.toHospitalId == getMyHospitalId() ||\n        isSuperAdmin()\n      );\n    }\n\n    // --------------------------------------------------------------------\n    // Primary Tenant Collections (Strict Isolation)\n    // --------------------------------------------------------------------\n\n    match /hospitals/{hospId} {\n      allow create: if isSignedIn() && (hospId == 'GAMMED_HQ' || isSuperAdmin());\n      allow get: if isSignedIn();\n      allow list: if isSuperAdmin();\n    }\n\n    match /users/{userId} {\n      allow get: if isSignedIn() && (request.auth.uid == userId || isSameHospital(resource.data));\n      allow list: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());\n      allow create: if isSignedIn() && isAdmin() && request.resource.data.hospitalId == getMyHospitalId();\n      allow update: if isSignedIn() && (request.auth.uid == userId || (isAdmin() && isSameHospital(resource.data)));\n    }\n\n    match /patients/{patientId} {\n      allow list: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());\n      allow get: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin() || isPatient(patientId));\n      allow create: if isSignedIn() && (isAdmin() || request.resource.data.hospitalId == getMyHospitalId());\n      allow update: if isSignedIn() && (isSameHospital(resource.data) || isSuperAdmin());\n      allow delete: if isAdmin() && isSameHospital(resource.data);\n    }\n\n    // --------------------------------------------------------------------\n    // Space & Facility Management\n    // --------------------------------------------------------------------\n\n    match /facilities/{facilityId} {\n      allow read: if isSignedIn() && isSameHospital(resource.data);\n      allow write: if isSignedIn() && isSameHospital(request.resource.data) && \n                   (getMyRole() == 'director' || getMyRole() == 'admin' || getMyRole() == 'space_manager');\n    }\n\n    match /facility_bookings/{bookingId} {\n      allow read: if isSignedIn() && isSameHospital(resource.data);\n      allow write: if isSignedIn() && isSameHospital(request.resource.data);\n    }\n\n    // --------------------------------------------------------------------\n    // Narcotic Control (High Security)\n    // --------------------------------------------------------------------\n\n    match /controlled_substances/{substanceId} {\n      allow read: if isSignedIn() && isSameHospital(resource.data);\n      allow write: if isSignedIn() && isSameHospital(request.resource.data) && \n                   (getMyRole() == 'pharmacist' || getMyRole() == 'admin');\n    }\n\n    match /controlled_substance_logs/{logId} {\n      allow read: if isSignedIn() && isSameHospital(resource.data);\n      allow create: if isSignedIn() && isSameHospital(request.resource.data) && \n                    (getMyRole() == 'pharmacist' || getMyRole() == 'admin' || getMyRole() == 'doctor');\n      allow update, delete: if false;\n    }\n\n    // --------------------------------------------------------------------\n    // Clinical & Operational Modules\n    // --------------------------------------------------------------------\n\n    match /vitals/{vitalId} {\n      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));\n      allow write: if isSignedIn() && isSameHospital(request.resource.data);\n    }\n\n    match /clinical_notes/{noteId} {\n      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));\n      allow write: if isSignedIn() && isSameHospital(request.resource.data);\n    }\n\n    match /lab_orders/{orderId} {\n      allow read: if isSignedIn() && (isSameHospital(resource.data) || isPatient(resource.data.patientId));\n      allow write: if isSignedIn() && isSameHospital(request.resource.data);\n    }\n\n    match /ot_sessions/{sessionId} {\n      allow read: if isSignedIn() && isSameHospital(resource.data);\n      allow write: if isSignedIn() && isSameHospital(request.resource.data);\n    }\n\n    match /dietary_orders/{orderId} {\n      allow read: if isSignedIn() && isSameHospital(resource.data);\n      allow write: if isSignedIn() && isSameHospital(request.resource.data);\n    }\n\n    match /{collection}/{docId} {\n      allow read, write: if isSignedIn() && (isSuperAdmin() || isSameHospital(resource.data));\n    }\n  }\n}\n"}]}}
