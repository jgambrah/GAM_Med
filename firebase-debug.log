[debug] [2025-09-10T13:06:50.578Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions to simplify rule logic\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    function isOwner(userId) {\n      return request.auth.uid == userId;\n    }\n    \n    function isManagerOrAdmin() {\n        let role = getUserRole();\n        return role == 'admin' || role == 'department_manager';\n    }\n\n    // Rules for 'users' collection\n    match /users/{userId} {\n      allow read: if isOwner(userId) || getUserRole() in ['admin', 'HR'];\n      // Employees can update their own profile, but cannot change their leave balance.\n      allow update: if (isOwner(userId) && !('leaveBalances' in request.resource.data)) || isManagerOrAdmin();\n      allow create: if getUserRole() == 'HR';\n    }\n\n    // Rules for 'shifts' collection\n    match /shifts/{shiftId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for 'rosters' collection\n    match /rosters/{rosterId} {\n        function isAssigned() {\n            // This is a simplified check. A real implementation might need to handle larger rosters.\n            return request.auth.uid in resource.data.staffAssignments.map(a => a.userId);\n        }\n\n        allow create: if isManagerOrAdmin();\n        allow read: if isManagerOrAdmin() || isAssigned();\n        allow update: if isManagerOrAdmin();\n    }\n    \n     // Rules for 'staff_availability' collection\n    match /staff_availability/{userId} {\n      allow read: if isManagerOrAdmin() || isOwner(userId);\n      allow write: if isManagerOrAdmin() || isOwner(userId);\n    }\n\n    // Rules for 'leave_requests' collection\n    match /leave_requests/{leaveId} {\n      allow read: if isManagerOrAdmin() || isOwner(resource.data.employeeId);\n      allow create: if isOwner(request.resource.data.employeeId);\n      allow update: if isManagerOrAdmin() || (resource.data.status == 'Pending' && isOwner(resource.data.employeeId));\n    }\n  }\n}\n"}]}}
