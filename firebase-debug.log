[debug] [2025-09-19T15:54:18.119Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user role\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || getUserRole() == 'admin';\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n\n    match /patients/{patientId} {\n      allow read, write: if getUserRole() == 'admin' \n                      || request.auth.uid == patientId\n                      || request.auth.uid in get(/databases/$(database)/documents/patients/$(patientId)).data.assignedCareTeam;\n    }\n\n    match /audit_logs/{logId} {\n      allow read: if getUserRole() == 'admin';\n      allow write: if false; // Immutable from the client\n    }\n\n    match /prescriptions/{prescriptionId} {\n      allow create: if getUserRole() == 'doctor';\n      allow update: if getUserRole() == 'pharmacist';\n      // No one can delete a prescription record directly, it must be marked as 'Canceled'.\n      allow delete: if false; \n    }\n\n    match /inventory/{itemId} {\n      // Only pharmacists can update inventory levels (e.g., through dispensing or restocking).\n      allow update: if getUserRole() == 'pharmacist';\n      allow read: if request.auth.uid != null; // Allow any authenticated user to read inventory levels\n      allow create, delete: if getUserRole() == 'admin'; // Only admins can add new items to the catalog\n    }\n  }\n}\n"}]}}
