[debug] [2025-09-08T17:28:00.881Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    function isUserAuthenticated() {\n      return request.auth != null;\n    }\n\n    function getUserRole() {\n      // In a real app, you might want to handle the case where the user document doesn't exist yet.\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Allow read access for all authenticated users to their own user document\n    match /users/{userId} {\n      allow read: if isUserAuthenticated();\n      allow write: if isUserAuthenticated() && request.auth.uid == userId;\n    }\n    \n    match /patients/{patientId} {\n      allow read: if isUserAuthenticated(); // More specific rules for subcollections\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse']; // Or a trusted Cloud Function\n      \n      // Rules for daily_care_plans subcollection\n      match /daily_care_plans/{carePlanId} {\n        allow create: if false; // Only allow creation via trusted Cloud Function\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'ward_manager'] \n                       || request.auth.uid == resource.data.assignedToUserId \n                       || request.auth.uid == patientId;\n        allow update: if getUserRole() in ['nurse', 'ward_manager'] && request.auth.uid == resource.data.assignedToUserId;\n      }\n    }\n\n    match /wards/{wardId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist', 'ward_manager'];\n      // Allow write only by ward managers or trusted functions\n      allow write: if getUserRole() == 'ward_manager';\n    }\n\n    match /beds/{bedId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];\n      // Allow write only by trusted functions (or specific admin roles like ward_manager)\n      allow write: if getUserRole() in ['admin', 'ward_manager'];\n    }\n    \n    match /operating_theatres/{theatreId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n      allow write: if getUserRole() == 'admin'; // Or trusted function\n    }\n  }\n}\n"}]}}
