[debug] [2025-09-05T15:43:24.293Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Allow users to read their own user document\n    match /users/{userId} {\n      allow read, write: if request.auth.uid == userId;\n    }\n    \n    // Patient data can only be read by the patient themselves or authorized staff.\n    match /patients/{patientId} {\n      allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow write: if getUserRole() in ['admin']; // Only admins can create/update patient records directly\n      \n      // Allow authorized staff to read/write to sub-collections\n      match /{subcollection}/{documentId} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      \n      match /lab_history/{resultId} {\n        allow create: if false; // Only allow create from a trusted Cloud Function\n        allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor'];\n      }\n    }\n    \n     // Lab results can be read by lab staff, doctors, or the patient themselves.\n    match /lab_results/{resultId} {\n       allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;\n    }\n    \n    // Equipment logs can only be created by a trusted source and read by lab staff.\n    match /equipment_logs/{logId} {\n      allow create: if false; // Should only be written by a trusted backend service/function\n      allow read: if getUserRole() in ['admin', 'lab_tech'];\n      allow write: if getUserRole() in ['admin']; // Allow admin to update/correct logs if needed\n    }\n    \n    // Reports can only be read by authorized management roles.\n    match /reports/{reportId} {\n       allow read: if getUserRole() in ['admin', 'lab_manager', 'financial_staff'];\n       allow write: if false; // Reports are write-once from a trusted function\n    }\n\n  }\n}\n"}]}}
