[debug] [2025-09-02T16:16:34.800Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the role of the current user\n    function getUserRole() {\n      // Access the user's custom claims, which should be set by a Cloud Function upon user creation/update\n      return request.auth.token.role;\n    }\n    \n    function isPatient() {\n      return getUserRole() == 'patient';\n    }\n    \n    // Helper function to get user data from the 'users' collection\n    function getUserData(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data;\n    }\n\n    // Default deny all reads and writes\n    match /{document=**} {\n      allow read, write: if false;\n    }\n    \n    // Allow users to read their own data\n    match /users/{userId} {\n      allow read, write: if request.auth.uid == userId;\n    }\n    \n    match /patients/{patientId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk'] || request.auth.uid == getUserData(request.auth.uid).patient_id;\n      allow update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow create: if getUserRole() in ['admin', 'receptionist'];\n\n      // Sub-collections\n      match /clinical_notes/{noteId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || isPatient();\n        allow create: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      \n       match /diagnoses/{diagnosisId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || isPatient();\n        allow create: if getUserRole() == 'doctor';\n      }\n      \n      match /medication_history/{medId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist'] || isPatient();\n        allow create: if getUserRole() == 'doctor'; // Prescriptions are created by doctors\n      }\n    }\n    \n    match /prescriptions/{prescriptionId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'pharmacist'] || isPatient();\n        allow create: if getUserRole() == 'doctor';\n        allow update: if getUserRole() in ['admin', 'pharmacist']; // Pharmacist updates status to 'Dispensed'\n    }\n\n    match /drug_interactions/{interactionId} {\n        allow read: if request.auth != null;\n        allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for the Laboratory Information System (LIS)\n    match /lab_tests/{testId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin';\n    }\n\n    match /lab_orders/{orderId} {\n      allow create: if getUserRole() in ['admin', 'doctor'];\n      allow update: if getUserRole() in ['admin', 'lab_technician'];\n      allow read: if getUserRole() in ['admin', 'doctor', 'lab_technician'] || request.auth.uid == resource.data.patientId;\n    }\n\n    match /lab_results/{resultId} {\n      allow create: if getUserRole() in ['admin', 'doctor', 'lab_technician']; // Can be created by lab tech or system\n      allow update: if getUserRole() in ['admin', 'lab_technician'];\n      allow read: if getUserRole() in ['admin', 'doctor', 'lab_technician'] || request.auth.uid == resource.data.patientId;\n    }\n    \n    // Rules for Controlled Substances\n    match /controlled_substances/{substanceId} {\n        allow read: if getUserRole() in ['admin', 'pharmacist', 'auditor'];\n        // Direct writes are disallowed. All updates must go through the logControlledSubstanceTransaction Cloud Function.\n        allow write: if false; \n    }\n\n    match /controlled_substance_log/{logId} {\n        allow read: if getUserRole() in ['admin', 'pharmacist', 'auditor'];\n        // Logs are immutable. Only the Cloud Function can create them.\n        allow write: if false; \n        allow create: if false; \n    }\n\n  }\n}\n"}]}}
