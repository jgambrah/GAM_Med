[debug] [2025-08-09T16:17:56.457Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the user's role from the 'users' collection.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Allow read access to users collection for authenticated users\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      // Write access might be more restricted, e.g., only by the user themselves or admins.\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      // Allow read access to clinical staff and the patient themselves\n      allow read: if request.auth != null && (getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || request.auth.uid == resource.data.uid);\n      \n      // Allow creation by admins and nurses\n      allow create: if request.auth != null && getUserRole() in ['admin', 'nurse'];\n\n      // Allow updates by clinical staff\n      allow update: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse'];\n      \n      // Deletion should be highly restricted, perhaps only by admins and requiring a 'soft-delete' flag.\n      allow delete: if request.auth != null && getUserRole() == 'admin';\n\n      // Rules for the 'admissions' sub-collection\n      match /admissions/{admissionId} {\n        // Read access for clinical staff and the specific patient.\n        allow read: if request.auth != null && \n                    (getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || \n                    get(/databases/$(database)/documents/patients/$(patientId)).data.uid == request.auth.uid);\n\n        // Allow creation during the admission process\n        allow create: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse'];\n\n        // Complex update rules based on discharge workflow state.\n        allow update: if request.auth != null && (\n            // Rule for Doctors: Can update the summary if it's not yet finalized.\n            ( getUserRole() == 'doctor' && resource.data.isSummaryFinalized == false ) ||\n            // Rule for Billing Clerks: Can only update specific financial fields.\n            ( getUserRole() == 'billing_clerk' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['finalBillId', 'status'])) ||\n            // Rule for Admins: Broader update permissions.\n            ( getUserRole() == 'admin' )\n        );\n      }\n    }\n    \n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n        // All clinical and admin staff can see bed status.\n        allow read: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'];\n        \n        // Only admins or nurses can update bed status (e.g., for cleaning, maintenance).\n        allow write: if request.auth != null && getUserRole() in ['admin', 'nurse'];\n    }\n\n    // Rules for the 'referrals' collection\n    match /referrals/{referralId} {\n      allow read: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow create, update: if request.auth != null && getUserRole() in ['admin', 'nurse'];\n      allow delete: if request.auth != null && getUserRole() == 'admin';\n    }\n\n    // Rules for the 'appointments' collection\n    match /appointments/{appointmentId} {\n      // Patients can read their own appointments, staff can read all.\n      allow read: if request.auth != null && \n                  (getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || \n                  resource.data.patient_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id);\n                  \n      // Staff can create appointments. Patients might be able to request them.\n      allow create: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse'];\n      \n      // Allow updates by staff or the patient who owns the appointment (e.g., to cancel).\n      allow update: if request.auth != null && \n                  (getUserRole() in ['admin', 'doctor', 'nurse'] || \n                  resource.data.patient_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id);\n    }\n  }\n}\n"}]}}
