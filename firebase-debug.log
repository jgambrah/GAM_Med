[debug] [2025-08-08T14:55:25.771Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // =====================================================================\n    // Helper Functions\n    // =====================================================================\n\n    // Check if the user is authenticated.\n    function isAuth() {\n      return request.auth != null;\n    }\n\n    // Get the data for a specific user document.\n    function getUserData(uid) {\n      return get(/databases/$(database)/documents/users/$(uid)).data;\n    }\n\n    // Get the role of a specific user.\n    function getUserRole(uid) {\n      return getUserData(uid).role;\n    }\n    \n    // Check if a user's role is one of the allowed roles.\n    function isOneOfRoles(uid, roles) {\n      return isAuth() && getUserRole(uid) in roles;\n    }\n\n    // =====================================================================\n    // Collection: users\n    // =====================================================================\n    match /users/{userId} {\n      // Allow users to read their own profile.\n      // Allow admins to read/write any user profile.\n      allow read: if isAuth() && (request.auth.uid == userId || getUserRole(request.auth.uid) == 'admin');\n      allow write: if isAuth() && getUserRole(request.auth.uid) == 'admin';\n    }\n\n    // =====================================================================\n    // Collection: patients\n    // =====================================================================\n    match /patients/{patientId} {\n      // READ: Allowed for clinical staff, admins, and the patient themselves.\n      // A user is the patient if their user document has a matching patient_id field.\n      allow read: if isOneOfRoles(request.auth.uid, ['admin', 'doctor', 'nurse', 'pharmacist']) ||\n                     (getUserData(request.auth.uid).patient_id == patientId);\n\n      // CREATE: Allowed for staff who handle patient registration.\n      allow create: if isOneOfRoles(request.auth.uid, ['admin', 'nurse']);\n\n      // UPDATE: Allowed for administrative staff.\n      // Field-level restrictions should be handled by Cloud Functions for complex validation.\n      allow update: if isOneOfRoles(request.auth.uid, ['admin', 'nurse']);\n      \n      // DELETE: Only admins can delete patient records (a destructive action).\n      allow delete: if isOneOfRoles(request.auth.uid, ['admin']);\n      \n      // --- Sub-collection: admissions ---\n      match /admissions/{admissionId} {\n        // READ: Access mirrors the parent patient document.\n        allow read: if isOneOfRoles(request.auth.uid, ['admin', 'doctor', 'nurse', 'pharmacist']) ||\n                       (getUserData(request.auth.uid).patient_id == patientId);\n                       \n        // WRITE: Admission creation/updates are highly sensitive and should be handled\n        // exclusively by trusted backend Cloud Functions to ensure data integrity.\n        allow write: if false; // No direct client writes allowed.\n      }\n    }\n\n    // =====================================================================\n    // Collection: beds\n    // =====================================================================\n    match /beds/{bedId} {\n       // READ: Clinical and admin staff need to see bed status in real-time.\n      allow read: if isOneOfRoles(request.auth.uid, ['admin', 'doctor', 'nurse']);\n      \n      // WRITE: Bed status changes are critical and should only be performed\n      // by trusted backend Cloud Functions to prevent unauthorized modifications.\n      allow write: if false; // No direct client writes allowed.\n    }\n  }\n}\n"}]}}
