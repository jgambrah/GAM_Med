[debug] [2025-09-17T13:20:51.041Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions\n    function isAuth() {\n      return request.auth != null;\n    }\n\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Default deny\n    match /{document=**} {\n      allow read, write: if false;\n    }\n\n    // Rules for collections\n\n    match /patients/{patientId} {\n      allow read, write: if isAuth(); // Simple rule for now\n    }\n\n    match /beds/{bedId} {\n        allow read, write: if isAuth();\n    }\n\n    match /appointments/{appointmentId} {\n        allow read, write: if isAuth();\n    }\n    \n    match /referrals/{referralId} {\n        allow read, write: if isAuth();\n    }\n    \n    match /prescriptions/{prescriptionId} {\n        allow read, write: if isAuth();\n    }\n    \n    match /pharmacy_orders/{orderId} {\n        allow read, write: if isAuth();\n    }\n    \n    match /lab_orders/{orderId} {\n        allow read, write: if isAuth();\n    }\n    \n    match /lab_results/{resultId} {\n        allow read, write: if isAuth();\n    }\n\n    match /doctor_schedules/{scheduleId} {\n        allow read, write: if isAuth();\n    }\n\n    match /expenses/{expenseId} {\n      allow create, update: if getUserRole() in ['admin', 'financial_staff'];\n      allow read: if getUserRole() in ['admin', 'financial_staff', 'hospital_manager'];\n    }\n\n    match /financial_summaries/{summaryId} {\n      allow read: if getUserRole() in ['admin', 'financial_staff', 'CEO', 'hospital_manager'];\n      allow write: if false; // Should only be written by backend functions\n    }\n    \n    match /saved_reports/{reportId} {\n        allow create, update, delete: if isAuth() && request.resource.data.userId == request.auth.uid;\n        allow read: if isAuth() && (resource.data.userId == request.auth.uid || getUserRole() == 'admin');\n    }\n\n    match /kpi_metrics/{metricId} {\n        allow read: if isAuth() && getUserRole() in ['admin', 'hospital_manager', 'CEO'];\n        allow write: if false; // Written by backend functions\n    }\n\n    match /bi_reports/{reportId} {\n        allow read: if isAuth() && getUserRole() in ['admin', 'financial_staff', 'CEO'];\n        allow write: if false; // Written by backend functions\n    }\n\n    match /clinical_reports/{reportId} {\n        allow read: if isAuth() && getUserRole() in ['admin', 'doctor', 'nurse', 'hospital_manager'];\n        allow write: if false; // Written by backend functions\n    }\n  }\n}\n"}]}}
