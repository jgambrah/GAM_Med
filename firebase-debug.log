[debug] [2025-09-09T16:28:30.938Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function getUserRole() {\n      // Return the role of the user making the request.\n      // This assumes a 'role' field exists on the user's document in the /users/ collection.\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    function isHRAdmin() {\n        return getUserRole() in ['admin', 'hr']; // Define HR role for reuse\n    }\n\n    match /users/{userId} {\n      // READ: Users can read their own profile. HR and Admins can read any profile.\n      allow read: if request.auth.uid == userId || isHRAdmin();\n      \n      // UPDATE: Users can update their own profile (potentially limited fields). HR and Admins can update any profile.\n      // A more granular rule could be: `allow update: if (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contactInfo'])) || isHRAdmin();`\n      allow update: if request.auth.uid == userId || isHRAdmin();\n      \n      // CREATE: Only HR and Admins can create new user/employee records.\n      allow create: if isHRAdmin();\n      \n      // DELETE: Only Admins can delete user records.\n      allow delete: if getUserRole() == 'admin';\n    }\n\n    match /patients/{patientId} {\n      allow read, write: if request.auth != null;\n\n      match /admissions/{admissionId} {\n        allow read, write: if request.auth != null;\n      }\n\n      match /clinical_notes/{noteId} {\n        allow read, write: if request.auth != null;\n      }\n      \n      match /vitals/{vitalId} {\n        allow read, write: if request.auth != null;\n      }\n      \n      match /care_plans/{planId} {\n        allow read, write: if request.auth != null;\n      }\n      \n       match /medication_history/{medId} {\n        allow read, write: if request.auth != null;\n      }\n      \n      match /lab_results/{testId} {\n        allow read, write: if request.auth != null;\n      }\n      \n      match /immunizations/{recordId} {\n         allow read, write: if request.auth != null;\n      }\n    }\n    \n    match /ot_sessions/{caseId} {\n      allow read, write: if getUserRole() in ['admin', 'surgeon', 'nurse'] OR request.auth.uid == resource.data.patientId;\n      \n      match /vitals_log/{logId} {\n         allow create: if getUserRole() in ['admin', 'nurse'];\n         allow read: if getUserRole() in ['admin', 'surgeon', 'nurse'] OR request.auth.uid == parent(collection).data.patientId;\n      }\n    }\n\n    match /beds/{bedId} {\n        allow read, write: if request.auth != null;\n    }\n    \n     match /appointments/{appointmentId} {\n        allow read, write: if request.auth != null;\n    }\n    \n    match /referrals/{referralId} {\n        allow read, write: if request.auth != null;\n    }\n    \n    match /pharmacy_orders/{orderId} {\n       allow read, write: if request.auth != null;\n    }\n    \n    match /prescriptions/{prescriptionId} {\n       allow read, write: if request.auth != null;\n    }\n    \n    match /results/{docId} {\n        allow read: if (resource.data.studentId == request.auth.uid && resource.data.isPublished == true) || getUserRole() in ['admin', 'registrar'];\n        allow write: if false;\n    }\n    \n    match /student_academic_records/{docId} {\n        allow read: if (resource.data.studentId == request.auth.uid && resource.data.finalResultPublished == true) || getUserRole() in ['admin', 'registrar'];\n        allow write: if false;\n    }\n    \n    match /employees/{employeeId} {\n      allow read: if request.auth.uid == employeeId || getUserRole() in ['admin', 'hr_manager'];\n      allow create: if getUserRole() == 'hr_manager';\n    }\n\n    match /employees/{employeeId}/employee_documents/{documentId} {\n      allow create: if request.auth.uid == employeeId || getUserRole() in ['admin', 'hr_manager'];\n      allow read: if request.auth.uid == employeeId || getUserRole() in ['admin', 'hr_manager'];\n    }\n\n    match /attendance_logs/{logId} {\n      allow create: if getUserRole() in ['admin', 'hr_manager']; // Simplified for this context\n      allow read: if getUserRole() in ['admin', 'hr_manager'];\n    }\n  }\n}\n"}]}}
