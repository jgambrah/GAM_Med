[debug] [2025-09-19T13:08:50.638Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    //\n    // Helper Functions\n    //\n    function isAuth() {\n      return request.auth != null;\n    }\n\n    function isPatientOwner(patientId) {\n      // Check if the authenticated user's UID matches the patient's UID in the users collection\n      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n      return user.patient_id == patientId;\n    }\n\n    function getUserRole() {\n        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    function isDoctor() {\n      return getUserRole() == 'doctor';\n    }\n\n    function isNurse() {\n        return getUserRole() == 'nurse';\n    }\n\n    function isAdmin() {\n        return getUserRole() == 'admin';\n    }\n\n    //\n    // Collection Rules\n    //\n\n    // Users can read other user profiles (for names, etc.) but only update their own.\n    // Critically, users cannot change their own role.\n    match /users/{userId} {\n      allow read: if isAuth();\n      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;\n      allow create, delete: if isAdmin();\n    }\n    \n    // Roles and Audit Logs are admin-only and immutable from the client.\n    match /roles/{roleId} {\n        allow read, write, create, delete: if isAdmin();\n    }\n    \n    match /audit_logs/{logId} {\n        // No client access. All writes should be from trusted backend functions.\n        allow read, write: if false;\n    }\n    \n    // Health content is readable by any authenticated user, but only writable by admins.\n    match /health_content/{contentId} {\n        allow read: if isAuth();\n        allow write: if isAdmin();\n    }\n    \n    // Reminders are private to the patient they belong to. Only backend can create them.\n    match /reminders/{reminderId} {\n        allow read: if isPatientOwner(resource.data.patientId);\n        allow write: if false; // Should be managed by Cloud Functions\n    }\n\n    // Core patient data and sub-collections\n    match /patients/{patientId} {\n      allow read, write: if isDoctor() || isNurse() || isAdmin();\n      allow create: if isAuth();\n\n      // Patients can only book their own appointments. Doctors and staff can also view.\n      match /appointments/{appointmentId} {\n        allow create: if isPatientOwner(request.resource.data.patientId);\n        allow read: if isPatientOwner(resource.data.patientId) || isDoctor() || isNurse() || isAdmin();\n        // Allow updates only from authorized users or the patient themselves for cancellation.\n        allow update: if isDoctor() || isAdmin() || isPatientOwner(resource.data.patientId);\n      }\n      \n      // Clinical data is restricted to clinical staff.\n      match /clinical_notes/{noteId} {\n        allow read, create: if isDoctor() || isNurse() || isAdmin();\n      }\n      \n      match /vitals/{vitalId} {\n        allow read, create: if isDoctor() || isNurse() || isAdmin();\n      }\n\n      // Other sub-collections can inherit from the parent or have specific rules.\n      // By default, access is denied unless explicitly allowed.\n    }\n  }\n}\n"}]}}
