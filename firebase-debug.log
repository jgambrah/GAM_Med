data.reviewerId) || getUserRole() in ['admin', 'hr'];\n    }\n\n    match /training_courses/{courseId} {\n        allow read: if isUserAuthenticated();\n        allow write: if getUserRole() in ['admin', 'hr'];\n    }\n  }\n}\n"}]}}
