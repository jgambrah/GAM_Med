[debug] [2025-09-17T14:56:10.379Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rule for the main 'users' collection\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || getUserRole() in ['admin'];\n      allow update: if request.auth.uid == userId; // Allow users to update their own profile\n    }\n\n    // Patients can only read their own data.\n    // Clinical and admin staff can read any patient data.\n    match /patients/{patientId} {\n      // Patients can read their own document by matching the patientId in their user profile\n      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId || getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId;\n    }\n    \n    // Messages can only be read/written by the patient or their doctor.\n    match /patients/{patientId}/messages/{messageId} {\n      allow read, create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId || getUserRole() in ['doctor', 'nurse'];\n    }\n\n    // Shared collections that require patient-specific access control\n    match /appointments/{appointmentId} {\n      allow read: if request.auth.token.patient_id == resource.data.patient_id || getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];\n    }\n\n    match /lab_results/{resultId} {\n        allow read: if request.auth.token.patient_id == resource.data.patientId || getUserRole() in ['admin', 'doctor', 'lab_technician'];\n    }\n\n    match /invoices/{invoiceId} {\n        allow read: if request.auth.token.patient_id == resource.data.patientId || getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    match /prescriptions/{prescriptionId} {\n       allow read: if request.auth.token.patient_id == resource.data.patientId || getUserRole() in ['admin', 'doctor', 'pharmacist'];\n    }\n\n    // Rules for aggregated data collections\n    match /kpi_metrics/{docId} {\n      allow read: if getUserRole() in ['admin'];\n    }\n\n    match /bi_reports/{docId} {\n      allow read: if getUserRole() in ['admin'];\n    }\n    \n    match /clinical_reports/{docId} {\n        allow read: if getUserRole() in ['admin', 'doctor'];\n    }\n  }\n}\n"}]}}
