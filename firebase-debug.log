[debug] [2025-08-01T16:55:31.020Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Helper function to check if the user is an admin or system service\n    function isAdmin() {\n      return getUserRole() == 'Admin';\n    }\n\n    // Helper function to check for clinical staff\n    function isClinicalStaff() {\n      let role = getUserRole();\n      return role == 'Doctor' || role == 'Nurse';\n    }\n    \n    // Helper function to check for administrative staff\n    function isAdministrativeStaff() {\n        let role = getUserRole();\n        return role == 'Admin' || role == 'BillingClerk';\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || isAdmin();\n      allow create: if request.auth.uid == userId;\n      allow update: if request.auth.uid == userId || isAdmin();\n      allow list: if isAdmin();\n    }\n    \n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n        allow read: if isClinicalStaff() || isAdministrativeStaff() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == resource.data.contact.email;\n        allow create: if isAdministrativeStaff();\n        // Only allow specific fields to be updated by certain roles\n        allow update: if isAdministrativeStaff() || (isClinicalStaff() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmitted', 'currentAdmissionId', 'updatedAt']));\n        \n        // Rules for the 'admissions' sub-collection\n        match /admissions/{admissionId} {\n            allow read: if isClinicalStaff() || isAdministrativeStaff() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == get(/databases/$(database)/documents/patients/$(patientId)).data.contact.email;\n            allow create: if isAdministrativeStaff();\n            // Updates are primarily handled by server-side logic (simulated by actions)\n            allow update: if isAdmin(); \n        }\n    }\n\n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n        allow read: if isClinicalStaff() || isAdmin();\n        // Bed status updates should be handled by trusted server-side logic\n        allow update: if isAdmin();\n    }\n  }\n}\n"}]}}
