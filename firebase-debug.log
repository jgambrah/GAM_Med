[debug] [2025-08-22T14:46:51.472Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Helper function to check if the user is an admin or billing clerk\n    function isFinancialStaff() {\n      return getUserRole() in ['admin', 'billing_clerk'];\n    }\n\n    // Default deny all\n    match /{document=**} {\n      allow read, write: if false;\n    }\n    \n    // Allow users to read their own user document\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId;\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n        // Anyone authenticated can create a patient (via server action)\n        allow create: if getUserRole() in ['admin', 'nurse', 'receptionist'];\n\n        // Admins, doctors, and nurses can read any patient record.\n        // Patients can read their own record.\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'] || request.auth.uid == resource.data.uid;\n        \n        // Allow updates only by authorized staff, with specific field protection.\n        allow update: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist']\n                      // Protect patientType field to be only updatable by financial staff\n                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['patientType']) || isFinancialStaff());\n                      \n        // Allow deletion only by admins (generally discouraged)\n        allow delete: if getUserRole() == 'admin';\n\n        // Allow granular access to subcollections\n        match /{subcollection}/{docId} {\n          allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'];\n        }\n    }\n    \n    // Rules for top-level collections\n    match /appointments/{appointmentId} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'receptionist', 'billing_clerk'];\n    }\n    \n    match /beds/{bedId} {\n       allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n\n    match /referrals/{referralId} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'triage_officer'];\n    }\n\n    match /pharmacy_orders/{orderId} {\n        allow read, write: if getUserRole() in ['admin', 'pharmacist', 'doctor'];\n    }\n\n    match /prescriptions/{prescriptionId} {\n        allow read, write: if getUserRole() in ['admin', 'pharmacist', 'doctor'];\n    }\n    \n    match /waiting_lists/{listId} {\n        allow read, write: if getUserRole() in ['admin', 'receptionist'];\n    }\n\n    match /ot_sessions/{sessionId} {\n      allow read, write: if getUserRole() in ['admin', 'ot_coordinator', 'doctor'];\n    }\n\n    // == BILLING SECURITY RULES ==\n\n    // Rules for the central 'invoices' collection\n    match /invoices/{invoiceId} {\n      // Only financial staff can create/update invoices.\n      // In a real app, you'd add a condition to allow creation by a trusted Cloud Function.\n      allow create, update: if isFinancialStaff();\n\n      // Financial staff can read any invoice. Patients can read their own.\n      allow read: if isFinancialStaff() || get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.uid == request.auth.uid;\n    }\n    \n    // Rules for the 'payments' collection\n    match /payments/{paymentId} {\n      allow read, write: if isFinancialStaff();\n    }\n\n    // Rules for 'insurance_claims'\n    match /insurance_claims/{claimId} {\n      allow read, write: if isFinancialStaff();\n    }\n    \n    // Rules for 'billing_codes'\n    match /billing_codes/{codeId} {\n      // Allow read for authenticated users, but only write for financial staff.\n      allow read: if request.auth != null;\n      allow write: if isFinancialStaff();\n    }\n    \n    // Rules for 'pricing_tables'\n    match /pricing_tables/{pricingId} {\n      // ONLY financial staff can read or write pricing information.\n      allow read, write: if isFinancialStaff();\n    }\n  }\n}\n"}]}}
