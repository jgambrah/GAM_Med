[debug] [2025-09-12T11:43:17.841Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get user role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Allow public read for specific public-facing collections if needed\n    // e.g., match /public_data/{docId} { allow read: if true; }\n\n    // Rules for User management\n    match /users/{userId} {\n      allow read: if request.auth != null; // Allow any authenticated user to read user profiles (e.g., for contact info)\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin'; // Allow users to edit their own profile or admins to edit any\n    }\n    \n    // Rules for Patient Records\n    match /patients/{patientId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'] || request.auth.uid == patientId; // Patient can read their own record\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      \n      // Sub-collections within a patient's record\n      match /{subcollection}/{docId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'] || request.auth.uid == patientId;\n        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n    }\n    \n    // Rules for Pharmacy Module\n    match /pharmacy_orders/{orderId} {\n        allow read, write: if getUserRole() in ['admin', 'pharmacist', 'doctor'];\n    }\n    \n    // Rules for Appointments\n    match /appointments/{appointmentId} {\n      allow read: if request.auth != null;\n      allow create, update, delete: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n    }\n\n    // Rules for Beds and Wards\n    match /beds/{bedId} {\n      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    match /wards/{wardId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin';\n    }\n    \n    // Rules for Referrals\n    match /referrals/{referralId} {\n      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    // Rules for Billing and Financials\n    match /invoices/{invoiceId} {\n       allow read: if getUserRole() in ['admin', 'billing_clerk'] || get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.userId == request.auth.uid;\n       allow create, update: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    match /payments/{paymentId} {\n      allow read: if getUserRole() in ['admin', 'billing_clerk'];\n      allow create: if request.auth != null; // Allow patients and staff to create payments\n    }\n    \n    match /insurance_claims/{claimId} {\n      allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    // Rules for Asset & Facilities Management\n    match /assets/{assetId} {\n      allow read: if getUserRole() in ['admin', 'finance', 'it_manager', 'asset_manager', 'technician'];\n      // Only Admins or Asset Managers can create, update, or delete asset records directly.\n      // Specific fields like service dates are updated via a trusted Cloud Function.\n      allow create, delete: if getUserRole() in ['admin', 'asset_manager'];\n      allow update: if getUserRole() in ['admin', 'asset_manager', 'it_manager']; \n    }\n    \n    match /maintenance_logs/{logId} {\n      allow read: if getUserRole() in ['admin', 'manager', 'technician'];\n      // Maintenance logs are an immutable audit trail.\n      // They can only be created by technicians or admins. They cannot be updated or deleted.\n      allow create: if getUserRole() in ['admin', 'technician'];\n      allow update, delete: if false;\n    }\n  }\n}\n"}]}}
