[debug] [2025-08-07T18:35:30.198Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the requesting user's data from the 'users' collection\n    function getUserData() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n    \n    // Helper function to get the user's role\n    function getUserRole() {\n      return getUserData().role;\n    }\n\n    // Global rule for authenticated users to manage their own user data\n    match /users/{userId} {\n      allow read, update: if request.auth.uid == userId;\n      // Allow creation of a user document if one doesn't already exist for the auth UID\n      allow create: if request.auth.uid != null && !exists(/databases/$(database)/documents/users/$(request.auth.uid));\n    }\n\n    // Role-based access for the 'patients' collection\n    match /patients/{patientId} {\n      // Admins, Doctors, and Nurses can read all patient data.\n      // A patient can read their own data via the patient portal.\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || getUserData().patient_id == patientId;\n      \n      // Admins can create new patient records\n      allow create: if getUserRole() == 'admin';\n      \n      // Admins, Doctors, and Nurses can update patient records\n      allow update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      \n      // No one can delete patient records directly (soft delete should be used)\n      allow delete: if false;\n    }\n\n    // Rules for other collections will go here...\n    // e.g., appointments, EHR, billing, etc.\n\n  }\n}\n"}]}}
