[debug] [2025-09-19T10:14:09.756Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check user roles\n    function isUserRole(role) {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;\n    }\n\n    // Patients can only be created by admins/nurses.\n    // Patients can read/update their own data.\n    match /patients/{patientId} {\n      allow read, update: if request.auth.uid == patientId || isUserRole('admin') || isUserRole('doctor') || isUserRole('nurse');\n      allow create: if isUserRole('admin') || isUserRole('nurse');\n\n      // Sub-collections for a patient\n      match /{subcollection}/{docId} {\n        allow read, write: if request.auth.uid == patientId || isUserRole('admin') || isUserRole('doctor') || isUserRole('nurse');\n      }\n    }\n\n    // Users can read/update their own profile.\n    // Availability map can only be changed by backend functions (admins cannot edit directly).\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow update: if request.auth.uid == userId && !(\"availability\" in request.resource.data);\n      allow write: if isUserRole('admin');\n    }\n\n    // Beds can be read by any authenticated user, but only updated by clinical staff/admin.\n    match /beds/{bedId} {\n        allow read: if request.auth != null;\n        allow write: if isUserRole('admin') || isUserRole('doctor') || isUserRole('nurse');\n    }\n\n    // Appointments can be created by the patient themselves.\n    // They can be read by the patient or the doctor involved.\n    match /appointments/{appointmentId} {\n      allow create: if request.auth.uid == request.resource.data.patientId;\n      allow read: if request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId;\n      allow update, delete: if isUserRole('admin') || isUserRole('doctor') || isUserRole('receptionist');\n    }\n\n    // Health Content can be read by any authenticated user, but only written by an admin.\n    match /health_content/{contentId} {\n      allow read: if request.auth != null;\n      allow write: if isUserRole('admin');\n    }\n\n    // Reminders are private and can only be read by the patient they are assigned to.\n    // Creation is handled by secure backend Cloud Functions, so client-side create is denied.\n    match /reminders/{reminderId} {\n      allow read: if request.auth.uid == resource.data.patientId;\n      allow create, update, delete: if false; // Handled by backend\n    }\n  }\n}\n"}]}}
