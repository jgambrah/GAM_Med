[debug] [2025-09-15T15:06:22.906Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n\n    match /patients/{patientId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'] || (request.auth.uid == patientId && getUserRole() == 'patient');\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n\n      // Sub-collections\n      match /{allPaths=**} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n    }\n\n    match /beds/{bedId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow write: if getUserRole() in ['admin', 'nurse'];\n    }\n\n    match /appointments/{appointmentId} {\n      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'];\n      // Patients should only be able to see their own appointments. A better rule would be:\n      // allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || request.auth.uid == resource.data.patient_id;\n    }\n\n    match /prescriptions/{prescriptionId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'pharmacist'];\n        // write access is handled by cloud functions\n    }\n    \n    match /referrals/{referralId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n        allow write: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n    }\n\n    match /waiting_lists/{listId} {\n        allow read, write: if getUserRole() in ['admin', 'receptionist'];\n    }\n\n    match /invoices/{invoiceId} {\n        allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n        allow read: if request.auth.uid == resource.data.patientId; // Allow patient to read own invoice\n    }\n    \n    match /claims/{claimId} {\n        allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n\n    match /ot_sessions/{sessionId} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'ot_coordinator'];\n    }\n\n    match /lab_orders/{orderId} {\n        allow read, write: if getUserRole() in ['admin', 'lab_technician', 'doctor'];\n    }\n\n    match /lab_results/{resultId} {\n        allow read: if getUserRole() in ['admin', 'lab_technician', 'doctor'] || request.auth.uid == resource.data.patientId;\n        allow write: if getUserRole() in ['admin', 'lab_technician'];\n    }\n\n    match /radiology_orders/{orderId} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'receptionist', 'radiologist'];\n    }\n    \n    match /radiology_reports/{reportId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'radiologist'] || request.auth.uid == resource.data.patientId;\n        allow write: if getUserRole() in ['admin', 'radiologist'];\n    }\n    \n    match /assets/{assetId} {\n        allow read: if getUserRole() in ['admin', 'facilities_manager'];\n        // Allow updates only to non-financial fields by general staff, but financial details only by admin/functions.\n        allow update: if request.auth.uid != null && !(request.resource.data.financialDetails.diff(resource.data.financialDetails).affectedKeys().size() > 0);\n        allow update: if getUserRole() in ['admin']; // Admin can update anything.\n        allow create: if getUserRole() in ['admin'];\n    }\n\n    match /depreciation_records/{recordId} {\n        allow read: if getUserRole() in ['admin', 'financial_staff'];\n        // Disallow client-side creation/updates to ensure immutability.\n        allow write: if false; \n    }\n\n    match /bi_reports/{reportId} {\n      allow read: if getUserRole() in ['admin', 'hospital_manager', 'financial_staff'];\n      // BI reports are write-once by a trusted Cloud Function.\n      allow write: if false;\n    }\n\n    match /utility_consumption/{logId} {\n        allow read: if getUserRole() in ['admin', 'facilities_manager'];\n        allow create: if false; // Only allow creation via trusted Cloud Function\n    }\n\n    match /security_incidents/{incidentId} {\n        allow create: if getUserRole() in ['admin', 'security'];\n        allow read: if getUserRole() in ['admin', 'security'];\n    }\n\n    match /housekeeping_tasks/{taskId} {\n        allow create: if getUserRole() in ['admin', 'nurse'];\n        allow read: if getUserRole() in ['admin', 'nurse', 'housekeeping'];\n        // Allow housekeeping to update status\n        allow update: if getUserRole() in ['admin', 'housekeeping'] && request.resource.data.status != resource.data.status;\n    }\n  }\n}\n"}]}}
