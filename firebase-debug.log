[debug] [2025-08-29T14:29:19.185Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    function getUserRole() {\n      // Get the user's custom claims, which should contain their role.\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    match /users/{userId} {\n      // Users can read their own profile.\n      allow read: if request.auth.uid == userId;\n      // Admins can read/write any user profile.\n      allow read, write: if getUserRole() == 'admin';\n    }\n\n    match /patients/{patientId} {\n      // Patients can read their own data.\n      // Clinical staff (doctor, nurse) and admin staff can read any patient data.\n      allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'pharmacist'];\n\n      // Only admins can create or delete patient records through dedicated Cloud Functions.\n      allow create, delete: if getUserRole() == 'admin';\n      \n      // Only admins and certain clinical staff can update patient records.\n      allow update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n\n      // Rules for all EHR sub-collections under a patient\n      match /{subcollection}/{docId} {\n        allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'lab_technician'];\n        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n    }\n    \n    match /inventory/{itemId} {\n      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];\n      \n      // Only admins and pharmacists can update inventory, typically through a trusted Cloud Function.\n      // This prevents direct, unaudited changes to stock levels.\n      allow update: if getUserRole() in ['admin', 'pharmacist'];\n      \n      match /transactions/{transactionId} {\n        // Only admins and pharmacists can log new transactions, typically through a trusted Cloud Function.\n        allow create: if getUserRole() in ['admin', 'pharmacist'];\n        // Transactions are immutable, so no updates or deletes are allowed.\n        allow update, delete: if false;\n        // Reading transaction history has the same permissions as reading the item itself.\n        allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];\n      }\n    }\n\n    // Add other collection rules here...\n  }\n}\n"}]}}
