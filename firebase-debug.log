[debug] [2025-08-28T12:06:31.764Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId;\n      allow write: if request.auth.uid == userId;\n    }\n    \n    match /patients/{patientId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist'] || request.auth.uid == resource.data.userId;\n      allow create: if getUserRole() in ['admin', 'receptionist'];\n      allow update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    match /patients/{patientId}/{subcollection}/{docId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist'] || request.auth.uid == get(/databases/$(database)/documents/patients/$(patientId)).data.userId;\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n\n    match /appointments/{appointmentId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk'] || request.auth.uid == resource.data.patient_id;\n        allow create: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n        allow update: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n    }\n    \n    match /referrals/{referralId} {\n      allow read, update: if getUserRole() in ['admin', 'doctor'];\n      allow create: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n    }\n    \n    match /beds/{bedId} {\n      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    match /prescriptions/{prescriptionId} {\n      allow create: if getUserRole() in ['admin', 'doctor'];\n      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor'] \n                  || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == resource.data.patientId;\n      allow update: if getUserRole() in ['admin', 'pharmacist']\n                    && request.resource.data.status in ['Dispensed', 'Canceled'];\n    }\n    \n    match /inventory/{itemId} {\n      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];\n      allow create, delete: if getUserRole() == 'admin';\n      allow update: if getUserRole() in ['admin', 'pharmacist'];\n    }\n\n    match /pharmacy_orders/{orderId} {\n      allow read, create, update: if getUserRole() in ['admin', 'pharmacist'];\n    }\n  }\n}\n"}]}}
