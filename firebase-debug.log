[debug] [2025-09-12T12:39:21.409Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to get user's role\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // PATIENTS: Allow read/write access based on user roles or if the user is the patient themselves.\n    match /patients/{patientId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || request.auth.uid == patientId;\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n\n      // Sub-collections\n      match /{allSubcollections}/{docId} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n    }\n\n    // BEDS: More restrictive. Only clinical and admin staff can view. Only specific roles can update.\n    match /beds/{bedId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow write: if getUserRole() in ['admin', 'nurse'];\n    }\n\n    // USERS: Users can read their own profile, admins can read/write all.\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || getUserRole() == 'admin';\n      allow write: if getUserRole() == 'admin';\n    }\n    \n    // RADIOLOGY: Rules for radiology orders and reports\n    match /radiology_orders/{orderId} {\n        allow create: if getUserRole() == 'doctor';\n        allow read: if getUserRole() in ['doctor', 'admin', 'radiologist', 'receptionist'];\n        allow update: if getUserRole() in ['admin', 'radiologist', 'receptionist'];\n    }\n    \n    match /radiology_reports/{reportId} {\n        allow create: if getUserRole() == 'radiologist';\n        allow read: if getUserRole() in ['doctor', 'admin', 'radiologist'];\n        allow update: if getUserRole() == 'radiologist'; // Only the radiologist can finalize\n    }\n    \n    // ASSETS & MAINTENANCE: Rules for assets and work orders\n    match /assets/{assetId} {\n      allow read: if getUserRole() in ['admin', 'maintenance_manager', 'technician'];\n      // Allow update only by a trusted function or authorized roles.\n      // This rule is a placeholder for a more complex Cloud Function-based security model.\n      allow update: if getUserRole() in ['admin', 'maintenance_manager'];\n    }\n\n    match /work_orders/{workOrderId} {\n      allow create: if request.auth != null;\n      allow read: if getUserRole() in ['admin', 'maintenance_manager', 'technician'] \n                  || request.auth.uid == resource.data.assignedToUserId \n                  || request.auth.uid == resource.data.reportedByUserId;\n      allow update: if getUserRole() in ['admin', 'maintenance_manager']\n                    || (getUserRole() == 'technician' \n                        && request.auth.uid == resource.data.assignedToUserId \n                        && (request.resource.data.status == 'Resolved' || request.resource.data.status == 'In Progress'));\n    }\n\n    // Fallback rule: Deny all other reads/writes by default\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
