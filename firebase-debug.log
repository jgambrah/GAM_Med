[debug] [2025-08-01T16:53:40.853Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Get user role from the 'users' collection for the currently authenticated user.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Check if the user has one of the allowed roles.\n    function isOneOfRoles(allowedRoles) {\n      return getUserRole() in allowedRoles;\n    }\n\n    // users collection:\n    // - Users can read their own data.\n    // - Admins can read anyone's data.\n    // - Users can create their own user document on sign-up.\n    // - Users can update their own profile data.\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || isOneOfRoles(['Admin']);\n      allow create: if request.auth.uid == userId;\n      allow update: if request.auth.uid == userId;\n    }\n\n    // patients collection:\n    // - Patients can read their own data.\n    // - Doctors, Nurses, and Admins can read all patient data.\n    // - Admins can create and update patient records.\n    match /patients/{patientId} {\n      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientId == patientId \n                   || isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      allow create, update: if isOneOfRoles(['Admin']);\n      allow delete: if false; // Disallow deletion of patient records.\n\n      // admissions sub-collection:\n      // - Rules are inherited from patients, but we can add more specific ones.\n      // - Doctors, Nurses, and Admins can manage admissions.\n      match /admissions/{admissionId} {\n        allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientId == patientId \n                     || isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        allow create, update: if isOneOfRoles(['Admin', 'Doctor']);\n        allow delete: if false;\n      }\n    }\n\n    // beds collection:\n    // - Only Doctors, Nurses, and Admins can view bed status.\n    // - Only Admins can modify bed documents (e.g., add new beds, put into maintenance).\n    // - Admission/discharge logic handles occupied/vacant status via secure server-side functions.\n    match /beds/{bedId} {\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      allow write: if isOneOfRoles(['Admin']);\n    }\n  }\n}\n"}]}}
