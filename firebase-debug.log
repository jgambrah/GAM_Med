[debug] [2025-08-09T17:24:54.846Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the role of the currently authenticated user\n    function getUserRole() {\n      // Access the user's document in the 'users' collection using their UID\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Helper function to check if the user is a patient and their ID matches\n    function isPatientOwner(patientId) {\n      // Get the user document to access their linked patient_id\n      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n      return getUserRole() == 'patient' && userDoc.patient_id == patientId;\n    }\n\n    // Rules for the top-level 'patients' collection\n    match /patients/{patientId} {\n      // Allow read access to admins, clinical staff, and the patient themselves\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || isPatientOwner(patientId);\n      \n      // Allow writes only from authorized backend processes (e.g., Cloud Functions)\n      // For this prototype, we are allowing more open write access for admins/nurses for simplicity.\n      allow write: if getUserRole() in ['admin', 'nurse']; \n    }\n    \n    // Rules for the 'admissions' sub-collection\n    match /patients/{patientId}/admissions/{admissionId} {\n      // Allow read access to admins, clinical staff, and the patient who owns the record\n      allow read: if getUserRole() in ['admin', 'billing_clerk', 'doctor', 'nurse'] || isPatientOwner(patientId);\n\n      // Allow updates under specific conditions to enforce the discharge workflow\n      allow update: if \n        // Condition 1: Doctor finalizing their summary before administrative sign-off\n        (resource.data.isSummaryFinalized == false && getUserRole() == 'doctor' && request.auth.uid == resource.data.dischargeByDoctorId) ||\n        // Condition 2: Admin finalizing the summary\n        (resource.data.isSummaryFinalized == false && getUserRole() == 'admin') ||\n        // Condition 3: Billing clerk can ONLY update the finalBillId\n        (getUserRole() == 'billing_clerk' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['finalBillId']));\n        \n      // Allow creation of new admission records by authorized staff\n      allow create: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    // Rules for the 'referrals' collection\n    match /referrals/{referralId} {\n        // Allow creation by administrative or triage staff\n        allow create: if getUserRole() in ['admin', 'nurse', 'billing_clerk']; // Assuming 'nurse' or 'billing_clerk' can act as triage\n\n        // Allow reading by admin/triage staff, or the specific doctor it's assigned to\n        allow read: if getUserRole() in ['admin', 'nurse', 'billing_clerk', 'doctor'] && \n                     (getUserRole() != 'doctor' || request.auth.uid == resource.data.assignedToDoctorId);\n\n        // Allow updates by admin/triage staff, or by the assigned doctor under limited conditions\n        allow update: if getUserRole() in ['admin', 'nurse', 'billing_clerk'] ||\n                       (request.auth.uid == resource.data.assignedToDoctorId && \n                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));\n    }\n\n    // Rules for all other collections (e.g., users, beds, etc.)\n    // For this prototype, we'll keep them relatively open but in production,\n    // these would have very specific rules.\n    match /{document=**} {\n      allow read, write: if request.auth != null;\n    }\n  }\n}\n"}]}}
