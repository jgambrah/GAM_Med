[debug] [2025-09-16T15:52:15.695Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\n// Helper function to get user's role from a custom claim\n// In a real project, you would set a custom claim 'role' for each user.\nfunction getUserRole() {\n  return request.auth.token.role;\n}\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    // A user can only read and write their own preferences\n    match /user_preferences/{userId} {\n      allow read, write: if request.auth.uid == userId;\n    }\n\n    // BI reports are read-only for management roles\n    match /bi_reports/{reportId} {\n      allow read: if getUserRole() in ['admin', 'hospital_manager', 'department_head'];\n    }\n\n    // KPI metrics are read-only for management roles\n    match /kpi_metrics/{metricId} {\n      allow read: if getUserRole() in ['admin', 'hospital_manager', 'department_head'];\n    }\n\n    // Infection data can be created by clinical staff and read by a limited set of roles\n    match /infections/{infectionId} {\n      allow create: if getUserRole() in ['admin', 'infection_control_officer', 'doctor'];\n      allow read: if getUserRole() in ['admin', 'doctor', 'infection_control_officer'];\n    }\n\n    // Clinical reports are read-only for management and quality control roles\n    match /clinical_reports/{reportId} {\n      allow read: if getUserRole() in ['admin', 'hospital_manager', 'quality_control'];\n    }\n  }\n}\n"}]}}
