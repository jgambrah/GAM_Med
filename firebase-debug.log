[debug] [2025-09-01T14:52:26.931Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the role of the currently authenticated user.\n    function getUserRole() {\n      // Assumes there's a 'users' collection where document IDs are user UIDs.\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Users can read their own data. Admins can read any user's data.\n      allow read: if request.auth.uid == userId || getUserRole() == 'admin';\n      // Only admins can write to the users collection (e.g., to change roles).\n      allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for the main 'patients' collection\n    match /patients/{patientId} {\n      // Admins and receptionists can create new patient records.\n      allow create: if getUserRole() in ['admin', 'receptionist'];\n      // Admins, doctors, pharmacists, and the patient themselves can read.\n      allow read: if getUserRole() in ['admin', 'doctor', 'pharmacist'] || request.auth.uid == resource.data.uid;\n      // Admins, doctors, and receptionists can update patient demographic data.\n      allow update: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n      // Only admins should be able to delete patient records.\n      allow delete: if getUserRole() == 'admin';\n\n      // Rules for all sub-collections under a patient document\n      match /{allSubcollections}/{docId} {\n        // Clinical staff can read and write to all patient sub-collections (EHR).\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'lab_technician'];\n      }\n    }\n    \n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n        // All authenticated users can see bed status.\n        allow read: if request.auth != null;\n        // Only clinical and admin staff can update bed status (e.g., admit, transfer, clean).\n        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    // Rules for the 'appointments' collection\n    match /appointments/{appointmentId} {\n        allow read: if request.auth != null;\n        // Only clinical/admin staff can create/update appointments.\n        allow write: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];\n    }\n\n    // Rules for the 'referrals' collection\n    match /referrals/{referralId} {\n      // Allow creation by admin/receptionist.\n      allow create: if getUserRole() in ['admin', 'receptionist'];\n      // Allow read by admin/receptionist and the assigned doctor.\n      allow read: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.assignedDoctorId;\n      // Allow update by admin/receptionist and the assigned doctor.\n      allow update: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.assignedDoctorId;\n    }\n\n    // Rules for the 'waiting_lists' collection\n    match /waiting_lists/{waitinglistId} {\n        allow read: if request.auth != null;\n        // Allow write access to admin and reception staff for managing the list.\n        allow write: if getUserRole() in ['admin', 'receptionist'];\n    }\n    \n    // Rules for the 'prescriptions' collection (pharmacy work queue)\n    match /prescriptions/{prescriptionId} {\n        // Pharmacists, doctors, and admins can view the work queue.\n        allow read: if getUserRole() in ['pharmacist', 'doctor', 'admin'];\n        // Doctors create, pharmacists update (dispense).\n        allow write: if getUserRole() in ['doctor', 'pharmacist', 'admin'];\n    }\n\n    // Rules for billing and financial collections\n    match /invoices/{invoiceId} {\n      // Allow read for billing staff, admin, and the patient.\n      allow read: if getUserRole() in ['admin', 'billing_clerk'] || get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.uid == request.auth.uid;\n      // Allow write for billing staff and admin.\n      allow write: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    match /insurance_claims/{claimId} {\n      allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    match /payments/{paymentId} {\n      allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    // Rules for drug interaction knowledge base\n    match /drug_interactions/{interactionId} {\n        // Any authenticated staff can read interaction rules.\n        allow read: if request.auth != null;\n        // Only admins can add or modify interaction rules.\n        allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for supplier and procurement collections\n    match /suppliers/{supplierId} {\n      // Procurement and admin staff can read supplier info.\n      allow read: if getUserRole() in ['admin', 'pharmacist'];\n      // Only admins can add or modify suppliers.\n      allow write: if getUserRole() == 'admin';\n    }\n\n    match /purchase_orders/{poId} {\n      allow read, create, update: if getUserRole() in ['admin', 'pharmacist'];\n    }\n\n    match /goods_receipts/{receiptId} {\n      allow read, create, update: if getUserRole() in ['admin', 'pharmacist'];\n    }\n  }\n}\n"}]}}
