[debug] [2025-08-06T19:14:41.128Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // =================================\n    // Helper Functions\n    // =================================\n    function isLoggedIn() {\n      return request.auth != null;\n    }\n    \n    function getUserData(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data;\n    }\n\n    function getUserRole() {\n      return getUserData(request.auth.uid).role;\n    }\n    \n    // Check if the requesting user is the owner of their patient document\n    // NOTE: This assumes a mapping exists or could be created.\n    // For this ruleset, we primarily rely on roles.\n    function isPatientOwner(patientId) {\n        // This is a conceptual link. A real app might need a users/{uid}/patientId field.\n        // For now, we'll check against the user's role being 'Patient' and check the appointment record.\n        return getUserRole() == 'Patient';\n    }\n\n    // =================================\n    // User Profiles\n    // =================================\n    match /users/{userId} {\n      // Allow users to read their own profile, and admins to read any.\n      allow read: if isLoggedIn() && (request.auth.uid == userId || getUserRole() == 'Admin');\n      // Allow users to create their own profile during signup.\n      allow create: if isLoggedIn();\n      // Allow users to update their own profile.\n      allow update: if isLoggedIn() && request.auth.uid == userId;\n    }\n    \n    // =================================\n    // Appointments Collection Rules\n    // =================================\n    match /appointments/{appointmentId} {\n      allow read: if isLoggedIn() && (\n        getUserRole() == 'Admin' || \n        resource.data.attendingDoctorId == request.auth.uid || \n        isPatientOwner(resource.data.patientId) // Patients can see their appointments\n      );\n      allow create: if isLoggedIn() && getUserRole() in ['Admin', 'Doctor'];\n      allow update: if isLoggedIn() && (\n        getUserRole() == 'Admin' || \n        resource.data.attendingDoctorId == request.auth.uid // Doctor can update status\n      );\n      allow delete: if isLoggedIn() && getUserRole() == 'Admin';\n    }\n\n    // =================================\n    // Patient & EHR Rules\n    // =================================\n    match /patients/{patientId} {\n      allow read: if isLoggedIn() && getUserRole() in ['Admin', 'Doctor', 'Nurse'];\n      allow create, update, delete: if isLoggedIn() && getUserRole() == 'Admin';\n\n      // --- Generalized EHR Sub-collection Rules ---\n      match /{ehrCollection}/{ehrRecordId} {\n        // Allow read access to Admins, and clinical staff (Doctors, Nurses).\n        // A more granular rule could check if the doctor is part of the patient's care team.\n        allow read: if isLoggedIn() && getUserRole() in ['Admin', 'Doctor', 'Nurse'];\n        \n        // Allow creation of new EHR records by clinical staff.\n        allow create: if isLoggedIn() && getUserRole() in ['Doctor', 'Nurse'];\n\n        // Allow updates only by the original author of the record or an Admin.\n        // This ensures a clear audit trail.\n        // `request.resource.data` refers to the data in the incoming write request.\n        allow update: if isLoggedIn() && (\n          getUserRole() == 'Admin' ||\n          request.resource.data.recordedByUserId == request.auth.uid ||\n          request.resource.data.prescribedByDoctorId == request.auth.uid ||\n          request.resource.data.orderedByDoctorId == request.auth.uid\n        );\n        \n        // Deletes should be restricted, typically to Admins or via a soft-delete flag.\n        allow delete: if isLoggedIn() && getUserRole() == 'Admin';\n      }\n    }\n\n    // =================================\n    // Admissions Collection\n    // =================================\n    match /admissions/{admissionId} {\n      allow read, write: if isLoggedIn() && getUserRole() in ['Admin', 'Doctor'];\n    }\n\n    // =================================\n    // Beds Collection\n    // =================================\n    match /beds/{bedId} {\n      allow read: if isLoggedIn();\n      allow write: if isLoggedIn() && getUserRole() in ['Admin', 'Housekeeping'];\n    }\n  }\n}\n"}]}}
