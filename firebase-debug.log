[debug] [2025-08-09T11:23:21.767Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // =================================================================\n    // Helper Functions\n    // =================================================================\n    \n    // Placeholder function to get the role of the currently authenticated user.\n    // In a real implementation, this would look up the user's role from the 'users' collection.\n    // function getUserRole() {\n    //   return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    // }\n    \n    // =================================================================\n    // patients collection rules\n    // =================================================================\n    match /patients/{patientId} {\n      // Allow create only by admin or billing_clerk\n      // 1. User must have the correct role.\n      // 2. The document ID must match the patientId field in the data to ensure consistency.\n      allow create: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.role == 'nurse')\n                    && request.resource.id == request.resource.data.patient_id;\n\n      // Allow updates by authorized staff\n      // 1. User must have the correct role.\n      // 2. The patientId field cannot be changed after creation.\n      allow update: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.role == 'nurse')\n                    && request.resource.data.patient_id == resource.data.patient_id;\n                    \n      // Allow read access to authorized staff and the patient themselves.\n      allow read: if request.auth != null; // For prototype, allow any authenticated user.\n      \n      // =================================================================\n      // admissions sub-collection rules\n      // =================================================================\n      match /admissions/{admissionId} {\n        \n        // Allow read access to authorized staff and the patient themselves.\n        // A patient can read their own admission records.\n        // Clinical staff (doctor, nurse) and administrative staff (admin, billing_clerk) can also read.\n        allow read: if request.auth != null && \n                    (request.auth.token.patient_id == patientId ||\n                     request.auth.token.role in ['admin', 'doctor', 'nurse', 'billing_clerk']);\n        \n        // Allow creation by administrative staff who handle patient intake.\n        allow create: if request.auth != null && request.auth.token.role in ['admin', 'nurse'];\n\n        // Allow updates based on role.\n        // Admins and clinical staff can update visit records.\n        allow update: if request.auth != null && \n                      (request.auth.token.role in ['admin', 'doctor', 'nurse']);\n      }\n    }\n    \n    // =================================================================\n    // beds collection rules\n    // =================================================================\n    match /beds/{bedId} {\n      allow read: if request.auth != null;\n      // Bed updates are handled by backend functions, so direct client updates can be restricted.\n      allow write: if request.auth != null && request.auth.token.role == 'admin';\n    }\n    \n    // =================================================================\n    // users collection rules\n    // =================================================================\n    match /users/{userId} {\n      // Users can read their own profile. Admins can read any profile.\n      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');\n      // Only admins can create or modify user roles.\n      allow write: if request.auth != null && request.auth.token.role == 'admin';\n    }\n  }\n}\n"}]}}
