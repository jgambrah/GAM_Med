[debug] [2025-08-04T11:29:35.778Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions to get user data and check roles\n    function getUserData() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n\n    function isOneOfRoles(allowedRoles) {\n      return getUserData().role in allowedRoles;\n    }\n\n    // Rules for the users collection\n    match /users/{userId} {\n      // Users can read their own data.\n      allow read: if request.auth.uid == userId;\n      // Users can create their own user document upon signup.\n      allow create: if request.auth.uid == userId;\n      // Users can update their own data, but cannot change their role.\n      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;\n    }\n\n    // Rules for the patients collection\n    match /patients/{patientId} {\n      // Admins, Doctors, and Nurses can read all patient data.\n      // Patients can only read their own data (we'd need to match patientId to a field in their user doc).\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      \n      // Admins can create new patients.\n      allow create: if isOneOfRoles(['Admin']);\n      \n      // Admins, Doctors, and Nurses can update patient records.\n      allow update: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      \n      // Only Admins can delete patient records (soft-delete preferred).\n      allow delete: if isOneOfRoles(['Admin']);\n    }\n\n    // Rules for the admissions sub-collection\n    match /admissions/{admissionId} {\n        // Admins, Doctors, and Nurses can read all admission data.\n        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        // Admins, Doctors, and Nurses can create and update admissions.\n        allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n    }\n\n    // Rules for the beds collection\n    match /beds/{bedId} {\n      // Allow read access to all clinical and administrative staff.\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']);\n\n      // Only Admins can create new bed documents during initial system setup.\n      allow create: if isOneOfRoles(['Admin']);\n\n      // Allow updates based on role and valid state transitions.\n      // Server-side actions with admin privileges will bypass these client-side rules.\n      allow update: if \n        // Admins have full update access.\n        isOneOfRoles(['Admin']) ||\n        \n        // A Nurse can perform valid state transitions.\n        (isOneOfRoles(['Nurse']) && (\n            // Nurse can mark a bed as clean (cleaning -> vacant)\n            (resource.data.status == 'cleaning' && request.resource.data.status == 'vacant') ||\n            // Nurse can transfer a patient (occupied -> cleaning for the old bed)\n            (resource.data.status == 'occupied' && request.resource.data.status == 'cleaning') ||\n            // Nurse can admit a patient (vacant -> occupied)\n            (resource.data.status == 'vacant' && request.resource.data.status == 'occupied')\n        ));\n        \n       // No one should be able to delete a bed document from the client.\n       allow delete: if false;\n    }\n  }\n}\n"}]}}
