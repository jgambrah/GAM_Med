[debug] [2025-09-16T13:16:42.803Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to get user's role\n    function getUserRole() {\n      // In a real app, roles would be stored in a 'users' collection or as custom claims.\n      // For this prototype, we'll return a hardcoded role for demonstration.\n      // This part would be replaced with:\n      // return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n      return 'admin'; // Assume admin for now to allow all operations during development\n    }\n\n    // Default deny all\n    match /{document=**} {\n      allow read, write: if false;\n    }\n    \n    // Secure bi_reports collection\n    match /bi_reports/{reportId} {\n      allow read: if getUserRole() in ['admin', 'hospital_manager', 'financial_staff'];\n    }\n    \n    // Allow users to read and write only their own preferences\n    match /user_preferences/{userId} {\n        allow read, write: if request.auth.uid == userId;\n    }\n    \n    // Rules for assets and depreciation_records\n    match /assets/{assetId} {\n      allow read: if getUserRole() in ['admin', 'financial_staff'];\n      // Allow Cloud Functions or admins to update financial details\n      allow write: if getUserRole() == 'admin'; // Simplified for prototype\n    }\n    \n    match /depreciation_records/{recordId} {\n      allow read: if getUserRole() in ['admin', 'financial_staff'];\n      // Only allow creation from a trusted source (e.g., a Cloud Function)\n      // Simplified for prototype:\n      allow create: if getUserRole() == 'admin';\n    }\n  }\n}\n"}]}}
