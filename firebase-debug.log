[debug] [2025-08-01T18:29:19.500Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to get user's role from the 'users' collection\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n    \n    // Helper function to check if a user has a specific role\n    function isRole(role) {\n      return request.auth != null && getUserRole(request.auth.uid) == role;\n    }\n\n    // Helper function to check if a user has one of several roles\n    function isOneOfRoles(roles) {\n      return request.auth != null && getUserRole(request.auth.uid) in roles;\n    }\n\n    // Rules for the 'users' collection (basic setup)\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId || isRole('Admin');\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']) || request.auth.uid == patientId;\n      \n      allow create: if isOneOfRoles(['Admin', 'BillingClerk'])\n                    && request.resource.id == request.resource.data.patientId;\n                    \n      allow update: if isOneOfRoles(['Admin', 'BillingClerk', 'Doctor', 'Nurse'])\n                    && request.resource.data.patientId == resource.data.patientId;\n\n      // Rules for the 'admissions' sub-collection\n      match /admissions/{admissionId} {\n        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']) || request.auth.uid == patientId;\n        allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      }\n    }\n\n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n      allow read: if request.auth != null; // Any authenticated user can see bed status\n      allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n    }\n  }\n}\n"}]}}
