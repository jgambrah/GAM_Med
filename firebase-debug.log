[debug] [2025-08-25T11:26:01.251Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the role of the currently authenticated user\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Helper function to get the patientId of the currently authenticated user\n    function getUserPatientId() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id;\n    }\n\n    // =================================\n    // == General Access Rules\n    // =================================\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId; // Users can update their own profile\n    }\n\n    match /patients/{patientId} {\n      // Allow read access to the patient themselves or authorized staff\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'receptionist'] || getUserPatientId() == patientId;\n      // Allow writes only by authorized staff\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];\n    }\n\n    match /patients/{patientId}/{subcollection}/{documentId} {\n        // Allow authorized staff to access most patient sub-collections\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n\n    match /beds/{bedId} {\n      // All authenticated users can see bed status\n      allow read: if request.auth != null;\n      // Only authorized staff can update bed status\n      allow write: if getUserRole() in ['admin', 'nurse'];\n    }\n\n    match /appointments/{appointmentId} {\n        allow read, write: if request.auth != null; // Simplified for prototype\n    }\n    \n    // =================================\n    // == Billing & Claims Rules\n    // =================================\n\n    // Rules for managing insurance providers\n    match /insurance_providers/{providerId} {\n      allow read: if request.auth != null; // Any staff can see providers\n      allow write: if getUserRole() == 'admin'; // Only admins can modify providers\n    }\n\n    // Rules for managing insurance claims\n    match /insurance_claims/{claimId} {\n      // Only admin and billing staff can create, read, or update claims\n      allow create, read, update: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    // Rules for managing payments\n    match /payments/{paymentId} {\n      // Only admins and receptionists can log a new payment\n      allow create: if getUserRole() in ['admin', 'receptionist'];\n      // Only admin, billing staff, or the patient themselves can view payments\n      allow read: if getUserRole() in ['admin', 'billing_clerk'] || getUserPatientId() == resource.data.patientId;\n    }\n\n    // Rules for payment gateway configurations (highly restricted)\n    match /payment_gateways/{gatewayId} {\n       // Only admin and billing staff can see gateway configs\n       allow read: if getUserRole() in ['admin', 'billing_clerk'];\n       // Only admins can modify gateway configs\n       allow write: if getUserRole() == 'admin';\n    }\n\n    // =================================\n    // == Invoice & Receipt Rules\n    // =================================\n\n    match /invoices/{invoiceId} {\n      // A patient can read their own invoice, or authorized staff can read any invoice.\n      allow read: if getUserRole() in ['admin', 'billing_clerk'] || getUserPatientId() == resource.data.patientId;\n      // Writing to invoices is handled by backend functions, triggered by authorized users.\n      allow write: if getUserRole() in ['admin', 'billing_clerk'];\n\n      // Sub-collection for receipts\n      match /receipts/{receiptId} {\n        // Only the backend function can create a receipt document.\n        // We represent this by not allowing client-side creation.\n        allow create: if false; \n        \n        // Access rules are inherited from the parent invoice.\n        allow read: if getUserRole() in ['admin', 'billing_clerk'] || getUserPatientId() == resource.data.patientId;\n      }\n    }\n  }\n}\n"}]}}
