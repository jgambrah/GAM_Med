[debug] [2025-08-04T11:25:16.413Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user's role from the 'users' collection\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n\n    // Helper function to check if the user is an authenticated staff member\n    function isStaff() {\n      return request.auth != null && getUserRole(request.auth.uid) in ['Admin', 'Doctor', 'Nurse', 'BillingClerk'];\n    }\n    \n    // Helper function to check for Admin role\n    function isAdmin() {\n      return request.auth != null && getUserRole(request.auth.uid) == 'Admin';\n    }\n\n    // Helper function to check for Nurse or Admin role\n    function isNurseOrAdmin() {\n      return request.auth != null && getUserRole(request.auth.uid) in ['Admin', 'Nurse'];\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId;\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      allow read: if isStaff() || (request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == resource.data.fullName);\n      allow create: if isStaff();\n      allow update: if isStaff();\n      allow delete: if isAdmin();\n    }\n    \n    // Rules for the 'admissions' collection\n    match /admissions/{admissionId} {\n       allow read: if isStaff() || (request.auth != null && get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.fullName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name);\n       allow create: if isNurseOrAdmin();\n       allow update: if isNurseOrAdmin();\n       allow delete: if isAdmin();\n    }\n\n    // --- Bed Management Security Rules ---\n    match /beds/{bedId} {\n      // Allow read access to all staff members\n      allow read: if isStaff();\n      \n      // Only Admins can create or delete bed documents\n      allow create, delete: if isAdmin();\n\n      // Allow updates only by authorized staff and under specific conditions\n      allow update: if isNurseOrAdmin() &&\n        (\n          // Case 1: Admin can do anything\n          isAdmin() ||\n          \n          // Case 2: Admitting a patient (vacant -> occupied)\n          (request.resource.data.status == 'occupied' && resource.data.status == 'vacant' && request.resource.data.currentPatientId != null) ||\n          \n          // Case 3: Discharging or transferring a patient (occupied -> cleaning)\n          (request.resource.data.status == 'cleaning' && resource.data.status == 'occupied' && request.resource.data.currentPatientId == null) ||\n          \n          // Case 4: Marking a bed as clean after service (cleaning -> vacant)\n          (request.resource.data.status == 'vacant' && resource.data.status == 'cleaning' && request.resource.data.currentPatientId == null)\n        );\n    }\n  }\n}\n"}]}}
