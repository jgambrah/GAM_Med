[debug] [2025-09-11T12:56:52.461Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // =====================================================================\n    // Helper Functions\n    // =====================================================================\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // =====================================================================\n    // User Management & HR Rules\n    // =====================================================================\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk', 'lab_technician', 'ot_coordinator', 'receptionist', 'radiologist', 'dietitian'];\n      // Allow users to update their own basic info.\n      // Admins can update any field.\n      allow update: if request.auth.uid == userId || getUserRole() == 'admin';\n      allow create: if getUserRole() == 'admin';\n    }\n    \n    match /employees/{employeeId} {\n      allow read: if getUserRole() in ['admin', 'HR', 'manager'] || request.auth.uid == employeeId;\n      // Allow updates by HR/Admins, or managers for their direct reports (conceptual).\n      // Employees can update their own goals or training records.\n      allow update: if getUserRole() in ['admin', 'HR'] || request.auth.uid == employeeId; \n    }\n    \n    match /performance_reviews/{reviewId} {\n      allow create: if getUserRole() in ['admin', 'HR', 'manager'];\n      allow read: if getUserRole() in ['admin', 'HR'] || request.auth.uid == resource.data.employeeId || request.auth.uid == resource.data.reviewerId;\n      allow update: if getUserRole() in ['admin', 'HR'] || request.auth.uid == resource.data.reviewerId;\n    }\n    \n    match /training_courses/{courseId} {\n        allow read: if request.auth != null;\n        allow write: if getUserRole() in ['admin', 'HR'];\n    }\n\n    // =====================================================================\n    // Patient & EHR Rules\n    // =====================================================================\n    match /patients/{patientId} {\n      // Patients can read their own data. Clinical/admin staff can read all patient data.\n      allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'];\n      allow create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      \n      // Sub-collection rules\n      match /admissions/{admissionId} {\n        allow read, create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      match /clinical_notes/{noteId} {\n        allow read, create: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      match /lab_results/{testId} {\n        allow read, create: if getUserRole() in ['admin', 'doctor', 'nurse', 'lab_technician'];\n      }\n       match /radiology_history/{reportId} {\n        allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'radiologist'];\n      }\n      match /medication_history/{prescriptionId} {\n         allow read, create: if getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist'];\n      }\n    }\n\n    // =====================================================================\n    // Pharmacy & Inventory Rules\n    // =====================================================================\n    match /prescriptions/{prescriptionId} {\n      allow read, create: if getUserRole() in ['admin', 'doctor', 'pharmacist'];\n      allow update: if getUserRole() in ['admin', 'pharmacist']; // Only pharmacy can update status to 'Dispensed'\n    }\n\n    match /inventory/{itemId} {\n      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];\n      // Only pharmacy staff and admins can update inventory levels.\n      allow create, update: if getUserRole() in ['admin', 'pharmacist'];\n    }\n    \n    match /purchase_orders/{poId} {\n      allow read, create, update: if getUserRole() in ['admin', 'pharmacist'];\n    }\n    \n    match /suppliers/{supplierId} {\n       allow read, create, update: if getUserRole() in ['admin', 'pharmacist'];\n    }\n    \n    match /controlled_substances/{substanceId} {\n        allow read, create, update: if getUserRole() in ['admin', 'pharmacist'];\n    }\n    \n    match /controlled_substance_log/{logId} {\n        allow read: if getUserRole() in ['admin', 'pharmacist'];\n        // All writes must go through the trusted Cloud Function, no direct client writes allowed.\n        allow write: if false;\n    }\n\n\n    // =====================================================================\n    // Payroll & Compensation Rules\n    // =====================================================================\n    // The main collection for each payroll run's summary.\n    match /payroll_runs/{runId} {\n      // Only admin/finance can read the summary of all payroll runs.\n      allow read: if getUserRole() in ['admin'];\n      \n      // Creating, updating (e.g., finalizing), and deleting runs is restricted to admins.\n      // This is primarily done via trusted Cloud Functions triggered by an admin action.\n      allow create, update, delete: if getUserRole() in ['admin'];\n\n      // Rules for the sub-collection of individual records within a run.\n      match /payroll_records/{recordId} {\n        // An employee can read their own payroll record. Admin/finance can read all records.\n        allow read: if getUserRole() in ['admin'] || request.auth.uid == resource.data.staffId;\n        \n        // No direct client writes are allowed to individual records. \n        // They are only created and managed by the trusted `processStaffPayroll` Cloud Function.\n        allow write: if false;\n      }\n    }\n\n    // =====================================================================\n    // Scheduling & Appointments\n    // =====================================================================\n    match /appointments/{appointmentId} {\n        allow read: if request.auth.uid == resource.data.patient_id || request.auth.uid == resource.data.doctor_id || getUserRole() in ['admin', 'receptionist'];\n        allow create, update: if request.auth.uid == resource.data.patient_id || getUserRole() in ['admin', 'receptionist', 'doctor'];\n    }\n    \n    match /referrals/{referralId} {\n        // Admin and the assigned doctor can read.\n        allow read: if getUserRole() == 'admin' || request.auth.uid == resource.data.assignedDoctorId;\n        // Only admins can create or update referral assignments.\n        allow create, update: if getUserRole() == 'admin';\n    }\n\n    // =====================================================================\n    // General Ledger & Financials\n    // =====================================================================\n    match /invoices/{invoiceId} {\n        allow read: if getUserRole() in ['admin', 'billing_clerk'] || request.auth.uid == resource.data.patientId;\n        allow create, update: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    match /payments/{paymentId} {\n       allow read: if getUserRole() in ['admin', 'billing_clerk'];\n       // Payments are created via a trusted Cloud Function that processes gateway transactions.\n       allow create: if request.auth != null; // Allow any authenticated user to attempt payment\n       allow update, delete: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    match /insurance_claims/{claimId} {\n        allow read: if getUserRole() in ['admin', 'billing_clerk'];\n        allow create, update, delete: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    match /ledger_accounts/{accountId} {\n        allow read, create, update: if getUserRole() in ['admin'];\n    }\n    match /ledger_entries/{entryId} {\n         allow read: if getUserRole() in ['admin'];\n         // All writes must go through a trusted Cloud Function to ensure double-entry integrity.\n         allow write: if false;\n    }\n    \n    // Conceptual Storage Rules (to be placed in storage.rules)\n    /*\n    service firebase.storage {\n      match /b/{bucket}/o {\n        // Credentials can only be read by the user they belong to, or by HR/Admin.\n        match /credentials/{userId}/{credentialId} {\n          allow read: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'hr'];\n          allow write: if request.auth.uid == userId; // Allow user to upload their own new documents\n        }\n\n        // Discharge summaries can only be read by the patient they belong to, or clinical/admin staff.\n        match /summaries/{patientId}/{admissionId}.pdf {\n             allow read: if request.auth.uid == patientId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'doctor', 'nurse'];\n             // Only trusted server-side processes (Cloud Functions) can write summaries.\n             allow write: if false;\n        }\n\n        // Payslips can only be read by the user they belong to, or by HR/Admin.\n         match /payslips/{userId}/{runId}.pdf {\n          allow read: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin'];\n          // Only trusted server-side processes (Cloud Functions) can write payslips.\n          allow write: if false;\n        }\n      }\n    }\n    */\n\n  }\n}\n"}]}}
