[debug] [2025-09-08T16:02:51.837Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\n// Helper function to get the user's role from the 'users' collection\nfunction getUserRole() {\n  return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n}\n\n// Helper function to check if the user is authenticated\nfunction isSignedIn() {\n  return request.auth != null;\n}\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Any authenticated user can read their own profile.\n      allow read: if isSignedIn() && request.auth.uid == userId;\n      // Admins can read/write any user profile.\n      allow read, write: if getUserRole() == 'admin';\n    }\n\n    // Rules for the main 'patients' collection\n    match /patients/{patientId} {\n      // Allow read access if user is staff or the patient themselves\n      allow read: if isSignedIn() && (getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist', 'billing_clerk'] || request.auth.uid == patientId);\n      // Allow create only by admin/reception/nurse\n      allow create: if getUserRole() in ['admin', 'receptionist', 'nurse'];\n      // Allow update by clinical staff or admin\n      allow update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    // Rules for the 'radiology_orders' collection\n    match /radiology_orders/{orderId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'receptionist', 'radiologist'] || request.auth.uid == resource.data.assignedRadiologistId;\n      allow create: if getUserRole() in ['admin', 'doctor'];\n      allow update: if getUserRole() in ['admin', 'receptionist', 'radiologist'];\n    }\n    \n    // Rules for the 'radiology_reports' collection\n    match /radiology_reports/{reportId} {\n      allow create: if getUserRole() in ['admin', 'radiologist'];\n      // Allow read by clinical staff or the patient to whom the report belongs.\n      // Assumes 'patientId' is denormalized onto the report document.\n      allow read: if getUserRole() in ['admin', 'doctor', 'radiologist'] || request.auth.uid == resource.data.patientId;\n      // Only allow updates if the report is not yet final.\n      allow update: if getUserRole() == 'radiologist' && resource.data.isFinal == false;\n    }\n\n    // Rules for the 'radiology_history' sub-collection within a patient's record.\n    match /patients/{patientId}/radiology_history/{historyId} {\n      // Disallow all direct client writes. Only backend functions can create/update this log.\n      allow write: if false; \n      // Allow read by the patient or authorized clinical staff.\n      allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor'];\n    }\n\n    // Default deny all other reads/writes\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
