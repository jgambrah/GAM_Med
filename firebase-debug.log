[debug] [2025-08-18T17:04:02.990Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    function isDoctor() {\n      return getUserRole() == 'doctor';\n    }\n    \n    function isPatient() {\n      return getUserRole() == 'patient';\n    }\n    \n    function isNurse() {\n      return getUserRole() == 'nurse';\n    }\n    \n    function isAdmin() {\n      return getUserRole() == 'admin';\n    }\n    \n    function isBillingClerk() {\n      return getUserRole() == 'billing_clerk';\n    }\n    \n    function isTriageOfficer() {\n        return getUserRole() == 'triage_officer';\n    }\n    \n    function isReceptionist() {\n        return getUserRole() == 'receptionist';\n    }\n\n    match /patients/{patientId} {\n      allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();\n      allow write: if isAdmin();\n      \n      match /admissions/{admissionId} {\n        allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();\n        allow write: if isDoctor() || isAdmin();\n      }\n      \n      match /clinical_notes/{noteId} {\n          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();\n          allow create: if isDoctor() || isNurse();\n          allow update, delete: if isAdmin();\n      }\n\n      match /diagnoses/{diagnosisId} {\n          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();\n          allow create: if isDoctor();\n          allow update, delete: if isAdmin();\n      }\n\n      match /lab_results/{testId} {\n          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();\n          allow create: if isDoctor(); // Only a doctor can order a test\n          allow update: if isDoctor() || isAdmin(); // Lab tech would update via a function\n      }\n      \n      match /medication_history/{prescriptionId} {\n          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();\n          allow create: if isDoctor();\n          allow update, delete: if isDoctor() || isAdmin();\n      }\n      \n      match /vitals/{vitalId} {\n          allow read: if request.auth.uid == patientId || isDoctor() || isNurse() || isAdmin();\n          allow create: if isNurse() || isDoctor();\n          allow update, delete: if isAdmin();\n      }\n\n      match /appointment_history/{appointmentId} {\n        allow read: if request.auth.uid == patientId || isReceptionist() || isAdmin();\n        allow write: if false; // Denormalized data, only written by backend functions\n      }\n    }\n\n    match /appointments/{appointmentId} {\n      allow create: if isReceptionist() || isAdmin() || request.auth.uid == request.resource.data.patientId;\n      allow read: if request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId || isReceptionist() || isAdmin();\n      // Patient can only update to cancel their own appointment.\n      allow update: if isReceptionist() || isAdmin() || (isDoctor() && request.auth.uid == resource.data.doctorId) || (request.auth.uid == resource.data.patientId && request.resource.data.status == 'cancelled');\n      allow delete: if isAdmin();\n    }\n    \n    match /doctor_schedules/{scheduleId} {\n        allow read: if request.auth != null;\n        allow create, update: if isAdmin() || (isDoctor() && request.auth.uid == resource.data.doctorId);\n        allow delete: if isAdmin();\n    }\n\n    match /resources/{resourceId} {\n        allow read: if request.auth != null;\n        allow write: if isAdmin();\n    }\n    \n    match /referrals/{referralId} {\n        allow read: if request.auth != null;\n        allow create: if isReceptionist() || isTriageOfficer() || isAdmin();\n        allow update: if isDoctor() || isReceptionist() || isTriageOfficer() || isAdmin();\n    }\n    \n    match /users/{userId} {\n        allow read: if request.auth.uid == userId || isAdmin();\n        allow write: if isAdmin();\n    }\n  }\n}\n"}]}}
