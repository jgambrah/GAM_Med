[debug] [2025-09-04T15:04:46.783Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user's role\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Patients:\n    // - Authenticated users can create their own patient record.\n    // - Only the patient themselves or authorized staff can read/write their data.\n    match /patients/{patientId} {\n      allow read, write: if request.auth != null && (request.auth.uid == resource.data.uid || getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk']);\n\n      // Sub-collections can inherit or have more specific rules.\n      match /{document=**} {\n        allow read, write: if request.auth != null && (request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'nurse']);\n      }\n    }\n    \n    // Users:\n    // - Only the user themselves or an admin can read/write their user document.\n    match /users/{userId} {\n      allow read, write: if request.auth != null && (request.auth.uid == userId || getUserRole() == 'admin');\n    }\n    \n    // Appointments:\n    // - Authenticated users can create appointments.\n    // - Only involved parties (patient, doctor) or staff can read/update.\n    match /appointments/{appointmentId} {\n        allow create: if request.auth != null;\n        allow read, update: if request.auth != null && \n                               (request.auth.uid == resource.data.patient_id || \n                                request.auth.uid == resource.data.doctor_id ||\n                                getUserRole() in ['admin', 'receptionist', 'nurse']);\n    }\n\n    // lab_tests: Read-only for authenticated users, write for admin\n    match /lab_tests/{testId} {\n        allow read: if request.auth != null;\n        allow write: if getUserRole() == 'admin';\n    }\n\n    // lab_orders: Role-based access for creating and updating lab orders.\n    match /lab_orders/{orderId} {\n        allow create: if getUserRole() in ['admin', 'doctor'];\n        allow update: if getUserRole() in ['admin', 'lab_tech'];\n        allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;\n    }\n\n    // lab_results: Role-based access for results.\n    match /lab_results/{resultId} {\n        allow create: if getUserRole() in ['admin', 'lab_tech'];\n        allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;\n    }\n\n  }\n}\n"}]}}
