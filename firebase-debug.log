[debug] [2025-09-19T15:30:41.950Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Allow users to read their own profile, or allow admins to read any profile.\n      allow read: if request.auth.uid == userId || getUserRole() == 'admin';\n\n      // Allow users to update their own profile, but NOT change their role.\n      allow update: if request.auth.uid == userId && !('role' in request.resource.data);\n    }\n    \n    // Rules for the 'patients' collection to enforce data privacy\n    match /patients/{patientId} {\n      // Allow read/write access if the user is an admin.\n      // Allow the patient to read their own record (patientId matches auth uid).\n      // Allow clinical staff (doctors, nurses) to read/write if their uid is in the patient's assignedCareTeam array.\n      allow read, write: if getUserRole() == 'admin' \n                      || request.auth.uid == patientId \n                      || (request.auth.uid in resource.data.assignedCareTeam);\n    }\n\n    // Rules for the 'audit_logs' collection to ensure immutability\n    match /audit_logs/{logId} {\n      // Only allow administrators to read the audit logs.\n      allow read: if getUserRole() == 'admin';\n      \n      // Deny all client-side writes (create, update, delete).\n      // Logs should only be created by secure backend Cloud Functions.\n      allow write: if false;\n    }\n  }\n}\n"}]}}
