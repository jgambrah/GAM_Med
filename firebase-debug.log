[debug] [2025-08-11T14:19:05.776Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions to simplify rule logic\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isUser(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    function getUserData() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n    \n    function getUserRole() {\n      // Return null if user isn't signed in to prevent errors\n      return isSignedIn() ? getUserData().role : null;\n    }\n\n    // Secure the users collection\n    match /users/{userId} {\n      allow read: if isSignedIn();\n      allow write: if isUser(userId); // Users can only edit their own profile\n    }\n\n    // Rules for the main patients collection and its sub-collections\n    match /patients/{patientId} {\n      // Clinical, admin, and billing staff can view patient records.\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'pharmacist', 'lab_technician'];\n      // Only admins should modify the top-level patient document to prevent accidental changes.\n      allow write: if getUserRole() == 'admin';\n      \n      // == NURSING MODULE RULES ==\n      // These rules grant nurses specific permissions for their workflows.\n      \n      // Vitals can be read by clinical staff, but only created/updated by nurses.\n      match /vitals/{vitalId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow create, update: if getUserRole() == 'nurse';\n        // No delete allowed to preserve history.\n        allow delete: if false;\n      }\n      \n      // Care plans can be read by clinical staff, but only created/updated by nurses.\n      match /care_plans/{planId} {\n         allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n         allow create, update: if getUserRole() == 'nurse';\n         allow delete: if false;\n      }\n      \n      // Medication administration logs can be read by clinical staff, but only created by nurses.\n      // Updates are disallowed to maintain the integrity of the log.\n      match /medication_administration_logs/{logId} {\n         allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n         allow create: if getUserRole() == 'nurse';\n         allow update, delete: if false;\n      }\n      \n      // Progress notes can be read by clinical staff, but only created by nurses.\n      // These are distinct from doctor's clinical notes.\n      match /progress_notes/{noteId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow create: if getUserRole() == 'nurse';\n        allow update, delete: if false;\n      }\n\n      // == DOCTOR-SPECIFIC RULES (FOR COMPARISON) ==\n      // These rules explicitly prevent nurses from writing to doctor-only sub-collections.\n      \n      // Clinical notes are the primary domain of doctors.\n      match /clinical_notes/{noteId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow write: if getUserRole() == 'doctor';\n      }\n      \n      // Diagnoses are made exclusively by doctors.\n      match /diagnoses/{diagnosisId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow write: if getUserRole() == 'doctor';\n      }\n\n      // Prescriptions are written exclusively by doctors.\n      match /medication_history/{prescriptionId} {\n          allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'patient'];\n          allow write: if getUserRole() == 'doctor';\n      }\n      \n      // Lab results can be read by clinical staff, but only written by the lab system/technician.\n      match /lab_results/{testId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'lab_technician'];\n        allow write: if getUserRole() == 'lab_technician'; // Or a dedicated service account\n      }\n\n      // Admissions history can be read widely, but written only by secure Cloud Functions.\n      match /admissions/{admissionId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'patient'];\n        allow write: if false; // Should only be written by backend functions\n      }\n    }\n  }\n}\n"}]}}
