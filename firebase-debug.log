[debug] [2025-09-09T17:11:53.205Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions for role-based access control\n    function isSignedIn() {\n      return request.auth != null;\n    }\n    \n    function getUserData() {\n        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data\n    }\n    \n    function getUserRole() {\n        return getUserData().role\n    }\n\n    function hasAnyRole(roles) {\n      return isSignedIn() && getUserRole() in roles;\n    }\n    \n    function isExamAdmin() {\n      return hasAnyRole(['admin', 'registrar']);\n    }\n    \n    function isStudent(studentId) {\n        return request.auth.uid == studentId;\n    }\n\n    // Rules for User Management\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || hasAnyRole(['admin', 'HR']);\n      allow update: if request.auth.uid == userId || hasAnyRole(['admin', 'HR']);\n      allow create: if hasAnyRole(['HR']);\n    }\n\n    // Rules for other collections...\n    match /beds/{bedId} {\n      allow read: if isSignedIn();\n      // Write access is typically handled by backend functions\n      allow write: if hasAnyRole(['admin', 'doctor', 'nurse']);\n    }\n\n    match /patients/{patientId} {\n      allow read: if isSignedIn();\n      // More granular rules can be added for sub-collections\n      allow write: if hasAnyRole(['admin', 'doctor', 'nurse']);\n\n      // Sub-collection rules can be nested here\n      // e.g., match /clinical_notes/{noteId} { ... }\n    }\n    \n    match /results/{docId} {\n        // READ: Only the student themselves can read their result IF it's published. Exam Admins can read all.\n        allow read: if (resource.data.studentId == request.auth.uid && resource.data.isPublished == true) || isExamAdmin();\n        // WRITE: Only a Cloud Function can manage results to ensure data integrity and controlled publication.\n        allow write: if false;\n    }\n    \n    match /student_academic_records/{docId} {\n        // READ: Students can only read their own records IF the final result is published. Exam Admins can read all.\n        allow read: if (resource.data.studentId == request.auth.uid && resource.data.finalResultPublished == true) || isExamAdmin();\n        // WRITE: Only a Cloud Function can write to this collection to ensure data integrity.\n        allow write: if false;\n    }\n    \n    // =============================================================\n    // == Shift & Roster Management Rules\n    // =============================================================\n    \n    match /shifts/{shiftId} {\n      // Anyone signed in can read the available shift patterns.\n      allow read: if isSignedIn();\n      // Only admins can create or modify shift definitions.\n      allow write: if hasAnyRole(['admin']);\n    }\n    \n    match /rosters/{rosterId} {\n      // Allow creation by admins or department managers.\n      allow create: if hasAnyRole(['admin', 'department_manager']);\n      // Allow read if user is an admin/manager, or if their UID is in the roster's assignment list.\n      // NOTE: This assumes a field like 'assignedUserIds' exists on the roster document for efficiency.\n      allow read: if hasAnyRole(['admin', 'department_manager']) || request.auth.uid in resource.data.assignedUserIds;\n      // Allow updates only by admins or managers.\n      allow update: if hasAnyRole(['admin', 'department_manager']);\n    }\n    \n    match /staff_availability/{userId} {\n      // Allow read access to admins, managers, and the staff member themselves.\n      allow read: if hasAnyRole(['admin', 'department_manager']) || request.auth.uid == userId;\n      // Allow write access to admins, managers, and the staff member themselves.\n      allow write: if hasAnyRole(['admin', 'department_manager']) || request.auth.uid == userId;\n    }\n\n  }\n}\n"}]}}
