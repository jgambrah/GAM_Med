[debug] [2025-09-17T14:07:36.789Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to get the user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the main 'patients' collection\n    match /patients/{patientId} {\n      // Patients can read their own data.\n      // Admins, doctors, and nurses can read any patient's data.\n      allow read: if request.auth.uid == resource.data.uid || getUserRole() in ['admin', 'doctor', 'nurse'];\n\n      // Patients can update their own non-critical data (e.g., contact info).\n      // Clinical/admin staff can update all fields.\n      // Note: More granular field-level security would be enforced in Cloud Functions.\n      allow update: if request.auth.uid == resource.data.uid || getUserRole() in ['admin', 'doctor', 'nurse'];\n      \n      // Only admins/nurses can create new patients.\n      allow create: if getUserRole() in ['admin', 'nurse'];\n\n      // Patients should not be able to delete their own records.\n      allow delete: if getUserRole() == 'admin';\n      \n      // Rules for the 'messages' sub-collection\n      match /messages/{messageId} {\n          // A patient can read/write messages in their own sub-collection.\n          // A doctor can also read/write messages to any patient.\n          allow read, create: if request.auth.uid == patientId || getUserRole() == 'doctor';\n      }\n\n      // Add rules for other patient sub-collections as needed...\n      match /{allPaths=**} {\n        allow read, write: if getUserRole() in ['admin', 'doctor'];\n      }\n    }\n\n    // Rules for user roles and profiles\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n\n    // Rules for aggregated reporting data\n    match /kpi_metrics/{docId} {\n      allow read: if getUserRole() == 'admin';\n      allow write: if false; // Only backend functions can write\n    }\n    match /bi_reports/{docId} {\n      allow read: if getUserRole() == 'admin';\n      allow write: if false;\n    }\n    match /clinical_reports/{docId} {\n      allow read: if getUserRole() in ['admin', 'doctor'];\n      allow write: if false;\n    }\n    \n    // Rules for saved ad-hoc reports\n    match /saved_reports/{reportId} {\n        // Users can manage their own reports.\n        allow read, create, update, delete: if request.auth.uid == resource.data.userId;\n        \n        // Admins can read any report. (Future: Add sharing logic here)\n        allow read: if getUserRole() == 'admin';\n    }\n\n    // Fallback rule: Deny all other access by default\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
