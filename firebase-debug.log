[debug] [2025-08-04T16:00:41.819Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // =================================================================\n    // Helper Functions\n    // =================================================================\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function getUserData(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data;\n    }\n\n    function getUserRole(userId) {\n      return getUserData(userId).role;\n    }\n\n    // =================================================================\n    // Collection: users\n    // =================================================================\n    match /users/{userId} {\n      // Users can read their own data.\n      // Admins can read anyone's data.\n      allow read: if isAuthenticated() && (request.auth.uid == userId || getUserRole(request.auth.uid) == 'Admin');\n      \n      // Users can create their own user document during sign-up.\n      allow create: if isAuthenticated() && request.auth.uid == userId;\n\n      // Users can update their own data. Admins can update anyone's data.\n      allow update: if isAuthenticated() && (request.auth.uid == userId || getUserRole(request.auth.uid) == 'Admin');\n    }\n    \n    // =================================================================\n    // Collection: patients\n    // =================================================================\n    match /patients/{patientId} {\n      // CREATE: Only Admins and Nurses can register new patients.\n      allow create: if isAuthenticated() && (getUserRole(request.auth.uid) in ['Admin', 'Nurse']);\n\n      // READ:\n      // - Admins, Doctors, and Nurses can read any patient's record.\n      // - A patient can read their own record by matching their UID to a (hypothetical) 'ownerId' field.\n      //   (Note: For this app's mock data, we don't have a direct UID link, but this rule structure is best practice).\n      allow read: if isAuthenticated() && \n                    (getUserRole(request.auth.uid) in ['Admin', 'Doctor', 'Nurse', 'BillingClerk'] || resource.data.ownerId == request.auth.uid);\n\n      // UPDATE: Only Admins and Nurses can update patient demographics.\n      allow update: if isAuthenticated() && (getUserRole(request.auth.uid) in ['Admin', 'Nurse']);\n      \n      // DELETE: No one can delete a patient record from the front-end to ensure data integrity.\n      allow delete: if false;\n    }\n    \n    // =================================================================\n    // Collection: admissions\n    // =================================================================\n    match /admissions/{admissionId} {\n      // CREATE: Admins and Nurses can create new admission records.\n      allow create: if isAuthenticated() && (getUserRole(request.auth.uid) in ['Admin', 'Nurse']);\n\n      // READ: Admins, Doctors, Nurses can read all admissions.\n      // A patient can read their own admission records.\n      allow read: if isAuthenticated() && \n                    (getUserRole(request.auth.uid) in ['Admin', 'Doctor', 'Nurse', 'BillingClerk'] || resource.data.patientId == request.resource.data.patientId);\n                    \n      // UPDATE: Admins, Doctors, Nurses can update admission records.\n      allow update: if isAuthenticated() && (getUserRole(request.auth.uid) in ['Admin', 'Doctor', 'Nurse', 'BillingClerk']);\n      \n      allow delete: if false;\n    }\n\n    // =================================================================\n    // Collection: beds\n    // =================================================================\n    match /beds/{bedId} {\n        // All authenticated staff can see bed status.\n        allow read: if isAuthenticated() && getUserRole(request.auth.uid) in ['Admin', 'Doctor', 'Nurse', 'Housekeeping', 'BillingClerk'];\n        \n        // Only Admins, Nurses, and Housekeeping can update bed status (e.g., admit, discharge, clean).\n        allow update: if isAuthenticated() && getUserRole(request.auth.uid) in ['Admin', 'Nurse', 'Housekeeping'];\n        \n        // Bed records should not be created or deleted manually.\n        allow create, delete: if false;\n    }\n    \n    // =================================================================\n    // Collection: referrals\n    // =================================================================\n    match /referrals/{referralId} {\n      // CREATE: Only Admins and Nurses (acting as triage) can log a new referral.\n      allow create: if isAuthenticated() && getUserRole(request.auth.uid) in ['Admin', 'Nurse'];\n\n      // READ:\n      // - Admins and Nurses (triage) can read all referrals.\n      // - A doctor can read a referral only if they are assigned to it.\n      allow read: if isAuthenticated() && (\n        getUserRole(request.auth.uid) in ['Admin', 'Nurse'] || \n        request.auth.uid == resource.data.assignedToDoctorId\n      );\n\n      // UPDATE:\n      // - Admins and Nurses can update any field.\n      // - An assigned doctor can only update the status (e.g., to 'Patient Seen') or link an appointment.\n      allow update: if isAuthenticated() && (\n        getUserRole(request.auth.uid) in ['Admin', 'Nurse'] ||\n        (\n          request.auth.uid == resource.data.assignedToDoctorId &&\n          request.resource.data.keys().hasOnly(['status', 'appointmentId', 'updatedAt'])\n        )\n      );\n\n      // DELETE: No one can delete a referral to maintain a clear audit trail.\n      allow delete: if false;\n    }\n  }\n}\n"}]}}
