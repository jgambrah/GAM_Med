[debug] [2025-08-29T17:56:11.606Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the user's role from their user document.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the main collections\n    match /patients/{patientId} {\n      allow read, write: if request.auth != null; // Basic auth for now\n      \n      // Sub-collection rules can be more granular\n      match /{document=**} {\n        allow read, write: if request.auth != null;\n      }\n    }\n    \n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId; // Users can update their own profile\n    }\n\n    match /inventory/{itemId} {\n      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];\n\n      // Allow updates to inventory levels (batches) only by trusted functions\n      // and specific updates to reorder settings by authorized staff.\n      allow update: if (getUserRole() in ['admin', 'pharmacist', 'inventory_manager'] &&\n                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reorderLevel', 'isAutoReorder']))\n                     || (request.auth.uid in get(/databases/$(database)/documents/system/trusted_functions).data.uids); // Placeholder for trusted function UIDs\n    }\n    \n    match /inventory/{itemId}/transactions/{transactionId} {\n      // Allow creation only by authorized roles or trusted functions.\n      allow create: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager']\n                     || (request.auth.uid in get(/databases/$(database)/documents/system/trusted_functions).data.uids);\n      allow read: if getUserRole() in ['admin', 'pharmacist'];\n    }\n\n    match /reorder_requests/{requestId} {\n      allow read, update: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager'];\n      allow create: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager']\n                     || (request.auth.uid in get(/databases/$(database)/documents/system/trusted_functions).data.uids);\n    }\n    \n    match /{document=**} {\n      allow read, write: if false; // Default deny all\n    }\n  }\n}\n"}]}}
