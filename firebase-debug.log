[debug] [2025-09-10T13:14:51.816Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions to check user roles\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    function isExamAdmin() {\n      return getUserRole() in ['admin', 'exam_admin'];\n    }\n\n    function isStudent(studentId) {\n      return request.auth.uid == studentId;\n    }\n    \n    // Rules for user profiles\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || getUserRole() in ['admin', 'manager'];\n      allow create: if getUserRole() == 'admin';\n      // Only admins/managers can update leave balances.\n      // Users can update their own profile, but not these protected fields.\n      allow update: if (getUserRole() in ['admin', 'manager']) || \n                     (request.auth.uid == userId && !('leaveBalances' in request.resource.data));\n    }\n    \n    // Rules for patient data\n    match /patients/{patientId} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    // Rules for all subcollections of patients\n    match /patients/{patientId}/{collection}/{docId} {\n      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n\n    // Rules for hospital bed management\n    match /beds/{bedId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() in ['admin', 'nurse', 'doctor'];\n    }\n\n    // Rules for appointments\n    match /appointments/{appointmentId} {\n        allow read: if request.auth != null;\n        allow create: if request.auth != null;\n        allow update, delete: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    // Rules for shifts\n    match /shifts/{shiftId} {\n        allow read: if request.auth != null;\n        allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for rosters\n    match /rosters/{rosterId} {\n        allow create: if getUserRole() in ['admin', 'department_manager'];\n        allow read: if getUserRole() in ['admin', 'department_manager'] || request.auth.uid in resource.data.staffAssignments.map(a => a.userId);\n        allow update: if getUserRole() in ['admin', 'department_manager'];\n    }\n\n    // Rules for staff availability\n    match /staff_availability/{userId} {\n        allow read: if getUserRole() in ['admin', 'department_manager'] || request.auth.uid == userId;\n        allow write: if getUserRole() in ['admin', 'department_manager'] || request.auth.uid == userId;\n    }\n\n    // Rules for leave requests\n    match /leave_requests/{leaveId} {\n      allow create: if request.auth.uid != null && request.auth.uid == request.resource.data.employeeId;\n      allow read: if request.auth.uid == resource.data.employeeId || getUserRole() in ['admin', 'manager'];\n      // An employee can cancel their own request if it's pending. A manager can approve/reject.\n      allow update: if (getUserRole() in ['admin', 'manager']) || (request.auth.uid == resource.data.employeeId && resource.data.status == 'Pending');\n    }\n  }\n}\n"}]}}
