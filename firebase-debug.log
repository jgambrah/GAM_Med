[debug] [2025-08-10T14:01:19.951Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to get the user's role from the 'users' collection.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Users can read their own data. Admins can read anyone's data.\n      allow read: if request.auth.uid == userId || getUserRole() == 'admin';\n      // Only admins can create or update user roles/data.\n      allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      // Allow read access for the patient themselves, or authorized clinical/admin staff.\n      allow read: if request.auth.uid == get(/databases/$(database)/documents/patients/$(patientId)).data.auth_uid || \n                   getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'pharmacist'];\n      // Allow creation only by admins or nurses (reception).\n      allow create: if getUserRole() in ['admin', 'nurse'];\n      // Allow updates by admins, doctors, or nurses.\n      allow update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      \n      // Rules for EHR sub-collections\n      match /admissions/{admissionId} {\n        allow read: if request.auth.uid == get(/databases/$(database)/documents/patients/$(patientId)).data.auth_uid || \n                   getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'];\n        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      \n      match /clinical_notes/{noteId} {\n          allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n\n       match /billing/{billingId} {\n          allow read: if getUserRole() in ['admin', 'billing_clerk'];\n          allow write: if getUserRole() in ['admin', 'billing_clerk'];\n      }\n    }\n\n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n      // All clinical and admin staff can view bed status.\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      // Only admins and nurses can update bed status (admit, transfer, clean).\n      allow write: if getUserRole() in ['admin', 'nurse'];\n    }\n    \n     // Rules for the 'referrals' collection\n    match /referrals/{referralId} {\n        // Admin and triage staff can create new referrals.\n      allow create: if getUserRole() in ['admin', 'triage_officer', 'nurse'];\n      \n      // Admin, triage, and the assigned doctor can read the referral.\n      allow read: if getUserRole() in ['admin', 'triage_officer', 'nurse'] || request.auth.uid == resource.data.assignedDoctorId;\n        \n      // Admin and triage can manage the referral; the assigned doctor can update its status.\n      allow update: if getUserRole() in ['admin', 'triage_officer', 'nurse'];\n    }\n  }\n}\n"}]}}
