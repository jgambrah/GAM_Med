[debug] [2025-08-25T14:17:51.042Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to get user's role from a 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Secure the users collection\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n\n    // Rules for patient data, including sub-collections\n    match /patients/{patientId} {\n      allow read: if request.auth.uid == resource.data.patient_id || getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'];\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse']; // Or specific Cloud Functions\n\n      // Sub-collection rules inherit the parent's read access but can have stricter write access\n      match /admissions/{admissionId} {\n        allow read: if get(/databases/$(database)/documents/patients/$(patientId)).data.patient_id == request.auth.uid || getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      \n      // Allow clinical staff to write to these subcollections\n      match /{subcollection}/{docId} {\n         allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      \n       match /receipts/{receiptId} {\n          allow create: if false; // Only allow creation via Cloud Function\n          allow read: if getUserRole() in ['admin', 'billing_clerk'] || get(/databases/$(database)/documents/patients/$(patientId)).data.patient_id == request.auth.uid;\n       }\n    }\n    \n    // Beds are readable by most staff, but only writable by certain roles or functions\n    match /beds/{bedId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow write: if getUserRole() in ['admin', 'nurse']; // Admins and nurses can manually update bed status\n    }\n\n    // Appointments can be read by involved parties or staff\n    match /appointments/{appointmentId} {\n        allow read: if resource.data.patient_id == request.auth.uid || resource.data.doctor_id == request.auth.uid || getUserRole() in ['admin', 'receptionist'];\n        allow write: if getUserRole() in ['admin', 'receptionist']; // Or trusted Cloud Functions\n    }\n\n    // Referrals are managed by admins and doctors\n    match /referrals/{referralId} {\n        allow read: if getUserRole() in ['admin', 'doctor'];\n        allow write: if getUserRole() in ['admin', 'doctor']; // For assignment and status updates\n    }\n    \n    // Lab Results should be readable by patient and clinical staff\n    match /lab_results/{resultId} {\n        allow read: if resource.data.patientId == request.auth.uid || getUserRole() in ['admin', 'doctor', 'nurse', 'lab_technician'];\n        allow write: if getUserRole() in ['lab_technician']; // Only lab techs can fulfill\n    }\n    \n    // Prescriptions can be created by doctors and read by patient/pharmacist\n    match /prescriptions/{prescriptionId} {\n        allow read: if resource.data.patientId == request.auth.uid || getUserRole() in ['admin', 'doctor', 'pharmacist'];\n        allow create: if getUserRole() == 'doctor';\n        allow update: if getUserRole() == 'pharmacist'; // For status changes\n    }\n    \n    // Payment Gateways can only be managed by admins\n    match /payment_gateways/{gatewayId} {\n        allow read: if getUserRole() in ['admin', 'billing_clerk'];\n        allow write: if getUserRole() == 'admin';\n    }\n\n    // Invoices and Payments have strict access control\n    match /invoices/{invoiceId} {\n       allow read: if getUserRole() in ['admin', 'billing_clerk'] || resource.data.patientId == request.auth.uid;\n       allow write: if getUserRole() in ['admin', 'billing_clerk']; // Or trusted Cloud Functions\n    }\n    \n    match /payments/{paymentId} {\n      // Creation is handled by the processPayment Cloud Function\n      allow create: if false; \n      allow read: if getUserRole() in ['admin', 'billing_clerk'] || get(/databases/$(database)/documents/invoices/$(resource.data.invoiceId)).data.patientId == request.auth.uid;\n    }\n    \n    // Bills & Expenses (Accounts Payable)\n    match /bills/{billId} {\n        allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n        \n        match /bill_payments/{paymentId} {\n           allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n        }\n    }\n    \n    match /expenses/{expenseId} {\n       allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n\n  }\n}\n"}]}}
