[debug] [2025-08-09T11:37:09.262Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the user's role from the 'users' collection.\n    // This is more secure than relying on custom claims for this prototype.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the main 'users' collection\n    match /users/{userId} {\n      // Users can read their own data. Admins can read anyone's data.\n      allow read: if request.auth.uid == userId || getUserRole() == 'admin';\n      // Only admins can create or update user roles.\n      allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for the main 'patients' collection\n    match /patients/{patientId} {\n        // Allow creation if the user is an admin or billing clerk, AND\n        // the document ID being created matches the patientId field in the document body.\n        allow create: if (getUserRole() == 'admin' || getUserRole() == 'billing_clerk')\n                      && request.resource.id == request.resource.data.patientId;\n\n        // Allow reading for admins, clerks, doctors, and nurses.\n        // A patient can read their own record if their auth UID matches a linked user ID field (future feature).\n        allow read: if getUserRole() in ['admin', 'billing_clerk', 'doctor', 'nurse'];\n\n        // Allow updates if the user is an admin or clerk.\n        // Crucially, this rule PREVENTS the patientId field from being changed after creation.\n        allow update: if (getUserRole() == 'admin' || getUserRole() == 'billing_clerk')\n                      && request.resource.data.patientId == resource.data.patientId;\n    }\n    \n    // Rules for the 'admissions' sub-collection\n    match /patients/{patientId}/admissions/{admissionId} {\n      // Allow read access to a broad set of roles, including the patient themselves.\n      // In a real app, doctor/nurse access might be further restricted to only patients in their department.\n      allow read: if getUserRole() in ['admin', 'billing_clerk', 'doctor', 'nurse']\n                  || request.auth.uid == patientId; // Allows patient to read their own admission history\n\n      // Only admins and clerks can create new admission records (e.g., for a new visit).\n      allow create: if getUserRole() in ['admin', 'billing_clerk'];\n\n      // Allow updates based on role:\n      // - Admins can update any field.\n      // - Doctors/nurses can update clinical status fields.\n      // - Clerks might update billing-related fields (not yet defined).\n      allow update: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'];\n    }\n\n    // Rules for all other collections (beds, appointments, etc.)\n    // For this prototype, we'll allow read/write access to authenticated users.\n    // In production, these would have granular rules similar to patients/admissions.\n    match /{document=**} {\n      allow read, write: if request.auth != null;\n    }\n  }\n}\n"}]}}
