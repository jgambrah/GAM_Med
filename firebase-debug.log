[debug] [2025-09-17T16:52:56.883Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check user role\n    function isUserRole(role) {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;\n    }\n    \n    // Patients can only read their own data. Clinical staff can read all patient data.\n    match /patients/{patientId} {\n      allow read: if request.auth.uid == patientId || isUserRole('doctor') || isUserRole('nurse') || isUserRole('admin') || isUserRole('billing_clerk');\n      allow create: if isUserRole('admin') || isUserRole('nurse');\n      allow update: if isUserRole('admin') || isUserRole('doctor') || isUserRole('nurse');\n    }\n    \n    // Sub-collections under patients\n    match /patients/{patientId}/{subcollection}/{documentId} {\n        allow read: if request.auth.uid == patientId || isUserRole('doctor') || isUserRole('nurse') || isUserRole('admin');\n        // Create/Update rules should be more specific per subcollection if needed\n        allow write: if isUserRole('doctor') || isUserRole('nurse') || isUserRole('admin');\n    }\n\n    // Remote Patient Data Rules\n    match /remote_patient_data/{dataId} {\n      allow create: if request.auth.uid == request.resource.data.patientId; // Patient can create their own data\n      allow read: if request.auth.uid == resource.data.patientId || isUserRole('doctor') || isUserRole('nurse');\n      allow write: if false; // Data should be immutable once created\n    }\n\n    // Users can read their own profile, admins can read all\n    match /users/{userId} {\n      allow get: if request.auth.uid == userId || isUserRole('admin');\n      allow list: if request.auth != null;\n      // Users can update their own non-critical info. 'availability' is protected.\n      allow update: if request.auth.uid == userId && !(\"availability\" in request.resource.data);\n    }\n    \n    // Beds can be read by clinical staff, updated by clinical/admin staff\n    match /beds/{bedId} {\n        allow read: if isUserRole('doctor') || isUserRole('nurse') || isUserRole('admin');\n        allow write: if isUserRole('doctor') || isUserRole('nurse') || isUserRole('admin');\n    }\n    \n    // Appointments can be created by a patient for themselves.\n    // They can be read by the patient or the doctor involved.\n    match /appointments/{appointmentId} {\n        allow create: if request.auth.uid == request.resource.data.patientId;\n        allow read: if request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId;\n        allow update, delete: if isUserRole('admin') || isUserRole('doctor');\n    }\n  }\n}\n"}]}}
