[debug] [2025-08-03T18:23:59.092Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user's role from the 'users' collection\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n\n    // Security rules for the 'users' collection\n    match /users/{userId} {\n      // Any authenticated user can create their own user profile document\n      allow create: if request.auth != null && request.auth.uid == userId;\n      // Users can only read their own data\n      allow read: if request.auth != null && request.auth.uid == userId;\n      // Users can only update their own data, but cannot change their role\n      allow update: if request.auth != null && request.auth.uid == userId && request.resource.data.role == resource.data.role;\n    }\n\n    // Security rules for the 'patients' collection\n    match /patients/{patientId} {\n      // Admins and Nurses can create new patients\n      allow create: if getUserRole(request.auth.uid) in ['Admin', 'Nurse'];\n      // Admins, Nurses, and Doctors can read any patient's data\n      // Patients can read their own data (requires linking auth UID to patient record)\n      allow read: if getUserRole(request.auth.uid) in ['Admin', 'Nurse', 'Doctor'] || resource.data.authUid == request.auth.uid;\n       // Admins and Nurses can update patient data\n      allow update: if getUserRole(request.auth.uid) in ['Admin', 'Nurse'];\n    }\n    \n    // Security rules for the 'admissions' collection\n    match /admissions/{admissionId} {\n        // Admins, Nurses, and Doctors can create admission records\n        allow create: if getUserRole(request.auth.uid) in ['Admin', 'Nurse', 'Doctor'];\n        // Admins, Nurses, and Doctors can read any admission record\n        // Patients can read their own admission records\n        allow read: if getUserRole(request.auth.uid) in ['Admin', 'Nurse', 'Doctor'] || get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.authUid == request.auth.uid;\n        // Admins, Nurses, and Doctors can update admission records\n        allow update: if getUserRole(request.auth.uid) in ['Admin', 'Nurse', 'Doctor'];\n    }\n\n    // Security rules for the 'beds' collection\n    match /beds/{bedId} {\n        // Only Admins can create or delete bed records (initial setup)\n        allow create, delete: if getUserRole(request.auth.uid) == 'Admin';\n        // Any authenticated user can view the status of beds\n        allow read: if request.auth != null;\n        // Only Admins and Nurses can update bed statuses (e.g., for allocation, transfer, maintenance)\n        allow update: if getUserRole(request.auth.uid) in ['Admin', 'Nurse'];\n    }\n  }\n}\n"}]}}
