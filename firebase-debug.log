[debug] [2025-09-04T16:52:27.674Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user role\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Patients collection\n    match /patients/{patientId} {\n      allow read, write: if request.auth != null; // Placeholder, refine later\n      \n      // Sub-collections\n      match /admissions/{admissionId} {\n        allow read, write: if request.auth != null;\n      }\n      match /clinical_notes/{noteId} {\n        allow read, write: if request.auth != null;\n      }\n      // ... other sub-collections\n    }\n\n    // Lab Orders collection\n    match /lab_orders/{orderId} {\n      allow create: if getUserRole() in ['admin', 'doctor'];\n      allow update: if getUserRole() in ['admin', 'lab_tech'];\n      allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;\n      \n      // Sample Audit sub-collection\n      match /sample_audit/{auditId} {\n        allow create: if getUserRole() in ['admin', 'lab_tech'];\n        allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;\n        allow update, delete: if false; // Immutable\n      }\n    }\n\n    // Lab Results collection\n    match /lab_results/{resultId} {\n      allow create: if getUserRole() == 'lab_tech';\n      allow update: if getUserRole() in ['lab_tech', 'lab_supervisor'] && resource.data.status == 'Draft';\n      allow read: if getUserRole() in ['admin', 'doctor', 'lab_tech'] || request.auth.uid == resource.data.patientId;\n    }\n    \n    // Users collection\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId; // Users can edit their own profile\n    }\n  }\n}\n"}]}}
