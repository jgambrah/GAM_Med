[debug] [2025-08-04T15:16:25.251Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper Functions\n    function isAuth() {\n      return request.auth != null;\n    }\n\n    function isOneOfRoles(roles) {\n      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;\n    }\n\n    // Rules for 'users' collection\n    match /users/{userId} {\n      // Allow users to read their own profile\n      allow read: if isAuth() && request.auth.uid == userId;\n      // Allow users to create their own profile upon signup\n      allow create: if isAuth() && request.auth.uid == userId;\n      // Allow users to update their own profile\n      allow update: if isAuth() && request.auth.uid == userId;\n    }\n\n    // Rules for 'patients' collection\n    match /patients/{patientId} {\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']);\n      allow list: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      allow create: if isOneOfRoles(['Admin']);\n      allow update: if isOneOfRoles(['Admin', 'Doctor']);\n      allow delete: if isOneOfRoles(['Admin']);\n    }\n\n    // Rules for 'admissions' collection\n    match /admissions/{admissionId} {\n      allow read, list: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      allow create, update: if isOneOfRoles(['Admin', 'Doctor']);\n    }\n\n    // Rules for 'beds' collection\n    match /beds/{bedId} {\n      allow read, list: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'Housekeeping']);\n      allow update: if isOneOfRoles(['Admin', 'Nurse', 'Housekeeping']);\n    }\n    \n    // Rules for 'referrals' collection\n    match /referrals/{referralId} {\n        allow read, list: if isOneOfRoles(['Admin', 'Doctor']);\n        allow create: if isOneOfRoles(['Admin']);\n        allow update: if isOneOfRoles(['Admin', 'Doctor']);\n    }\n\n  }\n}\n"}]}}
