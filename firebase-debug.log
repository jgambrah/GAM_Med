[debug] [2025-08-04T11:34:07.130Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Helper function to check if the user is an Admin\n    function isAdmin() {\n      return getUserRole() == 'Admin';\n    }\n    \n    // Helper function to check if user is a staff member\n    function isStaff() {\n      return getUserRole() in ['Admin', 'Doctor', 'Nurse', 'BillingClerk', 'Pharmacist'];\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Allow users to read their own data\n      allow read: if request.auth.uid == userId || isAdmin();\n      // Allow users to create their own user document on signup\n      allow create: if request.auth.uid == userId;\n      // Allow users to update their own data, but not their role\n      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      // Staff can read/write all patient data.\n      allow read, write: if isStaff();\n      // Patients can only read their own data (requires a more complex rule, assuming a link field exists)\n      // allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientId == patientId;\n    }\n    \n    // Rules for the 'admissions' collection\n    match /admissions/{admissionId} {\n       allow read, write: if isStaff();\n       // Patients could potentially read their own admissions, similar to the patient rule above.\n    }\n\n    // --- Rules for the 'beds' collection ---\n    match /beds/{bedId} {\n      // READ: Allow authenticated staff members to view bed statuses.\n      allow read: if isStaff();\n\n      // CREATE: Only Admins can create new bed documents (for initial setup).\n      allow create: if isAdmin();\n\n      // UPDATE: Granular rules for updates.\n      // Admins have full update access.\n      // Nurses/other staff have limited access to perform valid state transitions.\n      allow update: if isAdmin() || isStateTransitionValid();\n      \n      // No user should ever be able to delete a bed document.\n      allow delete: if false;\n    }\n    \n    // Helper function to validate bed status transitions\n    function isStateTransitionValid() {\n      let userRole = getUserRole();\n      let incomingData = request.resource.data;\n      let existingData = resource.data;\n      \n      // Transition 1: A Nurse can assign a vacant bed to a patient.\n      // This is part of the admission/transfer action.\n      let isAssigningBed = existingData.status == 'vacant' \n                        && incomingData.status == 'occupied'\n                        && incomingData.currentPatientId != null\n                        && incomingData.currentAdmissionId != null;\n\n      // Transition 2: A Nurse can free up a bed after a patient is transferred/discharged.\n      let isVacatingBed = existingData.status == 'occupied'\n                       && incomingData.status == 'cleaning'\n                       && incomingData.currentPatientId == null\n                       && incomingData.currentAdmissionId == null;\n                       \n      // Transition 3: A Nurse/Housekeeper marks a bed as clean and available.\n      let isMarkingClean = existingData.status == 'cleaning'\n                        && incomingData.status == 'vacant'\n                        && incomingData.cleaningNeeded == false;\n\n      return (userRole == 'Nurse' && (isAssigningBed || isVacatingBed || isMarkingClean));\n    }\n  }\n}\n"}]}}
