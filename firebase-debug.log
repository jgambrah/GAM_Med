[debug] [2025-08-16T15:27:31.890Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // =====================================================================\n    // Helper Functions\n    // =====================================================================\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    function isPatient(patientId) {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId;\n    }\n\n    // =====================================================================\n    // Collection Rules\n    // =====================================================================\n\n    // Users can only read their own data, but this can be expanded for specific admin/doctor views.\n    match /users/{userId} {\n      allow read, update: if request.auth.uid == userId;\n    }\n\n    // Patients can be read by authorized staff, but only created/updated via secure functions.\n    match /patients/{patientId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'lab_technician'];\n      // Write access should be handled by backend Cloud Functions for security and data integrity.\n      allow write: if false; \n    }\n    \n    // Clinical Decision Support rules can be read by any authenticated user, but only written by admins.\n    match /clinical_rules/{ruleId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin';\n    }\n\n    // Alerts can only be created by backend functions. They can be read by clinical staff\n    // and acknowledged (updated) by doctors or admins.\n    match /patients/{patientId}/alerts/{alertId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow create: if false; // Should only be created by Cloud Functions\n      // Allow update only for the 'isAcknowledged' field by authorized roles.\n      allow update: if getUserRole() in ['admin', 'doctor']\n                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAcknowledged']);\n    }\n\n    // Beds can be read by clinical staff, but only updated via secure functions.\n    match /beds/{bedId} {\n       allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n       allow write: if false; // Bed status changes should be handled by backend functions.\n    }\n    \n    // Appointments can be read by involved parties, but only created/updated via secure functions.\n    match /appointments/{appointmentId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'billing_clerk'] || isPatient(resource.data.patient_id);\n        allow write: if false; // All mutations should go through Cloud Functions.\n    }\n\n    // The master vaccine catalog is readable by all authenticated users, but writable only by admins.\n    match /vaccine_catalog/{vaccineId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin';\n    }\n\n    // Patient immunization records can be read by staff and the patient themselves.\n    // Writes are restricted to clinical staff.\n    match /patients/{patientId}/immunizations/{immunizationId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || isPatient(patientId);\n      allow create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow delete: if getUserRole() == 'admin';\n    }\n    \n    // All other sub-collections under patients are restricted to clinical/admin staff for reading\n    // and should only be written to by backend functions.\n    match /patients/{patientId}/{collection}/{docId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'lab_technician', 'pharmacist'];\n      allow write: if false;\n    }\n  }\n}\n"}]}}
