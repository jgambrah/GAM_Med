[debug] [2025-08-07T18:08:04.724Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the user's role from the 'users' collection.\n    function getUserData() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n\n    // =============================================\n    // Users Collection\n    // =============================================\n    match /users/{userId} {\n      // Users can read their own data.\n      // Admins can read any user's data.\n      allow read: if request.auth.uid == userId\n                  || getUserData().role == 'Admin';\n                  \n      // Users can create their own user document upon registration.\n      allow create: if request.auth.uid == userId;\n      \n      // Users can update their own non-critical info. Role changes must be done by an Admin.\n      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role\n                    || getUserData().role == 'Admin';\n    }\n\n    // =============================================\n    // Patients Collection\n    // =============================================\n    match /patients/{patientId} {\n      // Admins, Doctors, and Nurses can create new patient records.\n      allow create: if getUserData().role in ['Admin', 'Doctor', 'Nurse'];\n\n      // Admins, Doctors, and Nurses can read patient records.\n      // Patients can read their own record (requires linking auth UID to patient record).\n      allow read: if getUserData().role in ['Admin', 'Doctor', 'Nurse'];\n      \n      // Admins, Doctors, and Nurses can update patient records.\n      allow update: if getUserData().role in ['Admin', 'Doctor', 'Nurse'];\n      \n      // Only Admins can delete patient records (soft delete recommended).\n      allow delete: if getUserData().role == 'Admin';\n    }\n\n    // =============================================\n    // Appointments Collection\n    // =============================================\n    match /appointments/{appointmentId} {\n        // Admins, Doctors, and Nurses can create appointments.\n        allow create: if getUserData().role in ['Admin', 'Doctor', 'Nurse'];\n\n        // Admins, Doctors, and Nurses can view any appointment.\n        // A patient can view their own appointment.\n        // A doctor can view an appointment assigned to them.\n        allow read: if getUserData().role in ['Admin', 'Doctor', 'Nurse']\n                    || resource.data.patientId == request.auth.uid // This assumes patientId is linked to auth UID\n                    || resource.data.doctorId == request.auth.uid;\n\n        // Admins, Doctors, and Nurses can update appointments.\n        // Patients can cancel their own appointments.\n        allow update: if getUserData().role in ['Admin', 'Doctor', 'Nurse']\n                      || (resource.data.patientId == request.auth.uid && request.resource.data.status == 'Canceled');\n                      \n        // Only Admins can delete appointments.\n        allow delete: if getUserData().role == 'Admin';\n    }\n  }\n}\n"}]}}
