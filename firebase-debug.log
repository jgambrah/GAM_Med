[debug] [2025-08-14T10:39:15.284Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the role of the currently authenticated user.\n    // It reads the 'role' field from the user's document in the 'users' collection.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Helper function to check if the user is authenticated.\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    // Rules for the 'users' collection.\n    match /users/{userId} {\n      // Any signed-in user can read their own user document.\n      // Admins can read any user document.\n      allow read: if isSignedIn() && (request.auth.uid == userId || getUserRole() == 'admin');\n      \n      // Only admins can create or update user documents.\n      allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for the 'patients' collection and its sub-collections.\n    match /patients/{patientId} {\n      // Allow read access to patient records for authenticated clinical and administrative staff.\n      allow read: if isSignedIn() && getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'pharmacist', 'lab_technician'];\n      \n      // Allow write access (e.g., updating admission status) to clinical and administrative staff.\n      allow write: if isSignedIn() && getUserRole() in ['admin', 'doctor', 'nurse'];\n\n      // == NURSING MODULE RULES ==\n      // These rules grant specific permissions to nurses for their workflow.\n\n      // Rules for the 'vitals' sub-collection.\n      match /vitals/{vitalId} {\n        // Doctors and nurses can read vitals.\n        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];\n        // Only nurses can create or update vitals records.\n        allow create, update: if getUserRole() == 'nurse';\n      }\n\n      // Rules for the 'care_plans' sub-collection.\n      match /care_plans/{planId} {\n        // Doctors and nurses can read care plans.\n        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];\n        // Only nurses can create or update care plans.\n        allow create, update: if getUserRole() == 'nurse';\n      }\n\n      // Rules for the 'medication_administration_logs' sub-collection.\n      match /medication_administration_logs/{logId} {\n        // Doctors and nurses can read the administration log.\n        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];\n        // Only nurses can create new log entries.\n        allow create: if getUserRole() == 'nurse';\n      }\n\n      // == DOCTOR-SPECIFIC & OTHER RULES ==\n      // These rules restrict write access on certain sub-collections to doctors.\n      // This also serves as the rule for `progress_notes` when nurses add notes,\n      // as they share the same data model.\n      match /clinical_notes/{noteId} {\n        // Doctors and nurses can read all notes.\n        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];\n        // Both Doctors (for clinical notes) and Nurses (for progress notes) can create notes.\n        allow create: if getUserRole() in ['doctor', 'nurse'];\n      }\n      \n      // Only doctors can write diagnoses.\n      match /diagnoses/{diagnosisId} {\n        allow read: if getUserRole() in ['doctor', 'nurse', 'admin'];\n        allow write: if getUserRole() == 'doctor';\n      }\n      \n      // Only doctors can write new prescriptions to the patient's history.\n      match /medication_history/{prescriptionId} {\n        allow read: if getUserRole() in ['doctor', 'nurse', 'pharmacist', 'admin'];\n        allow write: if getUserRole() == 'doctor';\n      }\n      \n      // Lab results can be read by clinical staff, but only written by lab technicians (or triggered functions).\n      match /lab_results/{resultId} {\n        allow read: if getUserRole() in ['doctor', 'nurse', 'admin', 'lab_technician'];\n        // Writes would typically be handled by a Cloud Function with admin privileges.\n        // Direct client writes might be limited to lab technicians updating the status.\n        allow write: if getUserRole() == 'lab_technician';\n      }\n      \n      // Admissions can be read by most staff, but only written by doctors or nurses.\n      match /admissions/{admissionId} {\n        allow read: if getUserRole() in ['doctor', 'nurse', 'admin', 'billing_clerk'];\n        allow write: if getUserRole() in ['doctor', 'nurse', 'admin'];\n      }\n    }\n  }\n}\n"}]}}
