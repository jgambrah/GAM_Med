[debug] [2025-08-03T14:34:37.828Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Helper function to check if the summary is already finalized\n    function isSummaryFinalized() {\n        return resource.data.isSummaryFinalized == true;\n    }\n\n    match /users/{userId} {\n      // Users can read their own profile, admins can read any profile\n      allow read: if request.auth.uid == userId || getUserRole() == 'Admin';\n      // Users can only create their own profile upon signup\n      allow create: if request.auth.uid == userId;\n      // Users can update their own profile, admins can update any profile\n      allow update: if request.auth.uid == userId || getUserRole() == 'Admin';\n    }\n\n    match /patients/{patientId} {\n      // Admins, Doctors, and Nurses can read any patient record.\n      // Patients can read their own record if their auth UID matches a linked field.\n      // (Assuming a 'userId' field on the patient document linking to the auth user)\n      allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse'] || request.auth.uid == resource.data.userId;\n      \n      // Only Admins or a trusted backend process should create patients.\n      allow create: if getUserRole() == 'Admin';\n      \n      // Only Admins, Doctors or a trusted backend process should update patients.\n      allow update: if getUserRole() in ['Admin', 'Doctor'];\n      \n      // Admissions sub-collection rules\n      match /admissions/{admissionId} {\n        \n        // READ: Admins, Doctors, Nurses, and Billing Clerks can read admissions.\n        // A patient can read their own admission records.\n        allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'BillingClerk'] \n                    || get(/databases/$(database)/documents/patients/$(patientId)).data.userId == request.auth.uid;\n                    \n        // CREATE: New admissions can be created by Admins or Doctors.\n        allow create: if getUserRole() in ['Admin', 'Doctor'];\n\n        // UPDATE (Doctor/Admin for Clinical Summary):\n        // Can update IF the summary is not yet finalized.\n        // This rule allows doctors and admins to fill out and save the discharge summary.\n        allow update: if isSummaryFinalized() == false && getUserRole() in ['Admin', 'Doctor'];\n        \n        // UPDATE (Billing Clerk for Bill ID):\n        // Can update ONLY the `finalBillId` field, and only if the summary is finalized.\n        // This prevents billing from altering clinical data.\n        allow update: if isSummaryFinalized() == true \n                      && getUserRole() == 'BillingClerk'\n                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['finalBillId']);\n                      \n        // The final state change from 'Pending Discharge' to 'Discharged' would be handled\n        // by a trusted server environment (e.g., a Server Action or Cloud Function)\n        // which has elevated privileges and is not subject to these rules.\n        // Direct client updates for this final step would be disallowed.\n      }\n    }\n    \n    match /beds/{bedId} {\n      // All authenticated users can see bed status for allocation purposes.\n      allow read: if request.auth != null;\n      // Only Admins, Nurses, or a backend process can update bed status.\n      allow update: if getUserRole() in ['Admin', 'Nurse'];\n    }\n  }\n}\n"}]}}
