[debug] [2025-09-01T11:44:57.883Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isUserAuthenticated() {\n      return request.auth != null;\n    }\n\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Global read access for authenticated users, but no global write access\n    match /{document=**} {\n      allow read: if isUserAuthenticated();\n      allow write: if false; // Default deny all writes\n    }\n\n    // -- Specific Collection Rules --\n\n    // Users can only read their own data, but admins can read any user.\n    match /users/{userId} {\n        allow read: if isUserAuthenticated() && (request.auth.uid == userId || getUserRole() == 'admin');\n        allow write: if false; // User data managed by backend functions or admins only\n    }\n    \n    // Inventory can only be updated by authorized staff or trusted functions.\n    match /inventory/{itemId} {\n        allow write: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager'];\n    }\n    \n    // Reorder requests can be created by authorized staff or automated functions.\n    match /reorder_requests/{requestId} {\n      allow create: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager']; // Assumes functions run with admin privileges\n      allow read, update: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager'];\n    }\n\n    // Supplier data can be read by staff but only written by admins.\n    match /suppliers/{supplierId} {\n      allow read: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager'];\n      allow write: if getUserRole() == 'admin';\n    }\n\n    // Procurement documents can be managed by procurement staff.\n    match /purchase_orders/{poId} {\n      allow create, read, update: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager'];\n    }\n    match /goods_receipts/{receiptId} {\n      allow create, read, update: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager'];\n    }\n\n    // Patients can only read their own sub-collections, but authorized staff can read/write.\n    match /patients/{patientId}/{subcollection}/{docId} {\n      allow read: if isUserAuthenticated() && (request.auth.uid == get(/databases/$(database)/documents/patients/$(patientId)).data.userId || getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk']);\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n     match /patients/{patientId} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n     }\n\n  }\n}\n"}]}}
