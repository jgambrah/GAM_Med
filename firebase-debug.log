[debug] [2025-08-19T17:13:19.101Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to get the user's role from their user document.\n    // In a real implementation, this would fetch from /users/{request.auth.uid}.\n    function getUserRole() {\n      // This is a placeholder. In a real scenario, you would use:\n      // return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n      return 'admin'; // Defaulting to admin for conceptual purposes.\n    }\n\n    // Placeholder function to get a user's assigned clinic.\n    function getUserClinic() {\n      // This would fetch from /users/{request.auth.uid}.\n      return 'Cardiology'; // Placeholder value\n    }\n\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n\n    match /patients/{patientId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin' || getUserRole() == 'nurse';\n      \n      // Allow read/write to subcollections for authorized roles\n      match /{allPaths=**} {\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n    }\n\n    match /beds/{bedId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() in ['admin', 'nurse'];\n    }\n\n    match /appointments/{appointmentId} {\n        allow read: if request.auth.uid == resource.data.patient_id \n                    || request.auth.uid == resource.data.doctor_id\n                    || getUserRole() == 'admin'\n                    || (getUserRole() == 'billing_clerk' && resource.data.clinicId == getUserClinic());\n        allow write: if getUserRole() in ['admin', 'doctor'];\n    }\n    \n    match /referrals/{referralId} {\n      allow read: if getUserRole() in ['admin', 'doctor'];\n      allow write: if getUserRole() in ['admin', 'doctor'];\n    }\n\n    match /doctor_schedules/{scheduleId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin' || (getUserRole() == 'doctor' && request.auth.uid == resource.data.doctorId);\n    }\n    \n    match /clinics/{clinicId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin';\n    }\n    \n    match /resources/{resourceId} {\n        allow read: if request.auth != null;\n        allow write: if getUserRole() == 'admin';\n    }\n  }\n}\n"}]}}
