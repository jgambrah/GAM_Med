[debug] [2025-08-07T15:45:37.802Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check user role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Helper function to check if the user is an admin\n    function isAdmin() {\n      return getUserRole() == 'Admin';\n    }\n\n    // =================================================================\n    // Users Collection\n    // =================================================================\n    match /users/{userId} {\n      // Allow users to read their own data\n      // Admins can read anyone's data\n      allow read: if request.auth.uid == userId || isAdmin();\n\n      // Users can only create their own user document\n      // No one can update their own role\n      allow create: if request.auth.uid == userId;\n      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;\n    }\n\n    // =================================================================\n    // Patients Collection\n    // =================================================================\n    match /patients/{patientId} {\n      allow read: if isAdmin() || getUserRole() == 'Doctor' || getUserRole() == 'Nurse';\n      \n      // Patients can read their own record if we can match their user ID\n      // to a field on the patient document. This requires a `userId` field\n      // on the patient document.\n      // allow read: if resource.data.userId == request.auth.uid;\n\n      allow create, update: if isAdmin() || getUserRole() == 'Doctor';\n      allow delete: if isAdmin();\n    }\n\n    // =================================================================\n    // Admissions Collection\n    // =================================================================\n    match /admissions/{admissionId} {\n        allow read, create, update: if isAdmin() || getUserRole() == 'Doctor';\n        // A patient can read their own admission history.\n        // allow read: if resource.data.patientId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientId;\n    }\n\n    // =================================================================\n    // Beds Collection\n    // =================================================================\n    match /beds/{bedId} {\n        allow read: if isAdmin() || getUserRole() == 'Doctor' || getUserRole() == 'Nurse' || getUserRole() == 'Housekeeping';\n        allow update: if isAdmin() || getUserRole() == 'Housekeeping'; // Housekeeping can update status to 'vacant'\n        // No one can create or delete beds from the front-end.\n        allow create, delete: if false;\n    }\n\n  }\n}\n"}]}}
