[debug] [2026-02-23T15:16:16.684Z] >>> [apiv2][query] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules [none]
[debug] [2026-02-23T15:16:16.685Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    /**\n     * GAMMED SAAS SECURITY RULES\n     *\n     * Core Philosophy:\n     * This ruleset implements a robust multi-tenant architecture where data isolation is \n     * enforced at the path level. Every document is nested under a specific hospital \n     * (/hospitals/{hospitalId}), ensuring that users only interact with data belonging \n     * to their authorized healthcare facility.\n     *\n     * Data Structure:\n     * Data is organized hierarchically: /hospitals/{hospitalId}/[collection]/{documentId}. \n     * This structure allows for clear separation between different medical facilities \n     * sharing the same database infrastructure.\n     *\n     * Key Security Decisions:\n     * 1. Path-Based Multi-Tenancy: The 'hospitalId' in the URL is the primary anchor for \n     *    all authorization decisions.\n     * 2. Profile-Based RBAC: Access permissions (Admin, Doctor, Staff, Patient) are \n     *    determined by fetching the user's profile from the specific hospital's \n     *    /userProfiles collection.\n     * 3. Relational Integrity: On creation, documents must contain a 'hospitalId' \n     *    matching the URL path to ensure query consistency and data ownership.\n     * 4. Immutability: Critical fields like 'hospitalId' are marked as immutable \n     *    to prevent data from being moved between tenants after creation.\n     *\n     * Denormalization for Authorization:\n     * 'hospitalId' is denormalized onto every document. This allows security rules \n     * to verify tenant ownership instantly. User roles are stored directly within \n     * the UserProfile document at the hospital-specific path, allowing for efficient \n     * role-based lookups.\n     */\n\n    // --- HELPER FUNCTIONS ---\n\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function getProfile(hospitalId) {\n      return get(/databases/$(database)/documents/hospitals/$(hospitalId)/userProfiles/$(request.auth.uid)).data;\n    }\n\n    function isHospitalMember(hospitalId) {\n      return isSignedIn() && exists(/databases/$(database)/documents/hospitals/$(hospitalId)/userProfiles/$(request.auth.uid));\n    }\n\n    function hasRole(hospitalId, role) {\n      return isHospitalMember(hospitalId) && getProfile(hospitalId).role == role;\n    }\n\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    function isExistingOwner(userId) {\n      return resource != null && isOwner(userId);\n    }\n\n    function isValidHospitalLink(hospitalId) {\n      return request.resource.data.hospitalId == hospitalId;\n    }\n\n    function isHospitalLinkImmutable() {\n      return request.resource.data.hospitalId == resource.data.hospitalId;\n    }\n\n    // --- COLLECTION RULES ---\n\n    /**\n     * @description Rules for the top-level Hospital configuration.\n     * @path /hospitals/{hospitalId}\n     * @allow (get) If the user is a member of the hospital.\n     * @deny (write) If the user is not an Admin of the hospital.\n     * @principle Multi-tenancy isolation and Admin-only configuration.\n     */\n    match /hospitals/{hospitalId} {\n      allow get: if isHospitalMember(hospitalId);\n      allow list: if isSignedIn() && hasRole(hospitalId, 'admin');\n      allow create: if isSignedIn() && request.resource.data.id == hospitalId;\n      allow update: if resource != null && hasRole(hospitalId, 'admin');\n      allow delete: if false; // Hospital deletion restricted to system super-admins\n    }\n\n    /**\n     * @description Manages user roles and identities within a hospital.\n     * @path /hospitals/{hospitalId}/userProfiles/{userId}\n     * @allow (create) If the user is setting up their own profile for this hospital.\n     * @deny (update) If the user tries to change their own role (only Admins can).\n     * @principle Self-creation with immutable role assignment for non-admins.\n     */\n    match /hospitals/{hospitalId}/userProfiles/{userId} {\n      allow get: if isOwner(userId) || hasRole(hospitalId, 'admin');\n      allow list: if isHospitalMember(hospitalId) && hasRole(hospitalId, 'admin');\n      allow create: if isOwner(userId) && isValidHospitalLink(hospitalId);\n      allow update: if (isExistingOwner(userId) && request.resource.data.role == resource.data.role) || hasRole(hospitalId, 'admin');\n      allow delete: if resource != null && hasRole(hospitalId, 'admin');\n    }\n\n    /**\n     * @description Stores sensitive patient demographic and medical data.\n     * @path /hospitals/{hospitalId}/patients/{patientId}\n     * @allow (read) All hospital staff members.\n     * @deny (write) Users not explicitly assigned as Staff or Admin.\n     * @principle HIPAA-aligned staff-only access within the tenant boundary.\n     */\n    match /hospitals/{hospitalId}/patients/{patientId} {\n      allow get, list: if isHospitalMember(hospitalId);\n      allow create: if isHospitalMember(hospitalId) && isValidHospitalLink(hospitalId);\n      allow update: if resource != null && isHospitalMember(hospitalId) && isHospitalLinkImmutable();\n      allow delete: if resource != null && hasRole(hospitalId, 'admin');\n    }\n\n    /**\n     * @description Organization units within the hospital (Cardiology, etc.).\n     * @path /hospitals/{hospitalId}/departments/{departmentId}\n     * @allow (read) Any member of the hospital.\n     * @deny (write) Anyone who is not a hospital Admin.\n     * @principle Public internal visibility with restricted administrative control.\n     */\n    match /hospitals/{hospitalId}/departments/{departmentId} {\n      allow get, list: if isHospitalMember(hospitalId);\n      allow create: if hasRole(hospitalId, 'admin') && isValidHospitalLink(hospitalId);\n      allow update: if resource != null && hasRole(hospitalId, 'admin') && isHospitalLinkImmutable();\n      allow delete: if resource != null && hasRole(hospitalId, 'admin');\n    }\n\n    /**\n     * @description Scheduled patient visits and consultations.\n     * @path /hospitals/{hospitalId}/appointments/{appointmentId}\n     * @allow (get) If the user is the patient, the assigned staff, or an admin.\n     * @deny (list) If the user is a patient (Patients should query their own ID).\n     * @principle Shared access between patient and care providers.\n     */\n    match /hospitals/{hospitalId}/appointments/{appointmentId} {\n      allow get: if isHospitalMember(hospitalId) && (isOwner(resource.data.patientId) || isOwner(resource.data.assignedStaffId) || hasRole(hospitalId, 'admin'));\n      allow list: if isHospitalMember(hospitalId);\n      allow create: if isHospitalMember(hospitalId) && isValidHospitalLink(hospitalId);\n      allow update: if resource != null && isHospitalMember(hospitalId) && isHospitalLinkImmutable();\n      allow delete: if resource != null && hasRole(hospitalId, 'admin');\n    }\n\n    /**\n     * @description Working hours and availability for medical personnel.\n     * @path /hospitals/{hospitalId}/staffSchedules/{scheduleId}\n     * @allow (write) The specific staff member or an Admin.\n     * @deny (create) If the staffId in data doesn't match the authenticated user.\n     * @principle Owner-based schedule management.\n     */\n    match /hospitals/{hospitalId}/staffSchedules/{scheduleId} {\n      allow get, list: if isHospitalMember(hospitalId);\n      allow create: if isHospitalMember(hospitalId) && (isOwner(request.resource.data.staffId) || hasRole(hospitalId, 'admin')) && isValidHospitalLink(hospitalId);\n      allow update: if resource != null && (isOwner(resource.data.staffId) || hasRole(hospitalId, 'admin')) && isHospitalLinkImmutable();\n      allow delete: if resource != null && (isOwner(resource.data.staffId) || hasRole(hospitalId, 'admin'));\n    }\n\n    /**\n     * @description High-value bookable assets like MRI machines or Theaters.\n     * @path /hospitals/{hospitalId}/hospitalResources/{resourceId}\n     * @allow (read) All hospital members.\n     * @deny (write) Non-admin users.\n     * @principle Restricted asset management.\n     */\n    match /hospitals/{hospitalId}/hospitalResources/{resourceId} {\n      allow get, list: if isHospitalMember(hospitalId);\n      allow create: if hasRole(hospitalId, 'admin') && isValidHospitalLink(hospitalId);\n      allow update: if resource != null && hasRole(hospitalId, 'admin') && isHospitalLinkImmutable();\n      allow delete: if resource != null && hasRole(hospitalId, 'admin');\n    }\n\n    /**\n     * @description Reservation records for hospital resources.\n     * @path /hospitals/{hospitalId}/resourceBookings/{bookingId}\n     * @allow (create) Any staff member making a booking.\n     * @deny (delete) Anyone except an Admin or the person who booked it.\n     * @principle Accountability for resource allocation.\n     */\n    match /hospitals/{hospitalId}/resourceBookings/{bookingId} {\n      allow get, list: if isHospitalMember(hospitalId);\n      allow create: if isHospitalMember(hospitalId) && isOwner(request.resource.data.bookedById) && isValidHospitalLink(hospitalId);\n      allow update: if resource != null && (isOwner(resource.data.bookedById) || hasRole(hospitalId, 'admin')) && isHospitalLinkImmutable();\n      allow delete: if resource != null && (isOwner(resource.data.bookedById) || hasRole(hospitalId, 'admin'));\n    }\n  }\n}"}]}}
