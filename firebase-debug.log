[debug] [2025-09-09T12:51:09.307Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get a user's role from the 'users' collection\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n\n    // Rules for User management\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId; // Users can update their own profile\n    }\n\n    // Rules for Patient records\n    match /patients/{patientId} {\n      // Allow read access to the patient themselves, or clinical/admin staff\n      allow read: if request.auth.token.patient_id == patientId || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'receptionist', 'billing_clerk'];\n      // Restrict writes to trusted server-side functions or admins\n      allow write: if getUserRole(request.auth.uid) == 'admin';\n      \n      // Rules for all patient sub-collections\n      match /{subcollection}/{docId} {\n        allow read: if request.auth.token.patient_id == patientId || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse'];\n        allow write: if getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse'];\n      }\n    }\n    \n    // Rules for Ward and Bed Management\n    match /wards/{wardId} {\n        allow read: if getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'receptionist'];\n        // In a real app, 'ward_manager' role would be used. For now, only admin can write.\n        allow write: if getUserRole(request.auth.uid) == 'admin';\n    }\n\n    match /beds/{bedId} {\n        allow read: if getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'receptionist'];\n        // Direct writes are disallowed; all updates must go through Cloud Functions.\n        allow write: if false; \n    }\n\n    // Rules for Dietary Management\n    match /dietary_profiles/{profileId} {\n      function isOwner() {\n        return get(/databases/$(database)/documents/patients/$(profileId)).data.uid == request.auth.uid;\n      }\n      allow create, update: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'dietitian'] || isOwner();\n      allow read: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'dietitian', 'doctor'] || isOwner();\n    }\n\n    match /meal_orders/{orderId} {\n       function isPatientOfOrder() {\n        return get(/databases/$(database)/documents/meal_orders/$(orderId)).data.patientId == request.auth.token.patient_id;\n      }\n      allow create: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'doctor'];\n      allow read: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'doctor', 'dietitian'] || isPatientOfOrder();\n      allow update: if getUserRole(request.auth.uid) in ['admin', 'nurse', 'dietitian']; // Assuming 'kitchen_staff' role is not yet defined\n    }\n  }\n}\n"}]}}
