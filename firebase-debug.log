[debug] [2025-08-01T16:54:22.887Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the user's role from their UID\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n\n    // Helper function to check if a user is authenticated\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n    \n    // Helper function to check if the user has one of the specified roles\n    function hasOneOfRoles(roles) {\n      return isAuthenticated() && getUserRole(request.auth.uid) in roles;\n    }\n    \n    // Helper function to check if the user is the owner of the document\n    function isOwner(userId) {\n        return request.auth.uid == userId;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Any authenticated user can read their own user profile\n      // Only Admins can read all user profiles\n      allow read: if isAuthenticated() && (isOwner(userId) || hasOneOfRoles(['Admin']));\n      // Users can create their own profile upon signup\n      // Admins can create other users\n      allow create: if isAuthenticated(); \n      // Users can update their own profile\n      // Admins can update any user's profile\n      allow update: if isAuthenticated() && (isOwner(userId) || hasOneOfRoles(['Admin']));\n      // Only admins can delete users\n      allow delete: if hasOneOfRoles(['Admin']);\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      allow read: if hasOneOfRoles(['Admin', 'Doctor', 'Nurse']) || (hasOneOfRoles(['Patient']) && resource.data.authUid == request.auth.uid);\n      allow create: if hasOneOfRoles(['Admin', 'BillingClerk']);\n      allow update: if hasOneOfRoles(['Admin', 'BillingClerk', 'Doctor', 'Nurse']);\n      allow delete: if hasOneOfRoles(['Admin']);\n    }\n\n    // Rules for the 'admissions' sub-collection within patients\n    match /patients/{patientId}/admissions/{admissionId} {\n        allow read: if hasOneOfRoles(['Admin', 'Doctor', 'Nurse']) || (hasOneOfRoles(['Patient']) && patientId == request.auth.uid);\n        allow create: if hasOneOfRoles(['Admin', 'Doctor']); // Doctors or Admins can admit patients\n        allow update: if hasOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        allow delete: if hasOneOfRoles(['Admin']);\n    }\n\n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n        allow read: if hasOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        allow list: if hasOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        allow create, update, delete: if hasOneOfRoles(['Admin']); // Only Admins can manage bed inventory\n    }\n  }\n}\n"}]}}
