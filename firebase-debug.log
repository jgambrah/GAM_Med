.diff(resource.data).affectedKeys().hasOnly(['assignedToUserId', 'location', 'status']));\n    }\n\n    match /facility_zones/{zoneId} {\n        allow read: if getUserRole() in ['admin', 'manager', 'technician'];\n        allow update: if getUserRole() in ['admin', 'facility_manager'];\n    }\n\n    match /maintenance_requests/{requestId} {\n        allow create: if request.auth != null; // Any staff member can report an issue\n        allow read: if getUserRole() in ['admin', 'manager', 'technician'];\n        allow update: if getUserRole() in ['admin', 'technician'];\n    }\n\n  }\n}\n"}]}}
