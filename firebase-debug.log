[debug] [2025-08-05T13:54:29.305Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // =================================================================\n    // Helper Functions\n    // =================================================================\n\n    // Gets the role of the currently authenticated user from the 'users' collection.\n    // This is the foundation for all our Role-Based Access Control (RBAC) rules.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Checks if the requesting user is the patient they are trying to access.\n    // This is used for patient portal access to their own records.\n    function isPatientSelf(patientId) {\n        // This assumes the patient's record in the 'users' collection has a 'patientId' field\n        // that links to their record in the 'patients' collection.\n        // This is a more secure way than matching UID to patientId directly.\n        // For this to work, the user document must contain a 'patientId' field.\n        let userPatientId = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientId;\n        return getUserRole() == 'Patient' && userPatientId == patientId;\n    }\n\n    // =================================================================\n    // Collection-Specific Rules\n    // =================================================================\n    \n    // The users collection stores basic user info and roles.\n    match /users/{userId} {\n      // Allow users to read their own document.\n      allow read: if request.auth.uid == userId;\n      // Allow users to update their own non-critical info, but not their role.\n      allow update: if request.auth.uid == userId && !('role' in request.resource.data);\n      // Only Admins can create new users or change roles.\n      allow create, delete: if getUserRole() == 'Admin';\n    }\n\n    // Main patient records collection.\n    match /patients/{patientId} {\n      // Allow read access to a wide range of clinical staff and the patient themselves.\n      // Note: 'lab_technician' might be too broad here, but following the spec.\n      // A patient should be able to read their own top-level record.\n      allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'Pharmacist', 'BillingClerk', 'Housekeeping'] || isPatientSelf(patientId);\n      \n      // Only Admins or Doctors can create or update patient demographic data.\n      allow write: if getUserRole() in ['Admin', 'Doctor'];\n\n      // --- EHR Sub-collection Rules ---\n\n      // Clinical notes are for doctors and nurses primarily.\n      match /clinical_notes/{noteId} {\n        allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse'];\n        allow write: if getUserRole() == 'Doctor'; // Only doctors can create, update, or delete notes.\n      }\n\n      // Vitals are typically recorded by nurses.\n      match /vitals/{vitalId} {\n        allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse'];\n        allow write: if getUserRole() == 'Nurse'; // Only nurses can create, update, or delete vital records.\n      }\n\n      // Diagnoses are made by doctors.\n      match /diagnoses/{diagnosisId} {\n        allow read: if getUserRole() in ['Admin', 'Doctor'];\n        allow write: if getUserRole() == 'Doctor'; // Only doctors can manage diagnoses.\n      }\n\n      // Medication history is viewed by many, but only prescribed by doctors.\n      match /medication_history/{prescriptionId} {\n        // Pharmacists need read access to fulfill prescriptions.\n        // Patients can see their own prescription history.\n        allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'Pharmacist'] || isPatientSelf(patientId);\n        // Only doctors can prescribe medication.\n        allow write: if getUserRole() == 'Doctor';\n      }\n\n      // Lab results have specific create/update rules for different roles.\n      match /lab_results/{testId} {\n        // Lab technicians need to read what test was ordered.\n        // Patients can see their own lab results.\n        allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'lab_technician'] || isPatientSelf(patientId);\n        \n        // A doctor orders a test by creating a new document in this sub-collection.\n        allow create: if getUserRole() == 'Doctor';\n        \n        // A lab technician can only update the result-related fields.\n        // They cannot change the test name, ordering doctor, etc.\n        allow update: if getUserRole() == 'lab_technician' \n                      && request.resource.data.diff(resource.data).affectedKeys()\n                         .hasOnly(['result', 'status', 'completedAt', 'labTechnicianId', 'units']);\n                         \n        // No one should be able to delete a lab result for audit purposes.\n        allow delete: if false;\n      }\n    }\n    \n    // Admissions collection records inpatient/outpatient events.\n    match /admissions/{admissionId} {\n        allow read, write: if getUserRole() in ['Admin', 'Doctor', 'Nurse'];\n    }\n\n    // Beds collection for real-time bed status.\n    match /beds/{bedId} {\n        // Housekeeping needs to update bed status, other clinical staff need to read it.\n        allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'Housekeeping'];\n        allow write: if getUserRole() in ['Admin', 'Housekeeping'];\n    }\n\n  }\n}\n"}]}}
