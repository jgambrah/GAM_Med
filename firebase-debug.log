[debug] [2025-08-01T18:09:51.065Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to get the user's role from the 'users' collection.\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n    \n    // Helper function to check if the user has one of the specified roles.\n    function isOneOfRoles(userId, roles) {\n      return getUserRole(userId) in roles;\n    }\n\n    // Rules for the 'users' collection itself\n    match /users/{userId} {\n      // Users can read their own user document.\n      allow read: if request.auth.uid == userId;\n      // Users can create their own user document upon sign-up.\n      allow create: if request.auth.uid == userId;\n      // Users can update their own profile information.\n      allow update: if request.auth.uid == userId;\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      // READ: Patients can see their own data. Clinical staff and admins can see any patient data.\n      allow read: if isOneOfRoles(request.auth.uid, ['Admin', 'Doctor', 'Nurse', 'BillingClerk']) || \n                     (get(/databases/$(database)/documents/patients/$(patientId)).data.authUid == request.auth.uid);\n\n      // CREATE: Admins and Billing Clerks can create new patients.\n      // The document ID must be identical to the patientId field within the document.\n      allow create: if isOneOfRoles(request.auth.uid, ['Admin', 'BillingClerk']) &&\n                     request.resource.id == request.resource.data.patientId;\n\n      // UPDATE: Admins and Billing Clerks can update patient records.\n      // The patientId field must NOT be changed after creation.\n      allow update: if isOneOfRoles(request.auth.uid, ['Admin', 'BillingClerk']) &&\n                     request.resource.data.patientId == resource.data.patientId;\n      \n      // DELETE: Only Admins can delete patient records (use with caution).\n      allow delete: if isOneOfRoles(request.auth.uid, ['Admin']);\n\n      // Rules for the 'admissions' sub-collection\n      match /admissions/{admissionId} {\n        // READ: Access rules mirror the parent patient document.\n        allow read: if isOneOfRoles(request.auth.uid, ['Admin', 'Doctor', 'Nurse', 'BillingClerk']) ||\n                       (get(/databases/$(database)/documents/patients/$(patientId)).data.authUid == request.auth.uid);\n\n        // WRITE: Admins, Doctors, and Nurses can create and update admission records.\n        allow write: if isOneOfRoles(request.auth.uid, ['Admin', 'Doctor', 'Nurse']);\n      }\n    }\n    \n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n      // READ: Any authenticated user can see the status of beds.\n      allow read: if request.auth.uid != null;\n      \n      // WRITE: Only clinical staff and admins can update bed status.\n      allow write: if isOneOfRoles(request.auth.uid, ['Admin', 'Doctor', 'Nurse']);\n    }\n  }\n}\n"}]}}
