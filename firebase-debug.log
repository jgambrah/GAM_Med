[debug] [2026-01-19T09:41:27.662Z] >>> [apiv2][query] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules [none]
[debug] [2026-01-19T09:41:27.667Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"/**\n * MedFlow GH - Firestore Security Rules\n *\n * Core Philosophy:\n * This ruleset enforces a Role-Based Access Control (RBAC) model combined with\n * strict data ownership. Patients have control over their own records, while\n * hospital employees (Doctors, Nurses, Admins) are granted access based on\n * their roles and relationship to the data. The default security posture is\n * to deny access unless explicitly permitted.\n *\n * Data Structure:\n * The database uses a set of top-level collections for primary entities like\n * `users`, `patients`, `employees`, and `appointments`. Sensitive patient data,\n * such as `medicalHistories`, is stored in a subcollection under the\n * corresponding patient document to facilitate inherited permissions.\n *\n * Key Security Decisions:\n * - User-Scoped Data: All data in `/users/{userId}` is strictly private to the\n *   authenticated user matching the `userId`.\n * - Employee Access: Authenticated employees are granted read access to patient,\n *   employee, and schedule collections to facilitate clinical workflows. Writes\n *   are more restricted.\n * - Patient Privacy: A user can only access a `/patients` document if their\n *   own user profile in `/users/{userId}` contains a matching `patientId`.\n * - Shared Documents: Access to `appointments` is shared between the patient\n *   and the doctor associated with the appointment, determined by the `patientId`\n *   and `doctorId` fields on the appointment document itself.\n * - Admin Operations: Collections like `departments` and `resources` are readable\n *   by all staff but are configured to be writable only by users with an 'Admin'\n *   role (currently locked down as a secure default).\n *\n * Denormalization for Authorization:\n * To create simpler and more performant rules, this ruleset relies on denormalization.\n * For example, the `/appointments/{appointmentId}` document contains `patientId` and\n * `doctorId` fields directly. This allows rules to check permissions without needing\n * slow and costly `get()` calls to other documents, enforcing the principle of\n * \"Authorization Independence\".\n *\n * Structural Segregation:\n * The data model separates distinct entities with different access patterns into\n * different top-level collections (e.g., `patients` vs. `employees`). This is\n * more secure and efficient for list queries than co-locating them and filtering\n * with a 'type' field.\n */\nrules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // --------------------------------------------------------------------\n    // Helper Functions\n    // --------------------------------------------------------------------\n\n    /**\n     * Returns true if the user is authenticated.\n     */\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    /**\n     * Returns true if the authenticated user's UID matches the provided userId.\n     * This is the fundamental check for document ownership.\n     */\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    /**\n     * Returns true if the user is an owner and the document already exists.\n     * Used for safe update and delete operations.\n     */\n    function isExistingOwner(userId) {\n      return isOwner(userId) && resource != null;\n    }\n    \n    /**\n     * Retrieves the authenticated user's profile document from the /users collection.\n     * This is used to check for roles and relationships (e.g., patientId).\n     */\n    function getUserData() {\n        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n    \n    /**\n     * Returns true if the authenticated user's role is 'Admin'.\n     * Used for granting privileged access.\n     */\n    function isAdmin() {\n        return isSignedIn() && getUserData().role == 'Admin';\n    }\n    \n    /**\n     * Returns true if the user's role is one of the employee types.\n     */\n    function isEmployee() {\n        return isSignedIn() && getUserData().role in ['Doctor', 'Nurse', 'Pharmacist', 'Admin'];\n    }\n\n    /**\n     * Returns true if the authenticated user is the patient specified by patientId.\n     * Checks the `patientId` field on the user's own profile document.\n     */\n    function isUserThePatient(patientId) {\n        return isSignedIn() && getUserData().patientId == patientId;\n    }\n\n    /**\n     * Returns true if the authenticated user is the employee specified by employeeId.\n     * Checks the `employeeId` field on the user's own profile document.\n     */\n    function isUserTheEmployee(employeeId) {\n        return isSignedIn() && getUserData().employeeId == employeeId;\n    }\n    \n    /**\n     * On create, validates that the new document's ID matches the user's UID.\n     */\n    function newUserDataIsValid(userId) {\n        return request.resource.data.id == userId;\n    }\n\n    /**\n     * On update, ensures the document's ID remains unchanged.\n     */\n    function existingUserDataIsValid() {\n        return request.resource.data.id == resource.data.id;\n    }\n\n    // --------------------------------------------------------------------\n    // Collection Rules\n    // --------------------------------------------------------------------\n\n    /**\n     * @description Users can create, read, and update their own user profile. Deletion is disallowed.\n     * @path /users/{userId}\n     * @allow (create) a new user creates their own user document: auth.uid == 'user_abc', path == '/users/user_abc'.\n     * @deny (get) a user tries to read another user's profile: auth.uid == 'user_123', path == '/users/user_456'.\n     * @principle Restricts access to a user's own data tree.\n     */\n    match /users/{userId} {\n      allow get: if isOwner(userId);\n      allow list: if false; // Disallow listing all users for privacy.\n      allow create: if isOwner(userId) && newUserDataIsValid(userId);\n      allow update: if isExistingOwner(userId) && existingUserDataIsValid();\n      allow delete: if false; // Users should not be able to delete their own auth record.\n    }\n\n    /**\n     * @description A patient can manage their own record. Employees can view any patient's record.\n     * @path /patients/{patientId}\n     * @allow (get) An authenticated doctor views a patient's record.\n     * @deny (update) A patient tries to update another patient's record.\n     * @principle Enforces a combination of data ownership for patients and role-based read access for staff.\n     */\n    match /patients/{patientId} {\n      allow get: if isUserThePatient(patientId) || isEmployee();\n      allow list: if isEmployee(); // Only employees can list/browse patients.\n      allow create: if false; // TODO: Patient records should be created by an Admin.\n      allow update: if (isUserThePatient(patientId) && resource != null) || (isAdmin() && resource != null);\n      allow delete: if false; // TODO: Patient records should be archived by an Admin, not deleted.\n    }\n    \n    /**\n     * @description Medical history is highly sensitive. Access is inherited from the parent patient record.\n     * @path /patients/{patientId}/medicalHistories/{medicalHistoryId}\n     * @allow (get) A doctor views the medical history of a patient they have access to.\n     * @deny (list) A patient tries to list the medical history of another patient.\n     * @principle Secures a subcollection by checking permissions on the parent document.\n     */\n    match /patients/{patientId}/medicalHistories/{medicalHistoryId} {\n      allow get: if isUserThePatient(patientId) || isEmployee();\n      allow list: if isUserThePatient(patientId) || isEmployee();\n      // Only employees (e.g., Doctors, Nurses) can create or update medical history.\n      allow create: if isEmployee() && request.resource.data.patientId == patientId;\n      allow update: if isEmployee() && resource != null && request.resource.data.patientId == resource.data.patientId;\n      allow delete: if isAdmin() && resource != null;\n    }\n\n    /**\n     * @description Employee profiles are viewable by any authenticated user (like a staff directory).\n     * @path /employees/{employeeId}\n     * @allow (get) Any signed-in user (e.g., a patient) can look up a doctor's profile.\n     * @deny (update) An employee tries to modify another employee's profile.\n     * @principle Implements a public-read directory model for non-sensitive data, with ownership for writes.\n     */\n    match /employees/{employeeId} {\n      allow get: if isSignedIn();\n      allow list: if isSignedIn();\n      allow create: if false; // TODO: Employee records should be created by an Admin.\n      allow update: if (isUserTheEmployee(employeeId) && resource != null) || (isAdmin() && resource != null);\n      allow delete: if isAdmin() && resource != null;\n    }\n\n    /**\n     * @description Appointments can be read by the patient or doctor involved. Patients can create them.\n     * @path /appointments/{appointmentId}\n     * @allow (get) A patient with patientId 'p123' reads an appointment where `resource.data.patientId` is 'p123'.\n     * @deny (update) A doctor tries to modify an appointment they are not assigned to.\n     * @principle Implements a shared access model for documents involving multiple parties.\n     */\n    match /appointments/{appointmentId} {\n      // An appointment can be read by the patient or the doctor involved.\n      function isParticipant(doc) {\n        return isUserThePatient(doc.patientId) || isUserTheEmployee(doc.doctorId);\n      }\n      \n      allow get: if isParticipant(resource.data);\n      allow list: if false; // Prevent querying all appointments; queries must be specific.\n      // A patient can create their own appointment, or an employee can create one for them.\n      allow create: if isUserThePatient(request.resource.data.patientId) || isEmployee();\n      // An existing appointment can be updated by a participant.\n      allow update: if isParticipant(resource.data) && resource != null;\n      // An existing appointment can be deleted (cancelled) by a participant.\n      allow delete: if isParticipant(resource.data) && resource != null;\n    }\n\n    /**\n     * @description Schedules are managed by the employee they belong to, but viewable by all staff.\n     * @path /schedules/{scheduleId}\n     * @allow (get) A nurse looks up a doctor's schedule.\n     * @deny (create) A patient tries to create a schedule for a doctor.\n     * @principle Enforces document ownership for writes while allowing broader read access for internal staff.\n     */\n    match /schedules/{scheduleId} {\n      allow get: if isEmployee();\n      allow list: if isEmployee();\n      // An employee can create a schedule for themselves.\n      allow create: if isUserTheEmployee(request.resource.data.employeeId);\n      // Only the assigned employee or an Admin can update/delete their schedule.\n      allow update: if (isUserTheEmployee(resource.data.employeeId) && resource != null) || (isAdmin() && resource != null);\n      allow delete: if (isUserTheEmployee(resource.data.employeeId) && resource != null) || (isAdmin() && resource != null);\n    }\n\n    /**\n     * @description Department and Resource info is public to all authenticated users, but writable only by Admins.\n     * @path /departments/{departmentId}\n     * @allow (get) Any authenticated user can read department information.\n     * @deny (create) Any non-admin user tries to create a new department.\n     * @principle Provides public read access for system-wide data with centralized admin control for writes.\n     */\n    match /departments/{departmentId} {\n      allow get, list: if isSignedIn();\n      allow create, update, delete: if false; // TODO: Implement `if isAdmin();` when admin role is fully defined.\n    }\n    \n    /**\n     * @description Department and Resource info is public to all authenticated users, but writable only by Admins.\n     * @path /resources/{resourceId}\n     * @allow (get) Any authenticated user can read resource information (e.g., operating rooms).\n     * @deny (create) Any non-admin user tries to create a new resource.\n     * @principle Provides public read access for system-wide data with centralized admin control for writes.\n     */\n    match /resources/{resourceId} {\n      allow get, list: if isSignedIn();\n      allow create, update, delete: if false; // TODO: Implement `if isAdmin();` when admin role is fully defined.\n    }\n  }\n}"}]}}
