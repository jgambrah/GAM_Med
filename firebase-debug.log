[debug] [2025-08-08T17:44:57.579Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the user's role from the 'users' collection.\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n\n    // Helper function to check if the user is an authorized clinical or admin staff.\n    function isStaff() {\n      let userRole = getUserRole(request.auth.uid);\n      return request.auth != null && (userRole == 'admin' || userRole == 'doctor' || userRole == 'nurse');\n    }\n\n    // Helper function to check for administrative roles that can handle records.\n    function isRecordsAdmin() {\n        let userRole = getUserRole(request.auth.uid);\n        return request.auth != null && (userRole == 'admin' || userRole == 'billing_clerk');\n    }\n\n    // =====================================================================\n    // PATIENTS Collection\n    // =====================================================================\n    match /patients/{patientId} {\n      /**\n       * READ:\n       * - Allow authorized staff (admin, doctor, nurse) to read any patient record.\n       * - Allow patients to read their own record if their user document is linked.\n       */\n      allow read: if isStaff() || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);\n\n      /**\n       * CREATE:\n       * - Only authorized administrative staff can create patient records.\n       * - Enforce that the document ID must be identical to the `patientId` field within the document.\n       *   This is a critical integrity check.\n       */\n      allow create: if isRecordsAdmin() && request.resource.id == request.resource.data.patientId;\n\n      /**\n       * UPDATE:\n       * - Only authorized administrative staff can update patient records.\n       * - Crucially, prevent the `patientId` field from ever being changed.\n       * - Other clinical fields would be updated via sub-collections with their own rules.\n       */\n      allow update: if isRecordsAdmin() && request.resource.data.patientId == resource.data.patientId;\n      \n      // DENY all deletes to prevent accidental data loss. Data should be marked 'inactive' or 'deceased'.\n      allow delete: if false;\n\n      // --- Admissions Sub-collection ---\n      match /admissions/{admissionId} {\n        /**\n         * READ:\n         * - Staff can read admission history.\n         * - Patients can read their own admission history.\n         */\n        allow read: if isStaff() || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);\n        \n        /**\n         * WRITE:\n         * - All admission/discharge logic is handled exclusively by secure Cloud Functions.\n         * - Direct client writes are forbidden to ensure data consistency.\n         */\n        allow write: if false; // Writes should only be from Cloud Functions\n      }\n    }\n\n    // =====================================================================\n    // BEDS Collection\n    // =====================================================================\n    match /beds/{bedId} {\n      /**\n       * READ:\n       * - Only authorized clinical and administrative staff can view bed status.\n       */\n      allow read: if isStaff();\n      \n      /**\n       * WRITE:\n       * - Bed status changes are highly sensitive and are only managed by secure Cloud Functions\n       *   during admission, transfer, or discharge to prevent inconsistencies.\n       */\n      allow write: if false; // Writes should only be from Cloud Functions\n    }\n\n    // =====================================================================\n    // USERS Collection\n    // =====================================================================\n    match /users/{userId} {\n       // Allow users to read their own document. Admins can read any user document.\n      allow read: if request.auth.uid == userId || getUserRole(request.auth.uid) == 'admin';\n      \n      // Allow users to update their own non-critical info. Role changes are admin-only.\n      allow update: if request.auth.uid == userId;\n    }\n  }\n}\n"}]}}
