[debug] [2025-09-08T16:33:42.344Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Helper function to check if a user is authenticated\n    function isSignedIn() {\n      return request.auth != null;\n    }\n    \n    // Rules for patients collection\n    match /patients/{patientId} {\n      // Anyone authenticated can read patient data (e.g. for searching)\n      // but sub-collection rules will be more restrictive.\n      allow read: if isSignedIn();\n      \n      // Only trusted server-side functions can create/update patients\n      // to ensure data integrity and proper ID generation.\n      allow write: if false; // Managed by Cloud Functions\n      \n      // Sub-collection rules\n      match /alerts/{alertId} {\n      \tallow read, write: if isSignedIn(); // Add more granular rules as needed\n      }\n      match /clinical_notes/{noteId} {\n      \tallow read, write: if isSignedIn(); // Add more granular rules as needed\n      }\n      match /vitals/{vitalId} {\n      \tallow read, write: if isSignedIn(); // Add more granular rules as needed\n      }\n       match /radiology_history/{reportId} {\n      \tallow create: if false; // Only allow creation via Cloud Function\n        allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor'];\n        allow update, delete: if false;\n      }\n    }\n    \n    // Rules for users collection\n    match /users/{userId} {\n      // Users can read their own profile, admins can read any.\n      allow read: if request.auth.uid == userId || getUserRole() == 'admin';\n      // Users can update their own profile, admins can update any.\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n\n    // Rules for radiology orders\n    match /radiology_orders/{orderId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'] || request.auth.uid == resource.data.assignedRadiologistId;\n        allow update: if false; // To be managed by a trusted Cloud Function\n        allow create: if getUserRole() in ['admin', 'doctor'];\n        allow delete: if getUserRole() == 'admin';\n    }\n\n    // Rules for radiology reports\n    match /radiology_reports/{reportId} {\n        allow create: if getUserRole() in ['admin', 'radiologist'];\n        allow read: if getUserRole() in ['admin', 'doctor', 'radiologist'] || request.auth.uid == resource.data.patientId;\n        // A report can only be updated if it is not yet final\n        allow update: if getUserRole() == 'radiologist' && resource.data.isFinal == false;\n        allow delete: if false; // Reports should be archived, not deleted\n    }\n\n    // Rules for Wards\n    match /wards/{wardId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];\n      // Writes should be handled by a trusted backend function to ensure counters are accurate\n      allow write: if false;\n    }\n\n    // Rules for Beds\n    match /beds/{bedId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];\n      // Bed assignments are critical and should only be handled by a trusted Cloud Function\n      allow write: if false; \n    }\n    \n    // Rules for Operating Theatres\n    match /operating_theatres/{theatreId} {\n       allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n       // OT bookings are complex and should be handled by a trusted Cloud Function\n       allow write: if false;\n    }\n  }\n}\n"}]}}
