[debug] [2025-08-28T16:00:41.808Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Allow read for authenticated users, but restrict writes to admins\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() == 'admin';\n    }\n\n    match /patients/{patientId} {\n      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      // Allow patients to read their own data\n      allow read: if request.auth.uid == resource.data.uid;\n    }\n    \n    // Prescriptions can be created by doctors/admins, read by clinical staff/the patient,\n    // and updated (status change) by pharmacists/admins.\n    match /prescriptions/{prescriptionId} {\n        allow create: if getUserRole() in ['admin', 'doctor'];\n        allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor'] || request.auth.uid == resource.data.patientId;\n        allow update: if getUserRole() in ['admin', 'pharmacist'] \n                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])\n                      && request.resource.data.status in ['Dispensed', 'Canceled'];\n    }\n\n    match /inventory/{itemId} {\n      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];\n      // Only allow authorized users to update the quantity. All other fields are protected.\n      allow update: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager']\n                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentQuantity']);\n\n      // Rules for the transactions sub-collection\n      match /transactions/{transactionId} {\n        // Only allow authorized users to create new transaction logs.\n        // Reading/updating/deleting logs is disallowed for data integrity.\n        allow read, update, delete: if false;\n        allow create: if getUserRole() in ['admin', 'pharmacist', 'inventory_manager'];\n      }\n    }\n\n    // By default, deny all other reads and writes\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}"}]}}
