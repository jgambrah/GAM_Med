[debug] [2025-08-01T18:56:54.107Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the role of the currently authenticated user\n    function getUserRole() {\n      // In a real application, you would also check if the user document exists\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Helper function to check if the request is coming from a specific set of roles\n    function isOneOfRoles(allowedRoles) {\n      return getUserRole() in allowedRoles;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Users can read their own data. Admins can read anyone's data.\n      allow read: if request.auth.uid == userId || isOneOfRoles(['Admin']);\n      // Users can update their own data. Admins can update anyone's data.\n      allow update: if request.auth.uid == userId || isOneOfRoles(['Admin']);\n      // Only admins can create or delete user records.\n      allow create, delete: if isOneOfRoles(['Admin']);\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'Pharmacist', 'BillingClerk']);\n      \n      allow create: if isOneOfRoles(['Admin', 'BillingClerk'])\n                    // Enforce that the document ID and the patientId field inside it match\n                    && request.resource.id == request.resource.data.patientId;\n\n      allow update: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk'])\n                    // Prevent the patientId from being changed after creation\n                    && request.resource.data.patientId == resource.data.patientId;\n                    \n      allow delete: if isOneOfRoles(['Admin']);\n\n      // Rules for the 'admissions' sub-collection\n      match /admissions/{admissionId} {\n        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']) ||\n                     // A patient can read their own admission records.\n                     (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientId == patientId);\n\n        allow create: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        \n        // Admins have full update rights.\n        // Clinical staff can update clinical fields.\n        // Billing staff can update billing fields.\n        allow update: if isOneOfRoles(['Admin']) || \n                       (isOneOfRoles(['Doctor', 'Nurse']) && onlyFieldsChanged(['status', 'attendingDoctorId', 'dischargeSummary'])) ||\n                       (isOneOfRoles(['BillingClerk']) && onlyFieldsChanged(['billingStatus'])); // Assuming a 'billingStatus' field exists\n                       \n        allow delete: if isOneOfRoles(['Admin']);\n      }\n    }\n\n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n      // Clinical and admin staff can see bed status.\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      // Only Admins can create/delete bed records.\n      // Clinical staff can update bed status (e.g., occupied, cleaning).\n      allow update: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      allow create, delete: if isOneOfRoles(['Admin']);\n    }\n    \n    // A helper function to check if only specific fields are being changed during an update.\n    function onlyFieldsChanged(allowedFields) {\n      return request.resource.data.keys().hasOnly(resource.data.keys().remove(allowedFields).concat(allowedFields));\n    }\n  }\n}\n"}]}}
