[debug] [2025-08-20T11:58:49.282Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // ===================================\n    // == Operating Theatre (OT) Rules\n    // ===================================\n    match /operating_theaters/{theaterId} {\n      allow read: if getUserRole() in ['admin', 'ot_coordinator', 'doctor'];\n      allow write: if getUserRole() == 'admin';\n    }\n    \n    match /ot_sessions/{sessionId} {\n      allow create: if getUserRole() in ['admin', 'ot_coordinator', 'doctor'] \n                    && request.resource.data.leadSurgeonId == request.auth.uid;\n      allow read: if getUserRole() in ['admin', 'ot_coordinator'] \n                  || request.auth.uid == resource.data.leadSurgeonId \n                  || request.auth.uid in resource.data.teamIds;\n      allow update: if getUserRole() in ['admin', 'ot_coordinator'];\n      // No delete rule for audit purposes\n    }\n\n    // ===================================\n    // == Resource Scheduling Rules\n    // ===================================\n    match /resources/{resourceId} {\n      allow read: if request.auth != null; // All authenticated users can see the resource catalog\n      allow write: if getUserRole() == 'admin'; // Only admins can add/edit resources\n    }\n\n    match /resource_bookings/{bookingId} {\n      allow create: if getUserRole() in ['admin', 'doctor', 'receptionist', 'ot_coordinator'];\n      allow read: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.bookedByUserId;\n      allow update: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.bookedByUserId;\n    }\n    \n    // Other rules will go here...\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
