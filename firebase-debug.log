[debug] [2025-08-18T14:18:36.901Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the role of the currently authenticated user.\n    // It reads from the /users/{userId} document.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Helper function to check if the authenticated user is the owner of the patient record.\n    function isPatient(patientId) {\n      // This is a more secure way to check. It fetches the user document\n      // and compares its patient_id field with the patientId from the path.\n      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n      return 'patient_id' in userDoc && userDoc.patient_id == patientId;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Admins can read and write any user document.\n      // Users can read and update their own document.\n      allow read, update: if getUserRole() == 'admin' || request.auth.uid == userId;\n      allow create: if getUserRole() == 'admin';\n    }\n\n    // Rules for the 'patients' collection and its sub-collections\n    match /patients/{patientId} {\n      // Allow create access to admins and nurses.\n      allow create: if getUserRole() in ['admin', 'nurse'];\n      \n      // Allow read/update access to admins, doctors, nurses, or the patient themselves.\n      allow read, update: if getUserRole() in ['admin', 'doctor', 'nurse'] || isPatient(patientId);\n      \n      // Deny delete access by default to prevent accidental data loss.\n      allow delete: if false;\n\n      // == Sub-collection: Clinical Notes ==\n      match /clinical_notes/{noteId} {\n        // Clinical staff can read all notes. Patients can only read notes for their own record.\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || isPatient(patientId);\n        // Only doctors and nurses can create or update notes.\n        allow create, update: if getUserRole() in ['doctor', 'nurse'];\n      }\n      \n      // == Sub-collection: Admissions ==\n      match /admissions/{admissionId} {\n        // Clinical/admin staff can read. Patients can read their own.\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || isPatient(patientId);\n        // Only clinical/admin staff can create or update admissions.\n        allow create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n\n      // == Sub-collection: Alerts (Clinical Decision Support) ==\n      match /alerts/{alertId} {\n        // Clinical/admin staff can read alerts.\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        // Alerts are created by Cloud Functions and can be updated (acknowledged) by doctors/admins.\n        allow create: if false; // Only backend functions can create alerts.\n        allow update: if getUserRole() in ['admin', 'doctor'];\n      }\n      \n      // == Sub-collection: Immunizations ==\n      match /immunizations/{immunizationId} {\n        // Allow read access to clinical staff or the patient themselves.\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'] || isPatient(patientId);\n        // Only clinical staff can create or update immunization records.\n        allow create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      \n      // == Sub-collection: Appointment History ==\n      match /appointment_history/{appointmentId} {\n        // Allow read to staff or the patient themselves.\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk'] || isPatient(patientId);\n        // Write access should be locked down, as this is a denormalized collection managed by Cloud Functions.\n        allow write: if false; // Deny direct client writes.\n      }\n    }\n    \n    // Rules for the 'beds' collection (Bed Management)\n    match /beds/{bedId} {\n        // All clinical and admin staff can view bed status.\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        // Only admins and nurses can update bed status (e.g., for cleaning, maintenance).\n        allow write: if getUserRole() in ['admin', 'nurse'];\n    }\n    \n    // Rules for the 'referrals' collection\n    match /referrals/{referralId} {\n      // Admins and doctors can manage referrals.\n      allow read, write: if getUserRole() in ['admin', 'doctor'];\n    }\n\n    // Rules for the 'clinical_rules' collection (CDS Engine)\n    match /clinical_rules/{ruleId} {\n      // All authenticated users (including CDS functions) can read the rules.\n      allow read: if request.auth != null;\n      // Only admins can modify the rules for the CDS engine.\n      allow write: if getUserRole() == 'admin';\n    }\n    \n    // Rules for the 'vaccine_catalog' collection (Immunization Module)\n    match /vaccine_catalog/{vaccineId} {\n      // Any authenticated user (including patients) can read the vaccine catalog.\n      allow read: if request.auth != null;\n      // Only admins can create, update, or delete vaccines from the catalog.\n      allow write: if getUserRole() == 'admin';\n    }\n    \n    // == Rules for Appointment & Scheduling Management ==\n    \n    // Rules for the top-level 'appointments' collection\n    match /appointments/{appointmentId} {\n      // Patients can book their own appointments. Admins and roles like 'billing_clerk' (receptionist) can book for others.\n      allow create: if getUserRole() in ['admin', 'billing_clerk'] || request.auth.uid == request.resource.data.patientId;\n\n      // A user can read an appointment if they are an admin, staff, the patient, or the assigned doctor.\n      allow read: if getUserRole() in ['admin', 'doctor', 'billing_clerk'] || request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId;\n\n      // Admins and receptionists can update any appointment.\n      // Doctors can update appointments they are assigned to.\n      // Patients can only update their own appointments if they are cancelling it.\n      allow update: if getUserRole() in ['admin', 'billing_clerk']\n                    || (getUserRole() == 'doctor' && request.auth.uid == resource.data.doctorId)\n                    || (isPatient(resource.data.patientId) && request.resource.data.status == 'Canceled');\n    }\n    \n    // Rules for the 'doctor_schedules' collection\n    match /doctor_schedules/{scheduleId} {\n      // Any authenticated user can read doctor schedules to check for availability.\n      allow read: if request.auth != null;\n      // Only an admin or the doctor themselves can write to their schedule.\n      allow write: if getUserRole() == 'admin' || request.auth.uid == resource.data.doctorId;\n    }\n    \n    // Rules for the 'resources' collection (e.g., rooms, equipment)\n    match /resources/{resourceId} {\n      // Any authenticated user can read resource availability.\n      allow read: if request.auth != null;\n      // Only admins can create, update, or delete resources.\n      allow write: if getUserRole() == 'admin';\n    }\n  }\n}\n"}]}}
