[debug] [2025-08-01T17:46:53.711Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions to simplify rule definitions\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function isUser(userId) {\n      return request.auth.uid == userId;\n    }\n\n    // Get the user's role from their document in the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    function isRole(role) {\n        return isAuthenticated() && getUserRole() == role;\n    }\n\n    function isOneOfRoles(roles) {\n      return isAuthenticated() && getUserRole() in roles;\n    }\n    \n    // Check if incoming data for an update only contains allowed fields\n    function isUpdatingAllowedFields(allowedFields) {\n      return request.resource.data.keys().hasOnly(allowedFields);\n    }\n\n    // --- Users Collection Rules ---\n    // Users can read their own data.\n    // Only authenticated users can create their own user record (during sign-up).\n    // Users can only update their own data.\n    match /users/{userId} {\n      allow read, update: if isAuthenticated() && isUser(userId);\n      allow create: if isAuthenticated();\n    }\n\n    // --- Patients Collection Rules ---\n    match /patients/{patientId} {\n      // READ: Admins, Doctors, Nurses, and BillingClerks can read any patient data.\n      // A patient can read their own record (assuming patientId might be linked to auth UID in a real scenario,\n      // but for RBAC, role is the primary gatekeeper).\n      // For this ruleset, we will rely on role-based access for clinical/admin staff.\n      // A rule for patients reading their own data would require a field like `uid` on the patient doc:\n      // `|| isUser(resource.data.uid)`\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']);\n\n      // CREATE: Only Admins and BillingClerks can register new patients.\n      allow create: if isOneOfRoles(['Admin', 'BillingClerk']);\n\n      // UPDATE: Admins/BillingClerks can update administrative fields.\n      // Clinical staff (Doctors/Nurses) can only update admission status as part of a workflow.\n      allow update: if isOneOfRoles(['Admin', 'BillingClerk']) ||\n                      (isOneOfRoles(['Doctor', 'Nurse']) && isUpdatingAllowedFields(['isAdmitted', 'currentAdmissionId', 'updatedAt']));\n                      \n      // DELETE: No one can delete patient records through the client. Deletion should be a backend process.\n      allow delete: if false;\n\n      // --- Admissions Sub-collection Rules ---\n      match /admissions/{admissionId} {\n        // READ: Access is granted if the user has rights to read the parent patient document.\n        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'BillingClerk']);\n        \n        // CREATE: Clinical staff and admins can create admission records.\n        allow create: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        \n        // UPDATE/DELETE: Primarily handled by server-side logic (simulated by Server Actions).\n        // Limited client-side updates can be allowed for specific fields if necessary.\n        allow update: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        allow delete: if false;\n      }\n    }\n    \n    // --- Beds Collection Rules ---\n    match /beds/{bedId} {\n        // READ: All clinical and admin staff can see bed statuses.\n        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        \n        // WRITE (Create, Update, Delete): Only clinical staff and admins can manage beds.\n        // This is crucial for the admission/discharge/transfer workflows.\n        allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n    }\n  }\n}\n"}]}}
