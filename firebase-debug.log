[debug] [2025-08-27T16:09:31.372Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n  \n    match /patients/{patientId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      \n      match /{allSubcollections=**} {\n        allow read, write: if request.auth != null;\n      }\n    }\n    \n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n    \n    match /appointments/{appointmentId} {\n        allow read, create: if request.auth != null;\n        allow update, delete: if getUserRole() in ['admin', 'doctor'];\n    }\n\n    match /inventory/{itemId} {\n      allow read: if getUserRole() in ['admin', 'pharmacist', 'doctor', 'nurse'];\n      allow update: if getUserRole() in ['admin', 'pharmacist'];\n      allow create, delete: if getUserRole() == 'admin';\n    }\n\n    match /pharmacy_orders/{orderId} {\n      allow read, create, update: if getUserRole() in ['admin', 'pharmacist'];\n    }\n  }\n}\n"}]}}
