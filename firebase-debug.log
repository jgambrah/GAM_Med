[debug] [2025-08-20T16:53:16.745Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the role of the requesting user.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // =============================================\n    // == User and Patient Data Rules\n    // =============================================\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n\n    match /patients/{patientId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'lab_technician'] || request.auth.uid == patientId;\n      allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n\n      // Rules for all patient sub-collections\n      match /{subcollection}/{docId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'lab_technician'] || request.auth.uid == patientId;\n        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n    }\n    \n    // =============================================\n    // == Core Module Rules\n    // =============================================\n    match /beds/{bedId} {\n      allow read: if request.auth != null;\n      allow write: if getUserRole() in ['admin', 'nurse'];\n    }\n    \n    match /appointments/{appointmentId} {\n      allow read: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.patient_id || request.auth.uid == resource.data.doctor_id;\n      allow write: if getUserRole() in ['admin', 'receptionist', 'doctor'];\n    }\n\n    match /prescriptions/{prescriptionId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'pharmacist'] || request.auth.uid == resource.data.patient_id;\n      allow write: if getUserRole() in ['admin', 'doctor', 'pharmacist'];\n    }\n\n    match /referrals/{referralId} {\n      allow read, write: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n    }\n\n    // =============================================\n    // == Waiting List Rules\n    // =============================================\n    match /waiting_lists/{waitingListId} {\n      allow create: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n      allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'] || request.auth.uid == resource.data.patientId;\n      allow update: if getUserRole() in ['admin', 'receptionist'];\n    }\n    \n    // =============================================\n    // == Resource Management Rules\n    // =============================================\n    match /resources/{resourceId} {\n        allow read: if request.auth != null;\n        allow write: if getUserRole() == 'admin';\n    }\n\n    match /resource_bookings/{bookingId} {\n        allow create: if getUserRole() in ['admin', 'doctor', 'receptionist', 'ot_coordinator'];\n        allow read: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.bookedByUserId;\n        allow update: if getUserRole() in ['admin', 'receptionist'] || request.auth.uid == resource.data.bookedByUserId;\n    }\n    \n    // =============================================\n    // == Financial Management Rules\n    // =============================================\n    match /invoices/{invoiceId} {\n      // Patients can read their own invoices. Financial staff and admins can read any.\n      allow read: if (getUserRole() in ['admin', 'billing_clerk']) || (exists(/databases/$(database)/documents/patients/$(request.auth.uid)) && get(/databases/$(database)/documents/patients/$(request.auth.uid)).data.patient_id == resource.data.patientId);\n      // Only financial staff and admins can create, update, or delete invoices.\n      allow write: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n\n    match /payments/{paymentId} {\n      // Only financial staff should be able to read payment records directly.\n      // A payment gateway would need a service account or special function identity.\n      allow read: if getUserRole() in ['admin', 'billing_clerk'];\n      // Only financial staff can manually create payments.\n      // In production, you would add a rule to allow creation from a trusted Cloud Function.\n      allow create: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n\n    match /insurance_claims/{claimId} {\n      // Only financial staff can manage insurance claims.\n      allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n\n    match /billing_codes/{codeId} {\n      // All authenticated staff can read the list of available services and prices.\n      allow read: if request.auth != null;\n      // Only admins can modify the master list of billing codes.\n      allow write: if getUserRole() == 'admin';\n    }\n  }\n}"}]}}
