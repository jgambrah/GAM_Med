[debug] [2025-08-05T12:53:05.940Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper functions for security rules\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    function isDoctor() {\n      return isSignedIn() && getUserRole() == 'Doctor';\n    }\n\n    function isNurse() {\n      return isSignedIn() && getUserRole() == 'Nurse';\n    }\n\n    function isAdmin() {\n      return isSignedIn() && getUserRole() == 'Admin';\n    }\n    \n    function isPharmacist() {\n        return isSignedIn() && getUserRole() == 'Pharmacist';\n    }\n    \n    function isPatientOwner(patientId) {\n      // Assuming the user's UID is the same as the patient's document ID in a `patients` collection\n      // or that there's a linking field. For this app, we check if the authenticated user's ID\n      // matches a `userId` field on the patient document.\n      // This part is conceptual as we don't have a direct user-to-patient link in the mock data.\n      // A real implementation would require this link. For now, we'll assume a patient can read their own data.\n      return request.auth.uid == resource.data.userId; \n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Users can read their own data. Admins can read anyone's data.\n      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());\n      // Users can create their own profile, or an admin can.\n      allow create: if isSignedIn();\n      // Users can update their own data. Admins can update anyone's.\n      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());\n    }\n\n    // Rules for the 'patients' collection and its sub-collections\n    match /patients/{patientId} {\n      // CREATE: New patients can be created by Admins or Doctors.\n      allow create: if isDoctor() || isAdmin();\n      \n      // READ: Admins, Doctors, and Nurses can read patient records.\n      // A patient should be able to read their own record (isPatientOwner check).\n      allow read: if isDoctor() || isNurse() || isAdmin() || isPatientOwner(patientId);\n      \n      // UPDATE: Patient demographics can be updated by Admins.\n      // Clinical status updates might be handled by Doctors or Nurses.\n      allow update: if isDoctor() || isAdmin();\n\n      // DELETE: Generally, patient records should not be deleted (soft-delete instead).\n      // Only allow deletion by a super-admin role if absolutely necessary.\n      allow delete: if false;\n\n      // --- EHR Sub-collections ---\n\n      // Clinical Notes (Doctors, Nurses)\n      match /clinicalNotes/{noteId} {\n        allow read, write: if isDoctor() || isNurse();\n      }\n\n      // Vital Signs (Primarily Nurses)\n      match /vitalSigns/{vitalId} {\n        allow read: if isDoctor() || isNurse();\n        allow write: if isNurse(); // Nurses typically record vitals\n      }\n\n      // Lab Results (Doctors, Nurses can view; Lab system writes)\n      match /labResults/{labResultId} {\n        allow read: if isDoctor() || isNurse();\n        // Writes would typically come from a trusted backend service/lab system, not directly from a user role.\n        // For direct entry, you could allow doctors.\n        allow write: if isDoctor(); \n      }\n\n      // Medication Orders (Doctors write; Pharmacists read/update status)\n      match /medicationOrders/{orderId} {\n        allow read: if isDoctor() || isNurse() || isPharmacist();\n        allow create: if isDoctor();\n        // Allow pharmacists to update the status (e.g., 'filled')\n        allow update: if isPharmacist();\n      }\n\n      // Allergy records\n      match /allergies/{allergyId} {\n        allow read, write: if isDoctor() || isNurse();\n      }\n      \n      // Imaging Reports\n      match /imagingReports/{reportId} {\n        allow read: if isDoctor();\n        // Write would come from a backend imaging service\n        allow write: if isDoctor(); \n      }\n    }\n    \n    // Rules for other collections\n    match /admissions/{admissionId} {\n        allow read, write: if isDoctor() || isAdmin();\n    }\n    \n    match /beds/{bedId} {\n        allow read: if isDoctor() || isNurse() || isAdmin();\n        allow write: if isAdmin(); // Only admins can directly manipulate bed status, others via actions.\n    }\n  }\n}\n"}]}}
