[debug] [2025-08-07T18:26:53.805Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get user role from the 'users' collection\n    function getUserData() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Allow users to read their own data\n      allow read: if request.auth.uid == userId;\n      // Allow admins to read any user data\n      allow read: if getUserData().role == 'Admin';\n      // Allow authenticated users to create their own user document\n      allow create: if request.auth.uid == userId;\n      // Allow users to update their own data\n      allow update: if request.auth.uid == userId;\n       // Disallow deletion of user accounts to maintain data integrity\n      allow delete: if false;\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      // Admins and Nurses can create, read, and update patient records\n      allow read, create, update: if getUserData().role in ['Admin', 'Nurse'];\n      // Doctors can read patient records\n      allow read: if getUserData().role == 'Doctor';\n      // Patients can read their own records, if we add a link in their user doc\n      // allow read: if request.auth.uid == resource.data.linkedUid; \n      allow delete: if getUserData().role == 'Admin';\n    }\n\n    // Rules for the 'appointments' collection\n    match /appointments/{appointmentId} {\n        // Admins and Nurses can manage all appointments\n        allow create, read, update: if getUserData().role in ['Admin', 'Nurse'];\n        \n        // Doctors can read appointments they are assigned to\n        allow read: if getUserData().role == 'Doctor' && getUserData().uid == resource.data.doctorId;\n        \n        // Doctors can update appointments assigned to them (e.g., to add notes)\n        allow update: if getUserData().role == 'Doctor' && getUserData().uid == resource.data.doctorId;\n\n        // Patients can read appointments they are part of\n        // allow read: if get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.linkedUid == request.auth.uid;\n        \n        // Only Admins can delete appointments\n        allow delete: if getUserData().role == 'Admin';\n    }\n  }\n}\n"}]}}
