[debug] [2025-08-04T14:15:08.120Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // =================================\n    // Helper Functions\n    // =================================\n    \n    // Check if the user's role is in the allowed list\n    function isOneOfRoles(allowedRoles) {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in allowedRoles;\n    }\n    \n    // Validate the incoming patient data schema\n    function isPatientDataValid(data) {\n      return data.fullName is string &&\n             data.dob is timestamp &&\n             data.gender is string &&\n             data.contact.primaryPhone is string &&\n             data.isAdmitted is bool;\n    }\n    \n    // =================================\n    // Collections\n    // =================================\n    \n    // User profile information, including their role.\n    match /users/{userId} {\n      // Users can only read their own profile.\n      allow read: if request.auth.uid == userId;\n      // Users can only create their own profile during signup.\n      allow create: if request.auth.uid == userId;\n      // Users can only update their own profile.\n      allow update: if request.auth.uid == userId;\n    }\n\n    // Main patient records collection.\n    match /patients/{patientId} {\n      \n      // CREATE: Only Admins can register new patients.\n      allow create: if isOneOfRoles(['Admin']) && isPatientDataValid(request.resource.data);\n      \n      // READ:\n      // - Admins, Doctors, and Nurses can read any patient's record.\n      // - A patient can read their own record (assumes patient doc has a 'uid' field matching their auth uid).\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']) || \n                     (isOneOfRoles(['Patient']) && resource.data.uid == request.auth.uid);\n      \n      // UPDATE: Only Admins and Doctors can update patient records.\n      allow update: if isOneOfRoles(['Admin', 'Doctor']) && isPatientDataValid(request.resource.data);\n      \n      // DELETE: No one should be able to delete patient records directly.\n      // Records should be marked as 'inactive' or 'deceased' via an update.\n      allow delete: if false;\n    }\n    \n    // Admissions records for patient visits.\n    match /admissions/{admissionId} {\n       allow read, write: if isOneOfRoles(['Admin', 'Doctor']);\n    }\n\n    // Bed status and allocation records.\n    match /beds/{bedId} {\n        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'Housekeeping']);\n        allow write: if isOneOfRoles(['Admin']);\n    }\n  }\n}\n"}]}}
