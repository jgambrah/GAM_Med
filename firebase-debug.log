[debug] [2025-08-24T15:22:05.114Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for patients collection\n    match /patients/{patientId} {\n      allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow create: if getUserRole() in ['admin', 'nurse'];\n    }\n\n    // Rules for all subcollections of patients\n    match /patients/{patientId}/{subcollection}/{docId} {\n       allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n\n    // Rules for insurance_claims collection\n    match /insurance_claims/{claimId} {\n        allow read, update, create: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    // Rules for insurance_providers collection\n    match /insurance_providers/{providerId} {\n        allow read: if request.auth != null;\n        allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for payments collection\n    match /payments/{paymentId} {\n      allow create: if getUserRole() in ['admin', 'receptionist', 'billing_clerk'];\n      // Patients should only be able to read their own payments, which requires a more complex rule.\n      // For now, we restrict read access to staff.\n      allow read: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    // Rules for payment_gateways collection\n    match /payment_gateways/{gatewayId} {\n      allow read: if getUserRole() in ['admin', 'billing_clerk'];\n      allow write: if getUserRole() == 'admin';\n    }\n    \n    // Default deny all other collections\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
