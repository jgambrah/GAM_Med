[debug] [2025-08-07T13:48:29.076Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user role\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow create: if request.auth.uid == userId; // Allow users to create their own profile\n      allow update: if request.auth.uid == userId; // Allow users to update their own profile\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      allow read: if request.auth != null && (getUserRole(request.auth.uid) == 'Admin' || getUserRole(request.auth.uid) == 'Doctor');\n      // Patients can read their own data, identified by a field linking to their auth UID\n      // allow read: if request.auth.uid == resource.data.authUid; \n      allow create, update, delete: if request.auth != null && getUserRole(request.auth.uid) == 'Admin';\n    }\n\n    // Rules for the 'admissions' collection\n    match /admissions/{admissionId} {\n        allow read: if request.auth != null && (getUserRole(request.auth.uid) == 'Admin' || getUserRole(request.auth.uid) == 'Doctor');\n        // allow read: if request.auth != null && exists(/databases/$(database)/documents/patients/$(resource.data.patientId)) && request.auth.uid == get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.authUid;\n        allow create, update: if request.auth != null && getUserRole(request.auth.uid) == 'Admin';\n    }\n\n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n        allow read: if request.auth != null; // All authenticated users can see bed status\n        allow update: if request.auth != null && (getUserRole(request.auth.uid) == 'Admin' || getUserRole(request.auth.uid) == 'Housekeeping');\n    }\n\n    // Rules for the 'referrals' collection\n    match /referrals/{referralId} {\n      // Admins can create referrals.\n      allow create: if request.auth != null && getUserRole(request.auth.uid) == 'Admin';\n\n      // Admins and the assigned doctor can read the referral.\n      allow read: if request.auth != null && \n                    (getUserRole(request.auth.uid) == 'Admin' || request.auth.uid == resource.data.assignedToDoctorId);\n\n      // Admins can update any field. Doctors can only update the status.\n      allow update: if request.auth != null && getUserRole(request.auth.uid) == 'Admin';\n      // A more granular rule for doctors would be:\n      // allow update: if (getUserRole(request.auth.uid) == 'Admin') || \n      //               (request.auth.uid == resource.data.assignedToDoctorId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));\n    }\n\n  }\n}\n"}]}}
