[debug] [2026-02-23T15:30:22.290Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // --------------------------------------------------------------------\n    // Helper Functions for Multi-Tenant Logical Isolation\n    // --------------------------------------------------------------------\n\n    /**\n     * Checks if the user is authenticated.\n     */\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    /**\n     * Retrieves the authenticated user's profile.\n     * Note: In a production environment with high scale, you would migrate \n     * 'hospitalId' and 'role' to Custom Auth Claims to avoid this 'get' call.\n     */\n    function getUserData() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n\n    /**\n     * Verifies that the document belongs to the user's hospital.\n     */\n    function isSameHospital(docData) {\n      return isSignedIn() && docData.hospitalId == getUserData().hospitalId;\n    }\n\n    /**\n     * Checks if the user is an employee of their hospital.\n     */\n    function isEmployee() {\n      return isSignedIn() && getUserData().role in [\n        'admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk', \n        'lab_technician', 'radiologist', 'dietitian', 'receptionist'\n      ];\n    }\n\n    /**\n     * Checks if the user is a hospital administrator.\n     */\n    function isAdmin() {\n      return isSignedIn() && getUserData().role == 'admin';\n    }\n\n    /**\n     * Checks if the authenticated user is the owner of the document.\n     */\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    // --------------------------------------------------------------------\n    // Collection Rules\n    // --------------------------------------------------------------------\n\n    // Hospitals (Tenant Masters)\n    match /hospitals/{hospitalId} {\n      allow get: if isSignedIn() && getUserData().hospitalId == hospitalId;\n      allow write: if false; // Provisioning is handled via system admin tools\n    }\n\n    // Users & Staff Profiles\n    match /users/{userId} {\n      allow get: if isOwner(userId) || (isEmployee() && isSameHospital(resource.data));\n      allow list: if isEmployee(); // Queries must filter by hospitalId\n      allow create: if isOwner(userId);\n      allow update: if isOwner(userId) || isAdmin();\n    }\n\n    // Patients\n    match /patients/{patientId} {\n      allow get: if (isSignedIn() && getUserData().patient_id == patientId) || (isEmployee() && isSameHospital(resource.data));\n      allow list: if isEmployee();\n      allow create: if isEmployee() && isSameHospital(request.resource.data);\n      allow update: if isEmployee() && isSameHospital(resource.data) && isSameHospital(request.resource.data);\n      allow delete: if isAdmin() && isSameHospital(resource.data);\n    }\n\n    // Appointments\n    match /appointments/{appointmentId} {\n      allow read: if (isSignedIn() && getUserData().patient_id == resource.data.patientId) || (isEmployee() && isSameHospital(resource.data));\n      allow create: if isSignedIn() && isSameHospital(request.resource.data);\n      allow update: if isEmployee() && isSameHospital(resource.data);\n      allow delete: if isAdmin() && isSameHospital(resource.data);\n    }\n\n    // Admissions & Beds\n    match /admissions/{admissionId} {\n      allow read, write: if isEmployee() && (resource == null || isSameHospital(resource.data)) && (request.resource == null || isSameHospital(request.resource.data));\n    }\n    match /beds/{bedId} {\n      allow read: if isEmployee() && isSameHospital(resource.data);\n      allow write: if isEmployee() && isSameHospital(request.resource.data);\n    }\n\n    // Billing & Invoices\n    match /invoices/{invoiceId} {\n      allow read: if (isSignedIn() && getUserData().patient_id == resource.data.patientId) || (isEmployee() && isSameHospital(resource.data));\n      allow create, update: if isEmployee() && isSameHospital(request.resource.data);\n    }\n\n    // Laboratory & Radiology\n    match /lab_results/{testId} {\n      allow read: if (isSignedIn() && getUserData().patient_id == resource.data.patientId) || (isEmployee() && isSameHospital(resource.data));\n      allow write: if isEmployee() && (resource == null || isSameHospital(resource.data)) && (request.resource == null || isSameHospital(request.resource.data));\n    }\n    match /radiology_orders/{orderId} {\n      allow read, write: if isEmployee() && (resource == null || isSameHospital(resource.data)) && (request.resource == null || isSameHospital(request.resource.data));\n    }\n\n    // Generic fallback for hospital-specific data (Clinical Notes, Vitals, etc.)\n    match /{collection}/{docId} {\n      allow read, write: if isEmployee() && \n        (resource == null || isSameHospital(resource.data)) && \n        (request.resource == null || isSameHospital(request.resource.data));\n    }\n  }\n}"}]}}
