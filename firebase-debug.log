[debug] [2025-09-15T13:04:37.749Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nfunction getUserRole() {\n  return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n}\n\nfunction isUserAuthenticated() {\n  return request.auth != null;\n}\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Default deny all access\n    match /{document=**} {\n      allow read, write: if false;\n    }\n\n    // Allow public read for basic data, but restrict sensitive info\n    match /users/{userId} {\n      allow read: if isUserAuthenticated();\n      allow write: if request.auth.uid == userId; // Users can only write to their own doc\n    }\n    \n    match /patients/{patientId} {\n        allow read: if isUserAuthenticated();\n        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n    \n    // Allow read access for authenticated users, but restrict writes to clinical staff\n    match /patients/{patientId}/{subcollection}/{docId} {\n        allow read: if isUserAuthenticated();\n        allow write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n\n    match /beds/{bedId} {\n        allow read, write: if isUserAuthenticated();\n    }\n\n    match /appointments/{appointmentId} {\n        allow read, write: if isUserAuthenticated();\n    }\n\n    match /referrals/{referralId} {\n        allow read, write: if isUserAuthenticated();\n    }\n\n    match /pharmacy_orders/{orderId} {\n        allow read, write: if getUserRole() in ['admin', 'pharmacist', 'doctor'];\n    }\n    \n    match /inventory/{itemId} {\n        allow read: if isUserAuthenticated();\n        allow write: if getUserRole() in ['admin', 'pharmacist']; // Only pharmacy staff can update inventory\n    }\n\n    match /controlled_substances/{substanceId} {\n      allow read: if getUserRole() in ['admin', 'pharmacist'];\n      // Writes must go through the trusted Cloud Function\n      allow write: if false;\n    }\n\n    match /controlled_substance_log/{logId} {\n      allow read: if getUserRole() in ['admin', 'pharmacist'];\n      // Immutable log\n      allow write: if false;\n    }\n\n    // New rules for assets and depreciation\n    match /assets/{assetId} {\n      allow read: if getUserRole() in ['admin', 'maintenance_manager', 'technician'];\n      // Restrict direct updates to financial details. \n      // This must be done via a trusted Cloud Function.\n      allow update: if getUserRole() == 'admin';\n      allow create: if getUserRole() in ['admin', 'maintenance_manager'];\n    }\n\n    match /depreciation_records/{recordId} {\n      // Only financial staff can view these sensitive records.\n      allow read: if getUserRole() in ['admin', 'billing_clerk'];\n      // The depreciation ledger is immutable and can only be created by the server.\n      allow create: if false;\n      allow update, delete: if false;\n    }\n    \n    match /utility_consumption/{logId} {\n      allow read: if getUserRole() in ['admin', 'facilities_manager'];\n      // Data ingested from smart meters via a Cloud Function\n      allow create, update, delete: if false;\n    }\n\n    match /security_incidents/{incidentId} {\n      allow read, create: if getUserRole() in ['admin', 'security'];\n      allow update: if getUserRole() in ['admin', 'security'];\n    }\n\n    match /housekeeping_tasks/{taskId} {\n      allow read: if getUserRole() in ['admin', 'nurse', 'housekeeping'];\n      allow create: if getUserRole() in ['admin', 'nurse'];\n      allow update: if getUserRole() in ['admin', 'housekeeping'];\n    }\n    \n    match /spare_parts/{partId} {\n      allow read: if getUserRole() in ['admin', 'technician'];\n      // Allow only admins to create or manually update spare parts.\n      // Day-to-day decrements should happen via a Cloud Function.\n      allow write: if getUserRole() == 'admin';\n    }\n\n    // Fallback for collections not explicitly defined\n    match /{path=**}/ {\n      allow read, write: if isUserAuthenticated() && getUserRole() == 'admin';\n    }\n  }\n}\n"}]}}
