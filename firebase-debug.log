[debug] [2025-09-17T16:00:14.911Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user's role\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Patients can only access their own data\n    match /patients/{patientId} {\n      allow read: if request.auth.uid == resource.data.userId || getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow update: if request.auth.uid == resource.data.userId; // Simplified for now\n\n      // Messages sub-collection\n      match /messages/{messageId} {\n        allow read, create: if request.auth.uid == patientId || request.auth.uid == resource.data.receiverId;\n      }\n    }\n\n    // Appointments can only be read by participants\n    match /appointments/{appointmentId} {\n        allow read: if request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId;\n    }\n    \n    // Remote patient data can be created by the patient and read by the patient or their care team\n    match /remote_patient_data/{dataId} {\n        allow create: if request.auth.uid == request.resource.data.patientId;\n        allow read: if request.auth.uid == resource.data.patientId || getUserRole() in ['admin', 'doctor', 'nurse'];\n    }\n  }\n}\n"}]}}
