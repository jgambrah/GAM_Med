[debug] [2025-09-19T14:44:45.299Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get the role of the currently authenticated user.\n    function isUserRole(role) {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;\n    }\n\n    // Rules for the users collection\n    match /users/{userId} {\n      // Allow users to read their own profile. Allow admins to read any profile.\n      allow read: if request.auth.uid == userId || isUserRole('admin');\n\n      // Allow users to update their own profile, but NOT their role.\n      // This prevents a user from escalating their own privileges.\n      allow update: if request.auth.uid == userId && !('role' in request.resource.data);\n    }\n    \n    // Rules for the central roles collection\n    match /roles/{roleId} {\n      // Only admins can read the roles and permissions.\n      allow read: if isUserRole('admin');\n      // Deny all write operations to prevent tampering with roles.\n      allow write: if false;\n    }\n\n    // Rules for the immutable audit logs\n    match /audit_logs/{logId} {\n      // Only admins can read the audit trail.\n      allow read: if isUserRole('admin');\n      // Deny all write operations to ensure the log is immutable from the client.\n      allow write: if false;\n    }\n    \n    // Rules for the patients collection\n    match /patients/{patientId} {\n      // Allow doctors to read any patient record.\n      // Allow patients to read their own record.\n      allow read: if isUserRole('doctor') || isUserRole('nurse') || request.auth.uid == patientId;\n      \n      // Only allow admins to create or update patient records directly.\n      // Most updates should go through secure Cloud Functions.\n      allow write: if isUserRole('admin');\n\n      // Rules for patient sub-collections (vitals, notes, etc.)\n      match /{subcollection}/{docId} {\n        allow read: if isUserRole('doctor') || isUserRole('nurse') || request.auth.uid == patientId;\n        allow write: if isUserRole('doctor') || isUserRole('nurse');\n      }\n    }\n    \n    // Rules for health content and reminders (Patient Portal)\n    match /health_content/{contentId} {\n      // Any authenticated user can read health content.\n      allow read: if request.auth != null;\n      // Only admins can write health content.\n      allow write: if isUserRole('admin');\n    }\n\n    match /reminders/{reminderId} {\n      // A user can only access reminders linked to their patientId.\n      allow read, write: if request.auth.uid == resource.data.patientId;\n    }\n\n    // Deny all other access by default\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
