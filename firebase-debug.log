[debug] [2025-08-07T15:59:24.503Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Any authenticated user can create their own user document (on signup)\n      allow create: if request.auth.uid == userId;\n      // Users can only read their own document\n      allow read: if request.auth.uid == userId;\n      // Users can only update their own document\n      allow update: if request.auth.uid == userId;\n      // Users cannot delete their own document\n      allow delete: if false;\n    }\n    \n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n        // Admins can create new patient records\n        allow create: if getUserRole() == 'Admin';\n        \n        // Admins and Doctors can read any patient record\n        // Patients can only read their own record (requires a field linking auth UID to patient ID)\n        allow read: if getUserRole() == 'Admin' || getUserRole() == 'Doctor';\n        \n        // Admins can update any patient record\n        allow update: if getUserRole() == 'Admin';\n        \n        // Deleting patient records is restricted to Admins\n        allow delete: if getUserRole() == 'Admin';\n    }\n    \n    // Rules for the 'admissions' collection\n    match /admissions/{admissionId} {\n        allow create, update: if getUserRole() == 'Admin' || getUserRole() == 'Doctor';\n        allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'BillingClerk'];\n        allow delete: if getUserRole() == 'Admin';\n    }\n    \n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n      allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'Housekeeping'];\n      allow update: if getUserRole() in ['Admin', 'Housekeeping']; \n      allow create, delete: if getUserRole() == 'Admin';\n    }\n\n    // Rules for the 'referrals' collection\n    match /referrals/{referralId} {\n      // Admins (or triage officers) can create new referral documents\n      allow create: if getUserRole() == 'Admin';\n\n      // Admins can read all referrals. Doctors can only read referrals assigned to them.\n      allow read: if getUserRole() == 'Admin' || request.auth.uid == resource.data.assignedToDoctorId;\n\n      // Admins can update any field. \n      // Doctors can only update the status of their assigned referrals.\n      allow update: if getUserRole() == 'Admin' || \n                     (request.auth.uid == resource.data.assignedToDoctorId && request.resource.data.status != resource.data.status);\n                     \n      // Deleting referrals is restricted to Admins\n      allow delete: if getUserRole() == 'Admin';\n    }\n  }\n}\n"}]}}
