[debug] [2025-08-10T17:23:11.577Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // =====================================================================\n    // Helper Functions\n    // =====================================================================\n    \n    // Get the role of the currently authenticated user from the 'users' collection.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    // Check if the user is one of the specified roles.\n    function isOneOfRoles(roles) {\n      return getUserRole() in roles;\n    }\n\n    // Check if the request is from an authenticated user.\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    // =====================================================================\n    // Collection Rules\n    // =====================================================================\n\n    // Users collection: Basic access controls\n    match /users/{userId} {\n      // Allow users to read their own profile.\n      // Admins can read any user's profile.\n      allow read: if isAuthenticated() && (request.auth.uid == userId || getUserRole() == 'admin');\n      \n      // Allow users to update their own profile. Admins can update any.\n      allow write: if isAuthenticated() && (request.auth.uid == userId || getUserRole() == 'admin');\n    }\n    \n    // Beds collection: Staff can read, only specific roles can update.\n    match /beds/{bedId} {\n      allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse', 'billing_clerk']);\n      allow write: if isAuthenticated() && isOneOfRoles(['admin', 'nurse']);\n    }\n\n    // Referrals collection: Staff can read, specific roles can write.\n    match /referrals/{referralId} {\n        allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse', 'triage_officer']);\n        allow write: if isAuthenticated() && isOneOfRoles(['admin', 'nurse', 'triage_officer']);\n    }\n    \n    // Pharmacy Orders: Pharmacists and prescribing doctors can access.\n    match /pharmacy_orders/{orderId} {\n        allow read, write: if isAuthenticated() && isOneOfRoles(['pharmacist', 'admin']);\n    }\n    \n    // Lab Requests: Lab technicians and ordering doctors can access.\n    match /lab_requests/{requestId} {\n        allow read, write: if isAuthenticated() && isOneOfRoles(['lab_technician', 'admin']);\n    }\n    \n    // Appointments Collection Rules\n    match /appointments/{appointmentId} {\n      // Allow read access to admins and the doctor assigned to the appointment.\n      allow read: if isAuthenticated() && \n                  (getUserRole() == 'admin' || resource.data.attendingDoctorId == request.auth.uid);\n                  \n      // Allow write access (e.g., for updating status) to admins and the assigned doctor.\n      allow write: if isAuthenticated() &&\n                   (getUserRole() == 'admin' || resource.data.attendingDoctorId == request.auth.uid);\n    }\n    \n    // =====================================================================\n    // Patient EHR Rules (Main Document and Sub-collections)\n    // =====================================================================\n    \n    match /patients/{patientId} {\n      // Allow read access to a wide range of clinical staff and the patient themselves.\n      // The patient's UID is assumed to be stored and retrievable for this check.\n      allow read: if isAuthenticated() && \n                  (isOneOfRoles(['admin', 'doctor', 'nurse', 'pharmacist', 'lab_technician', 'billing_clerk']) || \n                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);\n                  \n      // Write access to the main patient document is highly restricted.\n      allow write: if isAuthenticated() && isOneOfRoles(['admin', 'nurse']);\n\n      // --- EHR Sub-collection: Clinical Notes ---\n      match /clinical_notes/{noteId} {\n        allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse']);\n        // Only doctors and nurses can create/update notes.\n        // On update, we could add a check: resource.data.recordedByUserId == request.auth.uid\n        allow write: if isAuthenticated() && isOneOfRoles(['doctor', 'nurse']);\n      }\n      \n      // --- EHR Sub-collection: Vitals ---\n      match /vitals/{vitalId} {\n        allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse']);\n        // Only nurses can record vitals.\n        allow write: if isAuthenticated() && getUserRole() == 'nurse';\n      }\n\n      // --- EHR Sub-collection: Diagnoses ---\n      match /diagnoses/{diagnosisId} {\n        allow read: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse']);\n        // Only doctors can add or modify a diagnosis.\n        allow write: if isAuthenticated() && getUserRole() == 'doctor';\n      }\n\n      // --- EHR Sub-collection: Medication History ---\n      match /medication_history/{prescriptionId} {\n        allow read: if isAuthenticated() && \n                    (isOneOfRoles(['admin', 'doctor', 'nurse', 'pharmacist']) || \n                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);\n        // Only the prescribing doctor can create or modify a prescription.\n        allow create: if isAuthenticated() && getUserRole() == 'doctor';\n        allow update: if isAuthenticated() && getUserRole() == 'doctor' && resource.data.prescribedByDoctorId == request.auth.uid;\n      }\n      \n      // --- EHR Sub-collection: Lab Results ---\n      match /lab_results/{testId} {\n        allow read: if isAuthenticated() &&\n                    (isOneOfRoles(['admin', 'doctor', 'nurse', 'lab_technician']) ||\n                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);\n\n        // Only doctors can order a new test.\n        allow create: if isAuthenticated() && getUserRole() == 'doctor';\n        \n        // Only a lab technician can update a result, and they can only change specific fields.\n        allow update: if isAuthenticated() && getUserRole() == 'lab_technician' &&\n                      request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n                        'result', 'status', 'completedAt', 'labTechnicianId', 'resultPdfUrl'\n                      ]);\n      }\n      \n       // --- EHR Sub-collection: Admissions ---\n      match /admissions/{admissionId} {\n        // Broad read access for clinical staff and the patient.\n        allow read: if isAuthenticated() &&\n                    (isOneOfRoles(['admin', 'doctor', 'nurse', 'billing_clerk']) ||\n                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);\n                     \n        // Write access is restricted to clinical staff.\n        allow write: if isAuthenticated() && isOneOfRoles(['admin', 'doctor', 'nurse']);\n      }\n    }\n  }\n}\n"}]}}
