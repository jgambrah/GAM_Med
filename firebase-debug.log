[debug] [2025-08-08T13:47:03.004Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check if a user has a specific role\n    function isRole(role) {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;\n    }\n\n    // Helper function to check if a user is an admin, doctor, or nurse\n    function isClinicalStaff() {\n      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n      return userRole == 'admin' || userRole == 'doctor' || userRole == 'nurse';\n    }\n\n    //------------------------------------------------------------\n    // Users Collection\n    //------------------------------------------------------------\n    match /users/{userId} {\n      // Admins can read/write any user profile\n      // Users can read/update their own profile\n      allow read, update: if request.auth.uid == userId || isRole('admin');\n      // Only admins can create or delete user profiles\n      allow create, delete: if isRole('admin');\n    }\n\n    //------------------------------------------------------------\n    // Patients Collection\n    //------------------------------------------------------------\n    match /patients/{patientId} {\n      // Clinical staff can read any patient's record.\n      // A patient can read their own record (if their user doc is linked).\n      allow read: if isClinicalStaff() || \n                     (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);\n                     \n      // Clinical staff can update patient records.\n      allow update: if isClinicalStaff();\n\n      // Only admins or nurses can create new patient records.\n      allow create: if isRole('admin') || isRole('nurse');\n\n      // Deleting patient records should be highly restricted, e.g., only by an admin.\n      // Or, prefer soft-delete by setting a 'status' to 'archived'.\n      allow delete: if isRole('admin');\n\n      // --- Admissions Sub-collection ---\n      match /admissions/{admissionId} {\n        // Inherit read access from the parent patient document.\n        allow read: if isClinicalStaff() || \n                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id == patientId);\n        \n        // Only clinical staff can create or update admission records.\n        allow create, update: if isClinicalStaff();\n\n        // Deleting admission records should be restricted.\n        allow delete: if isRole('admin');\n      }\n    }\n\n    //------------------------------------------------------------\n    // Beds Collection\n    //------------------------------------------------------------\n    match /beds/{bedId} {\n        // All clinical staff can view bed status.\n        allow read: if isClinicalStaff();\n        // Bed status is updated via server-side logic (Cloud Functions), not directly by clients.\n        // Allowing direct client updates is risky as it could lead to race conditions.\n        // For this prototype, we allow clinical staff to update. In production, this would be locked down.\n        allow write: if isClinicalStaff();\n    }\n    \n    //------------------------------------------------------------\n    // Appointments Collection\n    //------------------------------------------------------------\n    match /appointments/{appointmentId} {\n        // Clinical staff can read any appointment.\n        // A patient can read their own appointments.\n        allow read: if isClinicalStaff() || resource.data.patient_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patient_id;\n        \n        // Clinical staff can create/update appointments.\n        // Patients might be allowed to create/cancel their own appointments in a portal.\n        allow write: if isClinicalStaff();\n    }\n  }\n}\n"}]}}
