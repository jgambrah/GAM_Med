a.userId;\n      allow read, update, delete: if request.auth.uid == resource.data.userId;\n\n      // Admins or other designated roles can also read reports (e.g., for collaboration)\n      allow read: if request.auth.uid == resource.data.userId || getUserRole() == 'admin';\n    }\n\n    // Default deny all other collections\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
