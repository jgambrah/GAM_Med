[debug] [2025-09-04T17:36:39.203Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n    \n    function isPatientOwner(patientId) {\n        return request.auth.uid == patientId;\n    }\n\n    function isDoctorAssignedToPatient(patientId) {\n        // This is a conceptual rule. A real implementation would require a list\n        // of doctors on the patient document or a similar mapping.\n        // For this prototype, we'll allow any doctor to read.\n        return getUserRole() == 'doctor';\n    }\n\n    // Protects patient records, allowing access only to the patient or authorized staff.\n    match /patients/{patientId} {\n      allow read: if isPatientOwner(patientId) || getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow write: if getUserRole() in ['admin']; // Only admins can create/delete patient records directly\n      \n      // Rules for sub-collections within a patient's record\n      \n      // lab_history is read-only for clients, populated by a Cloud Function.\n      match /lab_history/{resultId} {\n        allow read: if isPatientOwner(patientId) || getUserRole() in ['admin', 'doctor'];\n        allow create, update, delete: if false; // Deny all client-side writes.\n      }\n      \n      match /clinical_notes/{noteId} {\n        allow read: if isPatientOwner(patientId) || getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow create: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        allow update: if getUserRole() in ['admin', 'doctor'];\n        allow delete: if getUserRole() == 'admin';\n      }\n    }\n    \n    // Protects lab results, allowing access to lab staff or the patient's doctor.\n    match /lab_results/{resultId} {\n        allow read: if getUserRole() in ['admin', 'lab_tech', 'doctor'];\n        // Allow lab technicians to create results.\n        allow create: if getUserRole() == 'lab_tech';\n        // Allow updates only if the result is in a draft state.\n        allow update: if getUserRole() in ['lab_tech'] && resource.data.status == 'Draft';\n        // Prevent deletion.\n        allow delete: if false;\n    }\n\n    match /lab_orders/{orderId} {\n        // Allow read by lab staff, or the ordering doctor.\n        allow read: if getUserRole() in ['admin', 'lab_tech'];\n        // Only trusted backend processes can update.\n        allow update: if request.auth.uid == null || getUserRole() == 'admin';\n        \n        match /sample_audit/{auditId} {\n            allow read: if getUserRole() in ['admin', 'lab_tech'];\n            // Deny all client-side writes to maintain an immutable log.\n            allow create, update, delete: if false;\n        }\n    }\n  }\n}\n"}]}}
