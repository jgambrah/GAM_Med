[debug] [2025-09-10T16:29:36.863Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the users collection\n    match /users/{userId} {\n      // Admins and the user themselves can read the user document.\n      allow read: if request.auth != null && (request.auth.uid == userId || getUserRole() == 'admin');\n      \n      // Admins and the user themselves can update the user document.\n      // In a real app, you might restrict which fields a user can update.\n      allow write: if request.auth != null && (request.auth.uid == userId || getUserRole() == 'admin');\n    }\n\n    // Rules for the main patient collection\n    match /patients/{patientId} {\n      // Allow read access to the patient themselves, or any authenticated staff member.\n      allow read: if request.auth != null && (request.auth.uid == patientId || getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk', 'receptionist']);\n      \n      // Only allow admins and nurses to create or update patient records.\n      allow write: if request.auth != null && getUserRole() in ['admin', 'nurse'];\n\n      // Allow full access to all subcollections for authorized staff.\n      match /{allSubcollections=**} {\n        allow read, write: if request.auth != null && getUserRole() in ['admin', 'doctor', 'nurse', 'pharmacist', 'billing_clerk', 'receptionist'];\n      }\n    }\n    \n    // Rules for the credentials collection\n    match /credentials/{credentialId} {\n      // Only admins can create new credentials.\n      allow create: if getUserRole() == 'admin';\n      // Admins or the user themselves can read the credential.\n      allow read: if getUserRole() == 'admin' || request.auth.uid == resource.data.userId;\n      // Admins can update any field. Users can only update specific fields like status.\n      allow update: if getUserRole() == 'admin' || (request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys.hasOnly(['status']));\n    }\n\n    // Rules for other collections\n    match /{document=**} {\n      allow read, write: if request.auth != null; // Default to authenticated access for other collections for now\n    }\n  }\n}\n\n// == Conceptual Firebase Storage Rules ==\n// These rules would go in a 'storage.rules' file.\n\n// service firebase.storage {\n//   match /b/{bucket}/o {\n//     // Match any file path for credentials. Assumes a path like 'credentials/{userId}/{credentialId}.pdf'\n//     match /credentials/{userId}/{credentialId} {\n//       // Allow read access only to the user who owns the credential or an admin.\n//       allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');\n      \n//       // Allow write access (create, update, delete) only to admins.\n//       allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n//     }\n//   }\n// }\n"}]}}
