[debug] [2025-09-08T15:15:01.644Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to get user's role from their token\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the users collection\n    match /users/{userId} {\n      // Allow users to read their own data\n      allow read: if request.auth.uid == userId;\n      // Allow only admins to create or modify user roles\n      allow write: if getUserRole() == 'admin';\n    }\n    \n    // Rules for the patients collection and its subcollections\n    match /patients/{patientId} {\n        // Allow read/write access to clinical staff\n        allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n        \n        // Allow a patient to read their own main record\n        allow read: if request.auth.uid == resource.data.userId;\n\n        // Rules for patient subcollections (EHR data)\n        match /{subcollection}/{docId} {\n             // Allow read/write access to clinical staff\n            allow read, write: if getUserRole() in ['admin', 'doctor', 'nurse'];\n\n             // Allow a patient to read their own subcollection data\n            allow read: if request.auth.uid == get(/databases/$(database)/documents/patients/$(patientId)).data.userId;\n        }\n    }\n    \n    // Rules for the appointments collection\n    match /appointments/{appointmentId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist', 'radiologist'];\n        allow create, update: if getUserRole() in ['admin', 'receptionist', 'radiologist'];\n    }\n    \n    // Rules for equipment (resources)\n    match /equipment/{equipmentId} {\n        allow read: if request.auth.uid != null;\n        // Only allow admins (representing trusted server functions) to update availability\n        allow write: if getUserRole() == 'admin';\n    }\n\n    // Rules for radiology orders (worklist)\n    match /radiology_orders/{orderId} {\n      // Allow read access to relevant roles and the assigned radiologist\n      allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'] \n                  || request.auth.uid == resource.data.assignedRadiologistId;\n\n      // Allow creation by authorized roles (doctor, admin)\n      allow create: if getUserRole() in ['admin', 'doctor'];\n\n      // Allow updates by admin or receptionist (for scheduling)\n      // Restrict who can change specific fields. `isReported` is only changed by the Cloud Function (admin).\n      allow update: if (getUserRole() in ['admin', 'receptionist'] \n                      && request.resource.data.diff(resource.data).affectedKeys()\n                        .hasOnly(['status', 'scheduledDateTime', 'assignedRadiologistId']))\n                    || getUserRole() == 'admin'; // Admin can change anything\n    }\n    \n    // Rules for radiology reports\n    match /radiology_reports/{reportId} {\n       // Allow read to relevant staff or the patient themselves (conceptual)\n       allow read: if getUserRole() in ['admin', 'doctor', 'radiologist'];\n       // Allow writes only from trusted backend processes (represented by admin)\n       allow write: if getUserRole() == 'admin';\n    }\n  }\n}\n"}]}}
