[debug] [2025-08-22T16:26:28.405Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the role of the currently authenticated user.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      allow read, write: if request.auth != null; // Simplified for prototype\n      \n      // Granular update rule for patientType\n      allow update: if request.auth != null && (\n        (getUserRole() in ['admin', 'billing_clerk', 'receptionist'] && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['patientType'])) ||\n        // Allow other updates by other roles if patientType is not changed\n        (request.resource.data.patientType == resource.data.patientType)\n      );\n\n      // Sub-collections like clinical_notes, vitals, etc.\n      match /{allPaths=**} {\n        allow read, write: if request.auth != null; // Simplified for prototype\n      }\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId || getUserRole() == 'admin';\n    }\n\n    // Rules for the 'invoices' collection\n    match /invoices/{invoiceId} {\n        // Allow create/update for admin/billing staff. Cloud Functions bypass these rules.\n        allow create, update: if getUserRole() in ['admin', 'billing_clerk'];\n        // Allow read for admin/billing staff OR the patient who owns the invoice.\n        allow read: if getUserRole() in ['admin', 'billing_clerk'] || request.auth.uid == resource.data.patientId;\n    }\n    \n    // Rules for service collections to protect the 'isBilled' flag\n    function canUpdateIsBilled() {\n        // This rule is conceptual. In a real scenario, the Cloud Function would have trusted access.\n        // This client-side rule prevents users from manually toggling 'isBilled'.\n        // It allows updates only if 'isBilled' is NOT one of the fields being changed.\n        return !request.resource.data.diff(resource.data).affectedKeys().has('isBilled');\n    }\n\n    match /appointments/{appointmentId} {\n        allow read, write: if request.auth != null;\n        allow update: if canUpdateIsBilled();\n    }\n    \n    match /lab_results/{resultId} {\n        allow read, write: if request.auth != null;\n        allow update: if canUpdateIsBilled();\n    }\n    \n    // Rules for the 'pricing_tables' collection\n    match /pricing_tables/{pricingId} {\n        allow read, write: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n\n    // Rules for the 'insurance_claims' collection\n    match /insurance_claims/{claimId} {\n        allow create, read, update: if getUserRole() in ['admin', 'billing_clerk'];\n    }\n    \n    // Rules for the 'insurance_providers' collection\n    match /insurance_providers/{providerId} {\n        allow read: if request.auth != null;\n        allow write: if getUserRole() == 'admin';\n    }\n\n    // Default deny all other collections for security\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
