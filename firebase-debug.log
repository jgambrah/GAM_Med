[debug] [2025-09-09T15:46:10.887Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the user's role from the 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for User Profiles\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth.uid == userId;\n    }\n    \n    // Rules for Patients collection\n    match /patients/{patientId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'billing_clerk', 'pharmacist'] || request.auth.uid == patientId;\n      allow create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      \n      // Sub-collections\n      match /alerts/{alertId} {\n        allow read, create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n\n      match /clinical_notes/{noteId} {\n        allow read, create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      \n      match /vitals/{vitalId} {\n        allow read, create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n      \n      match /medication_history/{prescriptionId} {\n      \t allow read, create, update: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      }\n    }\n    \n    // Rules for Appointments\n    match /appointments/{appointmentId} {\n      allow read: if request.auth != null;\n      allow create, update: if getUserRole() in ['admin', 'receptionist', 'doctor'];\n      allow delete: if getUserRole() in ['admin', 'receptionist'];\n    }\n\n    // Rules for Beds\n    match /beds/{bedId} {\n      allow read: if getUserRole() in ['admin', 'doctor', 'nurse'];\n      allow update: if getUserRole() in ['admin', 'doctor', 'nurse']; // Only backend functions should create/delete\n    }\n\n    // Rules for OT Sessions\n    match /ot_sessions/{caseId} {\n      allow read: if getUserRole() in ['admin', 'surgeon', 'nurse', 'ot_coordinator'] || request.auth.uid == resource.data.patientId;\n      allow create, update: if getUserRole() in ['admin', 'surgeon', 'ot_coordinator'];\n\n      // Sub-collection for vitals during surgery\n      match /vitals_log/{logId} {\n        allow create: if getUserRole() in ['admin', 'nurse'];\n        // Note: parent(collection) is not a valid syntax. We refer to the parent document's data.\n        allow read: if getUserRole() in ['admin', 'surgeon', 'nurse'] || request.auth.uid == get(/databases/$(database)/documents/ot_sessions/$(caseId)).data.patientId;\n      }\n    }\n    \n    // Rules for Employee Data\n    match /employees/{employeeId} {\n        // Employees can read their own record, admins and HR managers can read any.\n        allow read: if getUserRole() in ['admin', 'hr_manager'] || request.auth.uid == employeeId;\n        // Only admins and HR managers can create, update, or delete employee records.\n        allow create, update, delete: if getUserRole() in ['admin', 'hr_manager'];\n\n        // Rules for employee documents sub-collection\n        match /documents/{documentId} {\n            // Employees can upload documents to their own record. HR/Admins can manage any.\n            allow create: if getUserRole() in ['admin', 'hr_manager'] || request.auth.uid == employeeId;\n            // Employees can read their own documents. HR/Admins can read any.\n            allow read: if getUserRole() in ['admin', 'hr_manager'] || request.auth.uid == employeeId;\n        }\n    }\n    \n    // Rules for Attendance Logs\n    match /attendance_logs/{logId} {\n        // Creating logs should ideally be handled by a trusted backend (like a Cloud Function)\n        // or a specific service account for a kiosk. For simplicity, we'll allow HR/Admins.\n        allow create: if getUserRole() in ['admin', 'hr_manager'];\n        // Only HR and admins can read attendance logs.\n        allow read: if getUserRole() in ['admin', 'hr_manager'];\n    }\n    \n  }\n}\n"}]}}
