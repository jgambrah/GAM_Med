[debug] [2025-08-04T14:37:30.212Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper Functions to make rules more readable and reusable.\n\n    // Get the role of the currently authenticated user from the 'users' collection.\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n\n    // Check if the user has one of the specified roles.\n    function isOneOfRoles(roles) {\n      let userRole = getUserRole(request.auth.uid);\n      return userRole in roles;\n    }\n\n    // --- Rules for 'users' Collection ---\n    // Users can read their own data. Only admins can create/update roles.\n    match /users/{userId} {\n      allow read: if request.auth.uid == userId || isOneOfRoles(['Admin']);\n      allow create: if request.auth.uid == userId; // Allow users to create their own record on sign-up\n      allow update: if request.auth.uid == userId || isOneOfRoles(['Admin']); // Admins can manage users\n    }\n\n    // --- Rules for 'patients' Collection ---\n    match /patients/{patientId} {\n      \n      // READ:\n      // - Staff roles (Admin, Doctor, Nurse, etc.) can read any patient's record.\n      // - A user with the 'Patient' role can only read their own document.\n      //   (This assumes the patient's document ID matches their user ID (uid)).\n      allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'Pharmacist', 'BillingClerk']) || \n                     (getUserRole(request.auth.uid) == 'Patient' && request.auth.uid == patientId);\n\n      // LIST (Query):\n      // - Staff roles can list all patients (e.g., for the main patient list view).\n      // - Patients cannot list all other patients.\n      allow list: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n      \n      // WRITE (Create, Update, Delete):\n      // - Only Admins can create new patient records.\n      // - Only Admins and Doctors can update a patient's record.\n      // - Deletes are disallowed for safety; use a status field instead.\n      allow create: if isOneOfRoles(['Admin']);\n      allow update: if isOneOfRoles(['Admin', 'Doctor']);\n      allow delete: if false; // Protect patient data from accidental deletion\n    }\n\n    // --- Rules for 'admissions' Collection ---\n    match /admissions/{admissionId} {\n        // Patients can read their own admission records.\n        // Staff can read any admission record.\n        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']) || \n                      (get(/databases/$(database)/documents/admissions/$(admissionId)).data.patientId == request.auth.uid);\n                      \n        allow list: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n\n        // Only Admins or Doctors can create or update admission records.\n        allow create, update: if isOneOfRoles(['Admin', 'Doctor']);\n        allow delete: if false;\n    }\n    \n    // --- Rules for 'beds' Collection ---\n    // Beds contain non-sensitive operational data.\n    match /beds/{bedId} {\n        // Most staff can view bed status.\n        allow read: if isOneOfRoles(['Admin', 'Doctor', 'Nurse', 'Housekeeping']);\n        \n        // Only Admins and Nurses can update bed status (admit, transfer, clean).\n        allow write: if isOneOfRoles(['Admin', 'Nurse', 'Housekeeping']);\n    }\n\n    // --- Conceptual Rule for Callable Function 'searchPatients' ---\n    //\n    // Security for Callable Cloud Functions is NOT defined in firestore.rules.\n    // Instead, it's checked inside the function's code itself.\n    // The rule would conceptually be:\n    // allow call: if request.auth != null;\n    //\n    // This is implemented in the Node.js function with the line:\n    // if (!context.auth) { throw new functions.https.HttpsError(...) }\n    //\n    // This ensures only authenticated users can trigger the search.\n  }\n}\n"}]}}
