[debug] [2025-08-13T10:46:18.353Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to check a user's role from the 'users' collection.\n    // The user's document ID in the 'users' collection must match their auth UID.\n    function getUserRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n\n    // Helper function to get the patient_id associated with a user's auth UID.\n    function getPatientIdForUser(userId) {\n        return get(/databases/$(database)/documents/users/$(userId)).data.patient_id;\n    }\n\n    // =====================================================================\n    // E-Prescribing Module Rules\n    // =====================================================================\n\n    // Rules for the central 'medications' formulary.\n    match /medications/{medicationId} {\n      // Allow any authenticated user to read the drug catalog for searching/display.\n      allow read: if request.auth != null;\n\n      // Only allow admins and pharmacists to write to the central drug formulary.\n      allow write: if getUserRole(request.auth.uid) in ['admin', 'pharmacist'];\n    }\n\n    // Rules for the top-level 'prescriptions' collection, used by the pharmacy.\n    match /prescriptions/{prescriptionId} {\n      // Only doctors can create new prescriptions.\n      allow create: if getUserRole(request.auth.uid) == 'doctor';\n\n      // Allow reading by admin, doctor, pharmacist, or the patient themselves.\n      allow read: if getUserRole(request.auth.uid) in ['admin', 'doctor', 'pharmacist']\n                  || getPatientIdForUser(request.auth.uid) == resource.data.patientId;\n\n      // Allow updates only by doctors (to cancel) or pharmacists (to dispense).\n      // This uses a more secure check on the request data to ensure only specific fields can be changed.\n      allow update: if (getUserRole(request.auth.uid) == 'doctor' && request.resource.data.status == 'Canceled')\n                    || (getUserRole(request.auth.uid) == 'pharmacist' && request.resource.data.status == 'Dispensed' && request.resource.data.filledAt != null);\n      \n      // Prescriptions should never be deleted to maintain a clear audit trail.\n      allow delete: if false;\n    }\n\n    // Rules for patient-specific data.\n    match /patients/{patientId} {\n        // Only allow read access by the patient, or clinical/admin staff.\n        // Assumes the patient's document in the `users` collection contains their `patient_id`.\n        allow read: if getPatientIdForUser(request.auth.uid) == patientId\n                    || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'pharmacist'];\n        \n        // Rules for the 'allergies' sub-collection within a patient's record.\n        match /allergies/{allergyId} {\n            // Allow reading by clinical staff or the patient themselves.\n            allow read: if getPatientIdForUser(request.auth.uid) == patientId\n                        || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'pharmacist'];\n            \n            // Only doctors and nurses can record or update allergy information.\n            allow create, update: if getUserRole(request.auth.uid) in ['doctor', 'nurse'];\n\n            // Allergy records should not be deleted to maintain history.\n            allow delete: if false;\n        }\n\n        // Rules for the 'medication_history' sub-collection within a patient's record.\n        match /medication_history/{prescriptionId} {\n            // This is a mirror of the top-level prescription for the patient's EHR.\n            // It should only be created by the system (via a Cloud Function).\n            // Direct client creation is denied.\n            allow create: if false;\n\n            // Reading is allowed by clinical staff or the patient.\n            allow read: if getPatientIdForUser(request.auth.uid) == patientId\n                        || getUserRole(request.auth.uid) in ['admin', 'doctor', 'nurse', 'pharmacist'];\n            \n            // Only the prescribing doctor can update (e.g., change status to 'Discontinued').\n            allow update: if getUserRole(request.auth.uid) == 'doctor' && resource.data.prescribedByDoctorId == request.auth.uid;\n\n            // History should never be deleted.\n            allow delete: if false;\n        }\n    }\n  }\n}\n"}]}}
