[debug] [2025-09-08T17:03:53.924Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get user's role from a 'users' collection\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Patients collection rules\n    match /patients/{patientId} {\n      allow read, write: if request.auth != null; // Simplified for prototype\n\n      // Sub-collections\n      match /radiology_history/{reportId} {\n         // This is a log. Only our backend function can create it.\n        allow create: if false;\n        // The patient and their doctors can read it.\n        allow read: if request.auth.uid == patientId || getUserRole() in ['admin', 'doctor'];\n        allow write: if false; // Immutable\n      }\n    }\n    \n    // Radiology reports rules\n    match /radiology_reports/{reportId} {\n      allow create: if getUserRole() in ['admin', 'radiologist'];\n      // The patient who owns the report, plus relevant staff can read it.\n      allow read: if request.auth.uid == resource.data.patientId || getUserRole() in ['admin', 'doctor', 'radiologist'];\n      // Only a radiologist can update a report, and only if it hasn't been finalized.\n      allow update: if getUserRole() == 'radiologist' && resource.data.isFinal == false;\n      allow delete: if getUserRole() == 'admin';\n    }\n\n    // Wards collection rules\n    match /wards/{wardId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];\n        // All writes must go through a trusted backend function\n        allow write: if false; \n    }\n\n    // Beds collection rules\n    match /beds/{bedId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'nurse', 'receptionist'];\n        // All writes must go through a trusted backend function\n        allow write: if false;\n    }\n\n     // Operating Theatres collection rules\n    match /operating_theatres/{theatreId} {\n        allow read: if getUserRole() in ['admin', 'doctor', 'receptionist'];\n        // All writes must go through a trusted backend function\n        allow write: if false;\n    }\n  }\n}\n"}]}}
