[debug] [2025-08-01T17:46:16.070Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions to check user roles and authentication\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function isUser(userId) {\n      return isAuthenticated() && request.auth.uid == userId;\n    }\n    \n    function getUserData() {\n        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n\n    function isRole(role) {\n        return isAuthenticated() && getUserData().role == role;\n    }\n    \n    function isOneOfRoles(roles) {\n        return isAuthenticated() && getUserData().role in roles;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Users can read their own profile information\n      allow read: if isUser(userId);\n      // New users can create their own profile during sign-up\n      allow create: if isAuthenticated();\n      // Users can update their own profile\n      allow update: if isUser(userId);\n      // Deletion should be restricted, e.g., only by an Admin\n      allow delete: if isRole('Admin');\n    }\n\n    // Rules for the 'patients' collection\n    match /patients/{patientId} {\n      // READ:\n      // - The patient themselves can read their own record.\n      // - Doctors, Nurses, and Admins can read any patient record.\n      allow read: if (isUser(patientId) && isRole('Patient')) || isOneOfRoles(['Doctor', 'Nurse', 'Admin']);\n\n      // CREATE:\n      // - Only Admins can create new patient records.\n      allow create: if isRole('Admin');\n      \n      // UPDATE:\n      // - Admins can update any field.\n      // - Doctors/Nurses can only update admission status fields.\n      allow update: if isOneOfRoles(['Admin']) || \n                     (isOneOfRoles(['Doctor', 'Nurse']) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmitted', 'currentAdmissionId', 'updatedAt']));\n\n      // DELETE:\n      // - Deleting patient records is a sensitive operation and restricted to Admins.\n      // - In a production environment, this might be disallowed entirely in favor of an 'inactive' status.\n      allow delete: if isRole('Admin');\n\n      // Rules for the 'admissions' sub-collection\n      match /admissions/{admissionId} {\n        // READ:\n        // - Access is inherited from the parent patient document.\n        allow read: if (isUser(patientId) && isRole('Patient')) || isOneOfRoles(['Doctor', 'Nurse', 'Admin']);\n        \n        // CREATE:\n        // - Admins, Doctors, or Nurses can create admission records.\n        allow create: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        \n        // UPDATE:\n        // - Admins or clinical staff can update admission records (e.g., to discharge).\n        allow update: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n        \n        // DELETE:\n        // - Deletion is restricted to Admins.\n        allow delete: if isRole('Admin');\n      }\n    }\n\n    // Rules for the 'beds' collection\n    match /beds/{bedId} {\n      // READ:\n      // - Bed status is generally not sensitive. Allow any authenticated user to see bed availability.\n      allow read: if isAuthenticated();\n      \n      // WRITE (create, update, delete):\n      // - Managing beds (allocating, cleaning, maintenance) is a clinical/admin task.\n      allow write: if isOneOfRoles(['Admin', 'Doctor', 'Nurse']);\n    }\n  }\n}\n"}]}}
