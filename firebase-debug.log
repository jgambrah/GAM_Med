[debug] [2025-08-04T14:23:20.399Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to get the role of the currently authenticated user.\n    // It reads the 'role' field from the user's document in the 'users' collection.\n    function getUserRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    // Rules for the 'users' collection itself.\n    // Users should be able to read their own profile data.\n    // Only admins should be able to modify roles (not shown here for brevity).\n    match /users/{userId} {\n      allow read, write: if request.auth.uid == userId;\n    }\n\n    // Rules for the 'patients' collection.\n    match /patients/{patientId} {\n      // READ access is granted to staff roles or to the patient themselves.\n      // Note: For a patient to read their own data, their user document\n      // would need a field linking to their patientId, e.g., `resource.data.linkedPatientId == patientId`.\n      // For simplicity here, we focus on staff access.\n      allow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'Pharmacist', 'BillingClerk'];\n      \n      // CREATE access is restricted to Admins.\n      allow create: if getUserRole() == 'Admin';\n\n      // UPDATE access is restricted to clinical staff (Admin, Doctor, Nurse).\n      allow update: if getUserRole() in ['Admin', 'Doctor', 'Nurse'];\n      \n      // DELETE access is highly restricted, typically only for Admins for data cleanup.\n      allow delete: if getUserRole() == 'Admin';\n    }\n    \n    // Rules for admissions\n    match /admissions/{admissionId} {\n    \tallow read, write: if getUserRole() in ['Admin', 'Doctor', 'Nurse'];\n    }\n    \n    // Rules for beds\n    match /beds/{bedId} {\n    \tallow read: if getUserRole() in ['Admin', 'Doctor', 'Nurse', 'Housekeeping'];\n      allow write: if getUserRole() in ['Admin', 'Housekeeping'];\n    }\n\n  }\n}\n"}]}}
